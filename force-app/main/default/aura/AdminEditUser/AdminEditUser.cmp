<aura:component implements="forceCommunity:availableForAllPageTypes" access="global" controller="AdminPanelApexController">
    <aura:attribute name="AccountInfo" type="Object" access="global"/>
    <aura:attribute name="sortedBy" type="String"/> 
    <aura:attribute name="mycolumns" type="List"/>
    <aura:attribute name="sortedDirection" type="String" default=""/>
    <aura:handler name="init" value="this" action="{!c.init}"/>
    
    <div class="slds-grid slds-wrap">
        <!-- added fields below notification to highlight required fields -
         CS21-426 - Veera -->
        <div class="slds-clearfix">
            <div class="slds-small-size--12-of-12 slds-medium-size--12-of-12 slds-large-size--12-of-12 slds-m-left_xx-large message">
                * Field is required
            </div>
        </div>
        <div class="slds-small-size--8-of-12 slds-medium-size--12-of-12 slds-large-size--12-of-12 ">
            <center> 
                <!--User Info Table start-->
                <table class="slds-table tableClass slds-max-medium-table_stacked" id="viewTable" style="width:90%;">
                    <thead class="TableHead">
                        <tr class="slds-line-height_reset ">
                            <aura:iteration items="{!v.mycolumns}" var="label">
                                <th class="thclass slds-cell-wrap" scope="col">
                                    <div class="slds-truncate slds-p-left_small" title="{!label.label}"> </div>
                                    <a href="javascript:void(0);" name="{!label.fieldName}" id="desc" class="textStyle" onclick="{!c.Sorttable}">
                                        <aura:if isTrue="{!(label.label == 'Last Name' || label.label == 'Email')}">
                                            <span class="message">*</span>
                                        </aura:if>
                                        {!label.label}
                                    </a>
                                    <div class="padd-dis">
                                        <aura:if isTrue="{!v.sortedBy == label.fieldName}">
                                            <aura:if isTrue="{!v.sortedDirection != 'desc'}">
                                                <lightning:icon iconName="utility:chevronup" size="xx-small" />
                                            </aura:if> 
                                        </aura:if>
                                    </div>
                                    <div class="padd-dis">
                                        <aura:if isTrue="{!v.sortedBy == label.fieldName}">
                                            <aura:if isTrue="{!v.sortedDirection == 'desc'}">
                                                <lightning:icon iconName="utility:chevrondown" size="xx-small" />
                                            </aura:if> 
                                        </aura:if>
                                    </div>
                                </th>
                            </aura:iteration>
                            <th scope="col" class="textStyle slds-cell-wrap">
                                <div class="slds-truncate padd" title="Status">Support Portal Access  
                                    <lightning:helptext content="{!$Label.c.Community_Active_Label}" />
                                </div>
                            </th>
                            <th scope="col"  class="textStyle slds-cell-wrap">
                                <div class="slds-truncate padd" title="Authorized">Admin Panel Access
                                    <lightning:helptext content="{!$Label.c.Community_Authorized_Label}" />
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="textStyle WrdBrk">

                        <aura:iteration items="{!v.AccountInfo.existingUsers}" var="usrInformation" IndexVar="rowNum2">
                            <!-- added Sytle class "errorMessage" to highlight rows when first Name, last name and email are blank -
             				CS21-426 - Veera -->
                            <tr class="{!(usrInformation.lastName == '' || usrInformation.email == '') ? 'rowborder requiredMessage' : 'rowborder'}">
                                <td class="slds-cell-wrap" scope="row" data-label="First Name">
                                    <lightning:input class="slds-p-bottom_large" readonly="{! v.isEdit}"  value="{!usrInformation.firstName}"/>
                                </td>
                                <td class="slds-cell-wrap" data-label="Last Name">
                                    <lightning:input class="slds-p-bottom_large" readonly="{! v.isEdit}"  value="{!usrInformation.lastName}"/> 
                                </td>
                                <td class="slds-truncate slds-cell-wrap" data-label="Email">
                                    <lightning:input class="slds-p-bottom_large" readonly="{! v.isEdit}" value="{!usrInformation.email}"/> 
                                </td>
                                <td class="slds-cell-wrap" data-label="Title">
                                    <lightning:input class="slds-p-bottom_large" readonly="{! v.isEdit}" value="{!usrInformation.title}"/> 
                                </td>
                                <td class="slds-cell-wrap" data-label="Phone">
                                    <lightning:input class="slds-p-bottom_large" readonly="{! v.isEdit}" value="{!usrInformation.phone}"/> 
                                </td>
                                <td class="slds-cell-wrap slds-text-align_center" data-label="Status">
                                    <lightning:input type="checkbox" checked="{!usrInformation.isActive}" disabled="{!usrInformation.userID == v.AccountInfo.CurrentUsers.Id}"/> 
                                </td>
                                <th class="slds-cell-wrap slds-text-align_center" scope="row" data-label="Authorized">
                                    <lightning:input type="checkbox" checked="{!usrInformation.adminUser}"/>
                                </th>
                            </tr>
                        </aura:iteration>
                    </tbody>
                </table> 
                <!--User Info Table start-->
                
                <br/><br/> 
            </center>
        </div>
    </div>
</aura:component>