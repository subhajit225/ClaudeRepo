<aura:component implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId" access="global" controller="CS_KCS_Controller">
    <aura:attribute name="kcsId" type="String"/>
    <aura:attribute name="show" type="Boolean" default="false"/>

    <aura:handler name="init" value="{!this}" action="{!c.doinit}"/>
    <aura:if isTrue="{!v.show}">
        <lightning:button label="Edit Article" onclick="{!c.editArticle}"/>
    </aura:if>
</aura:component>