<aura:component controller="LntgMySubscriptionController" implements="forceCommunity:availableForAllPageTypes" access="global" >
    <aura:attribute name="dataString" type="String" />
    <aura:attribute name="catMAp" type="Map" />
    <aura:attribute name="dataCategList" type="List" />
    <aura:handler name="init" action="{!c.doInit}" value="{!this}"/>
    
    <aura:iteration items="{!v.dataCategList}" var="dc" indexVar="key">
        <div class ="slds-large-size--12-of-12 slds-Medium-size--9-of-12 slds-small-size--12-of-12 slds-max-small-size--12-of-12 articles">
            <div class="container slds-grid slds-wrap" >
                <div class ="slds-large-size--11-of-12 slds-Medium-size--9-of-12 slds-small-size--12-of-12 slds-max-small-size--12-of-12 subscribeName"  >
                    <a class ="" href="{!'article/'+dc.urlName}">{!dc.Name}</a>
                </div>
                <div class ="slds-large-size--1-of-12 slds-Medium-size--9-of-12 slds-small-size--12-of-12 slds-max-small-size--12-of-12 subscribeName">
                    <a class ="subscribeName" data-index="{!dc.kbId}" onclick="{!c.UnsubscribeArticle}">Unsubscribe</a>
                </div>
                
            </div>
        </div>
        
    </aura:iteration>
</aura:component>