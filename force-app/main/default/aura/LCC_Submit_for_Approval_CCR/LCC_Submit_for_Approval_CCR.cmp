<aura:component extends="c:LCC_GenericLightningComponent"  
                implements="force:hasRecordId,force:lightningQuickActionWithoutHeader" controller="LCC_Submit_for_Approval_CCR_Controller">

    <aura:attribute name="displayMessage" type="String"/> 
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="showcancel" type="Boolean" default="false"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
	<div class="slds-p-top_large slds-align_absolute-center">
        {!v.displayMessage}
    </div>
    <aura:if isTrue="{!v.showcancel}">
        <div class="slds-p-top_large slds-align_absolute-center">
            <lightning:button variant="brand" label="Cancel"  onclick="{! c.handleCancel }"/>
        </div>  
    </aura:if>   
	

	
</aura:component>