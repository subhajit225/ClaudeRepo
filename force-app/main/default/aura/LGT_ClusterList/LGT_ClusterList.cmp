<aura:component controller="CaseDetailController" implements="flexipage:availableForAllPageTypes,force:hasRecordId" access="global" >
    <!--attributes-->
    <aura:attribute Name="clusterList" type="List"/>
    <aura:attribute Name="clusterListLess" type="List"/>
    <aura:attribute name="recordId" type="String"/>
    <aura:attribute name="allRecords" type="Boolean" default="false"/>
    <aura:attribute name="ClusterSectionHide" type="Boolean" default="false"/>
    <aura:attribute name="showAllButton" type="Boolean" default="false"/>
    <aura:attribute name="sortedBy" type="String" default="Name"/>
    <aura:attribute name="sortedDirection" type="String" default="desc"/>
    <aura:attribute name="SpinnerForCluster" type="boolean" default="false"/>	
    <!--Handler-->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <div class="slds-size_12-of-12 slds-medium-size_12-of-12 slds-large-size_12-of-12" aura:id="CL_Div">
        <lightning:card>
      		<!-- <Modifications By: Anmol Baweja 4 march, 2020>
      		<Reason>
        		To make Account's Cluster section collapsible by default and load the data on expansion as per CS-595
      		</Reason>-->
            <lightning:accordion aura:id="accordion" allowMultipleSectionsOpen="true" onsectiontoggle="{! c.handleSectionToggle}">
                <lightning:accordionSection name="A" label="Account's Clusters">
                    
                    <aura:set attribute="actions"> 
                        <div class="slds-size_12-of-12 slds-medium-size_12-of-12 slds-large-size_12-of-12">
                            <lightning:helptext class="helptext" content="Default Sorted By Cluster UUID" />
                        </div>
                    </aura:set>
                    <!--Loading Spinner Start-->
                    <aura:if isTrue="{!v.SpinnerForCluster}">	
                        <div aura:id="spinnerId" class="slds-spinner_container">	
                            <div class="slds-spinner--brand  slds-spinner slds-spinner--large slds-is-relative" role="alert">	
                                <span class="slds-assistive-text">Loading</span>	
                                <div class="slds-spinner__dot-a"></div>	
                                <div class="slds-spinner__dot-b"></div>	
                            </div>	
                        </div>	
                    </aura:if>
                    <!--Loading Spinner end-->
                    <!-- </Modifications By: Anmol Baweja>-->
                    <div class="slds-size_12-of-12 slds-medium-size_12-of-12 slds-large-size_12-of-12 tableDiv">
                        <div class="slds-size_12-of-12 slds-medium-size_12-of-12 slds-large-size_12-of-12 CL_highlightFields">
                            <table class="slds-table slds-table_cell-buffer slds-table_bordered slds-table_col-bordered tableBorder">
                                <thead class="font">
                                    <tr class="slds-line-height_reset">
                                        <th >
                                            <div class="slds-truncate" title="Cluster UUID">
                                                <div class="arrowContain">
                                                    <a class="casenocolor" href="javascript:void(0);" name="Name" id="desc"  onclick="{!c.Sorttable}">
                                                        Cluster UUID
                                                    </a>
                                                    <aura:if isTrue="{!v.sortedBy == 'Name'}">
                                                        <aura:if isTrue="{!v.sortedDirection != 'desc'}">
                                                            <lightning:icon class="right-alignment" iconName="utility:chevronup" size="xx-small" />
                                                            <aura:set attribute="else">
                                                                <lightning:icon class="right-alignment" iconName="utility:chevrondown" size="xx-small" />
                                                            </aura:set>
                                                        </aura:if> 
                                                    </aura:if>
                                                </div>
                                            </div>
                                        </th>
                                        <th >
                                            <div class="slds-truncate" title="Tag">
                                                <div class="arrowContain">
                                                    <a class="casenocolor" href="javascript:void(0);" name="tag__c" id="desc"  onclick="{!c.Sorttable}">
                                                        Tag
                                                    </a>
                                                    <aura:if isTrue="{!v.sortedBy == 'tag__c'}">
                                                        <aura:if isTrue="{!v.sortedDirection != 'desc'}">
                                                            <lightning:icon class="right-alignment" iconName="utility:chevronup" size="xx-small" />
                                                            <aura:set attribute="else">
                                                                <lightning:icon class="right-alignment" iconName="utility:chevrondown" size="xx-small" />
                                                            </aura:set>
                                                        </aura:if> 
                                                    </aura:if>
                                                </div>
                                            </div>
                                        </th>
                                        <th >
                                            <div class="slds-truncate" title="Archived">
                                                <div class="arrowContain">
                                                    <a class="casenocolor" href="javascript:void(0);" name="archived__c" id="desc"  onclick="{!c.Sorttable}">
                                                        Archived
                                                    </a>
                                                    <aura:if isTrue="{!v.sortedBy == 'archived__c'}">
                                                        <aura:if isTrue="{!v.sortedDirection != 'desc'}">
                                                            <lightning:icon class="right-alignment" iconName="utility:chevronup" size="xx-small" />
                                                            <aura:set attribute="else">
                                                                <lightning:icon class="right-alignment" iconName="utility:chevrondown" size="xx-small" />
                                                            </aura:set>
                                                        </aura:if> 
                                                    </aura:if>
                                                </div>
                                            </div>
                                        </th>
                                        <th >
                                            <div class="slds-truncate" title="Software Version">
                                                <div class="arrowContain">
                                                    <a class="casenocolor" href="javascript:void(0);" name="software_version__c" id="desc"  onclick="{!c.Sorttable}">
                                                        Software Version
                                                    </a>
                                                    <aura:if isTrue="{!v.sortedBy == 'software_version__c'}">
                                                        <aura:if isTrue="{!v.sortedDirection != 'desc'}">
                                                            <lightning:icon class="right-alignment" iconName="utility:chevronup" size="xx-small" />
                                                            <aura:set attribute="else">
                                                                <lightning:icon class="right-alignment" iconName="utility:chevrondown" size="xx-small" />
                                                            </aura:set>
                                                        </aura:if> 
                                                    </aura:if>
                                                </div>
                                            </div>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="font">
                                    <aura:iteration items="{!if(v.allRecords,v.clusterList,v.clusterListLess)}" var="Clusters">
                                        <tr class="bottomBorder" >
                                            <td ><a href="javascript:void(0);" id="{!Clusters.Id}" onclick="{!c.openAccountDetailPage}" tabindex="-1">{!Clusters.Name}</a></td>
                                            <td >{!Clusters.tag__c}</td>
                                            <td >{!Clusters.archived__c}</td>
                                            <td >{!Clusters.software_version__c}</td>
                                        </tr>
                                    </aura:iteration>
                                    
                                </tbody>
                            </table>
                            
                        </div>
                    </div>
                    <div>
                        <aura:if isTrue="{!!v.allRecords}">
                            <aura:if isTrue="{!v.showAllButton}">
                                <button onclick="{!c.showAllRecords}" class="showButton slds-button slds-button_icon slds-align_absolute-center" tabindex="0" title="Show All">
                                    Show All
                                </button>
                            </aura:if>
                            <aura:set attribute="else">
                                <button onclick="{!c.showLessRecords}" class="showButton slds-button slds-button_icon slds-align_absolute-center" tabindex="0" title="Show Less">
                                    Show Less
                                </button>
                            </aura:set>
                        </aura:if>
                        
                    </div>
                </lightning:accordionSection>
            </lightning:accordion>
        </lightning:card>
    </div>
</aura:component>