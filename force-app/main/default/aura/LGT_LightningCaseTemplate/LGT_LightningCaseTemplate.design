<design:component label="Two Region Custom App Page Template">
    <flexipage:template >
        <!-- The default width for the "left" region is "MEDIUM". In tablets,
        the width is "SMALL" -->
        <flexipage:region name="header" label="Header Region" defaultWidth="LARGE"/>
        <flexipage:region name="left" label="Left Region" defaultWidth="MEDIUM"/>
        <flexipage:region name="right" label="Right Region" defaultWidth="SMALL"/>
        <flexipage:region name="footer" label="Footer Region" defaultWidth="LARGE"/>
        <flexipage:region name="Activity" label="Activity Region" defaultWidth="LARGE"/>
        
        <flexipage:region name="leftBottom" label="Left bottom Region" defaultWidth="LARGE"/>
        <flexipage:region name="articleSection" label="Article Region" defaultWidth="LARGE"/>
        <flexipage:region name="Jira" label="Jira Region" defaultWidth="LARGE"/>
        <flexipage:region name="caseComment" label="Case Comment Region" defaultWidth="LARGE"/>
        <flexipage:region name="CaseMilestone" label="Case Milestone Region" defaultWidth="LARGE"/>
    </flexipage:template>
</design:component>