                        </div>
                    </a>
                    
                </th>-->
                
                
                
            </tr>
        </thead>
        <tbody>
        
            <aura:iteration items="{!v.visibleLeadRecords}" var="leadRec" indexVar="i">
                <c:ContactLeadConsoleAccordion recordObj="{! leadRec}" isContactConsole="false" expendAll="{!v.showContent}" />
            </aura:iteration>
        </tbody>
    </table>
    <aura:if isTrue="{!v.showStatusUpdateModal}">
        <section role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open slds-modal_small" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1">
            <div class="slds-modal__container" style="max-width: 55.0625rem;">
                <header class="slds-modal__header">
                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Update {!v.selectedIdWithNames.length} lead(s)                     
                    </h2>
                </header>
                
                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                    <label class="slds-form-element__label" for="4315:0" data-aura-rendered-by="4320:0"><!--render facet: 4321:0-->
                        <span class="" data-aura-rendered-by="4322:0">Selected Leads</span>
                    </label>
                    <div class="slds-pill_container">
                        <ul class="slds-listbox slds-listbox_horizontal" style="width:100%" role="listbox" aria-label="Selected Options:" aria-orientation="horizontal">
                            <aura:iteration items="{! v.selectedIdWithNames}" var="rec" indexVar="i">
                                <li class="slds-listbox-item" role="presentation" style="width:25%">
                                    <span class="slds-pill" style="width:100%" role="option" tabindex="0" aria-selected="true">
                                        <span class="slds-avatar slds-avatar_x-small slds-pill__icon_container">
                                            <lightning:icon iconName="standard:people" alternativeText="Connected" size="xx-small"
                                                            title="xx-small size" />
                                            
                                        </span>
                                        <span class="slds-pill__label" title="Full pill label verbiage mirrored here">{!rec.Name}</span>
                                        <span class="slds-icon_container slds-pill__remove" title="Remove">
                                            <lightning:buttonIcon iconName="utility:close"  size="small" name="{!rec.Id}"
                                                                  variant="bare" onclick="{!c.removeLead}" />
                                        </span>
                                    </span>
                                </li>
                            </aura:iteration>
                        </ul>
                    </div> 
                <lightning:select name="colorId" label="Status" aura:id="selectUser" value="{!v.selectedStatusToUpdate}" onchange="{!c.loadStatusOptions}" >
                    
                        <option text="Nurture" value="Nurture" />
                   		<!--<option text="Sales Nurture" value="Sales Nurture" />-->
                    <option text="Non-Qualified" value="Non-Qualified" />
                   

                </lightning:select>  
                    
                 <lightning:select name="rejectreason" label="Lead Reject Reason" aura:id="rejectreason" value="{!v.leadrejectreason}" onchange="{!c.loadStatusOptionsRejectReason}">
                    <option text="Select" value="Select" selected="selected"/>
                     <aura:iteration items="{!v.rejectreasonOptions}" var="item">
                         <option text="{!item.label}" value="{!item.value}" />
                     </aura:iteration>
                </lightning:select>
                    <aura:if isTrue="{!v.showValidationMessageRejectReason}">
                        <div class="slds-notify slds-notify_alert slds-alert_error" role="alert" style="justify-content: left;">
                            Please select Reject Reason
                        </div>
                        
                    </aura:if>
                    <aura:if isTrue="{!v.showhideaccounttoConvert}"> 
                    <c:SingleCustomLookup objectAPIName="account" 
                                  IconName="standard:account" 
                                  selectedRecord="{!v.selectedLookUpRecord}" 
                                  label="Account Name" RecordTypes ="Customer/Prospect"/>
                      </aura:if>
                    <aura:if isTrue="{!v.showValidationMessageConvertAccount}">
                        <div class="slds-notify slds-notify_alert slds-alert_error" role="alert">
                            Please select Account
                        </div>
                        
                    </aura:if>
                    <br/>
                    <br/>
                </div>
                <footer class="slds-modal__footer"> 
                    <lightning:button variant="brand" label="Cancel" title="Brand action" onclick="{!c.hideStatusUpdateModal}" />
                    <button class="slds-button slds-button_brand" onclick="{!c.updateStatus}">Save</button>
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </aura:if>
    
     <aura:if isTrue="{!v.showChangeOwnerModal}">
       
        <section role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open slds-modal_small" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1">
            <div class="slds-modal__container" style="max-width: 55.0625rem;">
                <header class="slds-modal__header">
                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Update {!v.selectedIdWithNames.length} lead(s)                     
                    </h2>
                </header>
                
                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                    <label class="slds-form-element__label" for="4315:0" data-aura-rendered-by="4320:0"><!--render facet: 4321:0-->
                        <span class="" data-aura-rendered-by="4322:0">Selected Leads</span>
                    </label>
                    <div class="slds-pill_container">
                        <ul class="slds-listbox slds-listbox_horizontal" style="width:100%" role="listbox" aria-label="Selected Options:" aria-orientation="horizontal">
                            <aura:iteration items="{! v.selectedIdWithNames}" var="rec" indexVar="i">
                                <li class="slds-listbox-item" role="presentation" style="width:25%">
                                    <span class="slds-pill" style="width:100%" role="option" tabindex="0" aria-selected="true">
                                        <span class="slds-avatar slds-avatar_x-small slds-pill__icon_container">
                                            <lightning:icon iconName="standard:people" alternativeText="Connected" size="xx-small"
                                                            title="xx-small size" />
                                            
                                        </span>
                                        <span class="slds-pill__label" title="Full pill label verbiage mirrored here">{!rec.Name}</span>
                                        <span class="slds-icon_container slds-pill__remove" title="Remove">
                                            <lightning:buttonIcon iconName="utility:close"  size="small" name="{!rec.Id}"
                                                                  variant="bare" onclick="{!c.removeLead}" />
                                        </span>
                                    </span>
                                </li>
                            </aura:iteration>
                        </ul>
                    </div> 
                    <lightning:select name="colorId" label="User/Queue" aura:id="selectUserId" value="{!v.selectedLeadOwnerType}" onchange="{!c.setuserqueueOptions}" >                    
                        <option text="User" value="User" />
                   		<option text="Queue" value="Queue" />                  
                </lightning:select>  
                    <aura:if isTrue="{!v.showValidationMessageSelectUserQueueType}">
                        <div class="slds-notify slds-notify_alert slds-alert_error" role="alert" style="justify-content: left;">
                            Please select owner type
                        </div>                        
                    </aura:if>                   
                    <c:SingleCustomLookup objectAPIName="{!v.objectName}" 
                                          IconName="standard:user"
                                          selectedRecord="{!v.selectedLookUpRecordLeadOwner}" 
                                          label="Assign To" />
                    <aura:if isTrue="{!v.showValidationMessageSelectUserQueue}">
                        <div class="slds-notify slds-notify_alert slds-alert_error" role="alert">
                            Please select Owner
                        </div>
                    </aura:if>
                    
                     <aura:if isTrue="{!v.showMessagedefaultqueue}">
                        <div class="slds-notify slds-notify_alert slds-alert_success" role="alert">
                            By default "Inbound" Queue is set as lead owner if nothing selected.
                        </div>
                        
                    </aura:if>
                        
                    <br/>
                    <br/>
                     <br/>
                    <br/>
                </div>
                <footer class="slds-modal__footer"> 
                    <lightning:button variant="brand" label="Cancel" title="Brand action" onclick="{!c.hideChangeLeadOwnereModal}" />
                    <button class="slds-button slds-button_brand" onclick="{!c.updateLeadOwner}">Save</button>
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </aura:if>
    <lightning:spinner alternativeText="Loading" class="{!v.showSpinner? '':'slds-hide'}" />
</aura:component>