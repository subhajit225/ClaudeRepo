<aura:component controller="ContactLeadConsole" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    <aura:attribute name="selectedTab" type="string" default="three"  />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <div class="slds-box slds-theme_default">
        <lightning:tabset selectedTabId="{!v.selectedTab}">
            <lightning:tab label="Lead" id="one">
                <c:LeadConsole/>
            </lightning:tab>
            <lightning:tab label="Contact" id="two">
                <c:ContactConsole/>
            </lightning:tab>
        </lightning:tabset>
    </div>
</aura:component>