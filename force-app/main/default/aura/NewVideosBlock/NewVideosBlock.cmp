<aura:component implements="forceCommunity:availableForAllPageTypes"   access="global" controller="LtngVideoBlockController">
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:attribute name="VideosLinks" type="List"/>
    <aura:attribute name="VideosSummary" type="String"/>
    <aura:attribute name="videoTitle" type="String"/>
    <aura:attribute name="ModalOpen" type="boolean" default="false"/>
    <aura:attribute name="ModalClose" type="boolean" default="true"/>
    <aura:attribute name="disright" type="boolean" default="false"/>
    <aura:attribute name="disLeft" type="boolean" default="true"/>
    
    <div class ="containerDiv">
        
        <div class ="slds-large-size--12-of-12 slds-Medium-size--6-of-12 slds-small-size--12-of-12  slds-size_12-of-12 videoDiv">
            <div class="slds-grid slds-wrap  padtopbotm">
                <div class="slds-large-size--12-of-12 slds-medium-size--12-of-12 slds-size_12-of-12 slds-align_absolute-center">
                    <p class="paraheadersize">Our Videos</p>
                </div>
                <div class="slds-large-size--12-of-12 slds-size_12-of-12 slds-align_absolute-center">
                    <a class="underlinenone" href="kblistpage?categoryType_Article=Videos" >
                        <p class="paraheadersize1">See All Videos ></p>
                    </a>
                </div>
                <div class ="slds-large-size--1-of-12 slds-medium-size--1-of-12 slds-size_2-of-12 slds-align_absolute-center">
                    <lightning:icon iconName="utility:chevronleft" alternativeText="Error!" onclick="{!c.slideLft}" class="{!if(v.disLeft,'utilitycls','utilitycls isAcArrow')}"/>
                </div>
                <div class ="slds-large-size--10-of-12 slds-medium-size--10-of-12 slds-size_8-of-12">
                    <div class ="tests" id="container"> 
                        <aura:iteration items='{!v.VideosLinks}' var="vid" indexVar="index">
                            <div class ="slds-large-size--3-of-12 slds-Medium-size--6-of-12 slds-small-size--6-of-12 slds-size_6-of-12 vLinks">
                                
                                <a onclick ="{!c.openModal}" href="javascript:void(0)" id="{!vid.value.Summary__c}" title="{!vid.value.Title}"><img id="{!vid.value.Summary__c}" class="imgwidth" src="{!vid.key}" title="{!vid.value.Title}" /></a>
                                <a onclick ="{!c.openModal}" class="underlinenone"> <div id="{!vid.value.Summary__c}" title="{!vid.value.Title}" class ="Title"> {!vid.value.Title}</div></a>
                                <div class ="summary"> {!vid.value.Summary}</div>
                                
                            </div>
                        </aura:iteration>
                    </div>
                </div>
                <div class ="slds-large-size--1-of-12 slds-size_2-of-12 slds-medium-size--1-of-12  slds-align_absolute-center">
                        <lightning:icon iconName="utility:chevronright" alternativeText="Error!" onclick="{!c.slideRight}" class="{!if(v.disright,'utilitycls','utilitycls isAcArrow')}" />
                </div>
            </div>
        </div>
        <aura:if isTrue="{!v.ModalOpen}">
            <!--###### MODAL BOX Start From Here ######-->
            <div id="contactSupportModal" role="dialog" tabindex="-1" aria-labelledby="header99" class="slds-modal slds-fade-in-open ">
                <div class="slds-modal__container ">
                    
                    <!-- ###### MODAL BOX HEADER Part Start From Here ######-->
                    <div class="slds-modal__header">
                        <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.closeModal}">
                            <lightning:icon iconName="action:remove" alternativeText="Approved" size="xx-small"/>
                            <span class="slds-assistive-text">Close</span>
                        </button>
                         <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate innerClass" style="text-align:left;" >{!v.videoTitle}</h2>
                        
                       
                    </div>            
                    
                    <!--###### MODAL BOX BODY Part Start From Here ######-->
                    <div class="slds-modal__content slds-p-around--medium innerClass">
                        <aura:unescapedHtml value="{!v.VideosSummary}"/>
                    </div>
                    <!--###### MODAL BOX FOOTER Part Start From Here ######-->
                </div>
            </div>
            <div class="slds-backdrop slds-backdrop--open"></div>
            <!--###### MODAL BOX Part END Here ######-->
        </aura:if>
    </div>

</aura:component>