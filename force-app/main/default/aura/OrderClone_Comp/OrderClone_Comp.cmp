<aura:component controller="OrderClone_Controller" extends="c:LCC_GenericLightningComponent" implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickActionWithoutHeader">
    
    <!--Attributes-->
    <aura:attribute name="fields" type="String[]" default="['Name','SBQQ__PaymentTerm__c','Bill_To_Name__c']" />
     
    <aura:attribute name="showConfirmDialogBox" type="boolean" default="false"/>
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="newOrderRecordId" type="String" />
    <aura:attribute name="spinner" type="boolean" default="false"/>
    
     <!--Modal Header-->  
    <aura:if isTrue="{!v.spinner}">
        <div aura:id="spinnerId" class="slds-spinner_container" style="position:fixed;">
            <div class="slds-spinner--brand  slds-spinner slds-spinner--large slds-is-relative" role="alert">
                <span class="slds-assistive-text">Loading...</span>
                <div class="slds-spinner__dot-a"></div>
                <div class="slds-spinner__dot-b"></div>
            </div>
        </div>
    </aura:if>
    <div class="modal-header slds-modal__header slds-size_1-of-1">
        <h4 class="title slds-text-heading--medium"><b>Clone Record</b></h4>
    </div>
    <!--End Modal Header-->  
     
    <!--Modal Body-->   
    <div class="slds-modal__content slds-p-around--x-small slds-align_absolute-center slds-size_1-of-1 slds-is-relative">
        <form class="slds-form--stacked">
            <h6 class="title slds-text-heading--medium">Do you want to clone the record</h6>
            
        </form> 
        
    </div>    
   
    <!--End of Modal Body--> 
     
    <!--Modal Footer-->
    <div class="modal-footer slds-modal__footer slds-size_1-of-1">
        <lightning:button variant="Brand" class="slds-button" label="OK" onclick="{!c.handleSubmit}"/>
        <lightning:button variant="Neutral" class="slds-button" label="Cancel" onclick="{!c.handleClose}"/>
    </div>
    <!--End of Modal Footer-->    
  
    
    <!--Component End-->
</aura:component>