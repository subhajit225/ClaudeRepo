<aura:component implements="forceCommunity:availableForAllPageTypes" access="global" >
    <aura:attribute name="label" type="string"/>
    <aura:attribute name="linkType" type="string"/>
    <aura:attribute name="url" type="string" default="contentdisplay"/>
    <aura:attribute name="width" type="string"/>
    <br/>
    <lightning:button label="{!v.label}" name ="{!v.label}" variant="brand" onclick="{!c.handleClick}" class="slds-align_absolute-center slds-size_3-of-4"/>
    
</aura:component>