<design:component label="PC_Button">
    <design:attribute name="label" label="Label" default="Submit" description="Name of the Button you want to show" />
    <design:attribute name="linkType" label="Link Type" description="Link Type" datasource="Community Page, External Url"/>
    <design:attribute name="url" label="Url" description="Navigationlink"/>
    <design:attribute name="width" label="width" description="Button width"/>
</design:component>