                    <div id="{!'content-id-0'+ (index+1)}" class="slds-carousel__panel" role="tabpanel" aria-hidden="false" aria-labelledby="indicator-id-01">
                        <a href="javascript:void(0);" class="slds-carousel__panel-action slds-text-link_reset" tabindex="{!if(v.selectedIndex == index, 0, -1)}">
                            <div class="slds-carousel__image">
                                <img src="{!image.Image_Url__c}" />
                            </div>
                            <div class="slds-carousel__content">
                                <h2 class="slds-carousel__content-title">{!image.Name}</h2>
                            </div>
                        </a>
                    </div>
                </aura:iteration>
            </div>
            <ul class="slds-carousel__indicators" role="tablist">
                <aura:iteration items="{!v.imageList}" var="image" indexVar="index">
                <li class="slds-carousel__indicator" role="presentation">
                    <a id="{!'indicator-id-0'+ (index+1)}" class="{!'slds-carousel__indicator-action' + if(v.selectedIndex == index, ' slds-is-active', '')}" 
                       href="javascript:void(0);" role="tab" tabindex="{!if(v.selectedIndex == index, 0, -1)}" aria-selected="{!if(v.selectedIndex == index, true, false)}" 
