<aura:component implements="forceCommunity:availableForAllPageTypes" access="global" controller="PC_TilesController">
    <aura:attribute name="imageList" type="object"/>
    <aura:attribute name="pageName" type="string" default="home"/>
    <aura:attribute name="imageType" type="string" default="Carousel"/>
    <aura:attribute name="selectedIndex" type="integer" default="0"/>
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    <!-- src = "https://rubrikinc-devsb-c.cs67.content.force.com/servlet/servlet.FileDownload?file=0150n000000ERpV"-->
    <!-- <ltng:require styles="{!$Resource.SLDS_SFDC + '/styles/lightning-design-system-ltng.css'}"/>-->
    <lightning:carousel disableAutoRefresh="false" disableAutoScroll="false" scrollDuration="6">        
        <aura:iteration items="{!v.imageList}" var="image" indexVar="index">            
            <lightning:carouselImage id="{!index}" src = "{!image.Image_Url__c}"
                                     href = "{!image.Navigate_Url__c}"
                                     onclick="{!c.onSelect}" target="_blank">
            </lightning:carouselImage>
        </aura:iteration>
    </lightning:carousel>
    <!--  href = "{!image.Navigate_Url__c}"
