<aura:component implements="forceCommunity:availableForAllPageTypes,force:hasRecordId" controller="PC_DealRegExtnReqController" access="global" >
	<aura:attribute name="recordId" type="string"/>
    <aura:attribute name="message" type="string"/>
    <aura:attribute name="status" type="string"/>
    <aura:attribute name="expDays" type="Double"/>
    <aura:attribute name="btndisable" type="boolean" default = "false"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <div style="text-align:right; height:0; overflow: visible;" >
    	<lightning:button label="Request Extension" class="top4rem" disabled="{!v.btndisable}" onclick="{!c.handleClick}"></lightning:button>
    </div>
</aura:component>