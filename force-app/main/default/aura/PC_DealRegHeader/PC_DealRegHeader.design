<design:component >
    <design:attribute name="label" label="Header" default="" description="Header name of the Tile" />
    <design:attribute name="btnlabel" label="Button Label" description="Name of the Button"/>	
    <design:attribute name="url" label="Url" description="Navigation url"/>	
    <design:attribute name="imgurl" label="Image Url" description="Image url"/>
    <design:attribute name="imgHeight" label="Height" description="Image Height" default="150"/>
</design:component>