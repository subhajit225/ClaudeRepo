<design:component label="PC_RecordBanner">
    <design:attribute name="iconName" label="Icon Name" default="custom:custom66_120" description="Name of the Icon you want to show" />
    <design:attribute name="sObjectName" label="Object Label" description="Name of the sObject you want to show" />
    <design:attribute name="recordName" label="Record Name" default="{!recordName}" description="Name of the record you want to show" />
    <design:attribute name="recordId" label="Record ID" default="{!recordId}" description="Id of the record you want to show" />
</design:component>