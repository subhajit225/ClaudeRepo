<aura:component implements="forceCommunity:availableForAllPageTypes" access="global" >
    <aura:attribute name="header" type="string" default="" description="Mobile Image Url"/>
    <aura:attribute name="label" type="string" default="" description="Mobile Image Height"/>
    <aura:attribute name="imgurl" type="string" default="/partnersnew/file-asset/ImageName?v=1"/>
    <aura:attribute name="imgHeight" type="string" default="150"/>
    <aura:attribute name="imgurlMobile" type="string" default="/partnersnew/file-asset/ImageName?v=1"/>
    <aura:attribute name="deviceType" type="string" default="Desktop"/>
    
    <aura:handler name="init" value="this" action="{!c.doInit}"/>
    
    <div class="slds-size_1-of-1" >  
        <div class="slds-align-absolute-center " style="{!'height:'+v.imgHeight+'px;'}">
            <a>
                <img class="hero" src="{!v.imgurl}"/>
            </a>
        </div>
    </div>
</aura:component>