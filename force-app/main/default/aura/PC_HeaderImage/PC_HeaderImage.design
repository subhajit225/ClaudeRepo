<design:component >
    <design:attribute name="imgurl" label="Desktop Image Url" description="Image url" default="/partnersnew/file-asset/ImageName?v=1"/>
    <design:attribute name="imgHeight" label="Height" description="Image Height" default="150"/>
    <design:attribute name="header" label="Mobile Image Url" default="" description="Header name of the Tile" />
    <design:attribute name="label" label="Mobile Image Height" default="" description="Text" />
</design:component>