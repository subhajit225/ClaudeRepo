<aura:component implements="forceCommunity:availableForAllPageTypes" access="global" >
    <lightning:layout multipleRows="true">
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="12" padding="around-small" class="alignTopBottom">
            <hr class="divTop"/>
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="2" largeDeviceSize="2" padding="around-small">
            <div class="circleBase number">1</div>
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="4" largeDeviceSize="4" padding="around-small" class="sectionTwo minHeight">
            Rubrik Self Service
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
            <div class="insideSectionThree insideSectionThreeFont bulletPoint">Watch the Rubrik Velocity Portal video for a tour of the partner portal features and functionality (coming soon)</div>
            <div class="insideSectionThreeSub insideSectionThreeFont bulletPoint">Read the Rubrik partner portal FAQ for answers to common portal-related questions (coming soon)</div>        
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="12" padding="around-small" class="alignTopBottom">
            <hr class="divTop"/>
        </lightning:layoutItem>
        
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="2" largeDeviceSize="2" padding="around-small">
            <div class="circleBase number">2</div>
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="4" largeDeviceSize="4" padding="around-small" class="sectionTwo minHeight">
            Rubrik Overview
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
            <div class="insideSectionThree insideSectionThreeFont bulletPoint">Watch the <a href="https://rubrik.docebosaas.com/partners/share/asset/view/259" target="_blank">Rubrik Founders story</a></div>
            <div class="insideSectionThreeSub insideSectionThreeFont bulletPoint">Check out <a href="https://www.youtube.com/channel/UCDoKLwlfdfH61rkzD3pu_ZQ" target="_blank">Rubrik’s YouTube channel</a></div>
            <div class="insideSectionThreeSub insideSectionThreeFont bulletPoint">Read key whitepapers and data sheets on the <a href="https://partner.rubrik.com/s/sales" target="_blank">Sell page</a></div>
        </lightning:layoutItem>        
        
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="12" padding="around-small" class="alignTopBottom">
            <hr class="divTop"/>
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="2" largeDeviceSize="2" padding="around-small">
            <div class="circleBase number">3</div>
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="4" largeDeviceSize="4" padding="around-small" class="sectionTwo minHeight">
            Learn How To Sell and Demo Rubrik
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
            <div class="insideSectionThree insideSectionThreeFont bulletPoint">Watch the <a href="https://rubrik.docebosaas.com/partners/pages/40/course-catalog" target="_blank">BrikLayer 101 and 201 Training</a></div>            
        </lightning:layoutItem>         
        
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="12" padding="around-small" class="alignTopBottom">
            <hr class="divTop"/>
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="2" largeDeviceSize="2" padding="around-small">
            <div class="circleBase number">4</div>
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="4" largeDeviceSize="4" padding="around-small" class="sectionTwo minHeight">
            Get Accredited
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
            <div class="insideSectionThree insideSectionThreeFont bulletPoint">
                Sign up for Rubrik <a href="https://rubrik.docebosaas.com/partners/learn/course/66/rubrik-foundations" target="_blank">Foundations</a> and 
                <a href="https://rubrik.docebosaas.com/partners/learn/course/82/rubrik-essentials" target="_blank">Essentials</a>, a two-day technical training and on-site lab</div>
        </lightning:layoutItem> 
        
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="12" padding="around-small" class="alignTopBottom">
            <hr class="divTop"/>
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="2" largeDeviceSize="2" padding="around-small">
            <div class="circleBase number">5</div>
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="4" largeDeviceSize="4" padding="around-small" class="sectionTwo minHeight">
            Sign Up
        </lightning:layoutItem>
        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
            <div class="insideSectionThree insideSectionThreeFont bulletPoint">Keep current on all that's happening at Rubrik. Sign up to get the Rubrik Partner Newsletter and updates</div>
        </lightning:layoutItem> 
    </lightning:layout>
    
</aura:component>