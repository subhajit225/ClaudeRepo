<aura:component extends="c:PC_UtilityCmp" implements="forceCommunity:availableForAllPageTypes" access="global"
    controller="PC_TagsContentController">
    <ltng:require styles="/resource/PartnerCommunityResource/Stylesheets/PartnerCommunityCSS.css"/>
    <aura:attribute name="Contents" type="Object" />
    <aura:attribute name="url" type="string" default="contentdetails" />
    <aura:attribute name="LibraryName" type="string" />
    <aura:attribute name="tags" type="list" />
    <aura:attribute name="tag" type="string" />
    <aura:attribute name="selectedTag" type="string" />
    <aura:attribute name="defaultTag" type="string" />

    <aura:handler name="init" value="{! this }" action="{! c.doInit }" />

    <aura:iteration items="{! v.tags}" var="tag" indexVar="index">
        <lightning:button label="{!tag}" name="{!tag}" variant="{!if(v.selectedTag == tag,'neutral','tab-button')}"
            onclick="{!c.handleClick}" class="slds-m-top_xx-small tab-button" />
    </aura:iteration>
    <br />
    <lightning:card title="{!v.selectedTag}" class="slds-m-top_medium no-style-slds-card">
        <lightning:layout multipleRows="true">
            <aura:iteration items="{!v.Contents}" var="Content" start="0" end="6">
                <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="4" largeDeviceSize="4"
                    padding="around-small">
                    <c:PC_ContentView id="{!Content.Id}"></c:PC_ContentView>
                </lightning:layoutItem>
            </aura:iteration>
            <aura:if isTrue="{!not(empty(v.Contents))}">
                <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="12"
                    padding="around-small">
                    <div class="slds-text-title_caps"><b>More Content..</b></div>
                </lightning:layoutItem>
                <aura:iteration items="{!v.Contents}" var="Content" start="6">
                    <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="3" largeDeviceSize="3"
                        padding="around-small">
                        <a id="{!Content.Id}" aura:id="contentId" onclick="{!c.PreviewContent}" class="cardUrl">{!Content.Title} </a>
                    </lightning:layoutItem>
                </aura:iteration>
            </aura:if>
        </lightning:layout>
    </lightning:card>
</aura:component>