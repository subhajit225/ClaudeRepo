<aura:component implements="forceCommunity:availableForAllPageTypes" access="global" >
    <aura:attribute name="label" type="string"/>
    <aura:attribute name="url" type="string"/>
    <aura:attribute name="btnlabel" type="string"/>
    <aura:attribute name="imgurl" type="string"/>
    <!-- <lightning:tile label="{!v.label}" href="{!'/' + v.url}">
        <lightning:button label="{!v.label}" variant="brand" onclick="{!c.handleClick}" class="slds-align_absolute-center"/>
    </lightning:tile> -->
    
    <div class="slds-size_1-of-1" >        
        <div class="slds-box_x-small slds-text-align_center tileMenuItemCard">
            
            <div class="uiMenuItem forceCommunityTileMenuItem" data-aura-class="uiMenuItem forceCommunityTileMenuItem">
                
                <span class="navTileLink" href="/partnersnew/s/dealreglist" role="menuitem" data-special-link="true" title="Register a Deal">
                   
                    <div class="tileLabel" onclick="{!c.handleClick}">{!v.label}</div> 
                     
                    <div class="slds-align--absolute-center imagePreview" clas="backImage" style="{!'background-image: url('+v.imgurl+'); height:150px;'}">
                        <div class="slds-grid slds-grid_vertical">
                          <div class="slds-col">
                            <span><p class="textColor">Register a Deal</p></span>
                          </div>
                          <div class="slds-col">&nbsp;</div>
                          <div class="slds-col">
                            <span><p>
                            <lightning:button label="{!v.btnlabel}" variant="Neutral" onclick="{!c.handleClick}" class="slds-align_absolute-center"/>
                        </p></span>
                          </div>
                        </div>
                        
                        
                    </div>
                </span>
            </div>
        </div>
    </div>
</aura:component>