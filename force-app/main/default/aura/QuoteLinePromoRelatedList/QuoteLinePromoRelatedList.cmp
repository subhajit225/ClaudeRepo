<aura:component controller="qlPromoRelatedListController" implements="flexipage:availableForRecordHome,force:hasRecordId" access="global" >
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="name" type="String" default="Prior Promo Details"/>
    <aura:attribute name="recordId" type="String"/>
    <!-- handlers-->
    <aura:handler name="init" value="{! this }" action="{! c.doInit }"/>
    
    <div style="border: 1px solid #D8D8D8; border-radius: 5px;">
        <article class="slds-card">
            <div class="slds-card__header">
                <header class="slds-media slds-media_center slds-has-flexi-truncate slds-theme_shade">
                    <div class="slds-media__body">
                        <h2 class="slds-card__header-title">
                            <div class="slds-card__header slds-truncate" title="Prior Promo Details">
                                <div class="slds-m-left_small slds-m-top_medium">
                                    <lightning:icon iconName="custom:custom93" size="small" />
                                    <span class="slds-m-left_small" style="font-weight: bold">{!v.name}</span>
                                </div>
                            </div>
                        </h2>
                    </div>
                </header>
                <lightning:datatable
                       keyField="Id"
                       data="{! v.data }"
                       columns="{! v.columns }"
                       showRowNumberColumn="true"
                       hideCheckboxColumn="true" 
                      >
                </lightning:datatable>
            </div> 
            
                
        </article>
    </div>
</aura:component>