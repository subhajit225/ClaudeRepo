<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" controller="su_vf_console.SUAuthentication">
    <!-- <c:SUAuthHeaderDynamic aura:id="SuAnalytics" /> -->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" access="global" />
     <!-- Client Driven Input Variable -->
     <aura:attribute name="selectedTypeFilter" type="String" default="" access="global" />
     <aura:attribute name="advanceFilterData" type="List" access="global" />
     <aura:attribute name="searchString" type="String" access="global" default="" />
     <aura:attribute name="pageSize" type="String" default="10" access="global" />
     <aura:attribute name="defaultSearchPage" type="String" access="global" default="" />
     <aura:attribute name="noSearchResultFoundMsg" type="String" default="Sorry, no results found." access="global" />
     <aura:attribute name="defaultFilterCollapse" type="Boolean" access="global" default="true" />
     <aura:attribute name="listview" type="Boolean" default="true" access="global" />
     <aura:attribute name="contentSourceTab" type="Boolean" default="true" access="global" />
     <aura:attribute name="collapsibleSummary" type="Boolean" access="global" default="true" />
     <aura:attribute name="advanceSearchEnabled" type="Boolean" access="global" default="false" />
     <!-- Client Driven Input Variable ends here-->
     <aura:attribute name="scConfigObj" type="Object" />
     <aura:attribute name="getRecommendations" type="Boolean" default="false" /> 
     <aura:attribute name="isCollapsed" type="Boolean" default="false" />
     <aura:attribute name="expandCollapseData" type="string" default="[ + ]" />
     <aura:attribute name="pageSizeAdvFiltr" type="String" default="10" />
     <aura:attribute name="active" type="string" default="all" />
     <aura:attribute name="refresh" type="Boolean" default="false"/>
     <aura:attribute name="sortByValues" type="List" />
     <aura:attribute name="hideFacetAdmin" type="Boolean" default="false" />
     <aura:attribute name="sortByCheck" type="String" default="_score" />
     <aura:attribute name="responseListData" type="List" />
     <aura:attribute name="currentCommunityURL" type="String" default="" />
     <aura:attribute name="currentCommunityEmail" type="String" default="" />
     <aura:attribute name="setCurrentEmail" type="String" default="" />
     <aura:attribute name="paginationList" type="List" />
     <aura:attribute name="searchUnifyDownStatus" type="Boolean" default="false" />
     <aura:attribute name="novaluesForResult" type="Boolean" default="false" />
     <aura:attribute name="isMobile" type="Boolean" default="false" />
     <aura:attribute name="aggregationsData" type="List" />
     <aura:attribute name="narrowSearch" type="Integer" default="1" />
     <aura:attribute name="filterOrder" type="String" default="" />
     <aura:attribute name="originalAggregationsData" type="List" />
     <aura:attribute name="pageNum" type="String" default="1" />
     <aura:attribute name="fromPage" type="Integer" />
     <aura:attribute name="toPage" type="Integer" />
     <aura:attribute name="lastPage" type="String" />
     <aura:attribute name="suggestData" type="String" default="" />
     <aura:attribute name="loadingResult" type="Integer" />
     <aura:attribute name="totalResults" type="Integer" default="0" />
     <aura:attribute name="resultImgUrl" type="String" />
     <aura:attribute name="errorMessage" type="String" />
     <aura:attribute name="endPoint" type="String" />
     <aura:attribute name="uid" type="String" />
     <aura:attribute name="searchResultTime" type="String" />
     <aura:attribute name="currentUserEmail" type="String" default="" />
     <aura:attribute name="customSettingErrorMessage" type="String" />
     <aura:attribute name="commBaseURL" type="String" />
     <aura:attribute name="exactPhrase" type="String" default="" />
     <aura:attribute name="withOneOrMore" type="String" default="" />
     <aura:attribute name="withoutTheWords" type="String" default="" />
     <aura:attribute name="metaStatus" type="Boolean" default="true" />
     <aura:attribute name="relatedTilesStatus" type="Boolean" default="true" />
    <aura:attribute name="applyTheme" type="Boolean" default="false" />
    <aura:attribute name="noResultAdvertisement" type="Boolean" default="false" />

     <aura:attribute name="meta_data" type="Object" />
     <aura:attribute name="knowledgeGraphResponseRecorded" type="Boolean" default="false" />
     <aura:attribute name="featuredResponseRecorded" type="Boolean" default="false" />
     <aura:attribute name="timeoutResponse" type="Boolean" default="false" />
     <aura:attribute name="featureSnippet" type="Object" />
     <aura:attribute name="relatedTiles" type="List" />
     <aura:attribute name="selectedRows" type="List" />
     <aura:attribute name="showClearFiltersButton" type="Boolean" default="false" />
     <aura:attribute name="similarSearchSuggestions" type="List" />
     <aura:attribute name="checkedBookmark" type="Boolean" default="true" />
     <aura:attribute name="count" type="Integer" default="0" />
     <!-- areabookmark -->
     <aura:attribute name="bookmarkSearches" type="List" />
     <aura:attribute name="viewSavePopup" type="Boolean" default="false" />
     <aura:attribute name="viewConfirmPopup" type="Boolean" default="false" />
     <aura:attribute name="bookmarkName" type="String" default="" />
     <aura:attribute name="query" type="Object" />
     <aura:attribute name="bookmark_clicked" type="Boolean" default="false" />
     <aura:attribute name="bookmark_queryPassed" type="Object" />
     <aura:attribute name="star_clicked" type="Boolean" default="false" />
     <aura:attribute name="disableButton" type="Boolean" default="true" />
     <aura:attribute name="disableButtonAdvancedSearch" type="Boolean" default="true" />
     <aura:attribute name="bookmark_list" type="Boolean" default="false" />
     <aura:attribute name="removebookmark" type="Object" />
     <aura:attribute name="initialised" type="Boolean" default="true" />
     <aura:attribute name="selectedStickyFilter" type="List" />
    <aura:attribute name="selectedStickyFilterData" type="List" />

     <aura:attribute name="topFiltersLayoutDiv" type="Boolean" default="false" />
     <aura:attribute name="showFilterLargeDiv" type="Boolean" default="false" />
     <aura:attribute name="showSticky" type="Boolean" default="false" />
     <!-- areabookmark -->
     <aura:attribute name="stickyFilter_label" type="List" />
     <aura:attribute name="activeSticky" type="string" />
     <aura:attribute name="currentClickedOrder" type="Object" />
     <aura:attribute name="viewMore" type="Boolean" default="false" />
     <aura:attribute name="searchTipsTab" type="Boolean" default="false" />
     <aura:attribute name="bookmarkTab" type="Boolean" default="false" />
     <aura:attribute name="viewMoreTab" type="Boolean" default="false" />
     <aura:attribute name="showScroll" type="Boolean" default="false" />
     <aura:attribute name="facetsList" type="List" />
     <aura:attribute name="customizeDiv" type="Boolean" default="false" />
     <aura:attribute name="filterToRight" type="Boolean" default="false" />
     <aura:attribute name="alignFilters" type="Boolean" default="false" />
     <aura:attribute name="hideTitle" type="Boolean" default="false" />
     <aura:attribute name="hideSummary" type="Boolean" default="false" />
     <aura:attribute name="hideUrl" type="Boolean" default="false" />
     <aura:attribute name="hideIcon" type="Boolean" default="false" />
     <aura:attribute name="hideTag" type="Boolean" default="false" />
     <aura:attribute name="hideMetadata" type="Boolean" default="false" />
     <aura:attribute name="toggleDisplayKeys" type="List" />
     <aura:attribute name="hiddenKeys" type="List" />
     <aura:attribute name="hiddenFacets" type="List" />
     <aura:attribute name="accessKeyValue" type="string" />
     <aura:attribute name="activeTabOrder" type="Integer" />
     <aura:attribute name="activeTabIndex" type="string" />
     <aura:attribute name="activeTabType" type="string" />
     <aura:attribute name="hideData" type="Boolean" default="false" />
     <aura:attribute name="setFlag" type="Boolean" default="false" />
     <aura:attribute name="applyChanges" type="Boolean" default="false" />
     <aura:attribute name="defaultTab" type="string" default="all" />
     <aura:attribute name="customize" type="Boolean" default="false" />
     <aura:attribute name="showPageSize" type="Boolean" default="false" />
     <aura:attribute name="resetType" type="Boolean" default="false" />
     <aura:attribute name="tabIndex" type="Boolean" default="false" />
     <aura:attribute name="confirmReset" type="Boolean" default="false" />
     <aura:attribute name="activeTabFunc" type="Boolean" default="false" />
     <aura:attribute name="contentSourceExists" type="Boolean" default="false" />
     <aura:attribute name="preview" type="Boolean" default="true" />
     <aura:attribute name="contentTag" type="Boolean" default="true" />
     <aura:attribute name="multiVersion" type="Boolean" default="true" />
     <aura:attribute name="previewSource" type="String" />
     <aura:attribute name="previewTitle" type="String" />
     <aura:attribute name="previewLabel" type="String" />
     <aura:attribute name="filtersArray" type="List" />
     <aura:attribute name="emptyResponseAggregations" type="List" />
     <aura:attribute name="values" type="Object" />
     <aura:attribute name="valuesBackup" type="Object" />
     <aura:attribute name="dragid" type="Integer" access="private" />
     <aura:attribute name="dropId" type="Integer" access="private" />
     <aura:handler name="init" value="{!this}" action="{!c.doinit}" />
     <aura:attribute name="defaultPageSize" type="String" default="10" />
     <aura:attribute name="advertisement" type="String" />
     <aura:attribute name="mergedArray" type="List" />
     <aura:attribute name="refine_search" type="String" default="Refine Search" />
     <aura:attribute name="save_bookmark" type="String" default="Saved Bookmarks" />
     <aura:attribute name="add_bookmark" type="String" default="Add Bookmark" />
     <aura:attribute name="close" type="String" default="Close" />
     <aura:attribute name="title_bookmark" type="String" default="Title for this bookmark" access="global"/>
     <aura:attribute name="filter" type="String" default="Filter" />
     <aura:attribute name="exact_phrase" type="String" default="With the exact phrase" />
     <aura:attribute name="one_or_more" type="String" default="With one or more words" />
     <aura:attribute name="without_words" type="String" default="Without the words" />
     <aura:attribute name="mobile" type="String" default="Mobile Advance search" />
     <aura:attribute name="list_view" type="String" default="List View" />
     <aura:attribute name="grid_view" type="String" default="Grid View" />
     <aura:attribute name="result_per_page" type="String" default="Results per page" />
     <aura:attribute name="search_tips" type="String" default="Search Tips" />
     <aura:attribute name="settings" type="String" default="Settings" />
     <aura:attribute name="search_preview" type="String" default="Preview" />
     <aura:attribute name="showSummary" type="Boolean" default="false" />
     <aura:attribute name="searchSummaryLength" type="String" default="100" />
     <aura:attribute name="showMoreSummary" type="Map" default="{}" />
     <aura:attribute name="language" type="String" default="Language" />
     <aura:attribute name="searchFacet" type="String" default="Search Facet" />
     <aura:attribute name="result" type="String" default="results" />
     <aura:attribute name="componentLoaded" type="Boolean" />
     <aura:attribute name="directionText" type="String" default="LTR" />
     <aura:attribute name="languageSelectedByUser" type="String" />
     <aura:attribute name="translator" type="object" access="global" />
     <aura:attribute name="selectedLanguages" type="object" access="global" />
     <aura:attribute name="pagingAggregation" type="Object" />
     <aura:attribute name="translationObj" type="List"  />
     <aura:attribute name="finalLang" type="Object"/>
     <aura:attribute name="showLanguageDropdown" type="Boolean" default="true" />
     <aura:attribute name="showViewedResults" type="Boolean" default="false" />
     <aura:attribute name="filterSortingLoading" type="Boolean" default="false" />
     <aura:attribute name="allContentHideFacets" type="Boolean" default="true" />
     <aura:attribute name="resetFilters" type="Boolean" default="false" />
     <aura:attribute name="activeMergedChild" type="String" />
     <aura:attribute name="isAutoLearning" type="Boolean" default="true" />
     <aura:attribute name="isSmartFacetsAdmin" type="Boolean" default="true" />
     <aura:attribute name="isSmartFacets" type="Boolean" default="true" />
     <aura:attribute name="isSmartHidden" type="Boolean" default="false" />
     <aura:attribute name="smartAggregations" type="List" />
     <!--feedback variables-->
     <aura:attribute name="clickedTitleVal" type="Integer" default="0" />
      <aura:attribute name="feedbackRatingVal" type="Integer" default="0" />
     <aura:attribute name="feedbackConvObj" type="Object" />
     <aura:attribute name="pageFeedback" type="Boolean" default="false" />
     <aura:attribute name="feedbackModalShow" type="Boolean" default="true" />
     <aura:attribute name="displayModal" type="Boolean" default="false" />
     <aura:attribute name="displayThankModal" type="Boolean" default="false" />
     <aura:attribute name="searchFeedback" type="Boolean" default="false" />
      <aura:attribute name="searchPageFeedback" type="Boolean" default="false" />
     <aura:attribute name="responseSearchFeedbackData" type="Object" />
     <aura:attribute name="feedbackRating" type="List" default="[ 'star1', 'star2', 'star3', 'star4', 'star5' ]"/>
     <aura:attribute name="emailShowhide" type="Boolean" default="true" />
     <aura:attribute name="emailShowYes" type="String" default="" />
     <aura:attribute name="isButtonActive" type="Boolean" default="true" />
     <aura:attribute name="setHiddenFilters" type="Boolean" default="false"/>
     <aura:attribute name="isDuplicateBookmark" type="Boolean" default="false"/>
     <aura:attribute name="getFeedbackResData" type="Object" default="" />
     <aura:attribute name="isInputDisabled" type="Boolean" default="false" />
     <!-- <aura:method name="translateText" action="{!c.translateText}" /> -->
    <aura:method name="saveLangToLocal" action="{!c.saveLangToLocal}" />
    <aura:method name="typeSelect" action="{!c.typeSelect}">
        <aura:attribute name="itemRemoved" type="Object" />
    </aura:method>
    <aura:handler name="change" value="{!v.sortByCheck}" action="{!c.sortCall}" />
    <aura:registerEvent name="searchBoxEvent" type="su_vf_console:fillSearchBox" />
    <aura:method name="searchResult" action="{!c.searchResultFunction}">
        <aura:attribute name="data" type="List" />
        <aura:attribute name="pageResult" type="String" />
    </aura:method>
    <aura:attribute name="Bearer" type="string" />
    <aura:attribute name="customSettingsFilled" type="Boolean" default="false" />
    <aura:handler event="su_vf_console:SUComponentEvent" action="{!c.getValueFunc}" />
    <aura:if isTrue="{!v.customSettingsFilled}">
        <c:SUAuthHeaderDynamic aura:id="SuAnalytics" endPoint="{!v.endPoint}" uid="{!v.uid}" currentUserEmail="{!v.currentUserEmail}" customSettingErrorMessage="{!v.customSettingErrorMessage}" />
        <aura:if isTrue="{!v.componentLoaded}">
            <!--mainUI--><div dir="{!v.directionText}" class="{!if(v.showViewedResults == true, 'su__viewed-results slds-grid slds-wrap su__wrapper-block', 'slds-grid slds-wrap su__wrapper-block')}" aura:id="su_scrollWrapper">
    <aura:if isTrue="{!v.setFlag}">
        <img class="su__load-img" src="{!v.scConfigObj.client_url+v.uid+'/Assets/su-results-loader.gif'}" />
    </aura:if>
    <aura:if isTrue="{!v.setFlag == false}">
        <div id="su_searchUnifyContainer1" onscroll="{!c.scroll}" class="{!if(v.loadingResult == 1, 'su_component su__w-100 su__content_section su__bg-gray-50','su__w-100 su__content_section su__bg-gray-50 slds-transition-hide su__loading')}">
            <div class="su-popup-row" aura:id="popup-row">
                <!-- Add bookmark popups-->
                <!-- <aura:if isTrue="{!v.viewSavePopup}"> -->
                <div class="{!if(v.viewSavePopup,'su__anim-fadeindown su__bookmark-popup su__position-fixed su__shadow-lg su__bg-white su__radius-1 su__mx-auto su__zindex-2 su__d-block','visibilityHidden su__position-absolute')}">
                    <div class="su__w-100 ">
                        <div class="su__bookmark-popup-title su__p-2 su__flex-vcenter su__bg-blue-grd">
                            <div class="su__p-2 su__bg-white-circle su__radius-50">
                                <div class="bg-Save_book_mark su-bookmark-info"></div>
                            </div>
                            <div class="su__bookmark-title su__flex-1 su__ml-2 su__rtlml-0 su__rtlmr-2"><label class="font-16 su__text-white">
                                {!v.finalLang.Add_Bookmarks ? v.finalLang.Add_Bookmarks : 'Add Bookmarks'} </label>
                            </div>
                            <div class="su__close-icon su__cursor" onclick="{!c.viewSavePopup_toggle}">
                                <div class="bg-white_close_icon su-bookmark-info"  title="{!v.close}"></div>
                            </div>
                        </div>
                        <div class="su__bookmark-inner su__p-3 su__bg-white">
                            <div class="su__no-bookmark su__my-3 su__my-sm-1 su__text-center">
                                <div class="bg-add_bookmark su-bookmark-info" title="{!v.finalLang.Add_Bookmark? v.finalLang.Add_Bookmark : v.add_bookmark}"></div>
                            </div>
                            <div class="su__w-100 su__my-3 su__text-left">
                                <lightning:input class="su__form-control su__bookmark-input" placeholder="{!v.finalLang.Title_for_this_bookmark ? v.finalLang.Title_for_this_bookmark : v.title_bookmark }" value="{!v.bookmarkName}" name="bookmarkName" onchange="{!c.validateName}" />
                                <p class="su__d-none font-10 su__text-black su__mb-0">
                                    {!v.finalLang.You_can_bookmark_upto_20_searches ? v.finalLang.You_can_bookmark_upto_20_searches : 'You can bookmark upto 20 searches'}
                                </p>
                            </div>
                            <aura:if isTrue="{!v.isDuplicateBookmark}">
                                <h5 class='su__duplicate-bookmark'>{!v.finalLang.Bookmark_with_same_name_already_exists ? v.Bookmark_with_same_name_already_exists : 'Bookmark with same name already exists'}</h5>
                            </aura:if>
                            <div class="su__bookmark-btn su__w-100">
                                <aura:if isTrue="{!or(v.bookmarkSearches.length == 20, v.disableButton)}">
                                    <button class="su__btn su__bg-blue-grd font-12 su__w-100 su__text-white su__cursor su__bookmark-save" disabled="disabled">
                                        {!v.finalLang.Save ? v.finalLang.Save : 'Save'}</button>
                                    <aura:set attribute="else">
                                        <button onclick="{!c.saveToLocal}" class="su__btn su__bg-blue-grd su__w-100 su__text-white su__cursor su__bookmark-save">
                                            {!v.finalLang.Save ? v.finalLang.Save : 'Save'}
                                        </button>
                                    </aura:set>
                                </aura:if>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="{!if(v.viewSavePopup, 'su__bg-overlay', 'su__d-none')}" onclick="{!c.viewSavePopup_toggle}" role="button"></div>
                <!-- </aura:if> -->
                <!-- Add bookmark popups end-->
                <!-- save and delete bookmark popups-->
                <div aura:id="bookmark-section" class="{!if(v.bookmark_list,'su__anim-fadeindown su__bookmark-popup su__position-fixed su__shadow-lg su__bg-white su__radius-1 su__mx-auto su__zindex-2 su__d-block','visibilityHidden su__position-absolute')}">
                    <div class="su__w-100 ">
                        <div class="su__bookmark-popup-title su__p-2 su__flex-vcenter su__bg-blue-grd">
                            <div class="su__p-2 su__bg-white-circle su__radius-50">
                                <div class="bg-Save_book_mark su-bookmark-info" title="{!v.save_bookmark}"></div>
                            </div>
                            <div class="su__bookmark-title su__flex-1 su__ml-2 su__rtlml-0 su__rtlmr-2"><label class="font-16 su__text-white">
                                {!v.finalLang.Saved_Bookmarks ? v.finalLang.Saved_Bookmarks : 'Saved Bookmarks'} </label>
                            </div>
                            <div class="su__close-icon su__cursor" onclick="{!c.closeBookmark}">
                                <div class="bg-white_close_icon su-bookmark-info" title="{!v.close}"></div>
                            </div>
                        </div>
                        <div class="su__bookmark-inner su__bg-white">
                            <aura:if isTrue="{!v.bookmarkSearches.length}">
                                <div class="su__bookmark-ul su__miniscroll">
                                    <aura:iteration items="{!v.bookmarkSearches}" var="result">
                                        <div class="su__flex-vcenter su__px-3 su__py-2 su__mb-1 su__border-b su__word-break">
                                            <div class="su__flex-1 su__cursor">
                                                <a class="sidebar-bookmark font-12" onclick="{!c.bookmarkClicked}" data-query="{!result.href}">
                                                    {!result.title}
                                                    <!--{!v.finalLang.result.title ? v.finalLang.result.title : result.title}-->
                                                </a>
                                            </div>
                                            <div class="su__ml-3 su__outline-none su__cursor su__position-relative su__filter-checkbox su__loading-view">
                                                <ui:inputCheckbox click="{!c.onCheck}" class="su__toggle-input su__position-absolute su__cursor" aura:id="bookmark-box" name="{!result.title}" text="{!result.href}" />
                                                <label class="su__toggle-label su__d-inline-flex su__cursor su__loading-view-border font-12"><span class="su__toggle__text"></span>
                                                    <span class="su__nested__text su__loading su__d-none su__position-relative"></span></label>
                                            </div>
                                        </div>
                                    </aura:iteration>
                                </div>
                                <div class="su__bookmark-btn su__flex-vcenter su__justify-content-between su__px-3 su__py-2 ng-scope">
                                    <button class="su__btn su__p-2 su__bg-gray-40 su__radius-1 su__bookinput-h font-md-12" onclick="{!c.deleteBookmarks}">
                                        {!v.finalLang.Remove_Bookmark ? v.finalLang.Remove_Bookmark : 'Remove Bookmark'}</button>
                                </div>
                                <aura:set attribute="else">
                                    <div class="su__text-center">
                                        <div class="su__no-bookmark su__py-4 su__py-sm-1">
                                            <div class="su-bookmark-info bg-No_book_mark"></div>
                                        </div>
                                        <p class="su__my-3 font-32 su__text-black su__font-bold su__line-height-n">
                                            {!v.finalLang.Oops ? v.finalLang.Oops : 'Oops'}! </p>
                                        <p class="font-14 su__my-2 su__pb-3">
                                            {!v.finalLang.There_is_nothing_here__Zilch__Return_to_search ? v.finalLang.There_is_nothing_here__Zilch__Return_to_search : 'There is nothing here. Zilch. Return to search'}<br />
                                            {!v.finalLang.and_create_your_first_bookmark ? v.finalLang.and_create_your_first_bookmark : 'and create your first bookmark'}.</p>
                                    </div>
                                </aura:set>
                            </aura:if>
                        </div>
                    </div>
                </div>
                <div class="{!if(v.bookmark_list, 'su__bg-overlay', 'su__d-none')}" onclick="{!c.closeBookmark}" role="button"></div>
            </div>
            <!-- areabookmark end-->
            <!-- search tabs start -->
            <aura:if isTrue="{!if(v.totalResults > 0,true,false)}">
                <div class="suHideInSmallView su__tabing su__bg-white su__radius-1">
                    <div id="su__ContentSourceTabs" class="su__tabing-row su__flex-vcenter su__flex-nowrap su__mb-3 su__my-sm-1 su__mt-1 su__border-b su__overflow-x su__miniscroll su__miniscroll-black">
                        <aura:iteration items="{!v.aggregationsData}" var="filter">
                            <aura:if isTrue="{!and(filter.values.length > 0, filter.order == 0)}">
                                <div class="su__tabing-list font-14 su__text-center su__position-relative su__loading-view">
                                    <div class="{!if(v.active=='all','indexData su__tab-active su__cursor su__text-nowrap','indexData su__tabing-item su__text-nowrap su__cursor')}" accessKey="all" order="{!filter.order}" onclick="{!c.indexSearchCall}">
                                        {!v.finalLang.All_Content ? v.finalLang.All_Content : 'All Content'}
                                    </div>
                                </div>
                                <aura:iteration items="{!filter.values}" var="filterType">                                            
                                    <div class="su__tabing-list font-14 su__text-center su__position-relative su__loading-view">
                                        <aura:if isTrue="{!filterType.merged == true &amp;&amp; filterType.showChild == '1' ? true : false}">
                                            <div class="{!if(v.active == filterType.Contentname || filterType.selected || filterType.indeterminate == true,'indexData su__tab-active su__tabing-item su__cursor su__text-nowrap','indexData su__tabing-item su__cursor su__text-nowrap')}">
                                                <aura:if isTrue="{!and(filterType.merged == true, filterType.showChild == '1')}">
                                                    <div class="su__mergedFilter-CS-tab">
                                                        <div class="su__mergedFilter-CS-button">
                                                            <span class="su__mergedFilter-CS-svg su__flex-vcenter" accessKey="exceptall" onclick="{!c.MergedIndexSearchCall}" tabindex="{!filterType}" data-item="{!filterType.parent}" data-order="{!filter.order}" id="{!filterType.Contentname}">
                                                                {!filterType.displayName}
                                                                <div class="bg-keydown_arrow  su__arrow-icons su__d-block su__transition-5s su__cursor" accessKey="exceptall" tabindex="{!filterType}" data-item="{!filterType.parent}" data-order="{!filter.order}" id="{!filterType.Contentname}"></div>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <aura:if isTrue="{!filterType.showClickedCS ? true : false}">
                                                        <div>
                                                            <div class="su__merge-options">
                                                                <aura:iteration items="{!filterType.childArray}" var="child">
                                                                    <div class="{!child.selected ? 'su__merge-options-active su__merge-options-child su__loading-view' : 'su__merge-options-child su__loading-view'}" accessKey="exceptall" tabindex="{!filterType}" data-item="{!filterType.parent}" data-order="{!filter.order}" id="{!child.Contentname}" onclick="{!c.indexSearchCall}">
                                                                        {!child.displayName || child.Contentname}
                                                                    </div>
                                                                </aura:iteration>
                                                            </div>
                                                            <div class="su__d-block su__advance-overlay su__bg-overlay" data-order="{!filter.order}" data-close="close" role="button" onclick="{!c.MergedIndexSearchCall}"></div>
                                                        </div>
                                                    </aura:if>
                                                </aura:if>
                                            </div>
                                            <aura:set attribute="else">
                                                <div class="{!if(v.active == filterType.Contentname || filterType.selected || filter.indeterminate == true,'indexData su__tab-active su__tabing-item su__cursor su__text-nowrap','indexData su__tabing-item su__cursor su__text-nowrap')}" 
                                                accessKey="exceptall" tabindex="{!filterType}" data-item="{!filterType.parent}" data-order="{!filter.order}" id="{!filterType.Contentname}" onclick="{!c.indexSearchCall}">
                                                    {!filterType.displayName}
                                                </div>
                                            </aura:set>
                                        </aura:if>
                                    </div>
                                </aura:iteration>
                            </aura:if>
                        </aura:iteration>
                    </div>
                </div>
            </aura:if>
            <div class="{!if(v.customizeDiv,'su__d-block su__anim-fadeindown su__facetPrefrence','visibilityHidden su__position-absolute')}">
                <div class="su__editClient font-14 su__p-3 su__md-pd-10 su__bg-white su__radius-1 su__position-fixed">
                    <div class="editDiv">
                        <span class="su-edit su__color-black su__font-regular">
                            {!v.finalLang.Edit_Page_Layout ? v.finalLang.Edit_Page_Layout : 'Edit Page Layout'}
                        </span>
                        <span class="closeCustomizeDiv su__float-right su__cursor">
                            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/close.svg'}" onclick="{!c.discardChanges}" style="height:12px;" />
                        </span>
                        <div class="su__reset su__float-right su__mr-3">
                            <span class="apply su-btn-blue su__radius-0 su__cursor su__mr-2 su__p-2" onclick="{!c.toggleConfirmationDialog}">
                                {!v.finalLang.Reset ? v.finalLang.Reset : 'Reset'}</span>
                            <span class="apply su__bg-blue-grd su__radius-0 su__cursor su__p-2 su__text-white" onclick="{!c.applyTheme}">
                                {!v.finalLang.Apply_Changes ? v.finalLang.Apply_Changes : 'Apply Changes'}
                            </span>
                        </div>
                    </div>
                    <div class="su__pb-4 su__pt-3">
                        <div class="{!if(v.active=='all'  &amp;&amp; v.allContentHideFacets,'su-filterspref-active su__col-3 su__d-none','su-filterspref-not-active su__col-3 su__d-inline-block')}">
                            <div class="resultSection su__font-regular font-14 su__mb-3">
                                {!v.finalLang.Rearrange_Facets ? v.finalLang.Rearrange_Facets : 'Rearrange Facets'}
                            </div>
                            <div id="filterList" class="collapse in su__pr-3 su__overflow-auto su__miniscroll rearrangeFacets">
                                <div class="droparea" ondragover="{!c.cancel}" ondragenter="{!c.cancel}" ondrop="{!c.drop}">
                                    <aura:iteration items="{!v.values}" indexVar="index" var="filters">
                                        <aura:if isTrue="{!and(filters.values.length > 0,filters.order != 0)}">
                                            <div class="{!if(filters.smartHidden,'su__fp_indicator su-row ','su-row')}" draggable="true" ondragstart="{!c.dragstart}" data-drag-id="{!index}">
                                                <div class="font-md-12 su__w-100 su__flex-vcenter">
                                                <span class="su__text-truncate">{!filters.label}</span>
                                                <span class="toggleDisplay" id="hideContent">
                                                    <div class="{!if(!filters.hideEye,'su__d-block','visibilityHidden su__position-absolute')}">
                                                        <span class="toggleDisplay eyeIcon su__float-right" id="hideContent">
                                                            <div title="{!'Hide ' + filters.label}" data-query="{!filters.label}" class="{!if(filters.smartHidden, 'bg-show su-img-hide disabled', 'bg-show su-img-hide')}" onclick="{!c.hideFacets}"></div>
                                                        </span>
                                                    </div>
                                                    <div class="{!if(filters.hideEye,'su__d-block','visibilityHidden su__position-absolute')}">
                                                        <span class="toggleDisplay eyeIcon su__float-right" id="showContent">
                                                            <div title="{!'Show ' + filters.label}"  data-item="{!filters.label}" class="{!if(filters.smartHidden, 'bg-hide su-img-hide disabled', 'bg-hide su-img-hide')}" onclick="{!c.showFacets}"></div>
                                                        </span>
                                                    </div>
                                                </span>
                                            </div>
                                            <aura:if isTrue="{!and(filters.smartHidden, filters.hideEye)}">
                                                <div class="su__w-100 font-12">This Facet is still visible on the search page due to auto learning</div>
                                            </aura:if>
                                            <aura:if isTrue="{!and(filters.smartHidden, !filters.hideEye)}">
                                                <div class="su__w-100 font-12">This Facet cannot be hidden on the search page due to auto learning</div>
                                            </aura:if>
                                        </div>
                                        </aura:if>
                                    </aura:iteration>
                                </div>
                            </div>
                        </div>
                        <div class="{!if(v.active=='all' &amp;&amp; v.allContentHideFacets,'su__allcontent-show su__col-12','su__allcontent-notshow su__col-9 su-customize su__float-right')}">
                            <aura:iteration items="{!v.filtersArray}" var="filter">
                                <aura:if isTrue="{!and(filter.values.length > 0, filter.order == 0)}">
                                    <div class="resultSection su__font-regular font-14 su__mb-3">
                                        {!v.finalLang.Pre_Select_a_Tab ? v.finalLang.Pre_Select_a_Tab : 'Pre Select a Tab'}
                                    </div>
                                    <div class="facetsSection">
                                            <div class="yes su-content-tab">
                                                <div class="{!if(v.defaultTab=='all','indexData font-md-12 su__cursor su-tab-active','font-md-12 su__cursor indexData')}" accessKey="all" data-order="{!filter.order}" onclick="{!c.activeTab}" id="all">
                                                    {!v.finalLang.All_Content ? v.finalLang.All_Content : 'All Content'}
                                                </div>
                                            </div>
                                            <aura:iteration items="{!filter.values}" var="filterType">                                            
                                                <div class="yes su-content-tab">
                                                    <aura:if isTrue="{!filterType.merged == true &amp;&amp; filterType.showChild == '1' ? true : false}">
                                                        <div class="{!if(v.defaultTab == filterType.Contentname &amp;&amp; (filterType.merged &amp;&amp; filterType.showChild == '1' || filterType.indeterminate),'indexData su__cursor font-md-12 su-tab-active','font-md-12 su__cursor indexData')}">
                                                            <aura:if isTrue="{!and(filterType.merged == true, filterType.showChild == '1')}">
                                                                <div class="su__mergedFilter-CS-tab">
                                                                    <div class="su__mergedFilter-CS-button">
                                                                        <span class="su__mergedFilter-CS-svg su__flex-vcenter" accessKey="exceptall" onclick="{!c.mergedFacetPreferenceCS}" tabindex="{!filterType}" data-item="{!filterType.parent}" data-order="{!filter.order}" id="{!filterType.Contentname}">
                                                                            {!filterType.displayName}
                                                                            <div class="bg-keydown_arrow  su__arrow-icons su__d-block su__cursor" accessKey="exceptall" tabindex="{!filterType}" data-item="{!filterType.parent}" data-order="{!filter.order}" id="{!filterType.Contentname}"></div>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                                <aura:if isTrue="{!filterType.showFacetPreferenceClickedCS ? true : false}">
                                                                    <div>
                                                                        <div class="su__merge-options">
                                                                            <aura:iteration items="{!filterType.childArray}" var="child">
                                                                                <div class="{!v.activeMergedChild == child.Contentname ? 'su__merge-options-active su__merge-options-child su__loading-view' : 'su__merge-options-child su__loading-view'}" accessKey="exceptall" tabindex="{!filterType}" data-item="{!filterType.parent}" data-order="{!filter.order}" id="{!child.Contentname}" data-mergedCS="{!filterType.Contentname}" onclick="{!c.activeTab}">
                                                                                    {!child.displayName || child.Contentname}
                                                                                </div>
                                                                            </aura:iteration>
                                                                        </div>
                                                                        <div class="su__d-block su__advance-overlay su__bg-overlay" data-order="{!filter.order}" data-close="close" role="button" onclick="{!c.mergedFacetPreferenceCS}"></div>
                                                                    </div>
                                                                </aura:if>
                                                            </aura:if>
                                                        </div>
                                                        <aura:set attribute="else">
                                                            <div class="{!if(v.defaultTab == filterType.Contentname || (filterType.selected  &amp;&amp; filter.indeterminate == true),'indexData su__cursor font-md-12 su-tab-active','font-md-12 su__cursor indexData')}" 
                                                            accessKey="exceptall" tabindex="{!filterType}" data-item="{!filterType.parent}" data-order="{!filter.order}" id="{!filterType.Contentname}" onclick="{!c.activeTab}">
                                                                {!filterType.displayName}
                                                            </div>
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                            </aura:iteration>
                                        </div>
                                </aura:if>
                            </aura:iteration>
                            <div class="hideFacets su__pt-3 su__pb-3">
                                <div class="resultSection su__font-regular font-14 su__mb-3">
                                    {!v.finalLang.Search_Result ? v.finalLang.Search_Result : 'Search Result'}
                                </div>
                                <aura:iteration items="{!v.toggleDisplayKeys}" var="item">
                                    <span class="{!if(item.key == 'Tag' &amp;&amp; !v.contentTag, 'su__d-none su-display','su-display')}">
                                        <span class="toggleDisplay toggleKey su__font-regular" aura:id="showKeyVal">
                                            {!item.key}
                                        </span>
                                        <aura:if isTrue="{!if(item.hideEye == false,true,false)}">
                                            <span class="toggleDisplay" id="hideContent">
                                                <div data-name="{!item.hideEye}" data-query="{!item.key}" class="bg-show su-img-hide su__cursor" onclick="{!c.hideKey}"></div>
                                            </span>
                                        </aura:if>
                                        <aura:if isTrue="{!if(item.hideEye == true,true,false)}">
                                            <span class="toggleDisplay" id="showContent">
                                                <div data-label="{!item.hideEye}" data-item="{!item.key}" class="bg-hide  su-img-hide su__cursor" onclick="{!c.showKey}"></div>
                                            </span>
                                        </aura:if>
                                    </span>
                                </aura:iteration>
                            </div>
                            <div class="su__list-items su__bg-white su__sm-shadow su__radius-1 su__position-relative su__p-3 su__mb-3">
                                <div class="su__list-item-img su-icon su__d-inline-block su__d-xs-none su__mr-2 su__rtlml-2 su__rtlmr-0 su__loading-view">
                                    <aura:if isTrue="{!if(!v.toggleDisplayKeys[4].hideEye, true,false)}">
                                        <div class="{!if(v.loadingResult == 1, 'savedBookmarks su_ResultImage su__left-item-img','su_displayHide')}"></div>
                                    </aura:if>
                                </div>
                                <div class="su__list-item-text su__media-body su__overflow-hide su__word-break">
                                    <h5 class="su__list-item-title su__flex-vcenter su__mw-100 su__m-0 su__text-decoration su__text-black su__text-truncate font-14 su__font-bold">
                                        <aura:if isTrue="{!if(!v.toggleDisplayKeys[0].hideEye, true,false)}">
                                            What is Lorem Ipsum?
                                        </aura:if>
                                        <aura:if isTrue="{!if(!v.toggleDisplayKeys[5].hideEye &amp;&amp; v.contentTag == true, true,false)}">
                                            <span class="su__ribbon-title ab-testing-btn su__ribbon-list su__bg-blue font-12 font-m-10 su__px-2 su__ml-1 su__d-inline-block su__radius-3 su__rtlmx-2">Lorem text</span>
                                        </aura:if>
                                    </h5>
                                    <aura:if isTrue="{!if(!v.toggleDisplayKeys[2].hideEye, true,false)}">
                                        <div class="su-url-citation-div">
                                            <cite class="{!if(v.loadingResult == 1, 'su__text-decoration su__color-blue su__font-italic','su_loadingDisguise')}">https://www.lipsum.com/</cite>
                                        </div>
                                    </aura:if>
                                    <aura:if isTrue="{!if(!v.toggleDisplayKeys[1].hideEye, true,false)}">
                                        <span class="su__list-item-desc su__w-100 su__my-1 su__font-regular su__mb-2 font-12 su__loading-view su__word-break">
                                            Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s, when an unknown printer took a galley of type and scrambled it to make a type specimen book.
                                        </span>
                                    </aura:if>
                                    <aura:if isTrue="{!if(!v.toggleDisplayKeys[3].hideEye, true,false)}">
                                        <div class="{!if(v.loadingResult == 1, 'su-other-elements-section','su_displayHide')}">
                                            <b class="su-metadataTitle su__color-lgray su__ml-1 su__rtlml-0 su__rtlmr-1"> Created Date : 4/22/2019 2:13 PM</b>
                                        </div>
                                    </aura:if>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="su-bg-overlay su-filters" onclick="{!c.toggleEditMode}" role="button" tabindex="0"></div>
            </div>
            <aura:if isTrue="{!v.confirmReset}">
                <div style="z-index:102;" class="su__p-3 su__w-100 su__anim-fadeindown su__bookmark-popup su__position-fixed su__shadow-lg su__bg-white su__radius-1 su__mx-auto su__zindex0">
                    <div class="su__pt-2 su__pb-2 ">
                        {!v.finalLang.Are_you_sure_you_want_to_reset_your_changes_ ? v.finalLang.Are_you_sure_you_want_to_reset_your_changes_ : 'Are you sure you want to reset your changes?'}
                    </div>
                    <div class="su__pt-4 su__text-right">
                        <input type="button" class="su__mr-2 su__full-btn  su__text-secondary" value="Yes" onclick="{!c.reset}" />
                        <input type="button" class="su__full-btn  su__text-secondary" value="No" onclick="{!c.toggleConfirmationDialog}" />
                    </div>
                </div>
                <div class="su-bg-overlay su-filters" onclick="{!c.toggleConfirmationDialog}" role="button" tabindex="0"></div>
            </aura:if>
            <!-- search tabs end -->
            <aura:if isTrue="{!if(v.totalResults > 0,true,false)}">
                <div class="su__small-feature su__mb-2">
                    <div class="su__search-view su__flex-vcenter">
                        <!-- advance search section -->
                            <div class="su__advance-search advance__search su__col-xl-4 su__col-lg-4 su__flex-1 su__flex-vcenter su__mb-sm-0">
                                <aura:if isTrue="{!if(v.totalResults > 0,true,false)}">
                                    <div class="{!if(v.advanceSearchEnabled==true, 'su__advances-ipad su__w-100 su__radius-1 su__border  su__order-md-1 su__search_advance su__position-relative su__advance-active-border', 'su__advances-ipad su__w-100 su__radius-1 su__border  su__order-md-1 su__search_advance su__position-relative')}">
                                        <div class="su__d-md-block su__d-none">
                                            <button type="button" class="su__btn btn_advance-search su__w-100 su__radius-2  su__p-2 su__bg-white su__flex-vcenter su__loading-view" onclick="{!c.ToggleExpandAdvanceSearch}">
                                                <span class="su__advance-filter">
                                                        <div class="{!if(v.advanceSearchEnabled==true, 'su__advance-search-text-icon', 'bg-Filter')}"  title="{!v.filter}"></div>
                                                    </span>
                                                <span class="{!if(v.advanceSearchEnabled==true, 'su__text-black font-14 su__pl-2 su__rtlpr-2 su__rtlpl-0 su__font-regular su__color-advance-search', 'su__text-black font-14 su__pl-2 su__rtlpr-2 su__rtlpl-0 su__font-regular')}">
                                                    {!v.finalLang.Advanced_Search ? v.finalLang.Advanced_Search : 'Advanced Search'}
                                                </span>
                                            </button>
                                        </div>
                                        <!-- Advance search block -->
                                        <div aura:id="su_showAdvancedSearchBlock" class="slds-hide su__AdvancedSearch-Block su__fadeInDownSmall su__position-absolute su__trbl su__w-100 su__d-block">
                                            <div class="su__bookmark-popup-title su__p-2 su__d-md-none su__flex-vcenter su__bg-blue-grd">
                                                <div class="su__px-2 su__py-1 su__bg-white-circle su__radius-50" data-aura-rendered-by="555:0">
                                                        <div class="bg-Filter_white" title="{!v.close}"></div>
                                                    </div>
                                                <div class="su__bookmark-title su__flex-1 su__ml-2 su__rtlml-0 su__rtlmr-2">
                                                    <label class="font-16 su__text-white">
                                                        {!v.finalLang.Advanced_Search ? v.finalLang.Advanced_Search : 'Advanced Search'}
                                                    </label>
                                                </div>
                                                <div class="su__close-icon su__cursor">
                                                        <div class="bg-white_close_icon" title="{!v.close}" onclick="{!c.ToggleExpandAdvanceSearch}"></div>
                                                    </div>
                                            </div>
                                            <div class="su__advance-form-inner su__p-2 su__sm-radius-0 su__bg-white su__lg-shadow su__radius-2">
                                                <aura:if isTrue="{!!v.disableButtonAdvancedSearch}">
                                                    <button onclick="{!c.advanceClearInput}" class="su__advance-clearfilter su__cursor su__font-bold font-12 su__mb-2 su__p-0 su__color-lblue su__loading-view">
                                                    Clear
                                                    </button>
                                            </aura:if>
                                                <div class="su__advance_group su__mt-2 su__mb-3">
                                                    <lightning:input class="su__form-control1" value="{!v.exactPhrase}" onchange="{!c.validateName}" name="exactPhrase" placeholder="{!v.finalLang.With_the_exact_phrase ? v.finalLang.With_the_exact_phrase : v.exact_phrase}" />
                                                </div>
                                                <div class="su__advance_group su__mb-3">
                                                    <lightning:input class="su__form-control1" value="{!v.withOneOrMore}" onchange="{!c.validateName}" name="withOneOrMore" placeholder="{!v.finalLang.With_one_or_more_words ? v.finalLang.With_one_or_more_words : v.one_or_more}"/>
                                                </div>
                                                <div class="su__advance_group su__mb-3">
                                                    <lightning:input class="su__form-control1" value="{!v.withoutTheWords}" onchange="{!c.validateName}" name="withoutTheWords" placeholder="{!v.finalLang.Without_the_words ? v.finalLang.Without_the_words : v.without_words}" />
                                                </div>
                                                <div class="su__advance_group su__mb-2 su__text-center font-14">
                                                    <aura:if isTrue="{!v.disableButtonAdvancedSearch}">
                                                        <input type="button" class="su__full-btn su__bg-blue-grd su__text-white su__refine-search" value="{!v.finalLang.Refine_Search ? v.finalLang.Refine_Search : v.refine_search}" disabled="disabled"/>
                                                        <aura:set attribute="else">
                                                            <input type="button" class="su__full-btn su__bg-blue-grd su__text-white su__cursor" value= "{!v.finalLang.Refine_Search ? v.finalLang.Refine_Search : v.refine_search}" onclick="{!c.refineSearch}" />
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="su__d-block su__advance-overlay su__bg-overlay" role="button" onclick="{!c.ToggleExpandAdvanceSearch}"></div>
                                        <!-- Advance search block ends-->
                                    </div>
                                </aura:if>
                            <div class="{!if(v.active=='all'  &amp;&amp; v.allContentHideFacets,'su__facet-ipad su__order-0 su__d-xl-none su__d-xs-none su__mr-3','su__facet-ipad su__order-0 su__d-xl-none su__d-xs-block su__mr-3')}">
                                    <span class="su__btn-filters su__flex-vcenter su__text-center su__radius-1  su__p-2 font-12 su__border su__bg-white su__cursor su__loading-view" id="su_filter_menu" onclick="{!c.modalview}">
                                        <span class="su__filter-value su__mr-2 su__rtlmr-0 su__rtlml-2">
                                            <div class="bg-filter_icon" ></div>                                                           
                                        </span>
                                        <span>
                                            {!v.finalLang.Filter ? v.finalLang.Filter : 'Filter'}
                                        </span>
                                    </span>
                                </div>
                            </div>
                            <!-- advance search section -->
    
    
    
    
                        <div class="su__showing-desktop su__showing-result su__py-2 su__text-truncate">
                            <label class="su__showing-lable su__color-lgray font-12 su__font-regular su__loading-view su__d-xl-block su__d-xs-none">
                                {!v.finalLang.Showing_page ? v.finalLang.Showing_page : 'Showing page'}&zwnj;
                                <span class="su__font-bold"> {!v.pageNum}&zwnj; </span>
                                {!v.finalLang.of ? v.finalLang.of : 'of'}&zwnj;
                                <span class="su__font-bold"> {!v.lastPage}&zwnj; </span> {!v.finalLang.of ? v.finalLang.of : 'of'}&zwnj; {!v.totalResults}&zwnj;
                                {!v.finalLang.results ? v.finalLang.results : 'results'} &zwnj;({!v.searchResultTime}&zwnj;
                                {!v.finalLang.seconds ? v.finalLang.seconds : 'seconds'}).
                            </label>
                            
                        </div>
                        <div class="su__bookmark-btn su__flex-vcenter su__d-md-flex su__d-xs-none su__justify-content-between">
                            <span class="su__star-bookmark su__cursor su__p-2 su__radius-50 su__circle-hover su__loading-view" onclick="{!c.starClicked}">
                                <div class="bg-star_bookmark" title="{!v.finalLang.Add_Bookmark? v.finalLang.Add_Bookmark : v.add_bookmark}"></div>
                            </span>
                            <div class="{!if(v.bookmarkSearches.length == 0 ,'su__bookmark-list su__rtlmr-0 su__rtlml-0 su__radius-50 su__circle-hover su__cursor su__p-2 su__loading-view','su__invisible su__position-absolute')}" onclick="{!c.bookmarkList_toggle}">
                                <div class="su__d-block bg-savedBookmark_gray" title="{!v.finalLang.Saved_Bookmarks? v.finalLang.Saved_Bookmarks : v.save_bookmark}"></div>
                            </div>
                            <div class="{!if(v.bookmarkSearches.length > 0 ,'su__bookmark-list su__rtlmr-0 su__rtlml-0 su__radius-50 su__circle-hover su__cursor su__p-2 su__loading-view','su__invisible su__position-absolute')}" onclick="{!c.bookmarkList_toggle}">
                                <div class="su__d-block bg-savedBookmark_blue adjustSprite"  title="{!v.finalLang.Saved_Bookmarks? v.finalLang.Saved_Bookmarks : v.save_bookmark}"></div>
                            </div>
                        </div>
                        <aura:if isTrue="{!v.showLanguageDropdown}">
                            <div class="su__fillter-sortby su__mr-2 su__ml-1 su__flex-vcenter font-12 su__loading-view su__position-relative">
                                <lightning:select title="{!v.finalLang.Language ? v.finalLang.Language : v.language}" name="" aura:id="lang" value="{!v.languageSelectedByUser}" class="su__language-icon bg-language su-sorting-select su__loading-view su_translator" onchange="{!c.saveLangToLocal}">
                                    <aura:iteration items="{!v.selectedLanguages}" var="item">
                                        <option text="{!item.name +'-'+item.code}" value="{!item.code}" />
                                    </aura:iteration>
                                </lightning:select>
                            </div>
                        </aura:if>
                        <div class="su__fillter-sortby su__mx-2 su__flex-vcenter font-12 su__loading-view su__position-relative">
                            <lightning:select name="mySelect" aura:id="mySelect" value="{!v.sortByCheck}" class="su-sorting-select su__loading-view">
                                <aura:iteration items="{!v.sortByValues}" var="item">
                                    <option value="{!item.value}" selected="{!item.selected}">
                                        {!v.finalLang.Sort_by ? v.finalLang.Sort_by : 'Sort by'}&zwnj;
                                        <aura:if isTrue="{!item.method_name == 'Relevance'}">
                                            {!v.finalLang.Relevance ? v.finalLang.Relevance : 'Relevance'}
                                            <aura:set attribute="else">
                                                {!v.finalLang.Created_Date ? v.finalLang.Created_Date : 'Created Date'}
                                            </aura:set> 
                                        </aura:if>
                                        <!--{!v.finalLang.item.method_name ? v.finalLang.item.method_name : item.method_name} -->
                                        <!-- <c:SULanguages parent="{!this}" child='{!item.method_name}' /> -->
                                    </option>
                                </aura:iteration>
                            </lightning:select>
                        </div>
                        <div class="{!if(!!v.listview, 'su__d-md-flex su__loading-view su__d-xs-none su__flex-vcenter su__justify-content-between su__px-0', 'visibilityHidden su__position-absolute')}">
                            <div class="iconBright bg-list_view_active" title="{!v.finalLang.List_View ? v.finalLang.List_View : v.list_view}"></div>
                            <div class="bg-grid_view  iconBright su__cursor su__rtlmr-3" title="{!v.finalLang.Grid_View ? v.finalLang.Grid_View : v.grid_view}" onclick="{!c.hideListview}"></div>
                        </div>
                        <div class="{!if(!v.listview, 'su__d-md-flex su__loading-view su__d-xs-none su__flex-vcenter su__justify-content-between su__px-0', 'visibilityHidden su__position-absolute')}">
                            <div class="bg-list_view iconBright su__cursor" title="{!v.finalLang.List_View ? v.finalLang.List_View : v.list_view}" onclick="{!c.showListview}"></div>
                            <div class="bg-grid_view_active iconBright su__cursor su__rtlmr-3" title="{!v.finalLang.Grid_View ? v.finalLang.Grid_View : v.grid_view}"></div>
                        </div>
                    </div>
                </div>
            </aura:if>
            <aura:if isTrue="{!if(v.customSettingErrorMessage == '',true,false)}">
                <div class="su_bodyContainer slds-col slds-small-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--1-of-1">
                    <aura:if isTrue="{!if(v.searchUnifyDownStatus == false,true,false)}">
                        <div class="su__row su__d-block su__mx-sm-0 su__pt-sm-1 su__pb-4 su_resultContainer mainresult">
                            <!-- Code for Display the Filters starts here-->
                        <aura:if isTrue="{!if(v.aggregationsData.length > 0 &amp;&amp; v.totalResults > 0,true,false)}">
                                <div id="filtersSec"  class="{!if(v.active=='all'  &amp;&amp; v.allContentHideFacets,'su-filters-section su__col-xl-4 su__col-lg-4 su__col-md-4 su__col-xs-12 su__d-xl-none su__radius-1 su__float-left','su-filters-section su__col-xl-4 su__col-lg-4 su__col-md-4 su__col-xs-12 su__d-xl-block su__radius-1 su__float-left')}" aura:id="aggregation-filters">
                                
                                    <div class="su__sidebar-blocks su__left-sidebar  su__border-t-none su_modal_effect su_fade_effect" aura:id="aggregation-filters">
                                        <div
                                            class="su__searchTip-header su__d-xl-none su__d-xs-block su__p-3 su__bg-blue-grd su__text-white su__rtltext-left su__position-relative">
                                            <h4 class="su__m-0">
                                                {!v.finalLang.Narrow_your_search ? v.finalLang.Narrow_your_search : 'Narrow your search'}
                                            </h4>
                                            <div class="su__close-icon su__filter-close su__position-absolute su__cursor" onclick="{!c.dismiss_modal}">
                                                <div class="bg-white_close_icon" title="{!v.close}"></div>
                                            </div>
                                        </div>
                                        <div id="filterList" class="collapse in">
                                            <aura:if isTrue="{!v.novaluesForResult  &amp;&amp; v.isMobile}">
                                                <div class='su_no-filters-mobile'>
                                                    <span class='no_filter-msg'> No Filters available.</span>
                                                </div>
                                            </aura:if>   
                                            <aura:iteration items="{!v.aggregationsData}" var="filter" indexVar="index">
                                                <aura:if isTrue="{!and(filter.values.length > 0,filter.order != 0)}">
                                                    <aura:if isTrue="{!if(!filter.hide &amp;&amp; !filter.hideFacetAdmin,true,false)}">
                                                        <div class="su__filter-item">
                                                            <div class="su__w-100 su__position-relative su__flex-vcenter su__border-b su__p-3 su__bg-white clearfix">
                                                                <div class="su__d-flex su__w-100 su__cursor su__text-semi-gray">
                                                                    <aura:if isTrue="{!if(filter.key != 'post_time' &amp;&amp; filter.key != 'CreatedDate', true,false)}">
                                                                            <div id="{!index}" class="su__sort-filter-icon su__rtlmr-0 su__rtlml-1 su__cursor su__loading-view" onclick="{!c.filtersPopup}">
                                                                                <div id="{!index}" class="bg-dots  su__circle-hover"></div>
                                                                            </div>
                                                                            <div class="{!filter.isCollapsed? 'su__sort-filter su__position-absolute su__bg-white su__zindex-2 su__shadow': 'visibilityHidden su__position-absolute'}">
                                                                                <ul class="su__p-0 su__m-0 su__lg-shadow">
                                                                                    <li class="font-12 su__color-lblue su__text-black su__font-bold su__flex-vcenter su__justify-content-left su__px-4 su__py-2">
                                                                                        <div class="bg-sort"></div>
                                                                                        <span class="su__color-lblue">
                                                                                            {!v.finalLang.Sort_By ? v.finalLang.Sort_By : 'Sort By'}
                                                                                        </span>
                                                                                    </li>
                                                                                    <aura:if isTrue="{!if(filter.label == 'Sources', true,false)}">
                                                                                        <li id="{!index}" class="{!filter.sort == 'custom' ? 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover su__filters-sort-active': 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover'}" data-item="{!filter.key}" data-sort="custom" onclick="{!c.filterSorting}">
                                                                                            {!v.finalLang.Custom ? v.finalLang.Custom : 'Custom'}
                                                                                        </li>
                                                                                    </aura:if>
                                                                                    <li id="{!index}" class="{!filter.sort == 'term_asc' ? 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover su__filters-sort-active': 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover'}" data-item="{!filter.key}" data-sort="term_asc" onclick="{!c.filterSorting}">
                                                                                        {!v.finalLang.Alphabetically__a_z_ ? v.finalLang.Alphabetically__a_z_ : 'Alphabetically (a-z)'}
                                                                                    </li>
                                                                                    <li id="{!index}" class="{!filter.sort == 'term_desc' ? 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover su__filters-sort-active': 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover'}" data-item="{!filter.key}" data-sort="term_desc" onclick="{!c.filterSorting}">
                                                                                        {!v.finalLang.Alphabetically__z_a_ ? v.finalLang.Alphabetically__z_a_ : 'Alphabetically (z-a)'}
                                                                                    </li>
                                                                                    <li id="{!index}" class="{!filter.sort == 'count_desc' ? 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover su__filters-sort-active': 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover'}" data-item="{!filter.key}" data-sort="count_desc" onclick="{!c.filterSorting}">
                                                                                    {!v.finalLang.Count__desc_ ? v.finalLang.Count__desc_ : 'Count (desc)'}
                                                                                    </li>
                                                                                    <li id="{!index}" class="{!filter.sort == 'count_asc' ? 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover su__filters-sort-active': 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover'}" data-item="{!filter.key}" data-sort="count_asc" onclick="{!c.filterSorting}">
                                                                                        {!v.finalLang.Count__asc_ ? v.finalLang.Count__asc_ : 'Count (asc)'}
                                                                                    </li>
                                                                                </ul>
                                                                            </div>
                                                                        </aura:if>
                                                                    <div id="{!index}" class="{!filter.isCollapsed? 'su__bg-overlay su__overlay': 'su__d-none'}" role="button" onclick="{!c.filtersPopup}"></div>
                                                                    <div class="su__filter-title su__margin-top-custom su__text-truncate font-14 su__font-bold su__mr-3 su__rtlml-3 su__rtlmr-0 su__loading-view" onclick="{!c.collapseFilters}" id="{!'collapseExample-'+filter.key+'_icon'}">
                                                                        <aura:if isTrue="{!if(filter.label == 'Sources', true,false)}">
                                                                            {!v.finalLang.Sources ? v.finalLang.Sources : filter.label}
                                                                            <aura:set attribute="else">
                                                                                <aura:if isTrue="{!if(filter.label == 'Created Date', true,false)}">
                                                                                    {!v.finalLang.Created_Date ? v.finalLang.Created_Date : filter.label}
                                                                                    <aura:set attribute="else">
                                                                                        {!filter.label}
                                                                                    </aura:set>
                                                                                </aura:if>
                                                                            </aura:set>
                                                                        </aura:if>
                                                                    </div>
                                                                    <div class="su-filter-box-open-close su__filter-icon su__radius-50 su__cursor su__position-relative su__loading-view" aria-controls="collapseExample" aria-expanded="true">
                                                                        <div class="su__filter-arows su__outline-none su__position-absolute">
                                                                            <div class="{!if(v.defaultFilterCollapse == true,'su__d-none su__cursor','su__d-block su__cursor')}" id="{!'collapseExample-'+filter.key+'_toggleIconOn'}">
                                                                                <div class="bg-keyup_arrow su__arrow-icons su__d-block su__transition-5s" onclick="{!c.collapseFilters}" id="{!'collapseExample-'+filter.key+'_icon'}"  ></div>
                                                                            </div>
                                                                            <div class="{!if(v.defaultFilterCollapse == true,'su__d-block su__cursor su__transition-5s','su__d-none su__cursor')}" id="{!'collapseExample-'+filter.key+'_toggleIconOff'}">
                                                                                <div class="bg-keydown_arrow  su__arrow-icons su__d-block su__transition-5s" onclick="{!c.collapseFilters}" id="{!'collapseExample-'+filter.key+'_icon'}" ></div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <!-- left filter section start -->
                                                            <div class="{!filter.filterSortingLoad ? 'su__loading' : ''}">
                                                                <div class="{!if(v.defaultFilterCollapse,'su__filter-group-row su__overflow-hide collapse su__border-b','su__filter-group-row su__overflow-hide collapse in su__border-b')}" id="{!'collapseExample-'+filter.key}">
                                                                    <div class="{!if(!filter.expanded &amp;&amp; filter.values.length > 9,'su_nonExpanded su__filter-content-row su__py-2','su__filter-content-row su__py-2')}" id="{!filter.key+'_filter_'+filter.order}">
                                                                        <aura:iteration items="{!filter.values}" var="filterType">
                                                                            <div class="su__filter-group">
                                                                                <div class="{!if(filterType.value == 0,'disabled','yes')}">
                                                                                    <div class="su__w-100 su__flex-vcenter su__py-1 su__nested-img">
                                                                                        <aura:if isTrue="{! and(and(filterType.childArray, filterType.childArray.length > 0), or(!filterType.merged, and(filterType.merged, or(!filterType.showChild, filterType.showChild != '0')))) }">
                                                                                            <div class="{!if(filterType.open, 'su__loading-view su__pr-1 su__show su__nested-arrow-down', 'su__loading-view su__pr-1 su__nested-arrow-down')}" id="{!'collapseMerged-'+ filter.key + '-'+filterType.Contentname+'_toggleIconOff'}">
                                                                                                <div class="bg-keyright_arrow  su__arrow-icons su__d-block su__transition-5s su__cursor" onclick="{!c.toggleCollpase}" id="{!'collapseMerged-'+ filter.key + '-' +filterType.Contentname+'_span'}"></div>
                                                                                            </div>
                                                                                            <aura:set attribute="else">
                                                                                                <span class="su__pl-24"></span>
                                                                                            </aura:set>
                                                                                        </aura:if>
                                                                                        <div class="{!if(!filterType.indeterminate == false,'su__position-relative su__filter-checkbox su__loading-view su__indeterminate','su__position-relative su__filter-checkbox su__loading-view')}">
                                                                                            <input type="checkbox" accessKey="{!filter.order}" name="{!filterType.Contentname}" value="{!filterType.Contentname == 'All Time'? 'All':filterType.Contentname}" key="{!filter.key}" max="{!filterType.level}" class="{!'su__toggle-input su__position-absolute su__cursor checkType_'+filter.order}" id="{!filter.key+'_checkType_'+filterType.Contentname}" onclick="{!c.typeSelect}" step="{!filter.key}" checked="{!filterType.selected}" data-name="{!filterType.displayName || filterType.Contentname}" data-label="{!filter.label}" />
                                                                                            <label class="{!'su__toggle-label su__d-inline-flex su__cursor su__loading-view-border su__'+filter.key}" for="{!filter.key+'_checkType_'+filterType.Contentname}">
                                                                                                <span class="su__toggle__text"></span>
                                                                                                <span class="su__nested__text su__loading su__d-none su__position-absolute"></span>
                                                                                            </label>
                                                                                        </div>
                                                                                        <div class="su__filter-label su__text-truncate font-12 su__mr-3 su__rtlml-3 su__rtlmr-0 su__loading-view" title="{!filterType.displayName || filterType.Contentname}">
                                                                                            <label>
                                                                                                <aura:if isTrue="{!filterType.displayName}">
                                                                                                    {!filterType.displayName}
                                                                                                </aura:if>
                                                                                                <aura:if isTrue="{!if ( !filterType.displayName &amp;&amp; filterType.Contentname, true, false)}">
                                                                                                    {!filterType.Contentname}
                                                                                                </aura:if>
                                                                                            </label>
                                                                                        </div>
                                                                                        <div class="su__filter-badge font-12">
                                                                                            <label class="label-badge su__bg-light-gray su__loading-view">
                                                                                                {!filterType.value}
                                                                                            </label>
                                                                                        </div>
                                                                                    </div>
                                                                                    <aura:if isTrue="{!(and(filterType.childArray.length > 0, or(!filterType.showChild, filterType.showChild != '0')))}">
                                                                                        <div id="{!'collapseMerged-'+ filter.key + '-'+filterType.Contentname}" class="{!if(v.loadingResult == 1, if(filterType.open, 'slds-show su__fadeInDownSmall su__nested-filter', 'su__fadeInDownSmall slds-hide su__nested-filter') ,'')}">
                                                                                            <c:SUNestedDataDynamic parent="{!this}" endPoint="{!v.endPoint}" aura:id="SUNestedDataDynamic" assignNested="{!filterType.childArray}" method="{!c.typeSelect}" />
                                                                                        </div>
                                                                                    </aura:if>
                                                                                </div>
                                                                            </div>
                                                                        </aura:iteration>
                                                                    </div>
                                                                    <aura:if isTrue="{!if(filter.values.length > 9 || filter.merged,true,false)}">
                                                                        <div class="su__showmore su__position-relative su__show-more su__cursor su__p-2 su__bg-white font-14 su__flex-vcenter" id="{!'show-more-facetIcon-'+filter.key}">
                                                                            <aura:if isTrue="{!if(filter.values.length > 9,true,false)}">
                                                                                <div class="su__position-relative su__showmore-text font-12 su__color-blue su__font-regular su__loading-view" id="{!filter.key+'_filter_'+filter.order+'_showMore'}" onclick="{!c.showMore}">
                                                                                    {!v.finalLang.Show_more ? v.finalLang.Show_more : 'Show more'}
                                                                                    <span class="su__position-absolute su__showmore-icon">»</span>
                                                                                </div>
                                                                            </aura:if>
                                                                            <aura:if isTrue="{!if(filter.key != '_type',true,false)}">
                                                                                <div class="su__search-head-icon su__radius-50 su__cursor su__loading-view su__d-inline-block" onclick="{!c.searchFilters}">
                                                                                    <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/search-img.svg'}" class="{!'facetIcon-'+filter.key+' su__d-block su__search-facet-search-icon'}" id="{!'facetSearchIcon-facetIcon-'+filter.key}" />
                                                                                </div>
                                                                            </aura:if>
                                                                        </div>
                                                                    </aura:if>
                                                                    <div class="su__facet-parentDiv" onmouseleave="{!c.mouseleft}">
                                                                        <div class="su__w-100 su__p-2 su__d-none" id="{!'searchFacetDiv-facetIcon-'+filter.key}">
                                                                            <span class="su__search-facet su__loading-view">
                                                                                <div class="su__mb-sm-0 su__loading-view su__position-relative" id="{!filter.key+'-facetSearch'}">
                                                                                    <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/search-img.svg'}" class="su__position-absolute su__search-facet-icon"/>
                                                                                    <input type="text" onkeyup="{!c.searchFilterController}" id="{!'su__search-facet-input-'+filter.key}" class="{!if(filter.filterSuggest == 'no-result','su__search-facet-empty su__loading-view','su__search-facet-input su__loading-view')}" placeholder="{!v.finalLang.Search ? v.finalLang.Search : 'Search'}" name="{!'searchFacetDiv-facetIcon-'+filter.key}"/>
                                                                                    <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/search-close.svg'}" class="{!'facetIcon-'+filter.key+' su__position-absolute su__search-facet-close-icon su__cursor'}" id="{!'facetCloseIcon-facetIcon-'+filter.key}" onclick="{!c.filterClose}"/>
                                                                                </div>
                                                                            </span>
                                                                        </div>
                                                                        <div class="su__facet-main-div">
                                                                            <aura:if isTrue="{!if(filter.filterSuggestions.length > 0,true,false)}">
                                                                                <div class="su__search-facet-drop" id="{!filter.key}">
                                                                                    <aura:iteration items="{!filter.filterSuggestions}" var="filterSuggest">
                                                                                        <div class="su__search-facet-filter-div su__filter-group font-14 hover__effect su__search-facet-items">
                                                                                            <div class="su__flex-vcenter su__search_facet-list">
                                                                                                <div class="su__position-relative su__filter-checkbox su__loading-view">
                                                                                                    <input type="checkbox" accessKey="{!filter.order}" name="{!filterSuggest.Contentname}" value="{!filterSuggest.Contentname == 'All Time'? 'All':filterSuggest.Contentname}" key="{!filter.key}" max="{!filterSuggest.level}" class="{!'su__toggle-input su__position-absolute su__cursor checkType_'+filter.order}"
                                                                                                        id="{!filter.key+'_checkType_facet'+filterSuggest.Contentname}" onclick="{!c.typeFacetSelect}" step="{!filter.key}" checked="{!filterSuggest.selected}" data-name="{!filterSuggest.displayName || filterSuggest.Contentname}" data-label="{!filter.label}" />
                                                                                                    <label class="{!'su__toggle-label su__d-inline-flex su__cursor su__loading-view-border su__'+filter.key}" for="{!filter.key+'_checkType_'+filterSuggest.Contentname}">
                                                                                                        <span class="su__toggle__text"></span>
                                                                                                        <span class="su__nested__text su__loading su__d-none su__position-absolute"></span>
                                                                                                    </label>
                                                                                                </div>
                                                                                                <div class="su__filter-label su__text-truncate font-12 su__mr-3 su__rtlml-3 su__rtlmr-0 su__loading-view" title="{!filterSuggest.displayName || filterSuggest.Contentname}">
                                                                                                    <label>
                                                                                                        <aura:if isTrue="{!filterSuggest.displayName}">
                                                                                                            {!filterSuggest.displayName}
                                                                                                            <!-- <c:SULanguages parent="{!this}" child='{!filterSuggest.displayName}' /> -->
                                                                                                        </aura:if>
                                                                                                        <aura:if isTrue="{!if ( !filterSuggest.displayName &amp;&amp; filterSuggest.Contentname, true, false)}">
                                                                                                            <!-- <c:SULanguages parent="{!this}" child='{!filterSuggest.Contentname}' /> -->
                                                                                                            {!filterSuggest.Contentname}
                                                                                                        </aura:if>
                                                                                                    </label>
                                                                                                </div>
                                                                                                <div class="su__filter-badge font-12">
                                                                                                    <label class="label-badge su__bg-light-gray su__loading-view">
                                                                                                        {!filterSuggest.merged ? '' : filterSuggest.value}
                                                                                                    </label>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </aura:iteration>
                                                                                </div>
                                                                            </aura:if>
                                                                        </div>
                                                                    </div>  
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </aura:if>
                                                </aura:if>
                                            </aura:iteration>
                                        </div>
                                    </div>
                                    <div class="su__d-none su__bg-overlay left-sidebar-overlay" role="button" onclick="{!c.dismiss_modal}"></div>
                                </div>
                            </aura:if>
                            <!-- Code for Display the Filters ends here-->
                            <!-- Code for Display the Search Results starts here-->
                            <div class="{!if(!v.narrowSearch,'su__col-xl-8 su__col-lg-12 su__col-md-12 su__col-xs-12 su__mt-sm-4 su__px-sm-1 su__pb-sm-4 su__pb-sm-4 font-md-12' ,
                            'su__d-inline-block su__col-xl-8 su__col-lg-12 su__col-md-12 su__col-xs-12 su__mt-sm-4 su__px-sm-1 su__pb-sm-4 su__pb-sm-4 font-md-12'
                                )}" id="{!if((v.active=='all' &amp;&amp; v.allContentHideFacets) || (v.novaluesForResult &amp;&amp; v.active !='all'),'su__allcontent-visible','su__allcontent-notvisible')}" aura:id="suresultcomponent">
                                <div class="{!if(v.totalResults > 0,'su__d-xl-block su__d-xs-none su__mb-sm-1','su__d-xl-block su__mb-sm-1')}">
                                    <aura:if isTrue="{!if(v.suggestData != '',true,false)}">
                                        <div class="suggestion su__didumean">
                                            <label><span class="su__font-bold font-14 su__mr-2 su__rtlmr-0 su__rtlml-2 su__text-warning su__loading-view">
                                                {!v.finalLang.Did_you_mean ? v.finalLang.Did_you_mean : 'Did you mean'}:</span>
                                                <span class="su__loading-view"><a data-label="{!v.suggestData}" onclick="{!c.dymClickController}" class="font-12 su__text-decoration su__color-lgray">{!v.suggestData}</a></span>
                                            </label>
                                        </div>
                                    </aura:if>
                                </div>
                                <div class="search-results">
                                    <aura:if isTrue="{!if(v.totalResults > 0,true,false)}">
                                    
                                        <div class="su__d-xl-none su__d-xs-block su__mb-sm-1">
                                            <aura:if isTrue="{!if(v.suggestData != '',true,false)}">
                                                <div class="suggestion su__didumean">
                                                    <label><span class="su__font-bold font-14 su__mr-2 su__rtlmr-0 su__rtlml-2 su__text-warning su__loading-view">
                                                        {!v.finalLang.Did_you_mean ? v.finalLang.Did_you_mean : 'Did you mean'}
                                                        :</span>
                                                        <span class="su__loading-view"><a data-label="{!v.suggestData}" onclick="{!c.dymClickController}" class="font-12 su__text-decoration su__color-lgray">{!v.suggestData}</a></span>
                                                    </label>
                                                </div>
                                            </aura:if>
                                            <div class="su__showing-result su__flex-1 su__py-1">
                                                <label class="su__showing-lable su__color-lgray font-12 su__font-regular su__loading-view su__d-xl-none su__d-xs-block">
                                                    {!v.finalLang.Showing_page ? v.finalLang.Showing_page : 'Showing page'}&zwnj;
                                                    <span class="su__font-bold ng-binding"> {!v.pageNum}&zwnj;</span>
                                                    {!v.finalLang.of ? v.finalLang.of : 'of'}&zwnj;
                                                    <span class="su__font-bold ng-binding"> {!v.lastPage}&zwnj; </span> {!v.finalLang.of ? v.finalLang.of : 'of'}&zwnj; {!v.totalResults}&zwnj;
                                                    {!v.finalLang.results ? v.finalLang.results : 'results'}&zwnj; ({!v.searchResultTime}&zwnj;
                                                    {!v.finalLang.seconds ? v.finalLang.seconds : 'seconds'}).
                                                </label>
                                            </div>
                                        </div>
                                        <div class="su__clear-filter-block">
                                            <div class="su__clear-filters su__mb-1">
                                                <aura:if isTrue="{!v.showClearFiltersButton}">
                                                    <label onclick="{!c.clearFilters}" class="su__clear-filters-btn su__cursor su__font-bold font-12 su__mb-2 su__p-0 su__color-lblue su__loading-view">
                                                        {!v.finalLang.Clear_filters ? v.finalLang.Clear_filters : 'Clear filters'}
                                                    </label>
                                                </aura:if>
                                            </div>
                                            <!--  new sticky starts -->
                                            <div id="sticky-box" class="{! if( v.selectedStickyFilter.length > 2, 'su__selectedFilter-collapse', '' )}">
                                                <aura:iteration items="{!v.selectedStickyFilter}" var="filterType" indexVar="index">
                                                    <div class="su__sticky-row su__flex-vcenter su__flex-wrap">
                                                        <span class="su__sticky__head font-12 su__color-lgray su__font-bold su__mr-2 su__loading-view" data-label="{!filterType.label}" onclick="{!c.selectedSticky}">
                                                            <!--{!v.finalLang.filterType.label ? v.finalLang.filterType.label : filterType.label}:-->
                                                            {!filterType.label}:                                                                    
                                                        </span>
                                                        <aura:iteration items="{!filterType.values}" var="filterValue" indexVar="ind" end="{!4}">
                                                            <span class="su__sticky__filters su__cursor su__radius font-12 su__border su__mr-1 su__px-1 su__rtlmr-0 su__rtlml-1 su__mb-1 su__text-black su__bg-white su__text-nowrap su__loading-view su__close-icon-txt su__text-normal su__flex-vcenter su__position-relative" data-label="{!filterType.label}" data-contentname="{!filterValue.Contentname}" data-type="{!filterType.key}" data-level="{!filterValue.level}" data-immediateParent="{!filterValue.immediateParent}" data-path="{!filterValue.pathString}" onclick="{!c.removeStickyFilter}">
                                                                <!--{!(v.finalLang.filterValue.sticky_name || v.finalLang.filterValue.displayName || v.finalLang.filterValue.Contentname) ? (v.finalLang.filterValue.sticky_name || v.finalLang.filterValue.displayName || v.finalLang.filterValue.Contentname)  : (filterValue.sticky_name || filterValue.displayName || filterValue.Contentname)}-->
                                                                {!filterValue.sticky_name || filterValue.displayName || filterValue.Contentname}
                                                            </span>
                                                        </aura:iteration>
                                                        <aura:if isTrue="{!greaterthan(filterType.values.length , 4)}">
                                                            <label onclick="{!c.stickyList}" class="su-clear-filters-button font-12 su__mx-2 su__cursor su__text-nowrap su__loading-view" data-value="more" data-name="{!filterType.label}" id="{!filterType.label+'_seemore'}">
                                                                <div class="bg-view_more su__position-relative su__more-icon" ></div>
                                                                {!v.finalLang.See ? v.finalLang.See : 'See'}&zwnj; {!filterType.values.length -4}&nbsp;
                                                                {!v.finalLang.More ? v.finalLang.More : 'More'}
                                                            </label>
                                                            <div id="{!filterType.label+'_sticky'}" class="slds-hide su__flex-vcenter su__flex-wrap su__overflow-hide">
                                                                <aura:iteration items="{!filterType.values}" var="filterValue" indexVar="ind" start="{!4}">
                                                                    <span class="su__sticky__filters su__cursor su__radius font-12 su__border su__mr-1 su__px-1 su__rtlmr-0 su__rtlml-1 su__mb-1 su__text-black su__bg-white su__text-nowrap su__loading-view su__close-icon-txt su__text-normal su__flex-vcenter su__position-relative su__d-xl-inline-flex" data-label="{!filterType.label}" data-contentname="{!filterValue.Contentname}" data-type="{!filterType.key}" data-level="{!filterValue.level}" data-path="{!filterValue.pathString}" data-immediateParent="{!filterValue.immediateParent}" onclick="{!c.removeStickyFilter}">
                                                                        <!--{!(v.finalLang.filterValue.sticky_name || v.finalLang.filterValue.displayName || v.finalLang.filterValue.Contentname) ? (v.finalLang.filterValue.sticky_name || v.finalLang.filterValue.displayName || v.finalLang.filterValue.Contentname)  : (filterValue.sticky_name || filterValue.displayName || filterValue.Contentname)}-->
                                                                        {!filterValue.sticky_name || filterValue.displayName || filterValue.Contentname}
                                                                    </span>
                                                                </aura:iteration>
                                                                <label onclick="{!c.stickyList}" class="su-clear-filters-button font-12 su__mx-2 su__cursor su__text-nowrap  su__loading-view" data-name="{!filterType.label}" data-value="less">
                                                                    <div class="bg-view_more su__position-relative su__more-icon"></div>
                                                                    {!v.finalLang.See ? v.finalLang.See : 'See'}&zwnj;
                                                                    {!v.finalLang.less ? v.finalLang.less : 'less'}
                                                                </label>
                                                            </div>
                                                        </aura:if>
                                                    </div>
                                                </aura:iteration>
                                            </div>
                                            <aura:if isTrue="{!if(v.selectedStickyFilter.length > 2,true,false)}">
                                                <div class="su__flex-vcenter su__justify-content-center su__color-blue su__sticky-collapse">
                                                    <div class="su__show-all su__cursor su__loading-view" onclick="{!c.stickyShowAll}">
                                                        <span class="su__arrow-up"></span>
                                                        <span class="su__ml-3 su__rtlmr-3 su__rtlml-0 font-12" id="sticky-showAll">
                                                            {!v.finalLang.Show_all ? v.finalLang.Show_all : 'Show all'}
                                                        </span>
                                                        <span class="su__ml-3 su__rtlmr-3 su__rtlml-0 font-12 slds-hide" id="sticky-showLess">
                                                            {!v.finalLang.Show_less ? v.finalLang.Show_less : 'Show less'}
                                                        </span>
                                                    </div>
                                                </div>
                                            </aura:if>
                                        </div>
                                        <!-- sticky ends -->
                                        <div>
                                            <div class="su__loading-view">
                                                <aura:unescapedHtml value="{!v.advertisement}"></aura:unescapedHtml>
                                            </div>
                                            <!-- featured snippts start  -->
                                            <aura:if isTrue="{!if(v.featureSnippet &amp;&amp; v.featureSnippet.steps &amp;&amp; v.featureSnippet.steps.length != 0, true, false)}">
                                                <!-- desktop -->
                                                <div class="su__FeaturedSnippet su__bg-white su__sm-shadow su__radius-1 su__position-relative su__mb-3 su__p-3 su__d-md-flex su__overflow-hide su__w-100 su__md-none">
                                                    <div class="{! if( v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length, 'su__featureSnippet-left su__d-flex su__flex-column su__overflow-hide su__mr-4 su__w-75', 'su__featureSnippet-left su__d-flex su__flex-1 su__flex-column su__overflow-hide su__mr-4' )}">
                                                        <div class="su__featureSnippet-title font-16 su__font-bold su__mb-2 su__text-truncate su__loading-view">
                                                            {!v.featureSnippet.header}
                                                        </div>
                                                        <div>
                                                            <aura:if isTrue="{!if(!v.featureSnippet.isCollapsed, true,false)}">
                                                                <aura:iteration items="{!v.featureSnippet.steps}" var="result" indexVar="indexVar" end="{!3}">
                                                                    <div class="su__featureSnippet-list su__d-flex su__loading-view">
                                                                        <div class="su__steps-bullets"></div>
                                                                        <div class="su__font-13 su__text-black regular su__mb-2 su__text-truncate">
                                                                            {!result}
                                                                        </div>
                                                                    </div>
                                                                </aura:iteration>
                                                            </aura:if>
                                                            <aura:if isTrue="{!if(v.featureSnippet.isCollapsed, true,false)}">
                                                                <aura:iteration items="{!v.featureSnippet.steps}" var="result" indexVar="indexVar">
                                                                    <div class="su__featureSnippet-list su__d-flex su__loading-view">
                                                                        <div class="su__steps-bullets"></div>
                                                                        <div class="su__font-13 su__text-black regular su__mb-2 su__text-truncate">
                                                                            {!result}
                                                                        </div>
                                                                    </div>
                                                                </aura:iteration>
                                                            </aura:if>
                                                            <aura:if isTrue="{!greaterthan(v.featureSnippet.steps.length, 3)}">
                                                                <span onclick="{!c.featuredSnippetCollapse}" class="{!!v.featureSnippet.isCollapsed ? 'su__cursor su__position-relative su__mb-1 su__font-12 su__color-blue su__f-regular su__showmore-text su__d-inline-block su__loading-view': 'su__d-none'}">
                                                                    (More)
                                                                </span>
                                                                <span onclick="{!c.featuredSnippetCollapse}" class="{!v.featureSnippet.isCollapsed ? 'su__cursor su__position-relative su__mb-1 su__font-12 su__color-blue su__f-regular su__showmore-text su__d-inline-block su__loading-view': 'su__d-none'}">
                                                                    (Less)
                                                                </span>
                                                            </aura:if>
                                                        </div>
                                                        <a class="su__text-decoration font-14 su__text-black hover-color-dblue su__font-bold su__text-truncate su__mt-3 su__loading-view"
                                                            href="{!v.featureSnippet.href}" data-href="{!v.featureSnippet.href}" target="_blank"
                                                            rel="noopener noreferrer" onclick="{!c.runScriptMethod}" data-Id="{!v.featureSnippet._id}"
                                                            data-Rank="0" data-Sub="{!v.featureSnippet.highlight.TitleToDisplayString[0]}" data-url="{!v.featureSnippet.href}"
                                                            data-Type="{!v.featureSnippet.objName}" data-Index="{!v.featureSnippet.sourceName}"
                                                            data-Autotuned="{!v.featureSnippet.autotuned}" data-trackAnalytics="{!v.featureSnippet.trackAnalytics}">
                                                            <aura:unescapedHtml value="{!v.featureSnippet.highlight.TitleToDisplay[0]}"></aura:unescapedHtml>
                                                        </a>
                                                        <div class="su__href-txt su__text-decoration su__color-lgray font-12 su__font-italic su__text-truncate su__loading-view">
                                                            {!v.featureSnippet.href}
                                                        </div>
                                                    </div>
                                                    <div class="{! if( v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length, 'su__featureSnippet-right su__d-flex su__flex-column su__featured-thumbnail', 'su__featureSnippet-right su__d-flex su__flex-column su__w-80px' )}">
                                                        <div class="su__featureSnippet-response">
                                                            <aura:if isTrue="{!!v.featuredResponseRecorded}">
                                                                <div class="su__d-flex su__w-100">
                                                                    <div class="su__knowledge-feedback-row su__d-flex">
                                                                        <span class="su__featured-feedback su__cursor su__loading-view su__mr-2" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="0">
                                                                            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-down.png'}" class="ab-testing-btn" alt="Not Useful" />
                                                                        </span>
                                                                        <span class="su__featured-feedback su__cursor su__loading-view" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="1">
                                                                            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-up.png'}" class="ab-testing-btn" alt="Useful" />
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            </aura:if>
                                                            <aura:if isTrue="{!if(v.featuredResponseRecorded &amp;&amp; v.timeoutResponse, true, false)}">
                                                                <div class="su__feedback-thankyou su__feedback-steps su__position-absolute su__loading-view">
                                                                    <div class="su__flex-vcenter su__font-12">
                                                                        <span class="su__thankyou-text su__whitespace-no">
                                                                            {!v.finalLang.Thank_you_for_your_response ? v.finalLang.Thank_you_for_your_response : 'Thank you for your response'}!
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            </aura:if>
                                                        </div>
                                                        <aura:if isTrue="{!if(v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length != 0,true,false)}">
                                                            <div class="su__featureSnippet-right su__featured-thumbnail su__py-sm-2">
                                                                <div class="su__featured-thumbnail su__loading-view">
                                                                    <a class="su__position-relative su__d-flex" href="{!v.featureSnippet.multiMedia[0].href || v.featureSnippet.multiMedia[0].video_url}"
                                                                        data-href="{!v.featureSnippet.multiMedia[0].href || v.featureSnippet.multiMedia[0].video_url}"
                                                                        target="_blank" rel="noopener noreferrer" onclick="{!c.runScriptMethod}"
                                                                        data-Id="{!v.featureSnippet._id}" data-Rank="0" data-Sub="{!v.featureSnippet.highlight.TitleToDisplayString[0]}"
                                                                        data-url="{!v.featureSnippet.href}" data-Type="{!v.featureSnippet.objName}"
                                                                        data-Index="{!v.featureSnippet.sourceName}" data-Autotuned="{!v.featureSnippet.autotuned}"
                                                                        data-trackAnalytics="{!v.featureSnippet.trackAnalytics}">
                                                                        <aura:if isTrue="{!if(v.featureSnippet.multiMedia[0].thumbnail,true,false)}">
                                                                            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/play_arrow.svg'}" class="su__video-thumbnail-play" />
                                                                        </aura:if>
                                                                        <img src="{!v.featureSnippet.multiMedia[0].image_urls || v.featureSnippet.multiMedia[0].thumbnail}"
                                                                            class="su__img-featured" alt="{!v.featureSnippet.multiMedia[0].alt_attributes}" />
                                                                    </a>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                    </div>
                                                </div>
                                                <!-- mobile -->
                                                <div class="su__FeaturedSnippet su__bg-white su__sm-shadow su__radius-1 su__position-relative su__mb-3 su__p-3 su__d-md-flex su__overflow-hide su__w-100 su__md-block su__display-none">
                                                    <div class="su__featureSnippet-title font-16 su__font-bold su__mb-2 su__text-truncate su__loading-view">
                                                        {!v.featureSnippet.header}
                                                    </div>
                                                    <div class="su__featureSnippet-left su__d-flex su__overflow-hide su__mt-2 su__mb-2">
                                                        <div class="{! if( v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length, 'su__featureSnippet-list su__w-70 su__pr-2', 'su__featureSnippet-list su__w-100' )}">
                                                            <aura:if isTrue="{!if(!v.featureSnippet.isCollapsed, true,false)}">
                                                                <aura:iteration items="{!v.featureSnippet.steps}" var="result" indexVar="indexVar" end="{!3}">
                                                                    <div class="su__featureSnippet-list su__d-flex su__loading-view">
                                                                        <div class="su__steps-bullets"></div>
                                                                        <div class="su__font-13 su__text-black regular su__mb-2 su__text-truncate">
                                                                            {!result}
                                                                        </div>
                                                                    </div>
                                                                </aura:iteration>
                                                            </aura:if>
                                                            <aura:if isTrue="{!if(v.featureSnippet.isCollapsed, true,false)}">
                                                                <aura:iteration items="{!v.featureSnippet.steps}" var="result" indexVar="indexVar">
                                                                    <div class="su__featureSnippet-list su__d-flex su__loading-view">
                                                                        <div class="su__steps-bullets"></div>
                                                                        <div class="su__font-13 su__text-black regular su__mb-2 su__text-truncate">
                                                                            {!result}
                                                                        </div>
                                                                    </div>
                                                                </aura:iteration>
                                                            </aura:if>
                                                            <aura:if isTrue="{!greaterthan(v.featureSnippet.steps.length, 3)}">
                                                                <span onclick="{!c.featuredSnippetCollapse}" class="{!!v.featureSnippet.isCollapsed ? 'su__cursor su__position-relative su__mb-1 su__font-12 su__color-blue su__f-regular su__showmore-text su__d-inline-block su__loading-view': 'su__d-none'}">
                                                                    (More)
                                                                </span>
                                                                <span onclick="{!c.featuredSnippetCollapse}" class="{!v.featureSnippet.isCollapsed ? 'su__cursor su__position-relative su__mb-1 su__font-12 su__color-blue su__f-regular su__showmore-text su__d-inline-block su__loading-view': 'su__d-none'}">
                                                                    (Less)
                                                                </span>
                                                            </aura:if>
                                                        </div>
                                                        <div class="{! if( v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length, 'su__featureSnippet-right su__d-flex su__flex-column su__w-30', 'su__featureSnippet-right su__d-flex su__flex-column' )}">
                                                            <aura:if isTrue="{!if(v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length != 0,true,false)}">
                                                                <div class="su__featureSnippet-right">
                                                                    <div class="su__min-w-30 su__loading-view">
                                                                        <a class="su__position-relative su__d-flex" href="{!v.featureSnippet.multiMedia[0].href || v.featureSnippet.multiMedia[0].video_url}"
                                                                            data-href="{!v.featureSnippet.multiMedia[0].href || v.featureSnippet.multiMedia[0].video_url}"
                                                                            target="_blank" rel="noopener noreferrer" onclick="{!c.runScriptMethod}"
                                                                            data-Id="{!v.featureSnippet._id}" data-Rank="0" data-Sub="{!v.featureSnippet.highlight.TitleToDisplayString[0]}"
                                                                            data-url="{!v.featureSnippet.href}" data-Type="{!v.featureSnippet.objName}"
                                                                            data-Index="{!v.featureSnippet.sourceName}" data-Autotuned="{!v.featureSnippet.autotuned}"
                                                                            data-trackAnalytics="{!v.featureSnippet.trackAnalytics}">
                                                                            <aura:if isTrue="{!if(v.featureSnippet.multiMedia[0].thumbnail,true,false)}">
                                                                                <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/play_arrow.svg'}" class="su__video-thumbnail-play" />
                                                                            </aura:if>
                                                                            <img src="{!v.featureSnippet.multiMedia[0].image_urls || v.featureSnippet.multiMedia[0].thumbnail}"
                                                                                class="su__img-featured" alt="{!v.featureSnippet.multiMedia[0].alt_attributes}" />
                                                                        </a>
                                                                    </div>
                                                                </div>
                                                            </aura:if>
                                                        </div>
                                                    </div>
                                                    <a class="su__text-decoration font-14 su__text-black hover-color-dblue su__font-bold su__text-truncate su__mt-3 su__loading-view"
                                                        href="{!v.featureSnippet.href}" data-href="{!v.featureSnippet.href}" target="_blank"
                                                        rel="noopener noreferrer" onclick="{!c.runScriptMethod}" data-Id="{!v.featureSnippet._id}"
                                                        data-Rank="0" data-Sub="{!v.featureSnippet.highlight.TitleToDisplayString[0]}" data-url="{!v.featureSnippet.href}"
                                                        data-Type="{!v.featureSnippet.objName}" data-Index="{!v.featureSnippet.sourceName}"
                                                        data-Autotuned="{!v.featureSnippet.autotuned}" data-trackAnalytics="{!v.featureSnippet.trackAnalytics}">
                                                        <aura:unescapedHtml value="{!v.featureSnippet.highlight.TitleToDisplay[0]}"></aura:unescapedHtml>
                                                    </a>
                                                    <div class="su__href-txt su__text-decoration su__color-lgray font-12 su__font-italic su__text-truncate su__loading-view">
                                                        {!v.featureSnippet.href}
                                                    </div>
                                                    <div class="su__featureSnippet-response">
                                                        <aura:if isTrue="{!!v.featuredResponseRecorded}">
                                                            <div class="su__d-flex su__w-100">
                                                                <div class="su__d-flex su__pt-2">
                                                                    <span class="su__featured-feedback su__cursor su__loading-view su__mr-2" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="0">
                                                                        <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-down.png'}" class="ab-testing-btn" alt="Not Useful" />
                                                                    </span>
                                                                    <span class="su__featured-feedback su__cursor su__loading-view" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="1">
                                                                        <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-up.png'}" class="ab-testing-btn" alt="Useful" />
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                        <aura:if isTrue="{!if(v.featuredResponseRecorded &amp;&amp; v.timeoutResponse, true, false)}">
                                                            <div class="su__feedback-thankyou su__feedback-steps su__font-14 su__mb-2 su__position-relative su__loading-view">
                                                                <div class="su__flex-vcenter su__font-12">
                                                                    <span class="su__thankyou-text su__whitespace-no su__loading-view">
                                                                        {!v.finalLang.Thank_you_for_your_response ? v.finalLang.Thank_you_for_your_response : 'Thank you for your response'}!
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                    </div>
                                                </div>
                                            </aura:if>
                                            <aura:if isTrue="{!if(v.featureSnippet &amp;&amp; !v.featureSnippet.steps &amp;&amp; v.featureSnippet.questionAnswer &amp;&amp; v.featureSnippet.questionAnswer.answer &amp;&amp; v.featureSnippet.questionAnswer.short_summary, true, false)}">
                                                <!-- desktop -->
                                                <div class="su__FeaturedSnippet su__fs-bg-blue su__radius-1 su__position-relative su__mb-3 su__p-3 su__d-md-flex su__overflow-hide su__w-100 su__md-none">
                                                    <div class="{! if( v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length, 'su__featureSnippet-left su__d-flex su__flex-1 su__flex-column su__overflow-hide su__mr-4 su__w-75', 'su__featureSnippet-left su__d-flex su__flex-1 su__flex-column su__overflow-hide su__mr-4' )}">
                                                        <div class="su__featureSnippet-title font-18 su__font-bold su__text-truncate su__mb-2 su__loading-view">
                                                            {!v.featureSnippet.questionAnswer.answer}
                                                        </div>
                                                        <div class="su__su__featureSnippet-desc font-12">
                                                            <span class="su__text-black su__font-12 su__d-flex su__font-regular su__loading-view">
                                                                {!v.featureSnippet.questionAnswer.short_summary}
                                                            </span>
                                                        </div>
                                                        <div class="su__flex-vcenter su__loading-view su__pt-1">
                                                            <a class="su__href-txt su__text-decoration su__color-lgray su__font-12 su__font-italic" href="{!v.featureSnippet.href}"
                                                                data-href="{!v.featureSnippet.href}" target="_blank" rel="noopener noreferrer"
                                                                onclick="{!c.runScriptMethod}" data-Id="{!v.featureSnippet._id}" data-Rank="0"
                                                                data-Sub="{!v.featureSnippet.highlight.TitleToDisplayString[0]}" data-url="{!v.featureSnippet.href}"
                                                                data-Type="{!v.featureSnippet.objName}" data-Index="{!v.featureSnippet.sourceName}"
                                                                data-Autotuned="{!v.featureSnippet.autotuned}"
                                                                data-trackAnalytics="{!v.featureSnippet.trackAnalytics}">
                                                                {!v.featureSnippet.href}
                                                            </a>
                                                        </div>
                                                        <aura:if isTrue="{!if(v.featureSnippet.metadata &amp;&amp; v.featureSnippet.metadata.length > 0,true,false)}">
                                                            <div class="su__su__featureSnippet-meta font-12">
                                                                <div class="su__meta-item su__d-flex su__flex-wrap su__align-content-between su__mt-2 font-12">
                                                                    <aura:iteration items="{!v.featureSnippet.metadata}" var="meta" indexVar="ind">
                                                                        <aura:if isTrue="{!if(meta.value.length > 0 &amp;&amp; meta.key != 'Tag',true,false)}">
                                                                            <div class="su__meta-date su__word-break">
                                                                                <div class="su__meta-row su__mb-1 su__loading-view">
                                                                                    <span class="metaDataKey su__font-bold su__color-blue su__mr-2 su__rtlmr-0 su__rtlml-2 su__loading-view">
                                                                                        {!if(meta.key == 'post_time', 'Created Date', meta.key)}
                                                                                    </span>
                                                                                    <span class="metaDataKey">&lrm;:&lrm;</span>
                                                                                    <aura:if isTrue="{!if(meta.key == 'post_time',true,false)}">
                                                                                        <aura:iteration items="{!meta.value}" var="metadataVal">
                                                                                            <ui:outputDate value="{!metadataVal}"
                                                                                                format="EEE dd MMM yyyy / hh:mm a" />
                                                                                        </aura:iteration>
                                                                                        <aura:set attribute="else">
                                                                                            <aura:iteration items="{!meta.value}" var="metadataVal"
                                                                                                indexVar="singleVal">
                                                                                                <aura:if isTrue="{!singleVal == 0}">
                                                                                                    <span class="su__color-lgray su__mr-2 su__rtlmr-0 su__rtlml-2 su__loading-view">{!metadataVal}</span>
                                                                                                </aura:if>
                                                                                            </aura:iteration>
                                                                                        </aura:set>
                                                                                    </aura:if>
                                                                                </div>
                                                                            </div>
                                                                        </aura:if>
                                                                    </aura:iteration>
                                                                    <aura:iteration items="{!featureSnippet.metadata}" var="meta" indexVar="ind">
                                                                        <aura:if isTrue="{!if(meta.value.length > 0 &amp;&amp; meta.key == 'Tag', true, false)}">
                                                                            <div class="su__meta-row su__mb-1 su__loading-view">
                                                                                <aura:if isTrue="{!if(meta.key == 'Tag' , true, false)}">
                                                                                    <span class="metaDataKey su__font-bold su__color-blue su__mr-2 su__rtlmr-0 su__rtlml-2 su__loading-view">
                                                                                        {!if(meta.key == 'Tag', meta.key)}
                                                                                    </span>
                                                                                    <span class="metaDataKey">&lrm;:&lrm;</span>
                                                                                    <span class="su__color-black su__tags su__radius-3 su__mr-2 su__rtlmr-0 su__rtlml-2 su__tags-line-height su__loading-view">
                                                                                        {!meta.valueString}
                                                                                    </span>
                                                                                </aura:if>
                                                                            </div>
                                                                        </aura:if>
                                                                    </aura:iteration>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                    </div>
                                                    <div class="{! if( v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length, 'su__featureSnippet-right su__d-flex su__flex-column su__featured-thumbnail', 'su__featureSnippet-right su__d-flex su__flex-column su__w-80px' )}">
                                                        <div class="su__position-relative">
                                                            <aura:if isTrue="{!!v.featuredResponseRecorded}">
                                                                <div class="su__d-flex su__w-100 su__feedback-icon-above su__position-absolute su__zindex-1">
                                                                    <div class="{! if( v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length, 'su__feedback-row su__d-flex su__pt-2 su__pr-2', 'su__feedback-row su__d-flex' )}">
                                                                        <span class="su__featured-feedback su__cursor su__loading-view su__mr-2" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="0">
                                                                            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-down.png'}" class="ab-testing-btn" alt="Not Useful" />
                                                                        </span>
                                                                        <span class="su__featured-feedback su__cursor su__loading-view" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="1">
                                                                            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-up.png'}" class="ab-testing-btn" alt="Useful" />
                                                                        </span>
