                                                                                    <aura:if isTrue="{!if(!v.showSummary, true,false)}">
                                                                                        <aura:iteration indexVar="index" items="{!data.highlight.SummaryToDisplay}" var="summary">
                                                                                            <span class="{!data.isCollapsed? 'su__list-item-desc su__my-1 su__font-regular su__mb-2 font-12 su__word-break su__d-inline su__loading-view': 'su__list-item-desc su__my-1 su__font-regular su__mb-2 font-12 su__word-break su__d-block su__loading-view'}">
                                                                                                <aura:unescapedHtml value="{!summary}"></aura:unescapedHtml>
                                                                                            </span>
                                                                                        </aura:iteration>
                                                                                    </aura:if>          
                                                                                </div>
                                                                            </aura:if>
                                                                        </aura:if>
                                                                    </div>
                                                                    <aura:if isTrue="{!if(data.metadata.length > 0 &amp;&amp; !v.hideMetadata,true,false)}">
                                                                        <div class="su__meta-item su__d-flex su__flex-wrap su__align-content-between su__mt-2 font-12">
                                                                            <aura:iteration items="{!data.metadata}" var="metadata" indexVar="ind">
                                                                                <aura:if isTrue="{!if(metadata.value.length > 0 &amp;&amp; metadata.key != 'Tag' &amp;&amp; metadata.value[0] != '',true,false)}">
                                                                                    <div class="{!if(!!v.listview || (v.metaStatus || v.relatedTilesStatus) == true,  'su__meta-date su__word-break',  'su__meta-date su__word-break')}">
                                                                                        <div class="su__meta-row su__mb-1 su__loading-view"> 
                                                                                            <span class="metaDataKey su__font-bold su__color-blue su__rtlmr-0 su__rtlml-2">
                                                                                                {!if(metadata.key == 'post_time','Created Date',metadata.key)}
                                                                                            </span><span class="metaDataKey">&lrm;:&lrm;</span>
                                                                                            <aura:if isTrue="{!if(metadata.key == 'post_time',true,false)}">
                                                                                                <aura:iteration items="{!metadata.value}" var="metadataVal">
                                                                                                    <ui:outputDate value="{!metadataVal}" format="EEE dd MMM yyyy / hh:mm a" />
                                                                                                </aura:iteration>
                                                                                                <aura:set attribute="else">
                                                                                                    <aura:iteration items="{!metadata.value}" var="metadataVal" indexVar="singleVal">
                                                                                                        <aura:if isTrue="{!singleVal == 0}">
                                                                                                            <span class="su__color-lgray su__ml-1 su__rtlml-0 su__rtlmr-1">{!metadataVal}</span>
                                                                                                            
                                                                                                        </aura:if>
                                                                                                    </aura:iteration>
                                                                                                </aura:set>
                                                                                            </aura:if>
                                                                                        </div>
                                                                                    </div>
                                                                                </aura:if>
                                                                            </aura:iteration>
                                                                            <aura:iteration items="{!data.metadata}" var="metadata" indexVar="ind">
                                                                                <aura:if isTrue="{!if(metadata.value.length > 0 &amp;&amp; metadata.key == 'Tag' &amp;&amp; metadata.value[0] != '',true,false)}">
                                                                                    <div class="{!if(!!v.listview || (v.metaStatus || v.relatedTilesStatus) == true,  'su__word-break',  'su__word-break')}">
                                                                                        <div class="su__meta-row su__mb-1 su__loading-view">
                                                                                            <aura:if isTrue="{!if(metadata.key == 'Tag' , true, false)}">
                                                                                                <span class="metaDataKey su__font-bold su__color-blue su__rtlmr-0 su__rtlml-2">
                                                                                                    {!if(metadata.key == 'Tag', metadata.key)}
                                                                                                    <!-- <c:SULanguages parent="{!this}" child="{!if(metadata.key == 'Tag', metadata.key)}" /> -->
                                                                                                </span><span class="metaDataKey">&lrm;:&lrm;</span>
                                                                                                <span class="su__color-lgray su__ml-1 su__rtlml-0 su__rtlmr-1">
                                                                                                    {!metadata.valueString}
                                                                                                    <!-- <c:SULanguages parent="{!this}" child='{!metadata.valueString}' /> -->
                                                                                                </span>
                                                                                            </aura:if>
                                                                                        </div>
                                                                                    </div>
                                                                                </aura:if>
                                                                            </aura:iteration>
                                                                        </div>
                                                                    </aura:if>
                                                                    <!--ATTACHMENT IN METADATA-->
                                                                    <aura:if isTrue="{!if(data.highlight.AttachmentToDisplay.length > 0 &amp;&amp; !v.hideMetadata ,true,false)}">
                                                                        <span class="metaDataKey su__color-blue su__rtlmr-0 su__rtlml-2 su__loading-view"> Attachments: </span>
                                                                        <aura:iteration items="{!data.highlight.AttachmentToDisplay}" var="att" indexVar="ind">
                                                                            <div class="{!if(!!v.listview || (v.metaStatus || v.relatedTilesStatus) == true,  'su__meta-date su__word-break',  'su__meta-date su__word-break')}">
                                                                                <div class="su__meta-row su__mb-1 su__loading-view">
                                                                                    <span >
                                                                                        <a href="{!att.url}" target="_blank" class="su__color-blue su__ml-1 su__rtlml-0 su__rtlmr-1">{!att.name}</a>
                                                                                    </span>
                                                                                </div>
                                                                            </div>
                                                                        </aura:iteration>
                                                                    </aura:if>
                                                                    <!--ATTACHMENT IN METADATA-->
                                                                </div>
                                                                <aura:if isTrue="{!data.hits}">
                                                                    <div class="su__multi-version-mobile su__multiple-versions-block su__loading-view su__d-xl-none su__d-lg-none su__d-md-block su__d-xs-block">
                                                                        <div class="su__text-nowrap su__position-relative su__ml-2 su__ribbon-grid su__d-none su__text-left" onclick="{!c.collapseVersions}" id="{!'collapseVersion-2-'+data._id+'_icon'}">
                                                                            <div class="su__multiple-versions-row su__flex-vcenter su__justify-content-end">
                                                                                <div class="su__flex-vcenter su__parent-version su__w-135px su__cursor su__filter-arows">
                                                                                    <span class="su__w-100 su__custom-grey-color su__margin-right-auto su__text-decoration su__font-regular su__text-truncate font-10" id="{!'collapseVersion-3-'+data._id+'_icon'}">{!data.version}</span>
                                                                                    <div class="bg-keydown_arrow su_displayHide su__arrow-icons su__d-block su__transition-5s" id="{!'collapseVersion-3-'+data._id+'_toggleIcon'}"></div>
                                                                                </div>                                                                                            
                                                                            </div>
                                                                            <div class="su__position-absolute su__w-135px su__background-white su__sm-shadow su__multiple-versions-dropdown su__miniscroll" id="{!'collapseVersion-3-'+data._id}">
                                                                                <aura:iteration items="{!data.hits}" var="docsVersion">
                                                                                    <div class="su__bg-gray-hover su__multiple-versions-results">
                                                                                        <div class="su__custom-border-color su__multiple-versions su__text-truncate">
                                                                                            <a class="su__cursor su__custom-grey-color su__text-decoration su__font-regular font-10" target="_blank" title="{!docsVersion.version}" href="{!docsVersion.href}" onclick="{!c.runScriptMethod}" data-Id="{!docsVersion._id}" data-Rank="{!indexVar}" data-title="{!docsVersion.highlight.TitleToDisplayString[0]}" data-Sub="{!docsVersion.highlight.TitleToDisplayString[0]}" data-url="{!docsVersion.href}" data-Type="{!docsVersion.objName}" data-Index="{!docsVersion.sourceName}" data-trackAnalytics= "{!data.trackAnalytics}">{!docsVersion.version}</a>
                                                                                        </div>
                                                                                    </div>
                                                                                </aura:iteration>
                                                                            </div>
                                                                        </div>
                                                                        <div class="su__multiple-versions-overlay su__bg-overlay" id="{!'collapseVersion-3-'+data._id+'_overlay'}" role="button" onclick="{!c.collapseVersions}"></div>
                                                                    </div>
                                                                </aura:if>
                                                                <div class="{!if(v.listview, 'su__preview-results-block' , 'su__preview-results-block su__d-none')}">
                                                                    <div class="su__preview-inner-block">
                                                                        <aura:if isTrue="{!data.showPreview}">
                                                                            <div
                                                                                class="su__text-right su__preview-text su__mx-1 su__text-nowrap su__font-italic font-12 su__color-gray hover-color-dblue"
                                                                                onclick="{!c.resultPreview}">
                                                                                <div class="su__flex-vcenter su__preview-image-parent su__justify-content-end">
                                                                                    <span title="{!v.search_preview}" class="su__preview-image su__loading-view su__cursor"
                                                                                    data-label="{!data.contentTag}" 
                                                                                    data-title="{!data.highlight.TitleToDisplayString[0]}" 
                                                                                    href="{!data.href}"
                                                                                    data-Id="{!data._id}"
                                                                                    data-href="{!data.href}"
                                                                                    data-Rank="{!indexVar}"
                                                                                    data-Sub="{!data.highlight.TitleToDisplayString[0]}"
                                                                                    data-url="{!data.href}"
                                                                                    data-Type="{!data.objName}"
                                                                                    data-Index="{!data.sourceName}"
                                                                                    data-Autotuned="{!data.autotuned}"
                                                                                    data-trackAnalytics= "{!data.trackAnalytics}">
                                                                                        <label for="preview-image"></label>
                                                                                    </span>
                                                                                </div>
                                                                            </div>
                                                                        </aura:if>
                                                                    </div>
                                                                    <aura:if isTrue="{!data.hits}">
                                                                        <div class="su__multiple-versions-block su__multiple-versions-list su__loading-view su__d-xl-block su__d-lg-block su__d-xs-none">
                                                                            <div class="su__multiple-version-label su__custom-grey-color su__text-truncate su__ml-2 font-11 su__text-right" title="{!data.versionFieldName}">{!data.versionFieldName}</div>
                                                                            <div class="su__text-nowrap su__position-relative su__ml-2 su__ribbon-grid su__d-block su__text-left" onclick="{!c.collapseVersions}" id="{!'collapseVersion-2-'+data._id+'_icon'}">
                                                                                <div class="su__multiple-versions-row su__flex-vcenter su__justify-content-end">
                                                                                    <div class="su__flex-vcenter su__parent-version su__w-135px su__cursor su__filter-arows">
                                                                                        <span class="su__w-100 su__custom-grey-color su__margin-right-auto su__text-decoration su__font-regular su__text-truncate font-10" id="{!'collapseVersion-4-'+data._id+'_icon'}">{!data.version}</span>
                                                                                        <div class="bg-keydown_arrow su_displayHide su__arrow-icons su__d-block su__transition-5s" id="{!'collapseVersion-4-'+data._id+'_toggleIcon'}"></div>
                                                                                    </div>                                                                                            
                                                                                </div>
                                                                                <div class="su__position-absolute su__w-135px su__background-white su__sm-shadow su__multiple-versions-dropdown su__miniscroll" id="{!'collapseVersion-4-'+data._id}">
                                                                                    <aura:iteration items="{!data.hits}" var="docsVersion">
                                                                                        <div class="su__bg-gray-hover su__multiple-versions-results">
                                                                                            <div class="su__custom-border-color su__multiple-versions su__text-truncate">
                                                                                                <a class="su__cursor su__custom-grey-color su__text-decoration su__font-regular font-10" target="_blank" title="{!docsVersion.version}" href="{!docsVersion.href}" onclick="{!c.runScriptMethod}" data-Id="{!docsVersion._id}" data-Rank="{!indexVar}" data-title="{!docsVersion.highlight.TitleToDisplayString[0]}" data-Sub="{!docsVersion.highlight.TitleToDisplayString[0]}" data-url="{!docsVersion.href}" data-Type="{!docsVersion.objName}" data-Index="{!docsVersion.sourceName}" data-trackAnalytics= "{!data.trackAnalytics}">{!docsVersion.version}</a>
                                                                                            </div>
                                                                                        </div>
                                                                                    </aura:iteration>
                                                                                </div>
                                                                            </div>
                                                                            <div class="su__multiple-versions-overlay su__bg-overlay" id="{!'collapseVersion-4-'+data._id+'_overlay'}" role="button" onclick="{!c.collapseVersions}"></div>
                                                                        </div>
                                                                    </aura:if>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </aura:iteration>
                                                </div>
                                                <!-- </aura:if> -->
                                                <!-- Code to Display the Knowledge Graph starts here-->
                                                <aura:if isTrue="{!v.metaStatus || v.relatedTilesStatus}">
                                                    <div class="su__knowledgeGraph su__sm-fullwidth  su__col-xl-4 su__col-lg-12 su__col-md-12 su__col-xs-12 su__bg-white su__position-relative su__p-3 su__pb-0 su__mb-3 su__sm-shadow su__radius-1">
                                                        <aura:if isTrue="{!v.metaStatus}">
                                                            <div class="su__text-truncate su__m-0 su__loading-view">
                                                                <a href="{!v.meta_data.metaLink}" class="su__text-decoration font-14 su__text-black su__font-bold" target="_blank">
                                                                    <aura:unescapedHtml value="{!v.meta_data.metaTitle}"></aura:unescapedHtml>
                                                                </a>
                                                            </div>
                                                            <div class="su__list-item-desc su__w-100 su__m-0 su__mt-1 font-12 su__word-break su__loading-view">
                                                                <cite class="su__text-decoration su__color-lgray font-12">
                                                                    <aura:unescapedHtml value="{!v.meta_data.metaLink}"></aura:unescapedHtml>
                                                                </cite>
                                                            </div>
                                                            <aura:if isTrue="{!v.meta_data.metaImg}">
                                                                <div class="metaImg">
                                                                    <img class="knowledgeGraph-metaImg" src="{!v.meta_data.metaImg}" />
                                                                </div>
                                                            </aura:if>
                                                            <div class="su__list-item-desc su__w-100 su__m-0 su__mt-1 font-12 su__word-break su__loading-view">
                                                                <aura:unescapedHtml value="{!v.meta_data.metaDescription}"></aura:unescapedHtml>
                                                            </div>
                                                            <div class="su__meta-item su__mt-2 font-12">
                                                                <aura:iteration items="{!v.meta_data.metaFields}" var="mf">
                                                                    <div class="su__meta-row su__mb-1 su__loading-view">
                                                                        <span class="metaDataKey su__font-bold su__color-blue su__rtlmr-0 su__rtlml-2">
                                                                            <aura:unescapedHtml value="{!mf.key}"></aura:unescapedHtml>
                                                                        </span>
                                                                        : &lrm;
                                                                        <span class="su__color-lgray su__ml-1 su__rtlml-0 su__rtlmr-1">
                                                                            <aura:unescapedHtml value="{!mf.value}"></aura:unescapedHtml>
                                                                        </span>
                                                                    </div>
                                                                </aura:iteration>
                                                            </div>
                                                        </aura:if>
                                                        <aura:if isTrue="{!v.relatedTilesStatus}">
                                                            <aura:iteration items="{!v.relatedTiles}" var="rt">
                                                                <h4>
                                                                    <aura:unescapedHtml value="{!rt.tagLine}"></aura:unescapedHtml>
                                                                </h4>
                                                                <aura:iteration items="{!rt.relatedFields}" var="rti">
                                                                    <li>
                                                                        <a href="{!rti.link}" target="_blank">
                                                                            <aura:unescapedHtml value="{!rti.heading1}"></aura:unescapedHtml>
                                                                        </a>
                                                                    </li>
                                                                </aura:iteration>
                                                            </aura:iteration>
                                                        </aura:if>
                                                        <aura:if isTrue="{!!v.knowledgeGraphResponseRecorded}">
                                                            <div class="su-featured-text su__row su__flex-vcenter su__px-3 su__py-2 su__mt-2 su__bg-blue-grd su__loading-view">
                                                                <div class="font-12 su__mt-1 su__text-white su__mr-3 su__rtlmr-0 su__rtlml-3 su__loading-view">
                                                                    {!v.finalLang.Was_above_result_helpful ? v.finalLang.Was_above_result_helpful : 'Was above result helpful'}
                                                                    ?</div>
                                                                    <div class="su__knowledge-feedback-row su__d-flex">
                                                                        <span class="su__knowledge-feedback su__cursor su__loading-view" onclick="{!c.sendknowledgeGraphFeedback}" data-feedback="1">
                                                                            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/su__knowledge-feedback_thumbUp.svg'}" class="ab-testing-btn" alt="Useful" />
                                                                        </span>
                                                                        <span class="su__knowledge-feedback su__cursor su__loading-view" onclick="{!c.sendknowledgeGraphFeedback}" data-feedback="0">
                                                                            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/su__knowledge-feedback_thumbDown.svg'}" class="ab-testing-btn" alt="Not Useful" />
                                                                        </span>
                                                                    </div>
                                                            </div>
                                                        </aura:if>
                                                        <aura:if isTrue="{!v.knowledgeGraphResponseRecorded}">
                                                            <div class="su__knowledge-thankyou su__clearfix su__mb-sm-1">
                                                                <div class="su__text-success font-12 su__my-3 su__flex-vcenter su__px-1 su__position-relative su__loading-view ng-scope">
                                                                    <span class="su__mr-2 su__rtlmr-0 su__rtlml-2">
                                                                        <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/ok-icon.svg'}" class="ft-green-tick" alt="Success icon" />
                                                                    </span>
                                                                    <span>
                                                                        {!v.finalLang.Thank_you_for_your_response ? v.finalLang.Thank_you_for_your_response : 'Thank you for your response'}
                                                                        !</span>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                    </div>
                                                </aura:if>
                                                <!-- Code to Display the Knowledge Graph ends here-->
                                            </div>
                                            <!--For similar Search Suggestions-->
                                            <div class="su__Recommended_flex">
                                                <aura:if isTrue="{!v.getRecommendations}">
                                                    <c:SUAuthRecommendedData />
                                                 </aura:if>
                                                 <aura:if isTrue="{!v.similarSearchSuggestions}">
                                                    <div class="su__position-relative su__mt-4 su__p-3 su__sm-shadow su__bg-white similar-search-width" >
                                                        <div class="su__ribbon-block su__position-absolute">
                                                            <div class="su__ribbon-row-block su__w-auto su__clearfix su__loading-view">
                                                                <div class="su__ribbon-text font-12 su__float-left su__text-center su__text-black su__font-bold su__mb-2 su__radius-3">
                                                                    {!v.finalLang.Similar_Searches ? v.finalLang.Similar_Searches : 'Similar Searches'}
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <ul class="su__p-0 su__mb-3 su__mt-2">
                                                            <aura:iteration items="{!v.similarSearchSuggestions}" var="SearchSuggestion">
                                                                <li class="su__mb-2 su__px-3 su__py-1 su__d-flex su__border su__radius su__align-items-start hover__effect su__loading-view">
                                                                    <a class="font-14 su__text-decoration su__text-black hover-color-dblue" data-label="{!SearchSuggestion}" onclick="{!c.clickSearchSuggestionController}">{!SearchSuggestion}</a>
                                                                </li>
                                                            </aura:iteration>
                                                        </ul>
                                                    </div>
                                                </aura:if>
                                            </div>
                                        </div>
                                        <!--pagination start -->
                                        <aura:if isTrue="{!if(v.totalResults == 0, false,true)}">
                                            <div class="su__w-100 su__pagination-section su__mt-4" ng-class="{su__loading: loadingResults}">
                                                <div class="su__pagination-row su__float-right">
                                                    <div class="su__d-inline-block su__position-relative su__float-left">
                                                        <div class="resultsPerPage su__loading-view su__cursor su__radius-1 su__mr-3  font-12 su__font-regular su__pr-2 su__pl-2 su__pt-1 su__pb-1"
                                                            onclick="{!c.toggleResultsPerPage}">
                                                            <span class="su__text-black su__pr-2">{!v.finalLang.Results_per_page ? v.finalLang.Results_per_page : 'Results per page'}</span>{!v.pageSizeAdvFiltr}
                                                            <span class="pageSize_dropdown  su__arrow-icons su__d-inline-block"></span>
                                                        </div>
                                                        <div class="{!if(v.showPageSize, 'su__d-md-block', 'visibilityHidden')}">
                                                            <div class="resultsPerPage su__zindex-2  pageSize su__bg-white su__position-absolute su__d-inline-block font-12 su__radius-1 su__font-regular su__pr-2 su__pl-2 su__pt-1 su__pb-1">
                                                                <div accessKey="10" onclick="{!c.onSelectChange}" class="su__cursor">10</div>
                                                                <div accessKey="20" onclick="{!c.onSelectChange}" class="su__cursor">20</div>
                                                                <div accessKey="30" onclick="{!c.onSelectChange}" class="su__cursor">30</div>
                                                                <div accessKey="40" onclick="{!c.onSelectChange}" class="su__cursor">40</div>
                                                                <div accessKey="50" onclick="{!c.onSelectChange}" class="su__cursor">50</div>
                                                            </div>
                                                            <div class="su-bg-overlay " onclick="{!c.toggleResultsPerPage}" role="button" tabindex="0"></div>
                                                        </div>
                                                    </div>
                                                    <aura:if isTrue="{!if(v.totalResults le v.pageSize, false,true)}">
                                                        <div class="su__d-inline-block">
                                                            <ul class="pagination su__pagination su__justify-content-end font-14">
                                                                <li class="{!if(v.pageNum == '1', 'disabled', '')}">
                                                                    <a id="{!v.pageNum - 1}" onclick="{!c.pageChange}" class="hidden-xs su__loading-view">
                                                                        {!v.finalLang.Previous ? v.finalLang.Previous : 'Previous'}
                                                                    </a>
                                                                </li>
                                                                <aura:iteration items="{!v.paginationList}" var="paginationNumber">
                                                                    <li class="{!if(v.pageNum == ''+paginationNumber,'active','')}">
                                                                        <a id="{!paginationNumber}" class="su__loading-view" onclick="{!c.pageChange}">{!paginationNumber}</a>
                                                                    </li>
                                                                </aura:iteration>
                                                                <li class="{!if(v.pageNum == v.lastPage, 'disabled', '')}">
                                                                    <a onclick="{!c.nextPage}" class="hidden-xs su__loading-view">
                                                                        {!v.finalLang.Next ? v.finalLang.Next : 'Next'}</a>
                                                            
                                                                </li>
                                                            </ul>
                                                        </div>
                                                    </aura:if>
                                                </div>
                                            </div>
                                        </aura:if>
                                        <!--pagination end -->
                                        <!-- Code for Display the when no results found-->
                                        <!-- <aura:set attribute="else">
                                            
                                        </aura:set> -->
                                    </aura:if>
                                </div>
                            </div>
                            <!-- Code for Display the Search Results ends here-->
                        </div>
                        <button class="su_displayHide slds-hide" onclick="{!c.goToTop}" id="goToTopBtn" title="Go to top">GO TO TOP</button>
                        <!-- Code for Display the when search server is down -->
                        <aura:set attribute="else">
                            <div class="slds-col slds-small-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--1-of-1 su_errorMessage">
                                <span>
                                    <!-- <c:SULanguages parent="{!this}" child='{!v.errorMessage}'/> -->
                                    {!v.errorMessage}
                                </span>
                            </div>
                        </aura:set>
                    </aura:if>
                </div>
                <aura:if isTrue="{!if(v.totalResults == 0 &amp;&amp; v.noResultAdvertisement == true, true,false)}">
                    <div class="su__loading-view">
                       <aura:unescapedHtml value="{!v.advertisement}"></aura:unescapedHtml>
                   </div>
               </aura:if>
                <aura:if isTrue="{!if(v.totalResults == 0 &amp;&amp; v.noResultAdvertisement == false, true,false)}">
                    <aura:if isTrue="{!v.loadingResult == 1}">
                        <div class="su-clear-filters-section" style="{!if(v.showClearFiltersButton,'overflow:hidden;', 'overflow:hidden; display:inline')}">
                            <aura:if isTrue="{!v.showClearFiltersButton}">
                                <label onclick="{!c.clearFilters}" class="su__clear-filters-btn su__cursor su__font-bold font-12 su__mb-2 su__p-0 su__color-lblue su__loading-view">
                                    {!v.finalLang.Clear_filters ? v.finalLang.Clear_filters : 'Clear filters'}
                                </label>
                            </aura:if>
                        </div>
                        <div class="su_errorMessage su__w-100">
                            <div class="su__noresult-text su__w-100">
                                <div class="no-results-row su__row su__text-center">
                                    <div class="su__col-md-12 su__m-auto">
                                        <p class="su__sorry-no-result su__font-bold su__text-center">
                                            {!v.errorMessage}
                                            <!-- <c:SULanguages parent="{!this}" child='{!v.errorMessage}' /> -->
                                        </p>
                                        <div class="no-results-img su__text-center">
                                            <div class="bg-No_result_data ab-testing-btn"></div>
                                        </div>
                                        <!--<p class="su__font-bold font-14">
                                            <c:SULanguages parent="{!this}" child='Showing results using some of your recent search terms' />
                                        </p>-->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </aura:if>
                </aura:if>
            </aura:if>
                <!-- Code for Display the when search is not configured -->
            <aura:set attribute="else">
                <div class="slds-col slds-small-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--1-of-1 su_errorMessage">
                    <span>
                        {!v.customSettingErrorMessage}
                        <!-- <c:SULanguages parent="{!this}" child='{!v.customSettingErrorMessage}' /> -->
                    </span>
                </div>
            </aura:set>
            
            <!-- fixed mobile icons -->
            <div class="su__fixed-bottom docs-scroll-fab scrolling su__shadow su__bg-white su__d-md-none su__d-xs-block">
                <div class="su__mobile-navigation su__px-2 su__px-sm-1 su__py-2 su__flex-vcenter su__justify-content-between">
                    <div class="su__col su__text-center font-9 su__font-bold su__px-sm-1" onclick="{!c.goToTop}">
                        <div class="bg-Search_black adjustSprite"></div>
                        {!v.finalLang.Search ? v.finalLang.Search : 'Search'}
                    </div>
                    <div class="su__col su__text-center font-9 su__font-bold su__px-sm-1" onclick="{!c.ToggleExpandAdvanceSearch}">
                        <span class="su__d-block">
                            <div class="bg-Advance_Search_black"></div>
                        </span>
                        <span>
                            {!v.finalLang.Advanced_Search ? v.finalLang.Advanced_Search : 'Advanced Search'}
                        </span>
                    </div>
                    <div class="su__col su__text-center font-9 su__font-bold su__px-sm-1" onclick="{!c.starClicked}">
                        <span class="su__bookmark-list su__d-block bookmark-list-dots">
                            <div class="bg-Add_Bookmark adjustSprite"></div>                                
                        </span>
                        <span>
                            {!v.finalLang.Add_Bookmarks ? v.finalLang.Add_Bookmarks : 'Add Bookmarks'}</span>
                    </div>
                    <div class="su__col su__text-center font-9 su__font-bold su__px-sm-1 su__position-relative">
                        <div class="su__d-block su__more-hover" onclick="{!c.viewMoreToggle}">
                            <div class="bg-More_black adjustSprite"></div>                                    
                            <span class="su__d-block">
                                {!v.finalLang.More ? v.finalLang.More : 'More'}                                        </span>
                        </div>
                        <div class="su__viewMore su__position-absolute su__d-none su__sm-shadow su__p-2 su__bg-white">
                            <div class="su__w-100 su__flex-vcenter font-9 su__font-bold su__px-sm-1 su__p-1" onclick="{!c.toggleSearchTips}">
                                <div class="bg-Tips_black su__mr-2"></div>                                        
                                <span>
                                    {!v.finalLang.Search_Tips ? v.finalLang.Search_Tips : 'Search Tips'}
                                </span>
                            </div>
                            <div class="su__w-100 su__flex-vcenter font-9 su__font-bold su__px-sm-1 su__p-1" onclick="{!c.bookmarkList_toggle}">
                                <div class="bg-saved_bookmark_black su__mr-2"></div>
                                <span class="su__text-nowrap">
                                    {!v.finalLang.Saved_Bookmarks ? v.finalLang.Saved_Bookmarks : 'Saved Bookmarks'}
                                    <!-- <c:SULanguages parent="{!this}" child='Saved Bookmarks' /> -->
                                    </span>
                            </div>
                        </div>
                        <div class="su__d-none su__bg-overlay su__viewMore-overlay" role="button"></div>
                    </div>
                </div>
            </div>
            <!-- fixed mobile icons end -->
            <!-- Search Tips for mobile start-->
            <div class="su__side-Search-tips su-tab su__bg-blue-grd su__p-2 su__position-fixed su__cursor su__loading-view su__z-index su__d-md-block su__d-xs-none">
                <div onclick="{!c.toggleSearchTips}" class="bg-search_tips_white su__img-24"  title="{!v.search_tips}"></div>
            </div>
            <aura:if isTrue="{!if(v.totalResults > 0,true,false)}">
                <div id="gear" title="{!v.settings}" onclick="{!c.togglePopup}" class="{!if(v.customize, 'su__side-Search-tips-on su__bg-blue-grd su__p-2 su__position-fixed su__cursor su__loading-view su__d-lg-block su__d-xs-none', 'su__side-Search-tips su__bg-blue-grd su__p-2 su__position-fixed su__cursor su__loading-view su__d-lg-block su__d-xs-none')}" role="button">
                    <div class="bg-setting su__img-24 gear-icon"></div>                
                </div>
            </aura:if>
            <div class="{!if(v.customize, 'su__d-md-block', 'visibilityHidden')}">
                    <div class="su__side-Search-tips su__customized__settings su__side-customized-gear su__zindex-2 viewOptions su__bg-white su__position-fixed su__cursor su__loading-view su__zindex-1 su__d-md-block su__d-xs-none" role="button">
                        <aura:if isTrue="{!v.isSmartFacetsAdmin}">
                        <div class="su__customized__settings-inner">
                        <label class="su__customized_switch su__gear-min-width">
                            <input class="su__ml-2" id="auto-learning" type="checkbox" checked="{!v.isAutoLearning}" onclick="{!c.toggleAutoLearning}"/>
                            <span class="su__customized_switch_slider round"></span>
                        </label>
                        <label htmlFor="auto-learning" class="su__font-13 su__pl-2 su__rtlpl-0 su__rtlpr-2">{!v.finalLang.Auto_Learning ? v.finalLang.Auto_Learning : 'Auto Learning'}</label>
                        <img class="su__gear-min-width" src="{!v.scConfigObj.client_url+v.uid+'/Assets/Info.svg'}" style="height:15px;" title="Turn on this option to enable Auto Learning as well as Facet Pre Selection"/>
                        </div>
                        <hr class="su-customize-hr"/>
                        </aura:if>    
                        <div onclick="{!c.toggleEditMode}" class="su__customized__settings-inner" title="Customize">
                            <img class="su__gear-min-width" src="{!v.scConfigObj.client_url+v.uid+'/Assets/Customize.svg'}" style="height:25px;"/>
                            <p class="su__font-13 su__pl-2">{!v.finalLang.Customize ? v.finalLang.Customize : 'Customize'}</p>
                        </div>
                        <div onclick="{!c.toggleSearchTips}" class="su__customized__settings-inner" title="{!v.search_tips}">
                            <img class="su__gear-min-width" src="{!v.scConfigObj.client_url+v.uid+'/Assets/Tips.svg'}" style="height:25px;"/>
                            <p class="su__font-13 su__pl-2">{!v.finalLang.Search_Tips ? v.finalLang.Search_Tips : 'Search Tips'}</p>
                        </div>
                </div>
                <div class="su-bg-overlay" onclick="{!c.togglePopup}" role="button" tabindex="0"></div>
            </div>
            <div class="su__sidebar-desktop su__miniscroll su__right-sidebar su__border su__border-t-none su__radius-1 su_modal_effect su_fade_effect">
                <div class="su__searchTip-header su__p-3 su__bg-blue-grd su__text-white su__rtltext-left su__position-relative">
                    <h4 class="su__m-0"> {!v.finalLang.Search_Tips ? v.finalLang.Search_Tips : 'Search Tips'}</h4>
                    <div class="su__close-icon su__position-absolute su__cursor" role="button">
                        <div class="bg-white_close_icon" title="{!v.close}" onclick="{!c.dismiss_modal}"></div>
                    </div>
                </div>
                <div class="su__searchTip-content su__bg-white _md">
                    <div class="su__search-tipicons su__w-100 su__m-auto su__text-center">
                        <div class="bg-search_tips" title="{!v.close}"></div>         
                    </div>                   
                    <ul class="su__searchTip-list su__m-0 su__p-3 su__pl-5 su__rtlpr-5 su__rtlpl-3 font-12">
                        <li>
                            {!v.finalLang.Enter_just_a_few_key_words_related_to_your_question_or_problem ? v.finalLang.Enter_just_a_few_key_words_related_to_your_question_or_problem : 'Enter just a few key words related to your question or problem'}
                        </li>
                        <li>
                                {!v.finalLang.Add_Key_words_to_refine_your_search_as_necessary ? v.finalLang.Add_Key_words_to_refine_your_search_as_necessary : 'Add Key words to refine your search as necessary'}
                        </li>
                        <li>
                                {!v.finalLang.Do_not_use_punctuation ? v.finalLang.Do_not_use_punctuation : 'Do not use punctuation'}
                        </li>
                        <li>
                                {!v.finalLang.Search_is_not_case_sensitive ? v.finalLang.Search_is_not_case_sensitive : 'Search is not case sensitive'}
                        </li>
                        <li>
                                {!v.finalLang.Avoid_non_descriptive_filler_words_like__how____the____what___etc_ ? v.finalLang.Avoid_non_descriptive_filler_words_like__how____the____what___etc_ : 'Avoid non-descriptive filler words like "how", "the", "what", etc.'}
                        </li>
                        <li>
                                {!v.finalLang.If_you_do_not_find_what_you_are_looking_for_the_first_time_reduce_the_number_of_key_words_you_enter_and_try_searching_again_ ? v.finalLang.If_you_do_not_find_what_you_are_looking_for_the_first_time_reduce_the_number_of_key_words_you_enter_and_try_searching_again_ : 'If you do not find what you are looking for the first time,reduce the number of key words you enter and try searching again.'}
                        </li>
                        <li>
                                {!v.finalLang.Minimum_supported_Internet_Explorer_version_is_IE9 ? v.finalLang.Minimum_supported_Internet_Explorer_version_is_IE9 : 'Minimum supported Internet Explorer version is IE9'}
                        </li>
                    </ul>
                </div>
                <div class="su__d-none su__bg-overlay right-sidebar-overlay" role="button" onclick="{!c.dismiss_modal}"></div>
            </div>
            <div class="su__d-none su__bg-overlay right-sidebar-overlay" role="button" onclick="{!c.dismiss_modal}"></div>
            <!-- Search Tips for mobile end -->
            <!-- Goto top start -->
            <div class="{!if(v.showScroll, 'su__back-to-top su__position-fixed su__cursor su__zindex su__d-md-block su__d-xs-none', 'visibilityHidden')}" onclick="{!c.goToTop}">
                <div id="goToTopBtn" class="su__btn-back-to-top su_radius-top su__px-2 su__py-1 su__shadow docs-scroll-fab scrolling su__d-none su__bg-blue-grd" ng-click="goToTop()" docs-scroll-class="scrolling" aria-label="Back to Top" role="button" tabindex="0" style="display: block;">
                    <span class="su__text-white font-12">
                        {!v.finalLang.Page_Top ? v.finalLang.Page_Top : 'Page Top'}
                    </span>
                    <span>
                        <div class="bg-gototop" title="{!v.close}"></div>
                    </span>
                </div>
            </div>
            <!-- Goto top end -->
        </div>
        <!-- search result preview start -->
        <div class="su__iframe-modal-view su__bookmark-row su__position-fixed su__trbl-0 su__zindex-3 su__d-none">
            <div
                class="su__py-2 su__iframe-modal su__sm-w-100 su__sm-h-100 su__animate-fadeInRight su__position-fixed su__shadow-lg su__bg-white su__radius-1 su__mx-auto su__zindex-2">
                <div class="su__close-icon su__d-flex su__align-items-start">
                    <div class='su__flex-1 font-14 su__color-gray su__py-2 su__px-3 su__f-regular su__loading-view su__overflow-hide'>
                        <span class="su__word-break">
                            <span class="su__line-clamp">{!v.previewTitle}</span>
                        </span>
                        <aura:if isTrue="{!if(!v.toggleDisplayKeys[5].hideEye &amp;&amp; v.contentTag == true, true,false)}">
                            <span class="su__px-2 su__py-1 su__ml-2 su__f-regular su__color-black su__preview-contentLabel su__text-truncate font-14 su__font-bold">
                                {!v.previewLabel}
                            </span>
                        </aura:if>
                    </div>
                    <div class="su__close-icon su__cursor su__loading-view"  onclick="{!c.dismissPreview}">
                        <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/close.svg'}" style="height:12px;"/>
                    </div>
                </div>
                <div class="su__bookmark-inner su__p-3 su__loading-view">
                    <iframe class='su__iframe-height su__iframe-src' width="100%" height="100%" target="parent"
                        src="{!v.previewSource}"></iframe>
                </div>
            </div>
            <div class="su__bg-overlay right-sidebar-overlay" onclick="{!c.dismissPreview}"></div>
        </div>                                      
        <!-- search result preview end -->
    </aura:if>        
    <!-- Feedback modal here -->
    <aura:if isTrue="{!v.searchFeedback}">
        <div class="su__feedback-searchsvg su__font-12 su__position-fixed su__zindex su__cursor" onclick="{!c.feedbackPageShow}">
            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/search-feedbak.svg'}" />     
        </div>
    </aura:if>
    <aura:if isTrue="{!v.displayModal}">
        <div class="su__feedback-modal su__zindex-2">
            <div class="{!if(v.displayModal,'su__anim-fadeindown su__feedback-popup su__position-fixed su__shadow-lg su__bg-white su__radius-1 su__mx-auto su__zindex-3 su__d-block','visibilityHidden su__position-absolute')}">
                <div class="su__w-100 ">
                    <div class="su__feedback-close su__black-close-icon su__position-absolute su__cursor" onclick="{!c.closeBtn}">
                        <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/close.svg'}" style="height:12px;" />
                    </div>
                    <div class="su__feedback-row su__bg-white">
                        <div class="su__feed-title font-16">{!v.responseSearchFeedbackData.selectedSearchHeader}</div>
                        <div class="su__feed-desc  su__my-2 su__font-11 su__color-lgray">{!v.responseSearchFeedbackData.selectedSearchSubHeader}</div>
                        <div class="su__feed-rating su__font-10">
                            <div class="su__star-wrapper">
                                <aura:if isTrue="{!if(v.responseSearchFeedbackData.selectedSearchTemplate == 'Stars',true,false)}">
                                    <div class="su__feed-rating su__flex-vcenter su__font-10 su__mb-2">
                                        <aura:iteration items="[1,2,3,4,5]" var="index" indexVar="indexVar">
                                            <div onclick="{!c.buttonClick}" onmouseover="{!c.hoverButton}" onmouseleave="{!c.removeHoverButton}" class="{!'su__star-gray su__ratingicon  su__star su__mr-2 su__cursor su__star'+index}" data-index="{!indexVar+1}"></div>
                                        </aura:iteration>
                                    </div>
                                </aura:if>
                                <aura:if isTrue="{!if(v.responseSearchFeedbackData.selectedSearchTemplate == 'Emoticons',true,false)}">
                                    <div id="newId" class="su__feed-rating su__flex-vcenter su__font-10 su__mb-2">
                                        <aura:iteration items="[1,2,3,4,5]" var="index" indexVar="indexVar">
                                            <div onclick="{!c.buttonClick}" onmouseover="{!c.hoverButton}" onmouseleave="{!c.removeHoverButton}" class="{!'su__emoji su__ratingicon su__mr-1 su__cursor su__emoji-icon'+index}" data-index="{!indexVar+1}"></div>
                                        </aura:iteration>
                                    </div>
                                </aura:if>
                            </div>
                        </div>
                        
                            <aura:if isTrue="{!v.responseSearchFeedbackData.searchFeedbackToggle}">
                            <div class="su__feed-txtarea">
                                <div class="su__feedback-label  su__my-2 su__font-11 su__color-lgray">
                                    {!v.responseSearchFeedbackData.selectedTextFeedback}
                                </div>
                                <lightning:textarea aura:id="feedbacktxArea" onchange="{!c.feedbackAreaChange}" name="feeback-txtarea" class="su__feedtext-area su__w-100" id="su__feedtext-area" rows="4"/>
                            </div>
                            </aura:if>
                            <aura:if isTrue="{!v.responseSearchFeedbackData.followUpToggle}">
                        <div class="su__mt-2">
                            <div class="su__feedback-label su__my-2 su__font-11 su__color-lgray">{!v.responseSearchFeedbackData.selectedSearchFollowUp}</div>
                            <div class="su__feedradio-group">
                                <lightning:input type="radio" value="Yes" label="Yes"
                                                onchange="{!c.emailChanged }" name="place" aura:id="place"  checked="true" />
                                <lightning:input type="radio" value="No" label="No"
                                                onchange="{!c.emailChanged }" name="place" aura:id="place" />
                            </div>
                            <aura:if isTrue="{!v.emailShowhide}">
                                <div aura:id="ShowEmailOption" class="su__feed-email-boxs">
                                    <lightning:input disabled="{!v.isInputDisabled}" onchange="{!c.feedbackEmailChange}" name="su__feedback-email" id="su__feedback-email" aura:id="feedbackEmail" type="email"  value="{!v.setCurrentEmail || !v.responseSearchFeedbackData.searchEmailId }" placeholder="Enter Email Address" class="su__input-feedack su__w-100 su__su__font-14 su__text-black"/>
                                </div>
                            </aura:if>
                        </div>
                        </aura:if>
                        <button onclick="{!c.submitFeedback}" disabled="{!v.isButtonActive}" role="button" class="su__feedback-btn su__btn su__bg-blue-grd su__w-auto su__text-white su__cursor su__bookmark-save">{!v.responseSearchFeedbackData.submitButton}</button>
                    </div> 
                </div>
            </div>
            <div class="{!if(v.displayModal, 'su__bg-overlay', 'su__d-none')}" onclick="{!c.closeBtn}" role="button"></div>
        </div>
    </aura:if>
    <!-- end here -->
    <!-- Thank you feedback start-->
    <aura:if isTrue="{!v.displayThankModal}">
        <div class="su__feedback-modal su__zindex-2">
            <div class="{!if(v.displayThankModal,'su__anim-fadeindown su__feedback-popup su__position-fixed su__shadow-lg su__bg-white su__radius-1 su__mx-auto su__zindex-3 su__d-block','visibilityHidden su__position-absolute')}">
                <div class="su__w-100 ">
                    <div class="su__feedback-close su__black-close-icon su__position-absolute su__cursor" onclick="{!c.closeBtn}">
                            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/close.svg'}" style="height:12px;" />
                    </div> 
                    <div class="su__feedback-row su__bg-white">
                        <div class="su__text-success font-12 su__my-3 su__flex-vcenter su__px-1 su__position-relative su__loading-view ng-scope">
                        <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/ok-icon.svg'}" class="su__m-auto ft-green-tick" alt="Success icon" />
                        
                        </div>
                        <div class="su__feednack-thx su__feedback_search">
                            {!v.responseSearchFeedbackData.selectedSearchAcknowledgement}
                        </div>  
                    </div>
                </div>
            </div>
            <div class="{!if(v.displayThankModal, 'su__bg-overlay', 'su__d-none')}" onclick="{!c.closeBtn}" role="button"></div>
        </div>
    </aura:if>
    <!-- Thank you feedback end-->
</div><!--mainUI-->
        </aura:if>
    </aura:if>
</aura:component>