                                                            data-href="{!v.featureSnippet.href}" target="_blank" rel="noopener noreferrer"
                                                            onclick="{!c.runScriptMethod}" data-Id="{!v.featureSnippet._id}" data-Rank="0"
                                                            data-Sub="{!v.featureSnippet.highlight.TitleToDisplayString[0]}" data-url="{!v.featureSnippet.href}"
                                                            data-Type="{!v.featureSnippet.objName}" data-Index="{!v.featureSnippet.sourceName}"
                                                            data-Autotuned="{!v.featureSnippet.autotuned}"
                                                            data-trackAnalytics="{!v.featureSnippet.trackAnalytics}">
                                                            {!v.featureSnippet.href}
                                                        </a>
                                                    </div>
                                                    <aura:if isTrue="{!if(v.featureSnippet.metadata &amp;&amp; v.featureSnippet.metadata.length > 0,true,false)}">
                                                        <div class="su__su__featureSnippet-meta font-12">
                                                            <div class="su__meta-item su__d-flex su__flex-wrap su__align-content-between su__mt-2 font-12">
                                                                <aura:iteration items="{!v.featureSnippet.metadata}" var="meta" indexVar="ind">
                                                                    <aura:if isTrue="{!if(meta.value.length > 0 &amp;&amp; meta.key != 'Tag',true,false)}">
                                                                        <div class="su__meta-date su__word-break">
                                                                            <div class="su__meta-row su__mb-1 su__loading-view">
                                                                                <span class="metaDataKey su__font-bold su__color-blue su__mr-2 su__rtlmr-0 su__rtlml-2 su__loading-view">
                                                                                    {!if(meta.key == 'post_time', 'Created Date', meta.key)}
                                                                                </span>
                                                                                <span class="metaDataKey">&lrm;:&lrm;</span>
                                                                                <aura:if isTrue="{!if(meta.key == 'post_time',true,false)}">
                                                                                    <aura:iteration items="{!meta.value}" var="metadataVal">
                                                                                        <ui:outputDate value="{!metadataVal}"
                                                                                            format="EEE dd MMM yyyy / hh:mm a" />
                                                                                    </aura:iteration>
                                                                                    <aura:set attribute="else">
                                                                                        <aura:iteration items="{!meta.value}" var="metadataVal"
                                                                                            indexVar="singleVal">
                                                                                            <aura:if isTrue="{!singleVal == 0}">
                                                                                                <span class="su__color-lgray su__mr-2 su__rtlmr-0 su__rtlml-2 su__loading-view">{!metadataVal}</span>
                                                                                            </aura:if>
                                                                                        </aura:iteration>
                                                                                    </aura:set>
                                                                                </aura:if>
                                                                            </div>
                                                                        </div>
                                                                    </aura:if>
                                                                </aura:iteration>
                                                                <aura:iteration items="{!featureSnippet.metadata}" var="meta" indexVar="ind">
                                                                    <aura:if isTrue="{!if(meta.value.length > 0 &amp;&amp; meta.key == 'Tag', true, false)}">
                                                                        <div class="su__meta-row su__mb-1 su__loading-view">
                                                                            <aura:if isTrue="{!if(meta.key == 'Tag' , true, false)}">
                                                                                <span class="metaDataKey su__font-bold su__color-blue su__mr-2 su__rtlmr-0 su__rtlml-2 su__loading-view">
                                                                                    {!if(meta.key == 'Tag', meta.key)}
                                                                                </span>
                                                                                <span class="metaDataKey">&lrm;:&lrm;</span>
                                                                                <span class="su__color-black su__tags su__radius-3 su__mr-2 su__rtlmr-0 su__rtlml-2 su__tags-line-height su__loading-view">
                                                                                    {!meta.valueString}
                                                                                </span>
                                                                            </aura:if>
                                                                        </div>
                                                                    </aura:if>
                                                                </aura:iteration>
                                                            </div>
                                                        </div>
                                                    </aura:if>
                                                    <div class="{! if( v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length, 'su__featureSnippet-right su__d-flex su__flex-column su__featured-thumbnail', 'su__featureSnippet-right su__d-flex su__flex-column su__w-80px' )}">
                                                        <div class="su__position-relative">
                                                            <aura:if isTrue="{!!v.featuredResponseRecorded}">
                                                                <div class="su__d-flex su__w-100 su__feedback-icon-above su__zindex-1">
                                                                    <div class="su__d-flex su__pt-2 su__pr-2">
                                                                        <span class="su__featured-feedback su__cursor su__loading-view su__mr-2" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="0">
                                                                            <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-down.png'}" class="ab-testing-btn" alt="Not Useful" />
                                                                        </span>
