                                                                    <div class="{!data.isCollapsed? 'su__collapse su__d-flex su__w-100 su__loading-view': 'su__d-inline su__w-100 su__loading-view'}">
                                                                        <aura:if isTrue="{!(!v.hideSummary)}">
                                                                            <aura:if isTrue="{!if(data.highlight.SummaryToDisplay.length > 0, true,false)}">
                                                                                <div class="{!data.isCollapsed? 'su__text-truncate': 'su__d-inline su__text-normal'}">
                                                                                    <aura:if isTrue="{!if(v.showSummary, true,false)}">
