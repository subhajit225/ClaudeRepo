                                                                <aura:if isTrue="{!if(!item.response, true, false)}">
                                                                    <div class="su__d-flex su__w-100 su__feedback-icon-above su__position-absolute su__zindex-1">
                                                                        <div class="su__feedback-row su__d-flex su__pt-2 su__pr-2">
                                                                            <span class="su__featured-feedback su__cursor su__loading-view su__mr-2" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="0" data-featuredSnippet="true" data-index="{!indexVar}">
                                                                                <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-down.png'}" class="ab-testing-btn" alt="Not Useful" />
                                                                            </span>
                                                                            <span class="su__featured-feedback su__cursor su__loading-view" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="1" data-featuredSnippet="true" data-index="{!indexVar}">
                                                                                <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-up.png'}" class="ab-testing-btn" alt="Useful" />
                                                                            </span>
                                                                        </div>
                                                                    </div>
                                                                </aura:if>
                                                                <aura:if isTrue="{!if(item.response &amp;&amp; item.timeoutResponse, true, false)}">
                                                                    <div class="su__feedback-thankyou su__feedback-icon-above su__position-absolute su__right-0 su__zindex-1 su__loading-view">
                                                                        <div class="su__flex-vcenter su__font-12">
                                                                            <span class="su__thankyou-text su__whitespace-no su__loading-view">
                                                                                {!v.finalLang.Thank_you_for_your_response ? v.finalLang.Thank_you_for_your_response : 'Thank you for your response'}!
                                                                            </span>
                                                                        </div>
                                                                    </div>
                                                                </aura:if>
                                                            </div>
                                                            <a href="{!item.href || item.video_url}" data-href="{!item.href || item.video_url}" target="_blank"
                                                                rel="noopener noreferrer" onclick="{!c.runScriptMethod}" data-Id="{!v.featureSnippet._id}"
                                                                data-Rank="{!indexVar}" data-Sub="{!item.title[0]}" data-url="{!item.href || item.video_url}" data-Type="{!v.featureSnippet.objName}"
                                                                data-Index="{!v.featureSnippet.sourceName}" data-Autotuned="{!v.featureSnippet.autotuned}"
                                                                data-trackAnalytics="{!v.featureSnippet.trackAnalytics}">
                                                                <div class="su__featured-thumbnail su__loading-view su__position-relative">
                                                                    <aura:if isTrue="{!if(item.thumbnail,true,false)}">
                                                                        <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/play_arrow.svg'}" class="su__video-thumbnail-play" />
                                                                    </aura:if>
                                                                    <img src="{!item.image_urls || item.thumbnail}" class="su__img-featured"
                                                                        alt="{!item.alt_attributes}" />
                                                                </div>
                                                                <div class="su__href-txt su__text-decoration su__color-lgray font-12 su__font-italic su__loading-view">
                                                                    {!item.href || item.video_url}
                                                                </div>
                                                            </a>
                                                        </div>
                                                    </aura:iteration>
                                                </div>
                                            </aura:if>
                                            <aura:if isTrue="{!if(v.featureSnippet &amp;&amp; !v.featureSnippet.steps &amp;&amp; v.featureSnippet.questionAnswer.answer == null &amp;&amp; v.featureSnippet.questionAnswer.short_summary == null &amp;&amp; v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length == 1, true, false)}">
                                                <div class="su__fs-media-content su__mb-3 su__bg-white su__sm-shadow">
                                                    <div class="su__fs-inner-media su__d-md-flex su__overflow-hide">
                                                        <div class="su__w-25 su__featured-mobile-view-100">
                                                            <div class="su__featured-thumbnail su__loading-view">
                                                                <a class="su__d-flex su__position-relative"
                                                                    href="{!v.featureSnippet.multiMedia[0].href || v.featureSnippet.multiMedia[0].video_url}"
                                                                    data-href="{!v.featureSnippet.multiMedia[0].href || v.featureSnippet.multiMedia[0].video_url}"
                                                                    target="_blank" rel="noopener noreferrer" onclick="{!c.runScriptMethod}"
                                                                    data-Id="{!v.featureSnippet._id}" data-Rank="0" data-Sub="{!v.featureSnippet.multiMedia[0].title[0]}"
                                                                    data-url="{!v.featureSnippet.href}" data-Type="{!v.featureSnippet.objName}"
                                                                    data-Index="{!v.featureSnippet.sourceName}" data-Autotuned="{!v.featureSnippet.autotuned}"
                                                                    data-trackAnalytics="{!v.featureSnippet.trackAnalytics}">
                                                                    <aura:if isTrue="{!if(v.featureSnippet.multiMedia[0].thumbnail,true,false)}">
                                                                        <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/play_arrow.svg'}" class="su__video-thumbnail-play" />
                                                                    </aura:if>
                                                                    <img src="{!v.featureSnippet.multiMedia[0].image_urls || v.featureSnippet.multiMedia[0].thumbnail}"
                                                                        class="su__img-featured" role="img" />
                                                                </a>
                                                            </div>
                                                        </div>
                                                        <div class="su__d-flex su__flex-column su__w-75 su__p-3 su__word-break su__featured-mobile-view-100">
                                                            <span class="su__mb-1">
                                                                <a class="su__text-decoration su__d-block font-16 su__text-black hover-color-dblue su__font-bold su__text-truncate su__loading-view"
                                                                    href="{!v.featureSnippet.multiMedia[0].href || v.featureSnippet.multiMedia[0].video_url}"
                                                                    data-href="{!v.featureSnippet.multiMedia[0].href || v.featureSnippet.multiMedia[0].video_url}"
                                                                    target="_blank" rel="noopener noreferrer" onclick="{!c.runScriptMethod}"
                                                                    data-Id="{!v.featureSnippet._id}" data-Rank="0" data-Sub="{!v.featureSnippet.multiMedia[0].title[0]}"
                                                                    data-url="{!v.featureSnippet.href}" data-Type="{!v.featureSnippet.objName}"
                                                                    data-Index="{!v.featureSnippet.sourceName}" data-Autotuned="{!v.featureSnippet.autotuned}"
                                                                    data-trackAnalytics="{!v.featureSnippet.trackAnalytics}">
                                                                    <aura:unescapedHtml value="{!v.featureSnippet.highlight.TitleToDisplay[0]}"></aura:unescapedHtml>
                                                                </a>
                                                            </span>
                                                            <div class="su__href-txt su__text-decoration su__color-lgray font-12 su__font-italic su__text-truncate su__loading-view">
                                                                {!v.featureSnippet.href}
                                                            </div>
                                                            <div class="su__featureSnippet-response">
                                                                <aura:if isTrue="{!!v.featuredResponseRecorded}">
                                                                    <div class="su__d-flex su__w-100 su__mt-2">
                                                                        <div class="su__d-flex">
                                                                            <span class="su__featured-feedback su__cursor su__loading-view su__mr-2" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="0">
                                                                                <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-down.png'}" class="ab-testing-btn" alt="Not Useful" />
                                                                            </span>
                                                                            <span class="su__featured-feedback su__cursor su__loading-view" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="1">
                                                                                <img src="{!v.scConfigObj.client_url+v.uid+'/Assets/thumbs-up.png'}" class="ab-testing-btn" alt="Useful" />
                                                                            </span>
                                                                        </div>
                                                                    </div>
                                                                </aura:if>
                                                                <aura:if isTrue="{!if(v.featuredResponseRecorded &amp;&amp; v.timeoutResponse, true, false)}">
                                                                    <div class="su__mt-2 su__position-relative su__loading-view">
                                                                        <div class="su__flex-vcenter su__font-12">
                                                                            <span class="su__thankyou-text su__whitespace-no su__loading-view">
                                                                                {!v.finalLang.Thank_you_for_your_response ? v.finalLang.Thank_you_for_your_response : 'Thank you for your response'}!
                                                                            </span>
                                                                        </div>
                                                                    </div>
                                                                </aura:if>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </aura:if>
                                            <!-- featured snippts end  -->
                                            <!-- Code ends here -->
                                            <div class="{!if(v.metaStatus || v.relatedTilesStatus, 'su__d-flex su__d-md-flex su__d-xs-block su__d-sm-block su__align-items-start su__align-content-start  su__knowledgeGraph-show' , 'su__w-100 su__content-view-row  su__sm-fullwidth')}">
                                                <div class="{!if(v.listview, 'su__content-view su__grid-mobile su__list-views su__mb-3 su__flex-wrap su__sm-fullwidth' , 'su__content-view su__grid-mobile su__my-2 su__flex-wrap su__sm-fullwidth su__grid-content')}">
                                                    <aura:iteration items="{!v.responseListData}" var="data" indexVar="indexVar">
                                                        <div class="su__list-items su__bg-white su__sm-shadow su__radius-1 su__position-relative su__p-3 su__mb-3">
                                                            <aura:if isTrue="{!!v.listview}">
                                                                <div class="{!if(v.loadingResult == 1, if(!!v.listview, if((v.metaStatus || v.relatedTilesStatus) == true, 'su__thumbnail-img su-icon', 'su__thumbnail-img'),'su__thumbnail-img su__mb-2 su__loading-view'),'su__thumbnail-img su__mb-2 su__loading-view')}">
                                                                    <aura:if isTrue="{!if(data.imageSource, true,false)}">
                                                                        <img class="su-thumb" src="{!data.imageSource}" />
                                                                    </aura:if>
                                                                </div>
                                                            </aura:if>
                                                            <div class="su__thumbnail-mobile su__d-md-none su__d-xs-block ">
                                                                <div class="su__m-thumbnail-img su__loading-view">
                                                                    <aura:if isTrue="{!if(data.imageSource, true,false)}">
                                                                        <img class="su-thumb" src="{!data.imageSource}" />
                                                                    </aura:if>
                                                                </div>
                                                            </div>
                                                            <div class="su__list-item-row su__media">
                                                                <div class="su__listview-thumbnail">
