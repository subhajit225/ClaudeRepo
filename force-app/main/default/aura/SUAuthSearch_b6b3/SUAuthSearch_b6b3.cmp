                                                                                                {!v.finalLang.Show_less ? v.finalLang.Show_less : 'Show less'}</span>
                                                                                            <span id="{!indexVar}" onclick="{!c.toggleCollapse}" class="{!!data.isCollapsed? 'su__pl-1 font-12 su__color-blue su__cursor su__my-1 su__mb-2 su__text-nowrap': 'su__d-none'}">
