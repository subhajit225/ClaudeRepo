                                                                                            <aura:iteration indexVar="index" items="{!data.highlight.ShortSummary}" var="summary">
                                                                                                <span class="{!data.isCollapsed? 'su__list-item-desc su__my-1 su__font-regular su__mb-2 font-12 su__word-break su__loading-view su__text-normal': 'su__list-item-desc su__my-1 su__font-regular su__mb-2 font-12 su__text-normal su__word-break su__loading-view'}">
                                                                                                    <aura:unescapedHtml value="{!summary}"></aura:unescapedHtml>
                                                                                                </span> 
                                                                                            </aura:iteration>
                                                                                        </aura:if>
