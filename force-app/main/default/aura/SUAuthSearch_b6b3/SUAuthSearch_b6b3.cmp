                                                                        </aura:if>
                                                                        <img src="{!v.featureSnippet.multiMedia[0].image_urls || v.featureSnippet.multiMedia[0].thumbnail}"
                                                                            class="su__img-featured" alt="{!v.featureSnippet.multiMedia[0].alt_attributes}" />
                                                                    </a>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                    </div>
                                                </div>
                                                <!-- mobile -->
                                                <div class="su__FeaturedSnippet su__fs-bg-blue su__radius-1 su__position-relative su__mb-3 su__p-3 su__d-md-flex su__overflow-hide su__w-100 su__md-block su__display-none">
                                                    <div class="su__featureSnippet-title font-18 su__font-bold su__text-truncate su__mb-2 su__loading-view">
                                                        {!v.featureSnippet.questionAnswer.answer}
                                                    </div>
                                                    <div class="su__featureSnippet-left su__d-flex su__overflow-hide su__mt-2 su__mb-2">
                                                        <div class="{! if( v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length, 'su__featureSnippet-left su__d-flex su__flex-1 su__flex-column su__overflow-hide su__pr-2 su__w-70', 'su__featureSnippet-left su__d-flex su__flex-1 su__flex-column su__overflow-hide' )}">
                                                            <span class="su__text-black su__font-12 su__d-flex su__font-regular su__loading-view">
                                                                {!v.featureSnippet.questionAnswer.short_summary}
                                                            </span>
                                                        </div>
                                                        <div class="{! if( v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length, 'su__featureSnippet-right su__d-flex su__flex-column su__w-30', 'su__featureSnippet-right su__d-flex su__flex-column' )}">
                                                            <aura:if isTrue="{!if(v.featureSnippet.multiMedia &amp;&amp; v.featureSnippet.multiMedia.length != 0,true,false)}">
                                                                <div class="su__featureSnippet-right">
                                                                    <div class="su__min-w-30 su__loading-view">
