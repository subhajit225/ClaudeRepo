                                                                                                <span class="{!data.isCollapsed? 'su__list-item-desc su__my-1 su__font-regular su__mb-2 font-12 su__word-break su__text-normal su__loading-view': 'su__list-item-desc su__my-1 su__font-regular su__mb-2 font-12 su__word-break su__text-normal su__loading-view'}">
                                                                                                    <aura:unescapedHtml value="{!summary}"></aura:unescapedHtml>
                                                                                                </span>
                                                                                            </aura:iteration>
                                                                                        </aura:if>
