<design:component >
	<design:attribute name="searchString" label="SearchString" default="{!searchString}"></design:attribute>
	<design:attribute name="pagesize" label="Enter default page size"
     description="Enter how many records you want to display in autosuggest. Default value is 10"></design:attribute>
    <design:attribute name="PlaceHolderText" label="Place Holder Value" description="It is used to define the place holder value for searchbox. Default is: search..."></design:attribute>
	<design:attribute name="advanceFilterData" label="Content source type" description="It is used to define the content source type for which we want to restrict the result."></design:attribute>
    <design:attribute name="advanceFilterValue" label="Content source value" description="It is used to define the content source value for which we want to restrict the result.For example:idea,article"></design:attribute>
	<design:attribute name="showMetadata" label="Show metadata in the autosuggestion results" description="This checkbox is designed to restrict and show the metadata in the autosuggestion results."></design:attribute>
    <design:attribute name="showResultbody" label="Show body in autosuggestion results" description="This checkbox is designed to restrict and show the body in the autosuggestion results."></design:attribute>
	<design:attribute name="isEnableTitleRedirect"  label="Enable autosuggest title click" description="Title click opens its detail page.">
    </design:attribute>
</design:component>