<design:component >
  <design:attribute name="modalOpen" label="Show content detail in modal pop-up" description="If this box is selected then content will be displayed in pop-up otherwise on next page"></design:attribute>
  <design:attribute name="pagesize" label="Enter default page size" description="Enter how many records you want to display on page. Default value is 10"></design:attribute>
  <design:attribute name="pageHeaderTitle" label="Enter Page Header Title" description="For example: view suggested articles "></design:attribute>
  <design:attribute name="gotoSearchPageText" label="Enter here message to redirect on global search page" description="For example: Goto global search page."></design:attribute>
  <design:attribute name="noResultFoundMsg" label="Enter here message to show when no matching results found" description="Default value is: Sorry, no result found."></design:attribute>
  <design:attribute name="showMetadata" label="Show metadata in the list results" description="This checkbox is designed to restrict and show the metadata in the list results. Default is: false">
  </design:attribute>
  <design:attribute name="showResultbody" label="Show body in result" description="This checkbox is designed to restrict and show the content in the result list. Default is: true">
  </design:attribute>
  <design:attribute name="openNewTab" label="Open search result page in a new tab." description="If this box is checked then the search page will load on a new tab for more results on click of 'go to search page link'."></design:attribute>
</design:component>