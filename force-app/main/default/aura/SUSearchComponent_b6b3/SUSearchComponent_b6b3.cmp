<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" controller="SU_Ltng.SULtngController">
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" access="global" />
    <!-- Client Driven Input Variable -->
    <aura:attribute name="selectedTypeFilter" type="String" default="" access="global" />
    <aura:attribute name="advanceFilterData" type="List" access="global" />
    <aura:attribute name="searchString" type="String" access="global" default="" />
    <aura:attribute name="pageSize" type="String" default="10" access="global" />
    <aura:attribute name="defaultSearchPage" type="String" access="global" default="" />
    <aura:attribute name="noSearchResultFoundMsg" type="String" default="Sorry, no results found." access="global" />
    <aura:attribute name="defaultFilterCollapse" type="Boolean" access="global" default="true" />
    <aura:attribute name="listview" type="Boolean" default="true" access="global" />
    <aura:attribute name="contentSourceTab" type="Boolean" default="true" access="global" />
    <aura:attribute name="collapsibleSummary" type="Boolean" access="global" default="true" />
    <!-- Client Driven Input Variable ends here-->
    <aura:attribute name="isCollapsed" type="Boolean" default="false" />
    <aura:attribute name="expandCollapseData" type="string" default="[ + ]" />
    <aura:attribute name="pageSizeAdvFiltr" type="String" default="10" />
    <aura:attribute name="active" type="string" default="all" />
    <aura:attribute name="sortByValues" type="List" />
    <aura:attribute name="sortByCheck" type="String" default="_score" />
    <aura:attribute name="responseListData" type="List" />
    <aura:attribute name="currentCommunityURL" type="String" default="" />
    <aura:attribute name="paginationList" type="List" />
    <aura:attribute name="searchUnifyDownStatus" type="Boolean" default="false" />
    <aura:attribute name="aggregationsData" type="List" />
    <aura:attribute name="narrowSearch" type="Integer" default="1" />
    <aura:attribute name="filterOrder" type="String" default="" />
    <aura:attribute name="originalAggregationsData" type="List" />
    <aura:attribute name="pageNum" type="String" default="1" />
    <aura:attribute name="fromPage" type="Integer" />
    <aura:attribute name="toPage" type="Integer" />
    <aura:attribute name="lastPage" type="String" />
    <aura:attribute name="suggestData" type="String" default="" />
    <aura:attribute name="loadingResult" type="Integer" />
    <aura:attribute name="totalResults" type="Integer" default="0" />
    <aura:attribute name="resultImgUrl" type="String" />
    <aura:attribute name="errorMessage" type="String" />
    <aura:attribute name="endPoint" type="String" />
    <aura:attribute name="uid" type="String" />
    <aura:attribute name="searchResultTime" type="String" />
    <aura:attribute name="currentUserEmail" type="String" default="" />
    <aura:attribute name="customSettingErrorMessage" type="String" />
    <aura:attribute name="commBaseURL" type="String" />
    <aura:attribute name="exactPhrase" type="String" default="" />
    <aura:attribute name="withOneOrMore" type="String" default="" />
    <aura:attribute name="withoutTheWords" type="String" default="" />
    <aura:attribute name="metaStatus" type="Boolean" default="true" />
    <aura:attribute name="relatedTilesStatus" type="Boolean" default="true" />
    <aura:attribute name="meta_data" type="Object" />
    <aura:attribute name="knowledgeGraphResponseRecorded" type="Boolean" default="false" />
    <aura:attribute name="featuredResponseRecorded" type="Boolean" default="false" />
    <aura:attribute name="featureSnippet" type="Object" />
    <aura:attribute name="featureSnippetTitle" type="String" />
    <aura:attribute name="featureSnippetSteps" type="List" />
    <aura:attribute name="relatedTiles" type="List" />
    <aura:attribute name="selectedRows" type="List" />
    <aura:attribute name="showClearFiltersButton" type="Boolean" default="false" />
    <aura:attribute name="similarSearchSuggestions" type="List" />
    <aura:attribute name="checkedBookmark" type="Boolean" default="true" />
    <aura:attribute name="count" type="Integer" default="0" />
    <!-- areabookmark -->
    <aura:attribute name="bookmarkSearches" type="List" />
    <aura:attribute name="viewSavePopup" type="Boolean" default="false" />
    <aura:attribute name="viewConfirmPopup" type="Boolean" default="false" />
    <aura:attribute name="bookmarkName" type="String" default="" />
    <aura:attribute name="query" type="Object" />
    <aura:attribute name="bookmark_clicked" type="Boolean" default="false" />
    <aura:attribute name="bookmark_queryPassed" type="Object" />
    <aura:attribute name="star_clicked" type="Boolean" default="false" />
    <aura:attribute name="disableButton" type="Boolean" default="true" />
    <aura:attribute name="bookmark_list" type="Boolean" default="false" />
    <aura:attribute name="removebookmark" type="Object" />
    <aura:attribute name="initialised" type="Boolean" default="true" />
    <aura:attribute name="selectedStickyFilter" type="List" />
    <aura:attribute name="topFiltersLayoutDiv" type="Boolean" default="false" />
    <aura:attribute name="showFilterLargeDiv" type="Boolean" default="false" />
    <aura:attribute name="showSticky" type="Boolean" default="false" />
    <aura:attribute name="domWidth" type="Boolean" default="false" />
    <!-- areabookmark -->
    <aura:attribute name="stickyFilter_label" type="List" />
    <aura:attribute name="activeSticky" type="string" />
    <aura:attribute name="currentClickedOrder" type="Object" />
    <aura:attribute name="viewMore" type="Boolean" default="false" />
    <aura:attribute name="searchTipsTab" type="Boolean" default="false" />
    <aura:attribute name="bookmarkTab" type="Boolean" default="false" />
    <aura:attribute name="viewMoreTab" type="Boolean" default="false" />
    <aura:attribute name="showScroll" type="Boolean" default="false" />
    <aura:attribute name="facetsList" type="List" />
    <aura:attribute name="customizeDiv" type="Boolean" default="false" />
    <aura:attribute name="filterToRight" type="Boolean" default="false" />
    <aura:attribute name="alignFilters" type="Boolean" default="false" />
    <aura:attribute name="hideTitle" type="Boolean" default="false" />
    <aura:attribute name="hideSummary" type="Boolean" default="false" />
    <aura:attribute name="hideUrl" type="Boolean" default="false" />
    <aura:attribute name="hideIcon" type="Boolean" default="false" />
    <aura:attribute name="hideMetadata" type="Boolean" default="false" />
    <aura:attribute name="toggleDisplayKeys" type="List" />
    <aura:attribute name="hiddenKeys" type="List" />
    <aura:attribute name="hiddenFacets" type="List" />
    <aura:attribute name="accessKeyValue" type="string" />
    <aura:attribute name="activeTabOrder" type="Integer" />
    <aura:attribute name="activeTabIndex" type="string" />
    <aura:attribute name="hideData" type="Boolean" default="false" />
    <aura:attribute name="setFlag" type="Boolean" default="false" />
    <aura:attribute name="applyChanges" type="Boolean" default="false" />
    <aura:attribute name="defaultTab" type="string" default="all" />
    <aura:attribute name="customize" type="Boolean" default="false" />
    <aura:attribute name="resetType" type="Boolean" default="false" />
    <aura:attribute name="tabIndex" type="Boolean" default="false" />
    <aura:attribute name="confirmReset" type="Boolean" default="false" />
    <aura:attribute name="activeTabFunc" type="Boolean" default="false" />
    <aura:attribute name="contentSourceExists" type="Boolean" default="false" />
    <aura:attribute name="filtersArray" type="List" />
    <aura:attribute name="emptyResponseAggregations" type="List" />
    <aura:attribute name="values" type="Object" />
    <aura:attribute name="valuesBackup" type="Object" />
    <aura:attribute name="dragid" type="Integer" access="private" />
    <aura:attribute name="dropId" type="Integer" access="private" />
    <aura:handler name="init" value="{!this}" action="{!c.doinit}" />
    <aura:attribute name="defaultPageSize" type="String" default="10" />
    <aura:attribute name="advertisement" type="String" />
    <aura:attribute name="mergedArray" type="List" />
    <aura:attribute name="refine_search" type="String" default="Refine Search" />
    <aura:attribute name="save_bookmark" type="String" default="Save Bookmark" />
    <aura:attribute name="add_bookmark" type="String" default="Add Bookmark" />
    <aura:attribute name="close" type="String" default="Close" />
    <aura:attribute name="title_bookmark" type="String" default="Title for this bookmark" />
    <aura:attribute name="filter" type="String" default="Filter" />
    <aura:attribute name="exact_phrase" type="String" default="With the exact phrase" />
    <aura:attribute name="one_or_more" type="String" default="With one or more words" />
    <aura:attribute name="without_words" type="String" default="Without the words" />
    <aura:attribute name="mobile" type="String" default="Mobile Advance search" />
    <aura:attribute name="list_view" type="String" default="List View" />
    <aura:attribute name="grid_view" type="String" default="Grid View" />
    <aura:attribute name="result_per_page" type="String" default="Results per page" />
    <aura:attribute name="result" type="String" default="results" />
    <aura:attribute name="componentLoaded" type="Boolean" />
    <aura:attribute name="directionText" type="String" default="LTR" />
    <aura:attribute name="languageSelectedByUser" type="String" />
    <aura:attribute name="translator" type="object" access="global" />
    <aura:attribute name="selectedLanguages" type="object" access="global" />
    <aura:method name="translateText" action="{!c.translateText}" />
    <aura:method name="saveLangToLocal" action="{!c.saveLangToLocal}" />
    <aura:method name="typeSelect" action="{!c.typeSelect}">
        <aura:attribute name="itemRemoved" type="Object" />
    </aura:method>
    <aura:handler name="change" value="{!v.sortByCheck}" action="{!c.sortCall}" />
    <aura:registerEvent name="searchBoxEvent" type="SU_Ltng:fillSearchBox" />
    <aura:method name="searchResult" action="{!c.searchResultFunction}">
        <aura:attribute name="data" type="List" />
        <aura:attribute name="pageResult" type="String" />
    </aura:method>
    <c:SUSearchUnifyHeaderDynamic aura:id="SuAnalytics" />
    <aura:if isTrue="{!v.componentLoaded}">
        <!--mainUI--><div  class="slds-grid slds-wrap" aura:id="su_scrollWrapper">
    <aura:if isTrue="{!v.setFlag}">
        <img class="su__load-img" src="{!v.endPoint+'/resources/Assets/su-results-loader.gif'}" />
    </aura:if>
    <aura:if isTrue="{!v.setFlag == false}">
        <div id="su_searchUnifyContainer1" onscroll="{!c.scroll}" class="{!if(v.loadingResult == 1, 'su_component su__w-100 su__content_section su__bg-gray-50','su__w-100 su__content_section su__bg-gray-50 slds-transition-hide su__loading')}">
            <div class="su-popup-row" aura:id="popup-row">
                <!-- Add bookmark popups-->
                <!-- <aura:if isTrue="{!v.viewSavePopup}"> -->
                <div class="{!if(v.viewSavePopup,'su__anim-fadeindown su__bookmark-popup su__position-fixed su__shadow-lg su__bg-white su__radius-1 su__mx-auto su__zindex-2 su__d-block','visibilityHidden su__position-absolute')}">
                    <div class="su__w-100 ">
                        <div class="su__bookmark-popup-title su__p-2 su__flex-vcenter su__bg-blue-grd">
                            <div class="su__p-2 su__bg-white-circle su__radius-50">
                                <div class="bg-Save_book_mark su-bookmark-info" title="{!v.save_bookmark}"></div>
                            </div>
                            <div class="su__bookmark-title su__flex-1 su__ml-2 su__rtlml-0 su__rtlmr-2"><label class="font-16 su__text-white">
                                Add Bookmarks </label>
                            </div>
                            <div class="su__close-icon su__cursor" onclick="{!c.viewSavePopup_toggle}">
                                <div class="bg-white_close_icon su-bookmark-info"  title="{!v.close}"></div>
                            </div>
                        </div>
                        <div class="su__bookmark-inner su__p-3 su__bg-white">
                            <div class="su__no-bookmark su__my-3 su__my-sm-1 su__text-center">
                                <div class="bg-add_bookmark su-bookmark-info" title="{!v.add_bookmark}"></div>
                            </div>
                            <div class="su__w-100 su__my-3 su__text-left">
                                <ui:inputText class="su__form-control su__bookmark-input" placeholder="{!v.title_bookmark}" value="{!v.bookmarkName}" updateOn="keyup" keyup="{!c.validateName}" />
                                <p class="su__d-none font-10 su__text-black su__mb-0">
                                    You can bookmark upto 20 searches
                                </p>
                            </div>
                            <div class="su__bookmark-btn su__w-100">
                                <aura:if isTrue="{!or(v.bookmarkSearches.length == 20, v.disableButton)}">
                                    <button class="su__btn su__bg-blue-grd font-12 su__w-100 su__text-white su__cursor su__bookmark-save" disabled="disabled">
                                        Save</button>
                                    <aura:set attribute="else">
                                        <button onclick="{!c.saveToLocal}" class="su__btn su__bg-blue-grd su__w-100 su__text-white su__cursor su__bookmark-save">
                                            Save</button>
                                    </aura:set>
                                </aura:if>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="{!if(v.viewSavePopup, 'su__bg-overlay', 'su__d-none')}" onclick="{!c.viewSavePopup_toggle}" role="button"></div>
                <!-- </aura:if> -->
                <!-- Add bookmark popups end-->
                <!-- save and delete bookmark popups-->
                <div aura:id="bookmark-section" class="{!if(v.bookmark_list,'su__anim-fadeindown su__bookmark-popup su__position-fixed su__shadow-lg su__bg-white su__radius-1 su__mx-auto su__zindex-2 su__d-block','visibilityHidden su__position-absolute')}">
                    <div class="su__w-100 ">
                        <div class="su__bookmark-popup-title su__p-2 su__flex-vcenter su__bg-blue-grd">
                            <div class="su__p-2 su__bg-white-circle su__radius-50">
                                <div class="bg-Save_book_mark su-bookmark-info" title="{!v.save_bookmark}"></div>
                            </div>
                            <div class="su__bookmark-title su__flex-1 su__ml-2 su__rtlml-0 su__rtlmr-2"><label class="font-16 su__text-white">
                                Saved Bookmarks </label>
                            </div>
                            <div class="su__close-icon su__cursor" onclick="{!c.closeBookmark}">
                                <div class="bg-white_close_icon su-bookmark-info" title="{!v.close}"></div>
                            </div>
                        </div>
                        <div class="su__bookmark-inner su__bg-white">
                            <aura:if isTrue="{!v.bookmarkSearches.length}">
                                <div class="su__bookmark-ul su__miniscroll">
                                    <aura:iteration items="{!v.bookmarkSearches}" var="result">
                                        <div class="su__flex-vcenter su__px-3 su__py-2 su__mb-1 su__border-b su__word-break">
                                            <div class="su__flex-1 su__cursor">
                                                <a class="sidebar-bookmark font-12" onclick="{!c.bookmarkClicked}" data-query="{!result.href}">
                                                    {!result.title}</a>
                                            </div>
                                            <div class="su__ml-3 su__outline-none su__cursor su__position-relative su__filter-checkbox su__loading-view">
                                                <ui:inputCheckbox click="{!c.onCheck}" class="su__toggle-input su__position-absolute su__cursor" aura:id="bookmark-box" name="{!result.title}" text="{!result.href}" />
                                                <label class="su__toggle-label su__d-inline-flex su__cursor su__loading-view-border font-12"><span class="su__toggle__text"></span></label>
                                            </div>
                                        </div>
                                    </aura:iteration>
                                </div>
                                <div class="su__bookmark-btn su__flex-vcenter su__justify-content-between su__px-3 su__py-2 ng-scope">
                                    <button class="su__btn su__p-2 su__bg-gray-40 su__radius-1 su__bookinput-h font-md-12" onclick="{!c.deleteBookmarks}">
                                        Remove Bookmark</button>
                                </div>
                                <aura:set attribute="else">
                                    <div class="su__text-center">
                                        <div class="su__no-bookmark su__py-4 su__py-sm-1">
                                            <div class="su-bookmark-info bg-No_book_mark"></div>
                                        </div>
                                        <p class="su__my-3 font-32 su__text-black su__font-bold su__line-height-n">
                                            Oops! </p>
                                        <p class="font-14 su__my-2 su__pb-3">
                                            There is nothing here. Zilch. Return to search<br />
                                            and create your first bookmark.</p>
                                    </div>
                                </aura:set>
                            </aura:if>
                        </div>
                    </div>
                </div>
                <div class="{!if(v.bookmark_list, 'su__bg-overlay', 'su__d-none')}" onclick="{!c.closeBookmark}" role="button"></div>
            </div>
            <!-- areabookmark end-->
            <!-- search tabs start -->
            <aura:if isTrue="{!v.contentSourceTab}">
                <div class="suHideInSmallView su__tabing su__bg-white su__radius-1">
                    <div class="su__tabing-row su__flex-vcenter su__flex-nowrap su__mb-3 su__my-sm-1 su__mt-1 su__border-b su__overflow-x su__miniscroll su__miniscroll-black">
                        <aura:iteration items="{!v.aggregationsData}" var="filter">
                            <aura:if isTrue="{!and(filter.values.length > 0, filter.key == '_index')}">
                                <div class="su__tabing-list font-14 su__text-center su__position-relative su__loading-view">
                                    <div class="{!if(v.active=='all','indexData su__tab-active su__cursor su__text-nowrap','indexData su__tabing-item su__text-nowrap su__cursor')}" accessKey="all" order="{!filter.order}" onclick="{!c.indexSearchCall}">
                                        All Content
                                    </div>
                                </div>
                                <aura:iteration items="{!filter.values}" var="filterType">
                                    <div class="su__tabing-list font-14 su__text-center su__position-relative su__loading-view">
                                        <div class="{!if(v.active==filterType.Contentname,'indexData su__tab-active su__tabing-item su__cursor su__text-nowrap','indexData su__tabing-item su__cursor su__text-nowrap')}" accessKey="exceptall" order="{!filter.order}" id="{!filterType.Contentname}" onclick="{!c.indexSearchCall}">
                                            {!filterType.displayName || filterType.Contentname}
                                        </div>
                                    </div>
                                </aura:iteration>
                            </aura:if>
                        </aura:iteration>
                    </div>
                </div>
            </aura:if>
            <div class="{!if(v.customizeDiv,'su__d-block su__anim-fadeindown su__facetPrefrence','visibilityHidden su__position-absolute')}">
                <div class="su__editClient font-14 su__p-3 su__md-pd-10 su__bg-white su__radius-1 su__position-fixed">
                    <div class="editDiv">
                        <span class="su-edit su__color-black su__font-regular">
                            Edit Page Layout</span>
                        <span class="closeCustomizeDiv su__float-right su__cursor">
                            <img src="{!v.endPoint+'/resources/Assets/close.svg'}" onclick="{!c.discardChanges}" style="height:12px;" />
                        </span>
                        <div class="su__reset su__float-right su__mr-3">
                            <span class="apply su-btn-blue su__radius-0 su__cursor su__mr-2 su__p-2" onclick="{!c.toggleConfirmationDialog}">
                                Reset</span>
                            <span class="apply su__bg-blue-grd su__radius-0 su__cursor su__p-2 su__text-white" onclick="{!c.applyTheme}">
                                Apply Changes</span>
                        </div>
                    </div>
                    <div class="su__pb-4 su__pt-3">
                        <div class="su__col-3 su__d-inline-block">
                            <div class="resultSection su__font-regular font-14 su__mb-3">
                                Rearrange Facets
                            </div>
                            <div id="filterList" class="collapse in su__pr-3 su__overflow-auto su__miniscroll rearrangeFacets">
                                <div class="droparea" ondragover="{!c.cancel}" ondragenter="{!c.cancel}" ondrop="{!c.drop}">
                                    <aura:iteration items="{!v.values}" indexVar="index" var="filters">
                                        <aura:if isTrue="{!and(filters.count > 0, filters.label != 'Index')}">
                                            <div class="su-row font-md-12 su__w-100 su__flex-vcenter" draggable="true" ondragstart="{!c.dragstart}" data-drag-id="{!index}">
                                                <span class="su__text-truncate">{!filters.label}</span>
                                                <span class="toggleDisplay" id="hideContent">
                                                    <div class="{!if(!filters.hideEye,'su__d-block','visibilityHidden su__position-absolute')}">
                                                        <span class="toggleDisplay eyeIcon su__float-right" id="hideContent">
                                                            <div title="{!'Hide ' + filters.label}" data-query="{!filters.label}" class="bg-show su-img-hide" onclick="{!c.hideFacets}"></div>
                                                        </span>
                                                    </div>
                                                    <div class="{!if(filters.hideEye,'su__d-block','visibilityHidden su__position-absolute')}">
                                                        <span class="toggleDisplay eyeIcon su__float-right" id="showContent">
                                                            <div title="{!'Show ' + filters.label}"  data-item="{!filters.label}" class="bg-hide su-img-hide" onclick="{!c.showFacets}"></div>
                                                        </span>
                                                    </div>
                                                </span>
                                            </div>
                                        </aura:if>
                                    </aura:iteration>
                                </div>
                            </div>
                        </div>
                        <div class="su__col-9 su-customize su__float-right">
                            <aura:if isTrue="{!v.contentSourceTab}">
                                <div class="resultSection su__font-regular font-14 su__mb-3">
                                    Pre Select a Tab
                                </div>
                                <div class="facetsSection">
                                    <aura:iteration items="{!v.filtersArray}" var="filter">
                                        <aura:if isTrue="{!and(filter.values.length > 0, filter.key == '_index')}">
                                            <div class="yes su-content-tab">
                                                <div class="{!if(v.defaultTab=='all','indexData font-md-12 su__cursor su-tab-active','font-md-12 su__cursor indexData')}" accessKey="all" order="{!filter.order}" onclick="{!c.activeTab}" id="all">
                                                    All Content
                                                </div>
                                            </div>
                                            <aura:iteration items="{!filter.values}" var="filterType">
                                                <div class="yes su-content-tab">
                                                    <div class="{!if(v.defaultTab==filterType.Contentname,'indexData su__cursor font-md-12 su-tab-active','font-md-12 su__cursor indexData')}" accessKey="exceptall" order="{!filter.order}" id="{!filterType.Contentname}" onclick="{!c.activeTab}">
                                                        <aura:if isTrue="{!filterType.displayName}">
                                                            <c:SULanguages parent="{!this}" child="{!filterType.displayName}" />
                                                        </aura:if>
                                                        <aura:if isTrue="{!if ( !filterType.displayName &amp;&amp; filterType.Contentname, true, false)}">
                                                            <c:SULanguages parent="{!this}" child="{!filterType.Contentname}" />
                                                        </aura:if>
                                                    </div>
                                                </div>
                                            </aura:iteration>
                                        </aura:if>
                                    </aura:iteration>
                                </div>
                            </aura:if>
                            <div class="hideFacets su__pt-3 su__pb-3">
                                <div class="resultSection su__font-regular font-14 su__mb-3">
                                    Search Result
                                </div>
                                <aura:iteration items="{!v.toggleDisplayKeys}" var="item">
                                    <span class="su-display">
                                        <span class="toggleDisplay toggleKey su__font-regular" aura:id="showKeyVal">
                                            {!item.key}
                                        </span>
                                        <aura:if isTrue="{!if(item.hideEye == false,true,false)}">
                                            <span class="toggleDisplay" id="hideContent">
                                                <div data-name="{!item.hideEye}" data-query="{!item.key}" class="bg-show su-img-hide su__cursor" onclick="{!c.hideKey}"></div>
                                            </span>
                                        </aura:if>
                                        <aura:if isTrue="{!if(item.hideEye == true,true,false)}">
                                            <span class="toggleDisplay" id="showContent">
                                                <div data-label="{!item.hideEye}" data-item="{!item.key}" class="bg-hide  su-img-hide su__cursor" onclick="{!c.showKey}"></div>
                                            </span>
                                        </aura:if>
                                    </span>
                                </aura:iteration>
                            </div>
                            <div class="su__list-items su__bg-white su__sm-shadow su__radius-1 su__position-relative su__p-3 su__mb-4">
                                <div class="su__list-item-img su-icon su__d-inline-block su__d-xs-none su__mr-2 su__rtlml-2 su__rtlmr-0 su__loading-view">
                                    <aura:if isTrue="{!if(!v.toggleDisplayKeys[4].hideEye, true,false)}">
                                        <div class="{!if(v.loadingResult == 1, 'savedBookmarks su_ResultImage su__left-item-img','su_displayHide')}"></div>
                                    </aura:if>
                                </div>
                                <div class="su__list-item-text su__media-body su__overflow-hide su__word-break">
                                    <aura:if isTrue="{!if(!v.toggleDisplayKeys[0].hideEye, true,false)}">
                                        <h5 class="su__list-item-title su__flex-vcenter su__mw-100 su__m-0 su__text-decoration su__text-black su__text-truncate font-14 su__font-bold">
                                            What is Lorem Ipsum?
                                        </h5>
                                    </aura:if>
                                    <aura:if isTrue="{!if(!v.toggleDisplayKeys[2].hideEye, true,false)}">
                                        <div class="su-url-citation-div">
                                            <cite class="{!if(v.loadingResult == 1, 'su__text-decoration su__color-blue su__font-italic','su_loadingDisguise')}">https://www.lipsum.com/</cite>
                                        </div>
                                    </aura:if>
                                    <aura:if isTrue="{!if(!v.toggleDisplayKeys[1].hideEye, true,false)}">
                                        <span class="su__list-item-desc su__w-100 su__my-1 su__font-regular su__mb-2 font-12 su__loading-view su__word-break">
                                            Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s, when an unknown printer took a galley of type and scrambled it to make a type specimen book.
                                        </span>
                                    </aura:if>
                                    <aura:if isTrue="{!if(!v.toggleDisplayKeys[3].hideEye, true,false)}">
                                        <div class="{!if(v.loadingResult == 1, 'su-other-elements-section','su_displayHide')}">
                                            <b class="su-metadataTitle su__color-lgray su__ml-1 su__rtlml-0 su__rtlmr-1"> Created Date : 4/22/2019 2:13 PM</b>
                                        </div>
                                    </aura:if>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="su-bg-overlay su-filters" onclick="{!c.toggleEditMode}" role="button" tabindex="0"></div>
            </div>
            <aura:if isTrue="{!v.confirmReset}">
                <div style="z-index:102;" class="su__p-3 su__w-100 su__anim-fadeindown su__bookmark-popup su__position-fixed su__shadow-lg su__bg-white su__radius-1 su__mx-auto su__zindex0">
                    <div class="su__pt-2 su__pb-2 ">
                        Are you sure you want to reset your changes?
                    </div>
                    <div class="su__pt-4 su__text-right">
                        <input type="button" class="su__mr-2 su__full-btn  su__text-secondary" value="Yes" onclick="{!c.reset}" />
                        <input type="button" class="su__full-btn  su__text-secondary" value="No" onclick="{!c.toggleConfirmationDialog}" />
                    </div>
                </div>
                <div class="su-bg-overlay su-filters" onclick="{!c.toggleConfirmationDialog}" role="button" tabindex="0"></div>
            </aura:if>
            <!-- search tabs end -->
            <aura:if isTrue="{!if(v.customSettingErrorMessage == '',true,false)}">
                <div class="su_bodyContainer slds-col slds-small-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--1-of-1">
                    <aura:if isTrue="{!if(v.searchUnifyDownStatus == false,true,false)}">
                        <div class="su__row su__d-block su__mx-sm-0 su__pt-sm-1 su__pb-4 su_resultContainer mainresult">
                            <!-- Code for Display the Filters starts here-->
                            <div id="filtersSec" class="su-filters-section su__col-xl-4 su__col-lg-4 su__col-md-4 su__col-xs-12 su__d-xl-block su__radius-1 su__float-left" aura:id="aggregation-filters">
                                <!-- advance search section -->
                                <div class="su__advance-search su__mb-2 su__mb-sm-0">
                                    <aura:if isTrue="{!if(v.totalResults > 0,true,false)}">
                                        <div class="su__search_advance su__position-relative">
                                            <div class="su__d-xl-block su__d-none">
                                                <button type="button" class="su__btn btn_advance-search su__w-100 su__radius-2  su__p-2 su__bg-white su__flex-vcenter su__loading-view" onclick="{!c.ToggleExpandAdvanceSearch}">
                                                    <span class="su__advance-filter">
                                                            <div class="bg-Filter" title="{!v.filter}"></div>
                                                        </span>
                                                    <span class="su__text-black font-14 su__pl-2 su__rtlpr-2 su__rtlpl-0 su__font-regular">
                                                        Advanced Search</span>
                                                </button>
                                            </div>
                                            <!-- Advance search block -->
                                            <div aura:id="su_showAdvancedSearchBlock" class="slds-hide su__AdvancedSearch-Block su__fadeInDownSmall su__position-absolute su__trbl su__w-100 su__d-block">
                                                <div class="su__bookmark-popup-title su__p-2 su__d-md-none su__flex-vcenter su__bg-blue-grd">
                                                    <div class="su__px-2 su__py-1 su__bg-white-circle su__radius-50" data-aura-rendered-by="555:0">
                                                            <div class="bg-Filter_white" title="{!v.close}"></div>
                                                        </div>
                                                    <div class="su__bookmark-title su__flex-1 su__ml-2 su__rtlml-0 su__rtlmr-2">
                                                        <label class="font-16 su__text-white">
                                                            Advanced Search </label>
                                                    </div>
                                                    <div class="su__close-icon su__cursor">
                                                            <div class="bg-white_close_icon" title="{!v.close}" onclick="{!c.ToggleExpandAdvanceSearch}"></div>
                                                        </div>
                                                </div>
                                                <div class="su__advance-form-inner su__p-2 su__sm-radius-0 su__bg-white su__lg-shadow su__radius-2">
                                                    <div class="su__advance_group su__mt-2 su__mb-3">
                                                        <ui:inputText class="su__form-control" value="{!v.exactPhrase}" updateOn="keyup" placeholder="{!v.exact_phrase}" />
                                                    </div>
                                                    <div class="su__advance_group su__mb-3">
                                                        <ui:inputText class="su__form-control" value="{!v.withOneOrMore}" updateOn="keyup" placeholder="{!v.one_or_more}" />
                                                    </div>
                                                    <div class="su__advance_group su__mb-3">
                                                        <ui:inputText class="su__form-control" value="{!v.withoutTheWords}" updateOn="keyup" placeholder="{!v.without_words}" />
                                                    </div>
                                                    <div class="su__advance_group su__mb-3 font-14">
                                                        <ui:inputSelect class="ResultsPerPage su__form-control su__select-control" aura:id="levels" value="{!v.pageSizeAdvFiltr}" change="{!c.onSelectChange}">
                                                            <ui:inputSelectOption text="0" label="{! v.result_per_page}" disabled="true" />
                                                            <ui:inputSelectOption text="10" label="{!'10 ' + v.result}" />
                                                            <ui:inputSelectOption text="20" label="{!'20 ' + v.result}" />
                                                            <ui:inputSelectOption text="30" label="{!'30 ' + v.result}" />
                                                            <ui:inputSelectOption text="40" label="{!'40 ' + v.result}" />
                                                            <ui:inputSelectOption text="50" label="{!'50 ' + v.result}" />
                                                        </ui:inputSelect>
                                                    </div>
                                                    <div class="su__advance_group su__mb-2 su__text-center font-14">
                                                        <input type="button" class="su__full-btn su__bg-blue-grd su__text-white" value="{!v.refine_search}" onclick="{!c.refineSearch}" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="su__d-block su__advance-overlay su__bg-overlay" role="button" onclick="{!c.ToggleExpandAdvanceSearch}"></div>
                                            <!-- Advance search block ends-->
                                        </div>
                                    </aura:if>
                                </div>
                                <!-- advance search section -->
                                <div class="su__sidebar-blocks su__left-sidebar  su__border-t-none su_modal_effect su_fade_effect" aura:id="aggregation-filters">
                                    <div class="su__searchTip-header su__d-xl-none su__d-xs-block su__p-3 su__bg-blue-grd su__text-white su__rtltext-left su__position-relative">
                                        <h4 class="su__m-0">
                                            Narrow your search
                                        </h4>
                                        <div class="su__close-icon su__filter-close su__position-absolute su__cursor" onclick="{!c.dismiss_modal}">
                                                <div class="bg-white_close_icon" title="{!v.close}" ></div>
                                            </div>
                                    </div>
                                    <div id="filterList" class="collapse in">
                                        <aura:iteration items="{!v.aggregationsData}" var="filter" indexVar="index">
                                            <aura:if isTrue="{!and(filter.values.length > 0,filter.label !='Index')}">
                                                <aura:if isTrue="{!if(!filter.hide,true,false)}">
                                                    <div class="su__filter-item">
                                                        <div class="su__w-100 su__position-relative su__flex-vcenter su__border-b su__p-3 su__bg-white clearfix">
                                                            <div class="su__d-flex su__w-100 su__cursor su__text-semi-gray">
                                                                <div id="{!index}" class="su__sort-filter-icon su__rtlmr-0 su__rtlml-1 su__cursor su__loading-view" onclick="{!c.filtersPopup}">
                                                                    <div id="{!index}" class="bg-dots  su__circle-hover"></div>
                                                                </div>
                                                                <div class="{!filter.isCollapsed? 'su__sort-filter su__position-absolute su__bg-white su__zindex-1 su__shadow': 'visibilityHidden su__position-absolute'}">
                                                                    <ul class="{!if(v.loadingResult == 0, 'su__d-none', 'su__p-0 su__m-0 su__lg-shadow')}">
                                                                        <li class="font-12 su__color-lblue su__text-black su__font-bold su__flex-vcenter su__justify-content-left su__px-4 su__py-2">
                                                                            <div class="bg-sort"></div>
                                                                            <span class="su__color-lblue">
                                                                                <c:SULanguages parent="{!this}" child="Sort By" />
                                                                            </span>
                                                                        </li>
                                                                        <li id="{!index}" class="{!filter.alphabetetical ? 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover su__filters-sort-active': 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover'}" onclick="{!c.filterAlphabeticalSorting}">
                                                                            Alphabetically
                                                                        </li>
                                                                        <li id="{!index}" class="{!filter.ascending ? 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover su__filters-sort-active': 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover'}" onclick="{!c.filterValueSortingHighLow}">
                                                                            Count(Ascending)
                                                                        </li>
                                                                        <li id="{!index}" class="{!filter.descending ? 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover su__filters-sort-active': 'font-12 su__color-black su__px-4 su__py-2 su__cursor su__bg-gray-hover'}" onclick="{!c.filterValueSortingLowHigh}">
                                                                            Count(Descending)
                                                                        </li>
                                                                    </ul>
                                                                </div>
                                                                <div id="{!index}" class="{!filter.isCollapsed? 'su__bg-overlay su__overlay': 'su__d-none'}" role="button" onclick="{!c.filtersPopup}"></div>
                                                                <div class="su__filter-title su__margin-top-custom su__text-truncate font-14 su__font-bold su__mr-3 su__rtlml-3 su__rtlmr-0 su__loading-view" onclick="{!c.collapseFilters}" id="{!'collapseExample-'+filter.key+'_icon'}">
                                                                    {!filter.label}
                                                                </div>
                                                                <div class="su-filter-box-open-close su__filter-icon su__radius-50 su__cursor su__position-relative su__loading-view" aria-controls="collapseExample" aria-expanded="true">
                                                                    <div class="su__filter-arows su__outline-none su__position-absolute">
                                                                        <div class="{!if(v.defaultFilterCollapse == true,'su__d-none su__cursor','su__d-block su__cursor')}" id="{!'collapseExample-'+filter.key+'_toggleIconOn'}">
                                                                            <div class="bg-keyup_arrow su__arrow-icons su__d-block su__transition-5s" onclick="{!c.collapseFilters}" id="{!'collapseExample-'+filter.key+'_icon'}"  title="{!v.close}"></div>
                                                                        </div>
                                                                        <div class="{!if(v.defaultFilterCollapse == true,'su__d-block su__cursor su__transition-5s','su__d-none su__cursor')}" id="{!'collapseExample-'+filter.key+'_toggleIconOff'}">
                                                                            <div class="bg-keydown_arrow  su__arrow-icons su__d-block su__transition-5s" onclick="{!c.collapseFilters}" id="{!'collapseExample-'+filter.key+'_icon'}" title="{!v.close}"></div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <!-- left filter section start -->
                                                        <div class="{!if(v.defaultFilterCollapse,'su__filter-group-row su__overflow-hide collapse su__fadeInDownSmall su__border-b','su__filter-group-row su__overflow-hide su__fadeInDownSmall collapse in su__border-b')}" id="{!'collapseExample-'+filter.key}">
                                                            <div class="{!if(!filter.expanded &amp;&amp; filter.values.length > 5,'su_nonExpanded su__filter-content-row su__py-2','su__filter-content-row su__py-2')}" id="{!filter.key+'_filter_'+filter.order}">
                                                                <aura:iteration items="{!filter.values}" var="filterType">
                                                                    <div class="su__filter-group">
                                                                        <div class="{!if(filterType.value == 0,'disabled','yes')}">
                                                                            <div class="su__w-100 su__flex-vcenter su__py-1 su__nested-img">
                                                                                <aura:if isTrue="{! and(and(filterType.childArray, filterType.childArray.length > 0), or(!filterType.merged, and(filterType.merged, or(!filterType.showChild, filterType.showChild != '0')))) }">
                                                                                    <div class="{!if(filterType.open, 'su__loading-view su__pr-1 su__show', 'su__loading-view su__pr-1')}" id="{!'collapseMerged-'+filterType.Contentname+'_toggleIconOff'}">
                                                                                        <div class="bg-keyright_arrow  su__arrow-icons su__d-block su__transition-5s su__cursor" onclick="{!c.toggleCollpase}" id="{!'collapseMerged-'+filterType.Contentname+'_span'}"></div>
                                                                                    </div>
                                                                                    <aura:set attribute="else">
                                                                                        <span class="su__pl-24"></span>
                                                                                    </aura:set>
                                                                                </aura:if>
                                                                                <div class="su__position-relative su__filter-checkbox su__loading-view">
                                                                                    <input type="checkbox" accessKey="{!filter.order}" name="{!filterType.Contentname}" value="{!filterType.Contentname == 'All Time'? 'All':filterType.Contentname}" key="{!filter.key}" max="{!filterType.level}" class="{!'su__toggle-input su__position-absolute su__cursor checkType_'+filter.order}" id="{!filter.key+'_checkType_'+filterType.Contentname}" onclick="{!c.typeSelect}" step="{!filter.key}" checked="{!filterType.checked}" data-name="{!filterType.displayName || filterType.Contentname}" data-label="{!filter.label}" />
                                                                                    <label class="su__toggle-label su__d-inline-flex su__cursor su__loading-view-border" for="{!filter.key+'_checkType_'+filterType.Contentname}">
                                                                                        <span class="su__toggle__text"></span>
                                                                                    </label>
                                                                                </div>
                                                                                <div class="su__filter-label su__text-truncate font-12 su__mr-3 su__rtlml-3 su__rtlmr-0 su__loading-view" title="{!filterType.displayName || filterType.Contentname}">
                                                                                    <label>
                                                                                        <aura:if isTrue="{!filterType.displayName}">
                                                                                            <c:SULanguages parent="{!this}" child="{!filterType.displayName}" />
                                                                                        </aura:if>
                                                                                        <aura:if isTrue="{!if ( !filterType.displayName &amp;&amp; filterType.Contentname, true, false)}">
                                                                                            <c:SULanguages parent="{!this}" child="{!filterType.Contentname}" />
                                                                                        </aura:if>
                                                                                    </label>
                                                                                </div>
                                                                                <div class="su__filter-badge font-12">
                                                                                    <label class="label-badge su__bg-light-gray su__loading-view">
                                                                                        {!filterType.value}
                                                                                    </label>
                                                                                </div>
                                                                            </div>
                                                                            <aura:if isTrue="{!(and(filterType.childArray.length > 0, or(!filterType.showChild, filterType.showChild != '0')))}">
                                                                                <div id="{!'collapseMerged-'+filterType.Contentname}" class="{!if(v.loadingResult == 1, if(filterType.open, 'slds-show su__fadeInDownSmall su__nested-filter', 'su__fadeInDownSmall slds-hide su__nested-filter') ,'')}">
                                                                                    <c:SUNestedDataDynamic parent="{!this}" endPoint="{!v.endPoint}" aura:id="SUNestedDataDynamic" assignNested="{!filterType.childArray}" method="{!c.typeSelect}" />
                                                                                </div>
                                                                            </aura:if>
                                                                        </div>
                                                                    </div>
                                                                </aura:iteration>
                                                            </div>
                                                            <aura:if isTrue="{!if(filter.values.length > 5,true,false)}">
                                                                <div class="su__showmore su__show-more su__cursor su__p-2 su__bg-white font-14">
                                                                    <div class="su__position-relative su__showmore-text font-12 su__color-blue su__font-regular su__loading-view" id="{!filter.key+'_filter_'+filter.order+'_showMore'}" onclick="{!c.showMore}">
                                                                        Show more <span class="su__position-absolute su__showmore-icon">»</span></div>
                                                                </div>
                                                            </aura:if>
                                                        </div>
                                                    </div>
                                                </aura:if>
                                            </aura:if>
                                        </aura:iteration>
                                    </div>
                                </div>
                                <div class="su__d-none su__bg-overlay left-sidebar-overlay" role="button" onclick="{!c.dismiss_modal}"></div>
                            </div>
                            <!-- Code for Display the Filters ends here-->
                            <!-- Code for Display the Search Results starts here-->
                            <div id="resultsSec" class="{!if(!v.narrowSearch,'su__col-xl-8 su__col-lg-12 su__col-md-12 su__col-xs-12 su__mt-sm-4 su__px-sm-1 su__pb-sm-4 su__pb-sm-4 font-md-12' ,
                            'su__d-inline-block su__col-xl-8 su__col-lg-12 su__col-md-12 su__col-xs-12 su__mt-sm-4 su__px-sm-1 su__pb-sm-4 su__pb-sm-4 font-md-12'
                                )}" aura:id="suresultcomponent">
                                <div class="su__d-xl-block su__d-xs-none su__mb-sm-1">
                                    <aura:if isTrue="{!if(v.suggestData != '',true,false)}">
                                        <div class="suggestion su__didumean">
                                            <label><span class="su__font-bold font-14 su__mr-2 su__rtlmr-0 su__rtlml-2 su__text-warning su__loading-view">
                                                Did you mean:</span>
                                                <span class="su__loading-view"><a data-label="{!v.suggestData}" onclick="{!c.dymClickController}" class="font-12 su__text-decoration su__color-lgray">{!v.suggestData}</a></span>
                                            </label>
                                        </div>
                                    </aura:if>
                                </div>
                                <div class="search-results">
                                    <aura:if isTrue="{!if(v.totalResults > 0,true,false)}">
                                        <div class="su__search-view su__flex-vcenter">
                                            <div class="su__showing-result su__flex-1 su__py-2 su__text-truncate su__mr-2">
                                                <label class="su__showing-lable su__color-lgray font-12 su__font-regular su__loading-view su__d-xl-block su__d-xs-none">
                                                    Showing page 
                                                    <span class="su__font-bold"> {!v.pageNum} </span>
                                                     of 
                                                    <span class="su__font-bold"> {!v.lastPage} </span>  of&zwnj; {!v.totalResults}&zwnj;
                                                     results  ({!v.searchResultTime}
                                                     seconds).
                                                </label>
                                                <div class="su__d-xl-none su__d-xs-block">
                                                    <span class="su__btn-filters su__text-center su__radius-1  su__px-2 font-12 su__py-2 su__border su__bg-white su__cursor su__loading-view" id="su_filter_menu" onclick="{!c.modalview}">
                                                        <span class="su__filter-value su__mr-2 su__rtlmr-0 su__rtlml-2">
                                                            <div class="bg-filter_icon" ></div>                                                           
                                                        </span>
                                                        <span>
                                                            Filter</span>
                                                    </span>
                                                    <span class="su__btn-advance su__text-center su__radius-1 su__ml-3 su__px-2 font-12 su__py-2 su__border su__bg-white su__cursor su__loading-view" onclick="{!c.ToggleExpandAdvanceSearch}">
                                                        <span class="su__advance-filter">
                                                            <div class="bg-Filter su__d-inline-block" title="Mobile Advance search"></div>
                                                        </span>
                                                        <span class="su__text-black font-12 su__pl-2 su__rtlpr-2 su__rtlpl-0 su__font-regular">
                                                            Advanced Search</span>
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="su__bookmark-btn su__flex-vcenter su__d-md-flex su__d-xs-none su__justify-content-between">
                                                <span class="su__star-bookmark su__cursor su__p-2 su__radius-50 su__circle-hover su__loading-view" onclick="{!c.starClicked}">
                                                    <div class="bg-star_bookmark" title="{!v.add_bookmark}"></div>
                                                </span>
                                                <div class="{!if(v.bookmarkSearches.length == 0 ,'su__bookmark-list su__rtlmr-0 su__rtlml-0 su__radius-50 su__circle-hover su__cursor su__p-2 su__loading-view','su__invisible su__position-absolute')}" onclick="{!c.bookmarkList_toggle}">
                                                    <div class="su__d-block bg-savedBookmark_gray" title="{!v.save_bookmark}"></div>
                                                </div>
                                                <div class="{!if(v.bookmarkSearches.length > 0 ,'su__bookmark-list su__rtlmr-0 su__rtlml-0 su__radius-50 su__circle-hover su__cursor su__p-2 su__loading-view','su__invisible su__position-absolute')}" onclick="{!c.bookmarkList_toggle}">
                                                    <div class="su__d-block bg-savedBookmark_blue adjustSprite"  title="{!v.save_bookmark}"></div>
                                                </div>
                                            </div>
                                            <div class="su__fillter-sortby su__mr-2 su__ml-1 su__flex-vcenter font-12 su__loading-view su__position-relative">
                                                <lightning:select title="{!v.language}" name="" aura:id="lang" value="{!v.languageSelectedByUser}" class="su__language-icon bg-language su-sorting-select su__loading-view su_translator" onchange="{!c.saveLangToLocal}">
                                                    <aura:iteration items="{!v.selectedLanguages}" var="item">
                                                        <option text="{!item.name +'-'+item.code}" value="{!item.code}" />
                                                    </aura:iteration>
                                                </lightning:select>
                                            </div>
                                            <div class="su__fillter-sortby su__mx-2 su__flex-vcenter font-12 su__loading-view su__position-relative">
                                                <lightning:select name="mySelect" aura:id="mySelect" value="{!v.sortByCheck}" class="su-sorting-select su__loading-view">
                                                    <aura:iteration items="{!v.sortByValues}" var="item">
                                                        <option value="{!item.value}" selected="{!item.selected}">
                                                            Sort by 
                                                            {!item.method_name}
                                                        </option>
                                                    </aura:iteration>
                                                </lightning:select>
                                            </div>
                                            <div class="{!if(!!v.listview, 'su__d-md-flex su__loading-view su__d-xs-none su__flex-vcenter su__justify-content-between su__px-0', 'visibilityHidden su__position-absolute')}">
                                                <div class ="iconBright bg-list_view_active" title="{!v.list_view}"></div>
                                                <div class ="bg-grid_view  iconBright su__cursor" title="{!v.grid_view}" onclick="{!c.hideListview}"></div>
                                            </div>
                                            <div class="{!if(!v.listview, 'su__d-md-flex su__loading-view su__d-xs-none su__flex-vcenter su__justify-content-between su__px-0', 'visibilityHidden su__position-absolute')}">
                                                <div class="bg-list_view iconBright su__cursor" title="{!v.list_view}" onclick="{!c.showListview}"></div>
                                                <div class="bg-grid_view_active iconBright" title="{!v.grid_view}"></div>
                                            </div>
                                        </div>
                                        <div class="su__d-xl-none su__d-xs-block su__mb-sm-1">
                                            <aura:if isTrue="{!if(v.suggestData != '',true,false)}">
                                                <div class="suggestion su__didumean">
                                                    <label><span class="su__font-bold font-14 su__mr-2 su__rtlmr-0 su__rtlml-2 su__text-warning su__loading-view">
                                                            Did you mean:</span>
                                                        <span class="su__loading-view"><a data-label="{!v.suggestData}" onclick="{!c.dymClickController}" class="font-12 su__text-decoration su__color-lgray">{!v.suggestData}</a></span>
                                                    </label>
                                                </div>
                                            </aura:if>
                                            <div class="su__showing-result su__flex-1 su__py-1">
                                                <label class="su__showing-lable su__color-lgray font-12 su__font-regular su__loading-view su__d-xl-block su__d-xs-none">
                                                    Showing page 
                                                    <span class="su__font-bold"> {!v.pageNum} </span>
                                                     of 
                                                    <span class="su__font-bold"> {!v.lastPage} </span> of&zwnj; {!v.totalResults}&zwnj;
                                                     results  ({!v.searchResultTime}
                                                     seconds).
                                                </label>
                                            </div>
                                        </div>
                                        <div class="su__clear-filter-block">
                                            <div class="su__clear-filters su__mb-1">
                                                <aura:if isTrue="{!v.showClearFiltersButton}">
                                                    <label onclick="{!c.clearFilters}" class="su__clear-filters-btn su__cursor su__font-bold font-12 su__mb-2 su__p-0 su__color-lblue su__loading-view">
                                                        Clear filters
                                                    </label>
                                                </aura:if>
                                            </div>
                                            <!--  new sticky starts -->
                                            <div id="sticky-box" class="{! if( v.selectedStickyFilter.length > 2, 'su__selectedFilter-collapse', '' )}">
                                                <aura:iteration items="{!v.selectedStickyFilter}" var="filterType" indexVar="index">
                                                    <div class="su__sticky-row su__flex-vcenter su__flex-wrap">
                                                            <span class="su__sticky__head font-12 su__color-lgray su__font-bold su__mr-2 su__loading-view" data-label="{!filterType.label}" onclick="{!c.selectedSticky}">
                                                                {!filterType.label}:
                                                            </span>
                                                            <aura:iteration items="{!filterType.values}" var="filterValue" indexVar="ind" end="{!4}">
                                                                <span class="su__sticky__filters su__cursor su__radius font-12 su__border su__mr-1 su__px-1 su__rtlmr-0 su__rtlml-1 su__mb-1 su__text-black su__bg-white su__text-nowrap su__loading-view" data-label="{!filterType.label}" data-contentname="{!filterValue.Contentname}" data-type="{!filterType.key}" data-level="{!filterValue.level}" data-immediateParent="{!filterValue.immediateParent}" onclick="{!c.removeStickyFilter}">
                                                                    {!filterValue.sticky_name || filterValue.displayName || filterValue.Contentname}
                                                                </span>
                                                            </aura:iteration>
                                                        <aura:if isTrue="{!greaterthan(filterType.values.length , 4)}">
                                                            <label onclick="{!c.stickyList}" class="su-clear-filters-button font-12 su__mx-2 su__cursor su__text-nowrap su__loading-view" data-value="more" data-name="{!filterType.label}" id="{!filterType.label+'_seemore'}">
                                                                <div class="bg-view_more su__position-relative su__more-icon" ></div>
                                                                See  {!filterType.values.length -4}
                                                                 more
                                                            </label>
                                                            <div id="{!filterType.label+'_sticky'}" class="slds-hide" style="display: inline;">
                                                                <aura:iteration items="{!filterType.values}" var="filterValue" indexVar="ind" start="{!4}">
                                                                    <span class=" su__sticky__filters su__cursor su__radius font-12 su__border su__mr-1 su__px-1 su__rtlmr-0 su__rtlml-2 su__mb-1 su__text-black su__bg-white su__loading-view su__d-xl-inline-block" data-label="{!filterType.label}" data-contentname="{!filterValue.Contentname}" data-type="{!filterType.key}" data-level="{!filterValue.level}" data-immediateParent="{!filterValue.immediateParent}" onclick="{!c.removeStickyFilter}">
                                                                        {!filterValue.sticky_name || filterValue.displayName || filterValue.Contentname}
                                                                    </span>
                                                                </aura:iteration>
                                                                <label onclick="{!c.stickyList}" class="su-clear-filters-button font-12 su__mx-2 su__cursor su__text-nowrap  su__loading-view" data-name="{!filterType.label}" data-value="less">
                                                                    <div class="bg-view_more su__position-relative su__more-icon"></div>
                                                                    See 
                                                                    less
                                                                </label>
                                                            </div>
                                                        </aura:if>
                                                    </div>
                                                </aura:iteration>
                                            </div>
                                            <aura:if isTrue="{!if(v.selectedStickyFilter.length > 2,true,false)}">
                                                <div class="su__flex-vcenter su__justify-content-center su__color-blue">
                                                    <div class="su__show-all su__cursor su__loading-view" onclick="{!c.stickyShowAll}">
                                                        <span class="su__arrow-down"></span>
                                                        <span class="su__ml-3 su__rtlmr-3 su__rtlml-0 font-12" id="sticky-showAll">
                                                            Show all</span>
                                                    </div>
                                                </div>
                                            </aura:if>
                                        </div>
                                        <!-- sticky ends -->
                                        <div>
                                            <div class="su__loading-view">
                                                <aura:unescapedHtml value="{!v.advertisement}"></aura:unescapedHtml>
                                            </div>
                                            <!-- featured snippts start  -->
                                            <aura:if isTrue="{!v.featureSnippet}">
                                                <div class="su__featuredSnippetResult su__p-0 su__mt-4 su__sm-shadow su__bg-grayhover-40">
                                                    <div class="su__featured-table su__position-relative su__p-3 su__mb-4">
                                                        <div class="su__ribbon-block su__position-absolute">
                                                            <div class="su__ribbon-row-block su__w-auto su__clearfix su__loading-view">
                                                                <div class="su__ribbon-text font-12 su__float-left su__text-center su__text-black su__font-bold su__mb-2 su__radius-3">
                                                                    {!v.featureSnippet.sourceLabel}
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <aura:if isTrue="{!if(v.featureSnippetSteps.length > 0,true,false)}">
                                                            <ul class="su__result-wrapper-ul su__p-0 su__my-3">
                                                                <aura:iteration items="{!v.featureSnippetSteps}" var="featuredResponse">
                                                                    <li class="su-result-wrapper-li su__listing-border su__loading-view su__loading-view su__mb-2 su__px-3 su__py-2 font-14 su__d-flex">
                                                                        {!featuredResponse}
                                                                    </li>
                                                                </aura:iteration>
                                                            </ul>
                                                        </aura:if>
                                                        <a href="{!v.featureSnippet.href}" class="su__text-decoration font-14 su__text-black hover-color-dblue su__font-bold su__loading-view" target="_blank">
                                                            <aura:unescapedHtml value="{!v.featureSnippetTitle}"></aura:unescapedHtml>
                                                        </a>
                                                        <aura:if isTrue="{!!v.featuredResponseRecorded}">
                                                            <div class="thankyou-response">
                                                                <div class="su-featured-text">
                                                                    <div class="font-14 su__loading-view">
                                                                        Was above result helpful?</div>
                                                                    <div class="su__featured-row su__d-flex">
                                                                        <span class="su__featured-feedback su__cursor su__loading-view" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="1">
                                                                            <img src="{!v.endPoint+'/resources/Assets/thumbs-up.svg'}" class="ab-testing-btn" alt="Useful" />
                                                                        </span>
                                                                        <span class="su__featured-feedback su__cursor su__loading-view" onclick="{!c.sendFeaturedSnippedFeedback}" data-feedback="0">
                                                                            <img src="{!v.endPoint+'/resources/Assets/thumbs-down.svg'}" class="ab-testing-btn" alt="Not Useful" />
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                        <aura:if isTrue="{!v.featuredResponseRecorded}">
                                                            <div class="su__featured-thankyou su__text-success font-14 su__mt-2 su__position-relative su__loading-view">
                                                                <div class="su__text-success font-12 su__my-3 su__flex-vcenter su__px-1 su__position-relative su__loading-view ng-scope">
                                                                    <span class="su__mr-2 su__rtlmr-0 su__rtlml-2">
                                                                        <img src="{!v.endPoint+'/resources/Assets/ok-icon.svg'}" class="ft-green-tick" alt="Success icon" />
                                                                    </span>
                                                                    <span>
                                                                        Thank you for your response!</span>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                    </div>
                                                </div>
                                            </aura:if>
                                            <!-- featured snippts end  -->
                                            <!-- Code ends here -->
                                            <div class="{!if(v.metaStatus || v.relatedTilesStatus, 'su__d-flex su__d-md-flex su__d-xs-block su__d-sm-block su__align-items-start su__align-content-start  su__knowledgeGraph-show' , 'su__w-100 su__content-view-row  su__sm-fullwidth')}">
                                                <div class="{!if(v.listview, 'su__content-view su__grid-mobile su__list-views su__my-3 su__flex-wrap su__sm-fullwidth' , 'su__content-view su__grid-mobile su__my-2 su__flex-wrap su__sm-fullwidth su__grid-content')}">
                                                    <aura:iteration items="{!v.responseListData}" var="data" indexVar="indexVar">
                                                        <div class="su__list-items su__bg-white su__sm-shadow su__radius-1 su__position-relative su__p-3 su__mb-4">
                                                            <aura:if isTrue="{!!v.listview}">
                                                                <div class="{!if(v.loadingResult == 1, if(!!v.listview, if((v.metaStatus || v.relatedTilesStatus) == true, 'su__thumbnail-img su-icon', 'su__thumbnail-img'),'su__thumbnail-img su__mb-2 su__loading-view'),'su__thumbnail-img su__mb-2 su__loading-view')}">
                                                                    <aura:if isTrue="{!if(data.imageSource, true,false)}">
                                                                        <img class="su-thumb" src="{!data.imageSource}" />
                                                                    </aura:if>
                                                                </div>
                                                            </aura:if>
                                                            <div class="su__thumbnail-mobile su__d-md-none su__d-xs-block ">
                                                                <div class="su__m-thumbnail-img su__loading-view">
                                                                    <aura:if isTrue="{!if(data.imageSource, true,false)}">
                                                                        <img class="su-thumb" src="{!data.imageSource}" />
                                                                    </aura:if>
                                                                </div>
                                                            </div>
                                                            <div class="su__list-item-row su__media">
                                                                <div class="su__listview-thumbnail">
                                                                    <div class="su__m-thumbnail-img su__loading-view su__mr-2">
                                                                        <aura:if isTrue="{!if(data.imageSource, true,false)}">
                                                                            <img class="su-thumb" src="{!data.imageSource}" />
                                                                        </aura:if>
                                                                    </div>
                                                                </div>
                                                                <aura:if isTrue="{!(!v.hideIcon)}">
                                                                    <div class="su__list-item-img su__d-md-block su__d-xs-none su__mr-2 su__rtlml-2 su__rtlmr-0 su__loading-view">
                                                                        <aura:if isTrue="{!if(data.icon, true,false)}">
                                                                            <img class="su__left-item-img" src="{!data.icon}" alt="data images" />
                                                                        </aura:if>
                                                                    </div>
                                                                </aura:if>
                                                                <div class="{!if(!!v.listview, if((v.metaStatus || v.relatedTilesStatus) == true, 'su__list-item-text su__media-body su__overflow-hide su__word-break', 'su-result-icon su__w-100 su__overflow-hide'), 'su__list-item-text su__media-body su__overflow-hide su__word-break')}">
                                                                    <aura:if isTrue="{!(!v.hideTitle)}">
                                                                        <aura:if isTrue="{!if(!data.highlight.TitleToDisplay[0] || data.highlight.TitleToDisplay[0] == '', true, false)}">
                                                                            <h4 class="su__list-item-title su__flex-vcenter su__mw-100 su__m-0 su__loading-view">
                                                                                <aura:if isTrue="{!data.autotuned}">
                                                                                    <span class="su__auto-tuning su__ribbon-grid  su__d-none">
                                                                                        <img src="{!v.endPoint+'/resources/Assets/autoTuned.svg'}" />
                                                                                    </span>
                                                                                </aura:if>
                                                                                <!--Grid view Ribbon -->
                                                                                <span class="su__ribbon-title su__ribbon-grid su__bg-blue font-12 font-m-10 su__px-2 su__mr-1 su__d-none su__md-block su__radius-3">
                                                                                    <aura:if isTrue="{!data.objLabel}">
                                                                                        {!data.objLabel}
                                                                                    </aura:if>
                                                                                </span>
                                                                                <!--Grid view Ribbon end -->
                                                                                <a class="su__text-decoration su__text-black su__text-truncate font-14 su__font-bold su__cursor" href="{!data.href}" target="_blank" onclick="{!c.runScriptMethod}" data-Id="{!data._id}" data-Rank="{!indexVar}" data-Sub="{!data.href}" data-url="{!data.href}" data-Type="{!data.objName}" data-Index="{!data.sourceName}" data-Autotuned="{!data.autotuned}">
                                                                                    <aura:unescapedHtml value="{!data.href}"></aura:unescapedHtml>
                                                                                </a>
                                                                                <!--List view Ribbon -->
                                                                                <span class="su__ribbon-title su__ribbon-list su__bg-blue font-12 font-m-10 su__px-2 su__mr-1 su__md-none su__d-inline-block su__radius-3">
                                                                                    <aura:if isTrue="{!data.objLabel}">
                                                                                        {!data.objLabel}
                                                                                    </aura:if>
                                                                                </span>
                                                                                <!--List view Ribbon end-->
                                                                                <aura:if isTrue="{!data.autotuned}">
                                                                                    <span class="su__auto-tuning su__ribbon-list su__d-inline-block">
                                                                                        <img src="{!v.endPoint+'/resources/Assets/autoTuned.svg'}" />
                                                                                    </span>
                                                                                </aura:if>
                                                                            </h4>
                                                                            <aura:set attribute="else">
                                                                                <h4 class="su__list-item-title su__flex-vcenter su__mw-100 su__m-0 su__loading-view">
                                                                                    <aura:if isTrue="{!data.autotuned}">
                                                                                        <span class="su__auto-tuning su__ribbon-grid  su__d-none">
                                                                                            <img src="{!v.endPoint+'/resources/Assets/autoTuned.svg'}" />
                                                                                        </span>
                                                                                    </aura:if>
                                                                                    <span class="su__ribbon-title su__ribbon-grid su__bg-blue font-12 font-m-10 su__px-2 su__mr-1 su__d-none su__md-block su__radius-3">
                                                                                        <aura:if isTrue="{!data.objLabel}">
                                                                                            {!data.objLabel}
                                                                                        </aura:if>
                                                                                    </span>
                                                                                    <a class="su__text-decoration su__text-black su__text-truncate font-14 su__font-bold su__cursor" href="{!data.href}" target="_blank" onclick="{!c.runScriptMethod}" data-Id="{!data._id}" data-Rank="{!indexVar}" data-Sub="{!data.highlight.TitleToDisplayString[0]}" data-url="{!data.href}" data-Type="{!data.objName}" data-Index="{!data.sourceName}" data-Autotuned="{!data.autotuned}">
                                                                                        <aura:unescapedHtml value="{!data.highlight.TitleToDisplay[0]}"></aura:unescapedHtml>
                                                                                    </a>
                                                                                    <span class="su__ribbon-title su__ribbon-list su__bg-blue font-12 font-m-10 su__px-2 su__ml-1 su__d-inline-block su__md-none su__radius-3">
                                                                                        <aura:if isTrue="{!data.objLabel}"> 
                                                                                            {!data.objLabel}
                                                                                        </aura:if>
                                                                                    </span>
                                                                                    <aura:if isTrue="{!data.autotuned}">
                                                                                        <span class="su__auto-tuning su__ribbon-list su__d-inline-block">
                                                                                            <img src="{!v.endPoint+'/resources/Assets/autoTuned.svg'}" />
                                                                                        </span>
                                                                                    </aura:if>
                                                                                </h4>
                                                                            </aura:set>
                                                                        </aura:if>
                                                                    </aura:if>
                                                                    <aura:if isTrue="{!(!v.hideUrl)}">
                                                                        <p class="su__list-item-url  su__w-100 su__my-1 font-12 su__loading-view">
                                                                            <a href="{!data.href}" target="_blank" class="su__text-decoration su__color-blue su__font-italic">{!data.href}</a>
                                                                        </p>
                                                                    </aura:if>
                                                                    <div class="su__divider su__d-md-none su__d-xs-block"></div>
                                                                    <div class="{!data.isCollapsed? 'su__collapse su__d-flex su__w-100 su__loading-view': 'su__d-inline su__w-100 su__loading-view'}">
                                                                        <aura:if isTrue="{!(!v.hideSummary)}">
                                                                            <aura:if isTrue="{!if(data.highlight.SummaryToDisplayList.length > 0, true,false)}">
                                                                                <div class="{!data.isCollapsed? 'su__text-truncate': 'su__d-inline su__text-normal'}">
                                                                                    <aura:iteration indexVar="index" items="{!data.highlight.SummaryToDisplayList}" var="summary">
                                                                                        <p class="{!data.isCollapsed? 'su__list-item-desc su__my-1 su__font-regular su__mb-2 font-12 su__word-break su__d-inline su__loading-view': 'su__list-item-desc su__my-1 su__font-regular su__mb-2 font-12 su__word-break su__d-block su__loading-view'}">
                                                                                            <aura:unescapedHtml value="{!summary}"></aura:unescapedHtml>
                                                                                        </p>
                                                                                    </aura:iteration>
                                                                                </div>
                                                                                <aura:if isTrue="{!if(!v.domWidth == false, true, false)}">
                                                                                    <aura:if isTrue="{!if(data.highlight.length_SummaryToDisplay > 150, true,false)}">
                                                                                        <div class="{!if(!v.collapsibleSummary == true,'su__d-none','su__d-inline')}">
                                                                                            <span id="{!indexVar}" onclick="{!c.toggleCollapse}" class="{!data.isCollapsed? 'font-12 su__color-blue su__cursor su__my-1 su__mb-2 su__text-nowrap': 'su__d-none'}">
                                                                                                Show more</span>
                                                                                            <span id="{!indexVar}" onclick="{!c.toggleCollapse}" class="{!!data.isCollapsed? 'font-12 su__color-blue su__cursor su__my-1 su__mb-2 su__text-nowrap': 'su__d-none'}">
                                                                                                Show less</span>
                                                                                        </div>
                                                                                    </aura:if>
                                                                                </aura:if>
                                                                                <aura:if isTrue="{!if(v.domWidth == false, true, false)}">
                                                                                    <div class="{!if(!v.collapsibleSummary == true,'su__d-none','su__d-inline')}">
                                                                                        <span id="{!indexVar}" onclick="{!c.toggleCollapse}" class="{!data.isCollapsed? 'font-12 su__color-blue su__cursor su__my-1 su__mb-2 su__text-nowrap': 'su__d-none'}">
                                                                                            Show more</span>
                                                                                        <span id="{!indexVar}" onclick="{!c.toggleCollapse}" class="{!!data.isCollapsed? 'font-12 su__color-blue su__cursor su__my-1 su__mb-2 su__text-nowrap': 'su__d-none'}">
                                                                                            Show less</span>
                                                                                    </div>
                                                                                </aura:if>
                                                                            </aura:if>
                                                                        </aura:if>
                                                                    </div>
                                                                    <aura:if isTrue="{!if(data.metadata.length > 0 &amp;&amp; !v.hideMetadata,true,false)}">
                                                                        <div class="su__meta-item su__d-flex su__flex-wrap su__align-content-between su__mt-2 font-12">
                                                                            <aura:iteration items="{!data.metadata}" var="metadata" indexVar="ind">
                                                                                <aura:if isTrue="{!if(metadata.value.length > 0 &amp;&amp; metadata.key != 'Tag',true,false)}">
                                                                                    <div class="{!if(!!v.listview || (v.metaStatus || v.relatedTilesStatus) == true,  'su__meta-date su__word-break',  'su__meta-date su__word-break')}">
                                                                                        <div class="su__meta-row su__mb-1 su__loading-view">
                                                                                            <span class="metaDataKey su__font-bold su__color-blue su__rtlmr-0 su__rtlml-2">
                                                                                                <c:SULanguages parent="{!this}" child="{!if(metadata.key == 'post_time','Created Date',metadata.key)}" />
                                                                                            </span><span class="metaDataKey">&lrm;:&lrm;</span>
                                                                                            <aura:if isTrue="{!if(metadata.key == 'post_time',true,false)}">
                                                                                                <aura:iteration items="{!metadata.value}" var="metadataVal">
                                                                                                    <ui:outputDate value="{!metadataVal}" format="EEE dd MMM yyyy / hh:mm a" />
                                                                                                </aura:iteration>
                                                                                                <aura:set attribute="else">
                                                                                                    <aura:iteration items="{!metadata.value}" var="metadataVal" indexVar="singleVal">
                                                                                                        <aura:if isTrue="{!singleVal == 0}">
                                                                                                            <span class="su__color-lgray su__ml-1 su__rtlml-0 su__rtlmr-1">{!metadataVal}</span>

                                                                                                        </aura:if>
                                                                                                    </aura:iteration>
                                                                                                </aura:set>
                                                                                            </aura:if>
                                                                                        </div>
                                                                                    </div>
                                                                                </aura:if>
                                                                            </aura:iteration>
                                                                            <aura:iteration items="{!data.metadata}" var="metadata" indexVar="ind">
                                                                                <aura:if isTrue="{!if(metadata.value.length > 0 &amp;&amp; metadata.key == 'Tag',true,false)}">
                                                                                    <div class="{!if(!!v.listview || (v.metaStatus || v.relatedTilesStatus) == true,  'su__word-break',  'su__word-break')}">
                                                                                        <div class="su__meta-row su__mb-1 su__loading-view">
                                                                                                <aura:if isTrue="{!if(metadata.key == 'Tag' , true, false)}">
                                                                                            <span class="metaDataKey su__font-bold su__color-blue su__rtlmr-0 su__rtlml-2">
                                                                                                <c:SULanguages parent="{!this}" child="{!if(metadata.key == 'Tag', metadata.key)}" />
                                                                                            </span><span class="metaDataKey">&lrm;:&lrm;</span>
                                                                                                <span class="su__color-lgray su__ml-1 su__rtlml-0 su__rtlmr-1">
                                                                                                    {!metadata.valueString}
                                                                                                </span>
                                                                                            </aura:if>
                                                                                        </div>
                                                                                    </div>
                                                                                </aura:if>
                                                                            </aura:iteration>
                                                                        </div>
                                                                    </aura:if>
<!--CUSTOMATTACHMENT-->
                                                                    <aura:if isTrue="{!if(data.highlight.AttachmentToDisplay.length > 0 &amp;&amp; !v.hideMetadata ,true,false)}">
                                                                        <span class="metaDataKey su__color-blue su__rtlmr-0 su__rtlml-2"> Attachments: </span>
                                                                        <aura:iteration items="{!data.highlight.AttachmentToDisplay}" var="att" indexVar="ind">
                                                                            <div class="{!if(!!v.listview || (v.metaStatus || v.relatedTilesStatus) == true,  'su__meta-date su__word-break',  'su__meta-date su__word-break')}">
                                                                                <div class="su__meta-row su__mb-1 su__loading-view">
                                                                                    <span >
                                                                                        <a href="{!att.url}" target="_blank" class="su__color-blue su__ml-1 su__rtlml-0 su__rtlmr-1">{!att.name}</a>
                                                                                    </span>
                                                                                </div>
                                                                            </div>
                                                                        </aura:iteration>
                                                                    </aura:if>
                                                                    <!--CUSTOMATTACHMENT-->
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </aura:iteration>
                                                </div>
                                                <!-- </aura:if> -->
                                                <!-- Code to Display the Knowledge Graph starts here-->
                                                <aura:if isTrue="{!v.metaStatus || v.relatedTilesStatus}">
                                                    <div class="su__knowledgeGraph su__sm-fullwidth  su__col-xl-4 su__col-lg-12 su__col-md-12 su__col-xs-12 su__bg-white su__position-relative su__p-3 su__pb-0 su__mb-3 su__sm-shadow su__radius-1">
                                                        <aura:if isTrue="{!v.metaStatus}">
                                                            <div class="su__text-truncate su__m-0 su__loading-view">
                                                                <a href="{!v.meta_data.metaLink}" class="su__text-decoration font-14 su__text-black su__font-bold" target="_blank">
                                                                    <aura:unescapedHtml value="{!v.meta_data.metaTitle}"></aura:unescapedHtml>
                                                                </a>
                                                            </div>
                                                            <div class="su__list-item-desc su__w-100 su__m-0 su__mt-1 font-12 su__word-break su__loading-view">
                                                                <cite class="su__text-decoration su__color-lgray font-12">
                                                                    <aura:unescapedHtml value="{!v.meta_data.metaLink}"></aura:unescapedHtml>
                                                                </cite>
                                                            </div>
                                                            <aura:if isTrue="{!v.meta_data.metaImg}">
                                                                <div class="metaImg">
                                                                    <img class="knowledgeGraph-metaImg" src="{!v.meta_data.metaImg}" />
                                                                </div>
                                                            </aura:if>
                                                            <div class="su__list-item-desc su__w-100 su__m-0 su__mt-1 font-12 su__word-break su__loading-view">
                                                                <aura:unescapedHtml value="{!v.meta_data.metaDescription}"></aura:unescapedHtml>
                                                            </div>
                                                            <div class="su__meta-item su__mt-2 font-12">
                                                                <aura:iteration items="{!v.meta_data.metaFields}" var="mf">
                                                                    <div class="su__meta-row su__mb-1 su__loading-view">
                                                                        <span class="metaDataKey su__font-bold su__color-blue su__rtlmr-0 su__rtlml-2">
                                                                            <aura:unescapedHtml value="{!mf.key}"></aura:unescapedHtml>
                                                                        </span>
                                                                        : &lrm;
                                                                        <span class="su__color-lgray su__ml-1 su__rtlml-0 su__rtlmr-1">
                                                                            <aura:unescapedHtml value="{!mf.value}"></aura:unescapedHtml>
                                                                        </span>
                                                                    </div>
                                                                </aura:iteration>
                                                            </div>
                                                        </aura:if>
                                                        <aura:if isTrue="{!v.relatedTilesStatus}">
                                                            <aura:iteration items="{!v.relatedTiles}" var="rt">
                                                                <h4>
                                                                    <aura:unescapedHtml value="{!rt.tagLine}"></aura:unescapedHtml>
                                                                </h4>
                                                                <aura:iteration items="{!rt.relatedFields}" var="rti">
                                                                    <li>
                                                                        <a href="{!rti.link}" target="_blank">
                                                                            <aura:unescapedHtml value="{!rti.heading1}"></aura:unescapedHtml>
                                                                        </a>
                                                                    </li>
                                                                </aura:iteration>
                                                            </aura:iteration>
                                                        </aura:if>
                                                        <aura:if isTrue="{!!v.knowledgeGraphResponseRecorded}">
                                                            <div class="su-featured-text su__row su__flex-vcenter su__px-3 su__py-2 su__mt-2 su__bg-blue-grd su__loading-view">
                                                                <div class="font-12 su__mt-1 su__text-white su__mr-3 su__rtlmr-0 su__rtlml-3 su__loading-view">
                                                                    Was above result helpful?</div>
                                                                <div class="su__knowledge-feedback-row su__d-flex">
                                                                    <span class="su__knowledge-feedback su__cursor su__loading-view" onclick="{!c.sendknowledgeGraphFeedback}" data-feedback="1">
                                                                        <img src="{!v.endPoint+'/resources/Assets/thumbs-up.svg'}" class="ab-testing-btn" alt="Useful" />
                                                                    </span>
                                                                    <span class="su__knowledge-feedback su__cursor su__loading-view" onclick="{!c.sendknowledgeGraphFeedback}" data-feedback="0">
                                                                        <img src="{!v.endPoint+'/resources/Assets/thumbs-down.svg'}" class="ab-testing-btn" alt="Not Useful" />
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                        <aura:if isTrue="{!v.knowledgeGraphResponseRecorded}">
                                                            <div class="su__knowledge-thankyou su__clearfix su__mb-sm-1">
                                                                <div class="su__text-success font-12 su__my-3 su__flex-vcenter su__px-1 su__position-relative su__loading-view ng-scope">
                                                                    <span class="su__mr-2 su__rtlmr-0 su__rtlml-2">
                                                                        <img src="{!v.endPoint+'/resources/Assets/ok-icon.svg'}" class="ft-green-tick" alt="Success icon" />
                                                                    </span>
                                                                    <span>
                                                                        Thank you for your response!</span>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                    </div>
                                                </aura:if>
                                                <!-- Code to Display the Knowledge Graph ends here-->
                                            </div>
                                            <!--For similar Search Suggestions-->
                                            <aura:if isTrue="{!v.similarSearchSuggestions}">
                                                <div class="su__position-relative su__mt-4 su__p-3 su__sm-shadow su__bg-white">
                                                    <div class="su__ribbon-block su__position-absolute">
                                                        <div class="su__ribbon-row-block su__w-auto su__clearfix su__loading-view">
                                                            <div class="su__ribbon-text font-12 su__float-left su__text-center su__text-black su__font-bold su__mb-2 su__radius-3">
                                                                Similar Searches
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <ul class="su__p-0 su__mb-3 su__mt-2">
                                                        <aura:iteration items="{!v.similarSearchSuggestions}" var="SearchSuggestion">
                                                            <li class="su__mb-2 su__px-3 su__py-1 su__d-flex su__border su__radius su__align-items-start hover__effect su__loading-view">
                                                                <a class="font-14 su__text-decoration su__text-black hover-color-dblue" data-label="{!SearchSuggestion}" onclick="{!c.clickSearchSuggestionController}">{!SearchSuggestion}</a>
                                                            </li>
                                                        </aura:iteration>
                                                    </ul>
                                                </div>
                                            </aura:if>
                                        </div>
                                        <!--pagination start -->
                                        <aura:if isTrue="{!if(v.totalResults == 0 || v.totalResults le v.pageSize, false,true)}">
                                            <div class="su__w-100 su__pagination-section su__mt-4" ng-class="{su__loading: loadingResults}">
                                                <div class="su__pagination-row">
                                                    <ul class="pagination su__pagination su__justify-content-end font-14">
                                                        <li class="{!if(v.pageNum == '1', 'disabled', '')}">
                                                            <a id="{!v.pageNum - 1}" onclick="{!c.pageChange}" class="hidden-xs su__loading-view">
                                                                Previous </a>
                                                        </li>
                                                        <aura:iteration items="{!v.paginationList}" var="paginationNumber">
                                                            <li class="{!if(v.pageNum == ''+paginationNumber,'active','')}">
                                                                <a id="{!paginationNumber}" class="su__loading-view" onclick="{!c.pageChange}">{!paginationNumber}</a>
                                                            </li>
                                                        </aura:iteration>
                                                        <li class="{!if(v.pageNum == v.lastPage, 'disabled', '')}">
                                                            <a onclick="{!c.nextPage}" class="hidden-xs su__loading-view">
                                                                Next</a>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </aura:if>
                                        <!--pagination end -->
                                        <!-- Code for Display the when no results found-->
                                        <aura:set attribute="else">
                                            <aura:if isTrue="{!v.loadingResult == 1}">
                                                <div class="su-clear-filters-section" style="{!if(v.showClearFiltersButton,'overflow:hidden;', 'overflow:hidden; display:inline')}">
                                                    <aura:if isTrue="{!v.showClearFiltersButton}">
                                                        <label onclick="{!c.clearFilters}" class="su__clear-filters-btn su__cursor su__font-bold font-12 su__mb-2 su__p-0 su__color-lblue su__loading-view">
                                                            Clear filters
                                                        </label>
                                                    </aura:if>
                                                </div>
                                                <div class="su_errorMessage su__w-100">
                                                    <div class="su__noresult-text su__w-100">
                                                        <div class="no-results-row su__row su__text-center">
                                                            <div class="su__col-md-6 su__m-auto">
                                                                <p class="su__sorry-no-result su__font-bold su__text-center">
                                                                    {!v.errorMessage}
                                                                </p>
                                                                <div class="no-results-img su__text-center">
                                                                    <div class="bg-No_result_data ab-testing-btn"></div>
                                                                </div>
                                                                <!--<p class="su__font-bold font-14">
                                                                    Showing results using some of your recent search terms
                                                                </p>-->
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </aura:if>
                                        </aura:set>
                                    </aura:if>
                                </div>
                                <!--<c:SUAuthRecommendedData />-->
                            </div>
                            <!-- Code for Display the Search Results ends here-->
                        </div>
                        <button class="su_displayHide slds-hide" onclick="{!c.goToTop}" id="goToTopBtn" title="Go to top">GO TO TOP</button>
                        <!-- Code for Display the when search server is down -->
                        <aura:set attribute="else">
                            <div class="slds-col slds-small-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--1-of-1 su_errorMessage">
                                <span>{!v.errorMessage}</span>
                            </div>
                        </aura:set>
                    </aura:if>
                </div>
                <!-- Code for Display the when search is not configured -->
                <aura:set attribute="else">
                    <div class="slds-col slds-small-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--1-of-1 su_errorMessage">
                        <span>{!v.customSettingErrorMessage}</span>
                    </div>
                </aura:set>
            </aura:if>
            <!-- fixed mobile icons -->
            <div class="su__fixed-bottom docs-scroll-fab scrolling su__shadow su__bg-white su__d-md-none su__d-xs-block">
                <div class="su__mobile-navigation su__px-2 su__px-sm-1 su__py-2 su__flex-vcenter su__justify-content-between">
                    <div class="su__col su__text-center font-9 su__font-bold su__px-sm-1" onclick="{!c.goToTop}">
                        <div class="bg-Search_black adjustSprite"></div>
                        Search
                    </div>
                    <div class="su__col su__text-center font-9 su__font-bold su__px-sm-1" onclick="{!c.ToggleExpandAdvanceSearch}">
                        <span class="su__d-block">
                            <div class="bg-Advance_Search_black"></div>
                        </span>
                        <span>
                            Advanced Search</span>
                    </div>
                    <div class="su__col su__text-center font-9 su__font-bold su__px-sm-1" onclick="{!c.starClicked}">
                        <span class="su__bookmark-list su__d-block bookmark-list-dots">
                            <div class="bg-Add_Bookmark adjustSprite"></div>                                
                        </span>
                        <span>
                            Add Bookmarks</span>
                    </div>
                    <div class="su__col su__text-center font-9 su__font-bold su__px-sm-1 su__position-relative">
                        <div class="su__d-block su__more-hover" onclick="{!c.viewMoreToggle}">
                            <div class="bg-More_black adjustSprite"></div>                                    
                            <span class="su__d-block">
                                More
                            </span>
                        </div>
                        <div class="su__viewMore su__position-absolute su__d-none su__sm-shadow su__p-2 su__bg-white">
                            <div class="su__w-100 su__flex-vcenter font-9 su__font-bold su__px-sm-1 su__p-1" onclick="{!c.toggleSearchTips}">
                                <div class="bg-Tips_black su__mr-2"></div>                                        
                                <span>
                                Search Tips</span>
                            </div>
                            <div class="su__w-100 su__flex-vcenter font-9 su__font-bold su__px-sm-1 su__p-1" onclick="{!c.bookmarkList_toggle}">
                                <div class="bg-saved_bookmark_black su__mr-2"></div>
                                <span class="su__text-nowrap">
                                    Saved Bookmarks </span>
                            </div>
                        </div>
                        <div class="su__d-none su__bg-overlay su__viewMore-overlay" role="button"></div>
                    </div>
                </div>
            </div>
            <!-- fixed mobile icons end -->
            <!-- Search Tips for mobile start-->
            <div class="su__side-Search-tips su-tab su__bg-blue-grd su__p-2 su__position-fixed su__cursor su__loading-view su__z-index su__d-md-block su__d-xs-none">
                <div onclick="{!c.toggleSearchTips}" class="bg-search_tips_white su__img-24"  title="{!v.search_tips}"></div>
            </div>
            <div onclick="{!c.togglePopup}" class="su__side-Search-tips su__bg-blue-grd su__p-2 su__position-fixed su__cursor su__loading-view su__zindex-1 su__d-lg-block su__d-xs-none" role="button">
                <div class="bg-setting su__img-24"></div>                    
            </div>
            <div  class="{!if(v.customize, 'su__d-md-block', 'visibilityHidden')}">
                <div class="su__side-Search-tips su__zindex-2  viewOptions su__bg-blue-grd su__p-2 su__position-fixed su__cursor su__loading-view su__zindex-1 su__d-md-block su__d-xs-none" role="button">
                    <div onclick="{!c.toggleSearchTips}" class="bg-search_tips_white su__img-24 su__pb-2" title="{!v.search_tips}"></div>
                    <div onclick="{!c.toggleEditMode}" class="su__img-24 bg-edit" title="Customize"></div>
                </div>
                <div class="su-bg-overlay " onclick="{!c.togglePopup}" role="button" tabindex="0"></div>
            </div>
            <div class="su__sidebar-desktop su__miniscroll su__right-sidebar su__border su__border-t-none su__radius-1 su_modal_effect su_fade_effect">
                <div class="su__searchTip-header su__p-3 su__bg-blue-grd su__text-white su__rtltext-left su__position-relative">
                    <h4 class="su__m-0">Search Tips</h4>
                    <div class="su__close-icon su__position-absolute su__cursor" role="button">
                        <div class="bg-white_close_icon" title="{!v.close}" onclick="{!c.dismiss_modal}"></div>
                    </div>
                </div>
                <div class="su__searchTip-content su__bg-white _md">
                    <div class="su__search-tipicons su__w-100 su__m-auto su__text-center">
                        <div class="bg-search_tips" title="{!v.close}"></div>         
                    </div>                   
                    <ul class="su__searchTip-list su__m-0 su__p-3 su__pl-5 su__rtlpr-5 su__rtlpl-3 font-12">
                        <li>
                            Enter just a few key words related to your question or problem
                        </li>
                        <li>
                            Add Key words to refine your search as necessary
                        </li>
                        <li>
                            Do not use punctuation
                        </li>
                        <li>
                            Search is not case sensitive
                        </li>
                        <li>
                            Avoid non-descriptive filler words like "how", "the", "what", etc.
                        </li>
                        <li>
                            If you do not find what you are looking for the first time,reduce the number of key words you enter and try searching again.
                        </li>
                        <li>
                            Minimum supported Internet Explorer version is IE9
                        </li>
                    </ul>
                </div>
                <div class="su__d-none su__bg-overlay right-sidebar-overlay" role="button" onclick="{!c.dismiss_modal}"></div>
            </div>
            <div class="su__d-none su__bg-overlay right-sidebar-overlay" role="button" onclick="{!c.dismiss_modal}"></div>
            <!-- Search Tips for mobile end -->
            <!-- Goto top start -->
            <div class="{!if(v.showScroll, 'su__back-to-top su__position-fixed su__cursor su__zindex su__d-md-block su__d-xs-none', 'visibilityHidden')}" onclick="{!c.goToTop}">
                <div id="goToTopBtn" class="su__btn-back-to-top su_radius-top su__px-2 su__py-1 su__shadow docs-scroll-fab scrolling su__d-none su__bg-blue-grd" ng-click="goToTop()" docs-scroll-class="scrolling" aria-label="Back to Top" role="button" tabindex="0" style="display: block;">
                    <span class="su__text-white font-12">
                        Page Top</span>
                    <span>
                        <div class="bg-gototop" title="{!v.close}"></div>
                    </span>
                </div>
            </div>
            <!-- Goto top end -->
        </div>
        <aura:if isTrue="{!!v.loadingResult}">
            <div class="disSpinerDiv">
                <div aura:id="dvSpinner3" class="loadingCon global siteforceLoadingBalls su_disSpiner" data-aura-class="siteforceLoadingBalls">
                    <div class="customBalls">
                        <span class="loadingBall first"></span>
                        <span class="loadingBall second"></span>
                        <span class="loadingBall third"></span>
                        <span class="assistiveText">
                            Loading
                        </span>
                    </div>
                </div>
            </div>
        </aura:if>
    </aura:if>
</div>
<!--mainUI-->
    </aura:if>
</aura:component>