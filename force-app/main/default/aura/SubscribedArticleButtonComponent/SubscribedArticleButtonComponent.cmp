<aura:component controller ="LtngArticleListController" implements="flexipage:availableForAllPageTypes,forceCommunity:availableForAllPageTypes,force:hasRecordId" access="global">
    <aura:handler name="init" action="{!c.doInit}" value="{!this}"/>
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="UrlName"  type="string" />
    <aura:attribute name="isSubscribed"  type="Boolean" />
    <aura:attribute name="linkedCategory"  type="Object[]" />
    <aura:attribute name="ModalOpen"  type="Boolean" />
    <div class ="ContainerDiv slds-grid slds-wrap" style="    margin:auto;margin-top:2rem ;">
        <div class ="slds-large-size--8-of-12 slds-Medium-size--8-of-12 slds-size--8-of-12 slds-grid slds-wrap Categories">
            <b>CATEGORIES : &nbsp;</b>
            <aura:iteration items="{!v.linkedCategory}" var="item" indexVar="index">
                <lightning:badge label="{!item}"/>
            </aura:iteration>
        </div>
        <div class ="slds-large-size--4-of-12 slds-Medium-size--4-of-12 slds-size--4-of-12  sub">
            <lightning:button label="Return to Knowledge" class="redirectcls" onclick="{!c.redirect}"/>
            <lightning:buttonStateful
                                      state="{! v.isSubscribed }"
                                      variant="brand"
                                      labelWhenOff="Subscribe"
                                      labelWhenOn="Unsubscibe"
                                      onclick="{! c.manageSubscription }"
                                      />
            <div class="tooltip1"> 
                <img style="width: 20px;     margin-left: 5px;" src="data:image/png;base64,"/>
                <span class="tooltiptext">{!$Label.c.S_R_Article_subscribe_info_label}</span>
            </div>
        </div>
        
        <aura:if isTrue="{!v.ModalOpen}">
            <!--###### MODAL BOX Start From Here ######-->
            <div class="demo-only" style="height: 640px;">
                <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                    <div class="slds-modal__container">
                        <header class="slds-modal__header">
                            <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">You have {!if( v.isSubscribed,'subscribed','unsubscribed')} to this category.</h2>
                        </header>
                        <footer class="slds-modal__footer">
                            <button class="slds-button slds-button--brand" onclick="{!c.closeBttn}">Ok</button>
                        </footer>
                    </div>
                </section>
                <div class="slds-backdrop slds-backdrop_open"></div>
            </div>
            
            <div class="slds-backdrop slds-backdrop--open"></div>
            <!--###### MODAL BOX Part END Here ######-->
        </aura:if>
    </div>
    
</aura:component>