<aura:component controller="feedbackController"  implements="forceCommunity:availableForAllPageTypes" access="global">
    <aura:attribute name="IsValid" type="Boolean" default ="true"/>
     <aura:attribute name="IsDescriptionValid" type="Boolean" default ="false"/>
    <aura:attribute name="IsSubmitted" type="Boolean" default ="true"/>
    <aura:attribute name="options" type="List" access="global"/>
    <aura:attribute name="FieldWrapper" type="feedbackController.FieldsWrapper"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    <div>   
        <center>
            <aura:if isTrue="{!v.IsSubmitted}">
                <lightning:layout >
                    <lightning:layoutItem  padding="around-large" size="12">
                        <div aria-labelledby="feedbackform">
                            <!-- BOXED AREA -->
                            <fieldset class="slds-box slds-theme--default slds-container--small Alignlefttext">
                                <legend id="feedbackform" class="slds-text-heading--small slds-p-vertical--medium feedbackHeading" >
                                    Send us your Feedback!
                                </legend>                           
                                <form class="slds-form--stacked"> 
                                    <lightning:select label="Type" value="{!v.FieldWrapper.Type}" required="true" aura:id="Type" name="select"  accesskey="Type" class="slds-p-around_x-small" >
                                        <aura:iteration items="{!v.options}" var="option">
                                            <option text="{!option.label}" value="{!option.value}"/>
                                        </aura:iteration>                        
                                    </lightning:select> 
                                    <lightning:input class="slds-p-around_x-small" type="text" aura:id="Subject" accesskey="Subject" label="Subject"  required="true" value="{!v.FieldWrapper.Subject}" /> 
                                   <label class="desLabel">* Description</label>
                                    <lightning:inputRichText class="textAreaheigth slds-p-around_x-small" label="Description"   aura:id="Description" accesskey="Description" value="{!v.FieldWrapper.Description}"  onblur="{!c.validateDesc}" />   
                                    <aura:if isTrue="{!v.IsDescriptionValid}">
                                    	<span style="color:rgb(194, 57, 52);padding-left:9px;">Complete this field.</span>
                                    </aura:if>
                                    <aura:if isTrue="{!!v.IsValid}">
                                        <span style="color:red;font-family: gotham-light;">Please fill all required fields *</span>
                                    </aura:if>
                                    <lightning:button variant="brand" class="supportBtn btnPosition" onclick="{!c.SaveFormData}">Submit</lightning:button>
                                </form>
                            </fieldset>            
                        </div>
                    </lightning:layoutItem>
                </lightning:layout> 
            </aura:if>
            <aura:if isTrue="{!!v.IsSubmitted}">
                <center>
                    <div style="margin-top: 5%;margin-bottom:1%;font-family:Gotham-medium; font-size: 26px !important;">
                        Thanks for your valuable feedback!                    
                    </div>
                    <div style="margin-bottom:40px;">
                        <a href="#" onclick="{!c.changeForm}" class="hrefClass" style="margin-bottom: 3%;font-family: gotham-light;">Submit additional feedback</a>
                    </div>
                </center>
            </aura:if>
        </center>
    </div>
    
    
