<aura:component implements="forceCommunity:availableForAllPageTypes"  access="global">
    <aura:attribute name="accept" type="List" default="['.jpg', '.jpeg' '.tiff', '.gif', '.png', '.raw']"/>
    <aura:attribute name="multiple" type="Boolean" default="false"/>
    <aura:attribute name="disabled" type="Boolean" default="false"/>
    <aura:attribute name="caseObj" type="object" default=""/>
    <aura:attribute name="parentId" type="string" default=""/>
    <aura:attribute name="casenumber" type="string"/>
    
    <aura:handler name="init" action="{!c.doInit}" value="{!this}" />
    <div class="slds-grid">
       
        <div class="slds-size--1-of-1 ">
            <div class="slds-grid slds-wrap ">
                <div class="slds-col slds-large-size_1-of-12">
                </div>
                <div class="slds-col slds-large-size_10-of-12 uploadfilecls">
                    <div class="idsize">
                    Upload a File to Case {!v.casenumber}
                    </div>
                    <hr></hr>
                    <div>
                        
                        <p>Please choose the file you want to upload.</p>
                        <lightning:fileUpload  name="fileUploader"
                                              label= ""
                                              multiple="{!v.multiple}"
                                              recordId="{!v.parentId}"
                                              onuploadfinished="{! c.handleUploadFinished }"/>
                    </div>
                    <hr></hr>
                    <a class="padleft" href="{!$Label.c.Community_Base_URL+'viewcase?id='+v.parentId}"> <button class="slds-button slds-button_brand" onclick="">RETURN TO CASE</button></a>
                </div>
                <div class="slds-col slds-large-size_1-of-12">
                </div>
            </div>
        </div>
    </div>
</aura:component>