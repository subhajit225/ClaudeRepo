public class Batch_UpdatePSTaskCompletion implements Database.Batchable<sObject>, Schedulable, Database.RaisesPlatformEvents {
	
    public Database.QueryLocator start(Database.BatchableContext bc) {
        Set<String> setOmittedTaskType = new Set<String>{'T&E', 'Resident Engineer', 'Resident Engineer-PD'};
        Date todayDate = Date.today();
        Date lastMonthDate = todayDate.addDays(-1);    
        Date objStartDate = Date.newInstance( lastMonthDate.year() , lastMonthDate.month(), 26); //AND Hidden_Task_Completed_After_25__c=true
        String strquery = 'Select Id, Approved_Hours__c , Task_Type__c, Complete_till_25th__c, Billable_Hours_locked__c, Billable_Hours_Approved__c, Hidden_Task_Completed_After_25__c From PS_Task__c Where Task_Type__c Not In :setOmittedTaskType';
        
        if( Test.isRunningTest() ) {
            strquery += ' LIMIT 100';
        }
        return Database.getQueryLocator(strquery);
    }
    
    public void execute(SchedulableContext SC) {
        Database.executeBatch( new Batch_UpdatePSTaskCompletion() );
    }
    
    public void execute(Database.BatchableContext bc, List<PS_Task__c> lstTask) {
        List<PS_Task__c> lstTaskToUpdate = new List<PS_Task__c>();
        for( PS_Task__c objTask : lstTask ) {
            if( objTask.Billable_Hours_Approved__c > objTask.Billable_Hours_locked__c ) {
                objTask.Billable_Hours_locked__c = objTask.Billable_Hours_Approved__c;
                if(!objTask.Task_Type__c.contains('Non-Billable'))
                	objTask.Sync_to_Net_Suite__c = 'Sync to NetSuite';
                lstTaskToUpdate.add(objTask);
            }
        }
        if( !lstTaskToUpdate.isEmpty() ) {
            update lstTaskToUpdate;
        }
    }
    
    public void finish( Database.BatchableContext bc ){
    }
