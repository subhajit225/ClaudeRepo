public class CaseSummaryFeedbackController {
    
    /**
     * @description Method to fetch feedback records
     * @param relatedCaseId id of the case
     * @return List of  Case_Summary_by_Project_Genius_Feedback__c records
    */
    @AuraEnabled(cacheable=false)
    public static List<Case_Summary_by_Project_Genius_Feedback__c> getFeedbackRecord(Id relatedCaseId) {
        Id caseId;
        String recId = (String)relatedCaseId;
        if(recId.startsWith('500')){
            caseId = relatedCaseId;
        }
        else{
            caseId = [SELECT Id, Case__c FROM Assist_Request__c where Id =: recId].Case__c;
        }
        List<Case_Summary_by_Project_Genius_Feedback__c> feedbackRecords = [
            SELECT Id, Name, Case__c, User__c, Vote_Up__c, Vote_Down__c, VoteUp_Feedback_comment__c,Improvement_Suggestion__c, Problem_Type__c, Problem_in_Section__c, Automatically_Generated__c  
            FROM Case_Summary_by_Project_Genius_Feedback__c
            WHERE Case__c = :caseId AND User__c = :UserInfo.getUserId()
            ORDER BY CreatedDate DESC
        ];
        
        // Check if feedbackRecords has any records
        if (!feedbackRecords.isEmpty()) {
            return feedbackRecords;
        } else {
            return null; // Return null if no records are found
        }
    }
    
    /**
     * @description Method to save or update the record
     * @param feedbackRecord
    */
    @AuraEnabled
    public static void saveFeedbackRecord(Case_Summary_by_Project_Genius_Feedback__c feedbackRecord) {
        feedbackRecord.User__c = UserInfo.getUserId();
        Id caseId;
        String recId = (String)feedbackRecord.Case__c;
        if(recId.startsWith('500')){
            caseId = feedbackRecord.Case__c;
        }
        else{
            caseId = [SELECT Id, Case__c FROM Assist_Request__c where Id =: recId].Case__c;
            feedbackRecord.Case__c = caseId;
        }
        feedbackRecord.Automatically_Generated__c = ([Select AutoGenerated__c from SupportCaseIntelligence__c where Case__c =: caseId order by createddate desc limit 1]).AutoGenerated__c;
        insert feedbackRecord; // Upsert will insert if no ID, or update if an ID is present
    }

    /**
     * @description Method to get value of autogenerated field
     * @param caseId id of the case
     * @return ResponseBody
    */    
    @AuraEnabled(cacheable=true) 
    public static ResponseBody getAutoGeneratedField(Id caseId) {
        ResponseBody resBody = new ResponseBody();
        List<SupportCaseIntelligence__c> relatedRecord = new List<SupportCaseIntelligence__c>();
        if((String.valueOf(caseId)).startsWith('500')){
            relatedRecord = [SELECT id,AutoGenerated__c FROM SupportCaseIntelligence__c WHERE Case__c = :caseId LIMIT 1];
        }
        else{
            Id caseIdOfAR = [SELECT Id, Case__c FROM Assist_Request__c where Id =: caseId].Case__c;
            relatedRecord = [SELECT id,AutoGenerated__c FROM SupportCaseIntelligence__c WHERE Case__c = :caseIdOfAR LIMIT 1];
        }
        TimeZone tz = UserInfo.getTimeZone();
        if(relatedRecord.size()>0){
            resBody.autoGenerated = relatedRecord[0]?.AutoGenerated__c;
        }
        resBody.userTimeZone = tz.getID();
        resBody.userTimeZoneDisplayName = tz.getDisplayName();
        return resBody;
    }
    
    /**
     * @description wrapper class
    */   
    public class ResponseBody {
        @AuraEnabled public String autoGenerated;
        @AuraEnabled public String userTimeZone;
        @AuraEnabled public String userTimeZoneDisplayName;
    }
}