@isTest
private class CaseSummaryFeedbackControllerTest {

    @TestSetup
    static void setup() {
        // Create a test case record for use in test methods
        Account acc = new Account(name='testAcc');
        insert acc;

        Contact cont = new Contact(lastName='testCont');
        cont.Notify_For_case_creation__c = true;
        cont.Email=CaseTriggerHandler.JIRA_CASE_WEB_EMAIL;
        cont.AccountId=acc.Id;
        insert cont;
        
        Case cs = new case();
        cs.Accountid = acc.id;
        cs.contactid = cont.id;
        cs.Subject ='Test Case';
        cs.Origin = 'Alert';
        cs.Resolution__c = 'No Response';
        cs.Article_Created__c = false;
        cs.Resolution_Details__c  = 'test';
        cs.Next_Step__c = 'Test';
        cs.Current_Status__c  = 'testStatus';
        cs.Priority = 'P1';
        cs.CT_Rating__c = 'Gold';
        insert cs;
        
        // Create Supportcaseintelligence record for case ---
        SupportCaseIntelligence__c supportcase = new SupportCaseIntelligence__c(
            case__c = cs.Id,
            AutoGenerated__c = 'this is test'
        );
        
        insert supportcase;

        // Insert a test feedback record linked to the test case
        Case_Summary_by_Project_Genius_Feedback__c feedback = new Case_Summary_by_Project_Genius_Feedback__c(
            Case__c = cs.Id,
            User__c = UserInfo.getUserId(),
            Vote_Up__c = true,
            Vote_Down__c = false,
            VoteUp_Feedback_comment__c = 'Great!',
            Improvement_Suggestion__c = 'Add more details',
            Problem_Type__c = 'Inaccurate',
            Problem_in_Section__c = 'Overview'
        );
        insert feedback;
        
        // ----- insert AR record -----
        Assist_Request__c  ar = new Assist_Request__c (case__c = cs.Id);
        insert ar;
    }

    @isTest
    static void testGetFeedbackRecord() {
        // Fetch the test case created in @TestSetup
        Case testCase = [SELECT Id FROM Case LIMIT 1];

        // Fetch the feedback record using the controller method
        List<Case_Summary_by_Project_Genius_Feedback__c> result = new List<Case_Summary_by_Project_Genius_Feedback__c>();
        User testUser = [SELECT Id FROM User WHERE Profile.Name = 'System Administrator' AND IsActive = true LIMIT 1];
        System.runAs(testUser) {
            Test.startTest();
            result = CaseSummaryFeedbackController.getFeedbackRecord(testCase.Id);
            Test.stopTest();
        }
        System.assertEquals(UserInfo.getUserId(), UserInfo.getUserId(), 'Returned record should belong to the test user.');
    }

    @isTest
    static void testGetFeedbackRecordNoRecord() {
        // Create a new case with no feedback records associated
        Case newCase = new Case(Subject = 'Test Case Without Feedback',Priority = 'P1');
        insert newCase;

        // Fetch feedback record, expecting none to be found
        List<Case_Summary_by_Project_Genius_Feedback__c> result = new List<Case_Summary_by_Project_Genius_Feedback__c>();
        User testUser = [SELECT Id FROM User WHERE Profile.Name = 'System Administrator' AND IsActive = true LIMIT 1];
        System.runAs(testUser) {
            Test.startTest();
            result = CaseSummaryFeedbackController.getFeedbackRecord(newCase.Id);
            Test.stopTest();
        }

        // Assert that no record is found
        System.assertEquals(null, result, 'No feedback record should be found.');
    }

    @isTest
    static void testSaveFeedbackRecordInsert() {
        // Fetch the test case created in @TestSetup
        Case testCase = [SELECT Id FROM Case LIMIT 1];
        
        // Create Supportcaseintelligence record for case ---
        SupportCaseIntelligence__c supportcase = new SupportCaseIntelligence__c(
            case__c = testCase.Id,
            AutoGenerated__c = 'this is test'
        );
        
        insert supportcase;

        // Create a new feedback record to insert
        Case_Summary_by_Project_Genius_Feedback__c feedback = new Case_Summary_by_Project_Genius_Feedback__c(
            Case__c = testCase.Id,
            Vote_Up__c = false,
            Vote_Down__c = true,
            VoteUp_Feedback_comment__c = 'Good effort!',
            Improvement_Suggestion__c = 'Needs more data',
            Problem_Type__c = 'Others',
            Problem_in_Section__c = 'Overview'
        );

        // Call saveFeedbackRecord method
        User testUser = [SELECT Id FROM User WHERE Profile.Name = 'System Administrator' AND IsActive = true LIMIT 1];
        System.runAs(testUser) {
            Test.startTest();
            CaseSummaryFeedbackController.saveFeedbackRecord(feedback);
            Test.stopTest();
        }

        // Query to check if feedback record was inserted
        Case_Summary_by_Project_Genius_Feedback__c result = [SELECT Id, Case__c, User__c, Vote_Up__c, Vote_Down__c FROM Case_Summary_by_Project_Genius_Feedback__c WHERE Case__c = :testCase.Id AND Vote_Down__c = true LIMIT 1];
        System.assertNotEquals(null, result, 'Feedback record should be inserted.');
        System.assertEquals(result.User__c, result.User__c, 'Feedback record should have the correct user ID.');
    }
    
