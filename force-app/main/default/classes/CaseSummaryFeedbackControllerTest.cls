        CaseSummaryFeedbackController.ResponseBody result = new CaseSummaryFeedbackController.ResponseBody();
        System.runAs(testUser) {
            Test.startTest();
            result = CaseSummaryFeedbackController.getAutoGeneratedField(testCase.Id);
            Test.stopTest();
        }

        // Assert that the feedback record is retrieved correctly
        System.assertNotEquals(null, result, 'AutoGenerated value should be returned.');
    }

