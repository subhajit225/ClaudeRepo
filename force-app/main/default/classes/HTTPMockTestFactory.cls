            return res;
        }
        // Handle PUT requests for escalation (EscalateAhaIdeaRecord method)
        else if (req.getMethod() == 'PUT' && req.getEndpoint().contains('/ideas/')) {
            HTTPResponse res = new HTTPResponse();
            res.setHeader('Content-Type', 'application/json');
            res.setBody('{"success": true, "message": "Idea escalated successfully"}');
            res.setStatusCode(200);
            return res;
        }
        // Handle any PUT request to ideas endpoint
        else if (req.getMethod() == 'PUT') {
            HTTPResponse res = new HTTPResponse();
            res.setHeader('Content-Type', 'application/json');
            res.setBody('{"success": true, "message": "PUT request successful"}');
            res.setStatusCode(200);
            return res;
        }
        else{
            // Default response for any other endpoint
            HTTPResponse res = new HTTPResponse();
            res.setHeader('Content-Type', 'application/json');
            res.setBody('{"success": true}');
            res.setStatusCode(200);
            return res;
        }

    }

