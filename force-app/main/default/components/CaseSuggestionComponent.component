                                <apex:outputText escape="false" value="{!k}"/>
                            </apex:repeat>
                        </a>
                    </div>
                </div>
            </apex:repeat><br/>
        </apex:repeat>
    </div-->
    <div class="container-fluid" style="height:auto;">
        <table class="m_7201129186906164528MsoTableGrid" border="0" cellspacing="0" cellpadding="0" style="border-collapse:collapse;border:none">
            <tbody>
                <apex:variable var="count" value="{!0}"/>  <!-- Initialise-->
                <apex:repeat value="{!CaseRelatedSuggestion.result.hits}" var="i">
                    <apex:repeat value="{!i.highlight}" var="j">    
                        <apex:variable var="count" value="{!count+1}"/>
                        <tr>
                            <!--td width="53" style="width:40.1pt;padding:0in 5.4pt 0in 5.4pt">
                                <img src="{!i.icon}" width="40px"/>
                            </td-->
                            <td width="648" style="width:6.75in;padding:0in 5.4pt 0in 5.4pt">
                                <a href="{!i.href}" style="text-decoration: none;color:#009DAC;">
                                    <apex:repeat value="{!j.TitleToDisplay}" var="k">
                                        <p><apex:outputText escape="false" value="{!k}"/></p>
                                    </apex:repeat>
                                </a>
                            </td>
                        </tr>
                    </apex:repeat>
                </apex:repeat>
                <apex:repeat value="{!CaseWrapper}" var="i">
                    <apex:outputPanel rendered="{!count < 10}">
                        <tr>
                            <!--td width="53" style="width:40.1pt;padding:0in 5.4pt 0in 5.4pt">
                                <img src="{!i.icon}" width="40px"/>
                            </td-->
                            <td width="648" style="width:6.75in;padding:0in 5.4pt 0in 5.4pt">
                                <a href="{!i.href}" style="text-decoration: none;color:#009DAC;">
                                    <p><apex:outputText escape="false" value="{!i.caseNumber}"/></p>
                                </a>
                            </td>
                        </tr>
                        <apex:variable var="count" value="{!count+1}"/>
                    </apex:outputPanel>
                </apex:repeat>
            </tbody>
        </table>
    </div>    
</apex:component>