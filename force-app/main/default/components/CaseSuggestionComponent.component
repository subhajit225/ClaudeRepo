    <apex:attribute name="count" description="This will contain Row Count." type="Integer" assignTo="{!rowCount}" access="global"/>
    <style>
        p{
            margin-bottom: 4px;
        }
    </style>
    <!--div class="container-fluid" style="height:auto;">
        <apex:repeat value="{!CaseRelatedSuggestion.result.hits}" var="i">
