                            <apex:outputPanel rendered="{!IF(OR(cx.PricebookEntry.Product2.Name ==  'RA-PS-CON-ONST',cx.PricebookEntry.Product2.Name ==  'RA-PS-CON-RMOT', cx.PricebookEntry.Product2.Name =='RA-PS-INT',cx.PricebookEntry.Product2.Name ==  'RBK-PS-CNSLT-ONST',cx.PricebookEntry.Product2.Name ==  'RBK-PS-CNSLT-RMOT', cx.PricebookEntry.Product2.Name =='RBK-PS-INST'),false,true)}">
                                <apex:outputfield value="{!cx.Support_End_Date__c}" />
                            </apex:outputPanel>
                        </td>
                    </tr>
                </apex:repeat>
            </apex:outputPanel>

        </table>
