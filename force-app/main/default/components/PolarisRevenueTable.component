        <table width="100%" border="0" style="font-size:10px;">
            <tr>
                <td bgcolor="#f3f5f6" style="font-weight:bold;">&nbsp;</td>
                <td bgcolor="#f3f5f6" style="font-weight:bold;">Order Number</td>
                <td bgcolor="#f3f5f6" style="font-weight:bold;">Product</td>
                <td bgcolor="#f3f5f6" style="font-weight:bold;word-break: break-word;max-width:200px;min-width: 90px;">
                    Serial Number</td>
                <td bgcolor="#f3f5f6" style="font-weight:bold;">Description</td>
                <td bgcolor="#f3f5f6" style="font-weight:bold;">Total Quantity</td>
                <td bgcolor="#f3f5f6" style="font-weight:bold;">Fulfilled Quantity</td>
                <td bgcolor="#f3f5f6" style="font-weight:bold;">Support Start Date</td>
                <td bgcolor="#f3f5f6" style="font-weight:bold;">Support End Date</td>
            </tr>
            <apex:outputPanel rendered="{!!isRevenue}">
                <apex:repeat var="cx" value="{!lineItems}">
                    <apex:outputPanel rendered="{!IF(CONTAINS(cx.PricebookEntry.Product2.Bundle_Features__c,'Cloud Cluster'),true,false)}">
                        <apex:variable var="hasAWS" value="true" />
                    </apex:outputPanel>
                    <apex:outputPanel rendered="{!IF(CONTAINS(cx.PricebookEntry.Product2.Release_Product_Types__c,'PMC'),true,false)}">
                        <apex:variable var="hasPMC" value="true" />
                    </apex:outputPanel>
                    <apex:outputPanel rendered="{!AND(hasCodebaseRecoveryProduct != 'true',cx.PricebookEntry.Product2.Product_Type__c != '',  CONTAINS(cx.PricebookEntry.Product2.Product_Type__c, $Label.Codebase_Recovery))}">
                        <apex:variable var="hasCodebaseRecoveryProduct" value="true" />
                    </apex:outputPanel>
                    <apex:outputPanel rendered="{!AND(hasRSCProduct!= 'true', OR(cx.PricebookEntry.Product2.Product_Type__c == null , NOT(CONTAINS(cx.PricebookEntry.Product2.Product_Type__c, $Label.PredibaseProduct))))}">
                        <apex:variable var="hasRSCProduct" value="true" />
                    </apex:outputPanel>
                    <apex:outputPanel rendered="{!AND(hasPredibaseProduct != 'true',cx.PricebookEntry.Product2.Product_Type__c != '',  CONTAINS(cx.PricebookEntry.Product2.Product_Type__c, $Label.PredibaseProduct))}">
                        <apex:variable var="hasPredibaseProduct" value="true" />
                    </apex:outputPanel>
                    <tr>
                        <td>
                            <b>
                                <apex:outputlink value="{!cx.PricebookEntry.Product2.Welcome_Letter_Content__c}" rendered="{!cx.PricebookEntry.Product2.Welcome_Letter_Content__c!=null}">
                                    <apex:outputtext value=">> Get Started" />
                                </apex:outputlink>
                            </b>
                        </td>
                        <td>
                            <apex:outputfield value="{!cx.Order.OrderNumber}" />
                        </td>
                        <td>
                            <apex:outputfield value="{!cx.PricebookEntry.Product2.Name}" />
                        </td>
                        <td>
                        </td>
                        <td>
                            <apex:outputfield value="{!cx.PricebookEntry.Product2.Description}" />
                        </td>
                        <td>
                            <apex:outputfield value="{!cx.Quantity}" />
                        </td>
                        <td>
                            <apex:outputfield value="{!cx.Quantity}" />
                        </td>
                        <td>
                            <apex:outputfield value="{!cx.Support_Start_Date__c}" />
                        </td>
                        <td>
                            <apex:outputfield value="{!cx.EndDate}" />
                        </td>
                    </tr>
                </apex:repeat>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!isRevenue}">
