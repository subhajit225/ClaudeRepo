                                    <apex:outputtext value=">> Get Started" />
                                </apex:outputlink>
                            </b>
                        </td>
                        <td>
                            <apex:outputfield value="{!cx.Order.OrderNumber}" />
                        </td>
                        <td>
                            <apex:outputfield value="{!cx.PricebookEntry.Product2.Name}" />
                        </td>
