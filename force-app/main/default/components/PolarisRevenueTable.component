<apex:component access="global" controller="PolarisOrderTemplateClass">
    <apex:attribute name="orderId" description="Receive Order Id" type="Id" required="required" assignTo="{!ordId}" />
    <apex:variable var="doShow" value="false" />
    <apex:variable var="hasAWS" value="false" />
    <apex:variable var="hasCompleteEdition" value="false" />
    <apex:variable var="CompleteEdition" value="" />
    <apex:variable var="hasPMC" value="false" />
    <apex:variable var="hasCodebaseRecoveryProduct" value="false" />
    <apex:variable var="hasRSCProduct" value="false" />
    <apex:variable var="hasPredibaseProduct" value="false" />

    <apex:outputPanel rendered="{!hardwarEmailType}">
        <apex:repeat var="cx" value="{!lineItemsForHardware}">
            <b>Serial number (Chassis Serial number):</b> {!cx.SerialNumber}
            <br/>
            <b>Related software order number(s):</b> {!cx.OrderNumber}
        </apex:repeat>
    </apex:outputPanel>

    <apex:outputPanel rendered="{!!hardwarEmailType}">
