                                <apex:outputfield value="{!cx.Support_Start_Date__c}" />
                            </apex:outputPanel>
                        </td>
                        <td>
                            <apex:outputPanel rendered="{!IF(OR(cx.PricebookEntry.Product2.Name ==  'RA-PS-CON-ONST',cx.PricebookEntry.Product2.Name ==  'RA-PS-CON-RMOT', cx.PricebookEntry.Product2.Name =='RA-PS-INT',cx.PricebookEntry.Product2.Name ==  'RBK-PS-CNSLT-ONST',cx.PricebookEntry.Product2.Name ==  'RBK-PS-CNSLT-RMOT', cx.PricebookEntry.Product2.Name =='RBK-PS-INST'),true,false)}">
                                <apex:outputText value="{0,date,M'/'d'/'yyyy}">
                                    <apex:param value="{!ADDMONTHS(cx.Order.Actual_Order_Ship_Date__c,6)-1}" />
                                </apex:outputText>
