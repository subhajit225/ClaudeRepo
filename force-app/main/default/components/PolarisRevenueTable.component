        <br /> In addition, we&#39;ve included helpful information below to get you started with your Rubrik solutions and services.
        <br/>

        <!-- Added component as per ticket CS21-2607 -->
        <apex:outputPanel rendered="{!!isRevenue}">
            <c:WelcomeLetterForSFDataProtection orderId="{!orderId}"></c:WelcomeLetterForSFDataProtection>
        </apex:outputPanel>
        <!-- Added component as per ticket CS21-2607 -->

