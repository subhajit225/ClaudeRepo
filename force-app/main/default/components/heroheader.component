<apex:component controller="SearchController">
    <style>
        .row{ margin:0px!important;}
        body{margin:0px!Important;}
        .headerbacktop{margin:0px !important;height: 36px !important ;}
        .homeBannerBlock{background-image: url('{!URLFOR($Resource.RubrikCustomerCommunity,'RubrikCommunity/Images/banner.png')}');background-repeat: no-repeat;background-size: cover;}
        .center-block {float: none;margin-left: auto;margin-right: auto;}
        .searchBoxContainer{margin:40px 40px 80px 40px;}        
        .welcomeToCommunity{color:white !important;text-align: center;font-size:48px !important;margin-bottom: 30px !important;}
        .input-group .icon-addon .form-control {border-radius: 0;}
        .nopad{padding:0px;}
        .icon-addon {position: relative;color: #555;display: block;}
        .searchText > input{height:56px !important;width:600px !important;border-radius:2px !important;}
        .searchText{margin-left: 50px;}   
        .icon-addon:after,.icon-addon:before {display: table;content: " ";}
        .icon-addon:after {clear: both;}
        .icon-addon.addon-md .glyphicon,.icon-addon .glyphicon,.icon-addon.addon-md .fa,.icon-addon .fa {position: absolute;z-index: 2;font-size: 14px;width: 20px;margin-left: -2.5px;text-align: center;padding: 10px 0;top: 1px}
        .icon-addon.addon-lg .form-control {line-height: 1.33;height: 46px;font-size: 14px;padding:0px 0px 0px 15px;}
        .icon-addon.addon-sm .form-control {height: 30px;padding: 0px;font-size: 12px;line-height: 1.5;}
        button.input-group-addon {position: absolute;z-index: 2;font-size: 14px;width: 20px;margin-left: -2.5px;text-align: center;padding: 10px 0;top: 1px}
        .icon-addon.addon-lg .fa,.icon-addon.addon-lg .glyphicon {font-size: 26px;margin-left: 0;right: -100px;top: 5px;}
        .icon-addon .form-control:focus + .glyphicon,.icon-addon:hover .glyphicon,.icon-addon .form-control:focus + .fa,.icon-addon:hover .fa {color: #2580db;}
        .susearchBoxContainer.su-p-input-header { width: 60%;margin: 0 auto;}  
        .susearchBoxContainer .su-p-input-header__input{height:50px !important;font-size:1.2em !important}
        .susearchBoxContainer.su-p-input-header{margin-top:15px !important;}
        .susearchBoxContainer.su-p-input-header{padding:0px !important;}
        
        @media only screen and (min-width : 924px) and (max-width : 1224px){
        .searchText {margin-left: -25px;}
        .searchBoxContainer{margin:40px;} 
        }
         @media only screen and (min-width : 480px) and (max-width : 767px){
        .searchBoxContainer{margin:40px;} 
        }
        @media only screen and (min-width : 767px) and (max-width : 923px){
        .searchBoxContainer{margin:40px;} 
        }
    </style>
    <div class="row homeBannerBlock">
        <div class="container searchBoxContainer block">
            <h1 class='welcomeToCommunity'>Welcome to <b style="font-family: Gotham-medium;">Rubrik</b> Support</h1>
            <su_vf_community:SU_Vf_CommunitySearchBox placeHolderContent="Search everything…"/>
           <!-- <form method="GET" action="{!$Page.UnifiedSearch}" _lpchecked="1" class="col-md-12">
                <div class="col-sm-offset-2 col-sm-6 block hidden-sm hidden-xs">
                    <div class="icon-addon addon-lg block searchText">
                        <input type="text" placeholder="Enter your keyword here" class="form-control" name="search" id="search" style=""/>
                        <label for="search" class="glyphicon glyphicon-search" rel="tooltip" title="search"></label>
                    </div> 
                </div>
            </form>  -->   
        </div>
    </div><!--end container-->
</apex:component>