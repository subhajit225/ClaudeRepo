<apex:component controller="SearchController">
<style>
.center-block {
    float: none;
    margin-left: auto;
    margin-right: auto;
}

.input-group .icon-addon .form-control {
    border-radius: 0;
}

.icon-addon {
    position: relative;
    color: #555;
    display: block;
}

.icon-addon:after,
.icon-addon:before {
    display: table;
    content: " ";
}

.icon-addon:after {
    clear: both;
}

.icon-addon.addon-md .glyphicon,
.icon-addon .glyphicon, 
.icon-addon.addon-md .fa,
.icon-addon .fa {
    position: absolute;
    z-index: 2;
    font-size: 14px;
    width: 20px;
    margin-left: -2.5px;
    text-align: center;
    padding: 10px 0;
    top: 1px
}

.icon-addon.addon-lg .form-control {
    line-height: 1.33;
    height: 46px;
    font-size: 18px;
    padding: 10px 16px 10px 40px;
}

.icon-addon.addon-sm .form-control {
    height: 30px;
    padding: 5px 10px 5px 28px;
    font-size: 12px;
    line-height: 1.5;
}

  button.input-group-addon {
    position: absolute;
    z-index: 2;
    font-size: 14px;
    width: 20px;
    margin-left: -2.5px;
    text-align: center;
    padding: 10px 0;
    top: 1px
}

.icon-addon.addon-lg .fa,
.icon-addon.addon-lg .glyphicon {
    font-size: 26px;
    margin-left: 0;
    right: -40px;
    top: 4px;
}


.icon-addon .form-control:focus + .glyphicon,
.icon-addon:hover .glyphicon,
.icon-addon .form-control:focus + .fa,
.icon-addon:hover .fa {
    color: #2580db;
}

    .herogroups {
    font-family: Gotham-Light;
    font-weight: bold;
    font-size: 21px;
    line-height: 19px;
    padding-bottom: 4px;
    color: #FFFFFF;
    }

    a.herogroups {
    font-family: Gotham-Light;
    font-weight: bold;
    font-size: 21px;
    line-height: 19px;
    padding-bottom: 4px;
    color: #FFFFFF !important;
    }

    a.herogroups:hover {
    font-family: Gotham-Light;
    font-weight: bold;
    font-size: 21px;
    line-height: 19px;
    padding-bottom: 4px;
    color: #009DAC !important;
    }

    a.herolinks{
        font-size: 14px;
        line-height: 24px;
        color: #FFFFFF;
        }
        
    a.herolinks:before{
        padding: 0;
        content: "\00BB \0020";
        color: #FFFFFF;
        }

    .pmaingradient {
        min-height: 299px;
        //background-image: "{!URLFOR($Resource.pherobackground1)}";
        }        
    
</style>
<div class="row pmaingradient hidden-sm hidden-xs" style="background-image:url('{!URLFOR($Resource.pherobackground1)}'); background-repeat:no-repeat;background-attachment:fixed;background-position:center top;">
    <div class="container block">

    
    <!--top row-->
    <div class="row block ">
    <div class="col-md-12 block">
             <form method="GET" action="{!$Page.UnifiedSearch}" _lpchecked="1" class="col-md-12" style="margin:48px;">
              <div class="col-sm-offset-2 col-sm-6 block hidden-sm hidden-xs">

                     <div class="icon-addon addon-lg block">
                        <input type="text" placeholder="search resources..." class="form-control" name="search" id="search" style="height:56px; width:590px;"/>
                        <label for="email" class="glyphicon glyphicon-search" rel="tooltip" title="email"></label>
                    </div> 
                 

                </div>   
             </form>      
           
    </div>
    </div>
    <!--bottom row-->
    
    <div class="row">
      <div class="col-md-1 block hidden-sm hidden-xs"><a href="{!URLFOR($Page.PResources)}"><apex:image value="{!$Resource.presources}" style="width: 52px;"/></a></div>
      <div class="col-md-2 block">
      <div class="herogroups"><a href="{!URLFOR($Page.PResources)}" class="herogroups">Resources</a></div>
      <a href="{!URLFOR($Page.PResources, null, [scope='Technical'])}" class="herolinks">Technical</a><br/>
      <a href="{!URLFOR($Page.PResources, null, [scope='Sales'])}" class="herolinks">Sales</a><br/>
      <a href="{!URLFOR($Page.PResources, null, [scope='Marketing'])}" class="herolinks">Marketing</a>

      </div>
      <div class="col-md-1 block"><!--empty--></div>
      <div class="col-md-1 block hidden-sm hidden-xs"><a href="{!URLFOR($Page.DealRegHome)}"><apex:image value="{!$Resource.pdealreg}" style="width: 52px; "/></a></div>
      <div class="col-md-2 block"><div class="herogroups"><a href="{!URLFOR($Page.DealRegHome)}" class="herogroups">Deal Registration</a></div>
      <apex:outputLink value="{!URLFOR($Page.DealRegTcs)}" styleClass="herolinks">Register a Deal</apex:outputLink><br/>
      </div>
      <div class="col-md-1 block"><!--empty--></div>
      <div class="col-md-1 block hidden-sm hidden-xs"><a href="{!URLFOR($Page.PTrainingDoce)}"><apex:image value="{!$Resource.ptraining}" style="width: 52px;"/></a></div>
      <div class="col-md-2 block"><div class="herogroups"><a href="{!URLFOR($Page.PTrainingDoce)}" class="herogroups">Training</a></div>
      <apex:outputLink value="{!URLFOR($Page.PTrainingDoce)}" styleClass="herolinks">Get Smart</apex:outputLink><br/>
      </div>
      <div class="col-md-1"><!--empty--></div>
    </div>
    
    

    </div><!--end container-->
   </div>
 
    

</apex:component>