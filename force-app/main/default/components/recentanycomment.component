<apex:component controller="CaseSubHistoryController" access="global">
<apex:attribute name="thecaseId" assignTo="{!cseId}" type="String" description="Id of the case"/>  
<apex:attribute name="privatecomment" assignTo="{!isPrivate}" type="boolean" description="If the comment to filter on is private or not"/>  

<apex:repeat value="{!AnyComment}" var="cc">
<apex:outputtext value="{!IF(cc.isPublished, '', ' (Private Comment) ')}"/><BR/><apex:outputField value="{!cc.CommentBody}"></apex:outputField>
</apex:repeat>
</apex:component>