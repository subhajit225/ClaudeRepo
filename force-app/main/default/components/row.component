<apex:component layout="none" >
    
    <apex:attribute name="style" type="String" description="A inline style that to be applied to the component" required="false"/>
    <apex:attribute name="styleclass" type="String" description="The CSS style class to be used with the component"  required="false"/>

    
    <apex:outputPanel layout="block" styleClass="row {!styleclass}" style="{!style}">
        <apex:componentBody />
    </apex:outputPanel>
</apex:component>