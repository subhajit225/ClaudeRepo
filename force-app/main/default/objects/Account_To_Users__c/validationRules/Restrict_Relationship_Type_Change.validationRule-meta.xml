<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Restrict_Relationship_Type_Change</fullName>
    <active>true</active>
    <description>To Restrict Relationship Type Change</description>
    <errorConditionFormula>ISCHANGED(Relationship_Type__c)</errorConditionFormula>
    <errorDisplayField>Relationship_Type__c</errorDisplayField>
    <errorMessage>Relationship Type can not be changed once enter. Please create new record with different Relationship Type.</errorMessage>
</ValidationRule>
