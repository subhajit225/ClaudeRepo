<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Usage_Quantity__c</fullName>
    <externalId>false</externalId>
    <formula>IF(AND(ISPICKVAL(Account_Id__r.Type,&apos;MSP-Reseller&apos;),ISPICKVAL(Order_Service_Item__r.Product2.License_Type__c ,&apos;Consumption&apos;)),99999 ,
        IF(AND(ISPICKVAL(Account_Id__r.Type,&apos;MSP&apos;),ISPICKVAL(Order_Service_Item__r.Product2.License_Type__c ,&apos;Consumption&apos;)),99999 ,
        IF(AND(ISPICKVAL(Account_Id__r.Type,&apos;MSP Customer&apos;),ISPICKVAL(Order_Service_Item__r.Product2.License_Type__c ,&apos;Consumption&apos;)),99999 ,
        IF(AND(ISPICKVAL(Account_Id__r.Type,&apos;Customer&apos;),CONTAINS(UPPER(Account_Id__r.Name), &apos;RUBRIK&apos;)),99999 ,
        IF(AND(ISPICKVAL(Account_Id__r.Type,&apos;Customer&apos;),ISPICKVAL(Product__r.License_Subtype__c, &apos;ELA&apos;)),99999,
        IF(CONTAINS(Order_Service_Item__r.Product2.ProductCode, &quot;DELL-6420&quot;),4*Order_Service_Item__r.Quantity ,Order_Service_Item__r.Quantity))))))</formula>
    <label>Usage Quantity</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
