<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Justifications_is_required</fullName>
    <active>true</active>
    <description>Replaced Justifications__c with CCR_Subtype__c for SAL26-441</description>
    <errorConditionFormula>AND(
    RecordType.DeveloperName = &apos;Sales_CCR&apos;, ISBLANK(TEXT(CCR_Subtype__c)),
