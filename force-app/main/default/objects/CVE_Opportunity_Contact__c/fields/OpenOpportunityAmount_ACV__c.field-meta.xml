<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>OpenOpportunityAmount_ACV__c</fullName>
    <description>SAL25-641: shows amount ACV if opportunity is open</description>
    <formula>IF(
 AND(Opportunity__c != null, !Opportunity__r.IsClosed),
 Opportunity__r.ACV_Amount__c,
 0
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Open Opportunity Amount (ACV)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
