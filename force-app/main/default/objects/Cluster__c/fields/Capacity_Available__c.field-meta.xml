<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Capacity_Available__c</fullName>
    <description>Capacity left to be utilised</description>
    <formula>IF(
Capacity_Total__c &gt; 0.00,
( Capacity_Total__c  - ( Capacity_Snapshot__c  +  Capacity_System__c )) /  Capacity_Total__c,
0
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Capacity Available</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
