<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Delta__c</fullName>
    <description>Number of days between Linked Existing/New Oppty and Linked DR</description>
    <externalId>false</externalId>
    <formula>IF(ISBLANK( New_Opportunity__c ),( Deal_Registration__r.CreatedDate - Existing_Opportunity__r.CreatedDate),(Deal_Registration__r.CreatedDate - New_Opportunity__r.CreatedDate))</formula>
    <inlineHelpText>Number of days between Linked Existing/New Oppty and Linked DR Created Dates</inlineHelpText>
    <label>Delta</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
