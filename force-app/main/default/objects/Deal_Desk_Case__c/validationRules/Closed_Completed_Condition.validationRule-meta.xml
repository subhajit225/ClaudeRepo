<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Closed_Completed_Condition</fullName>
    <active>false</active>
    <errorConditionFormula>AND(ISCHANGED(Request_Status__c),
ISPICKVAL(Request_Status__c, &apos;Closed - Completed&apos;),
!ISPICKVAL(PRIORVALUE(Request_Status__c),&quot;Approved&quot;), !ISPICKVAL(PRIORVALUE(Request_Status__c),&quot;Rejected&quot;),
!ISPICKVAL(PRIORVALUE(Request_Status__c),&quot;Conditionally Approved&quot;))</errorConditionFormula>
    <errorDisplayField>Request_Status__c</errorDisplayField>
    <errorMessage>Only an Approved or Rejected case can be marked as Closed - Completed</errorMessage>
</ValidationRule>
