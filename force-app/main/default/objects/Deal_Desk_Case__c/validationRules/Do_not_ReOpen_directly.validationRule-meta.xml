<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Do_not_ReOpen_directly</fullName>
    <active>false</active>
    <errorConditionFormula>ISCHANGED(Request_Status__c) &amp;&amp; ISPICKVAL(Request_Status__c,&apos;Draft&apos;) &amp;&amp; !ISPICKVAL(ApprovalStatus__c,&apos;&apos;)</errorConditionFormula>
    <errorDisplayField>Request_Status__c</errorDisplayField>
    <errorMessage>You can&apos;t ReOpen the case directly from here. Click ReOpen button above if you want to reopen the case.</errorMessage>
</ValidationRule>
