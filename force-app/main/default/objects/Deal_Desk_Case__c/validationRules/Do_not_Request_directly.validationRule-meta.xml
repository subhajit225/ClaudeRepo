<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Do_not_Request_directly</fullName>
    <active>false</active>
    <errorConditionFormula>ISCHANGED(Request_Status__c) &amp;&amp; ISPICKVAL(Request_Status__c,&apos;Requested&apos;) &amp;&amp; !ISPICKVAL(ApprovalStatus__c,&apos;Pending&apos;)</errorConditionFormula>
    <errorDisplayField>Request_Status__c</errorDisplayField>
    <errorMessage>You can&apos;t Request the case directly from here, submit the case for approval then it will be auto requested</errorMessage>
</ValidationRule>
