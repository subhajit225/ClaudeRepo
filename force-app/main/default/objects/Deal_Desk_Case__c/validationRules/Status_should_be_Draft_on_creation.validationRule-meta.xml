<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Status_should_be_Draft_on_creation</fullName>
    <active>false</active>
    <errorConditionFormula>ISNEW() &amp;&amp; !ISPICKVAL(Request_Status__c,&apos;Draft&apos;)</errorConditionFormula>
    <errorDisplayField>Request_Status__c</errorDisplayField>
    <errorMessage>A deal desk case can only be created with Draft status</errorMessage>
</ValidationRule>
