<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Summary_of_Approval_Required</fullName>
    <active>false</active>
    <errorConditionFormula>ISPICKVAL(Request_Status__c,&apos;Closed - Completed&apos;) &amp;&amp;
ISBLANK(Summary_of_Approval__c)</errorConditionFormula>
    <errorDisplayField>Summary_of_Approval__c</errorDisplayField>
    <errorMessage>You can&apos;t close the Case without providing Summary of Approval</errorMessage>
</ValidationRule>
