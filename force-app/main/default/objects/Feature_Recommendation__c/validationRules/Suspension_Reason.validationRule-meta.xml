<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Suspension_Reason</fullName>
    <active>true</active>
    <description>Suspended reason is necessary for suspended status</description>
    <errorConditionFormula>AND(ISPICKVAL(Status__c,&quot;Suspended&quot;), ISBLANK(Suspended_Reason__c))</errorConditionFormula>
    <errorMessage>Please enter suspended reason</errorMessage>
</ValidationRule>
