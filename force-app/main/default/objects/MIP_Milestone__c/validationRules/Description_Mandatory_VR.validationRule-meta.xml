<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Description_Mandatory_VR</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
OR(ISPICKVAL(Milestone_Type__c,&apos;Other&apos;)),
ISBLANK( Activity_Description__c))</errorConditionFormula>
    <errorDisplayField>Activity_Description__c</errorDisplayField>
    <errorMessage>Please add an activity description when type is Other</errorMessage>
</ValidationRule>
