<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Support_Case_Required_For_Product_Issues</fullName>
    <active>true</active>
    <errorConditionFormula>AND(TEXT(Area__c) = &quot;Product Issue&quot;,   ISBLANK(Case__c), ISBLANK( TEXT(Impact__c )))</errorConditionFormula>
    <errorDisplayField>Case__c</errorDisplayField>
    <errorMessage>A support case is required to open a Product Issue</errorMessage>
</ValidationRule>
