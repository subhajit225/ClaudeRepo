<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Return_Date_is_mandatory</fullName>
    <active>true</active>
    <errorConditionFormula>ISPICKVAL(Status__c, &apos;Returned&apos;) 
&amp;&amp; (
ISBLANK( Returned_date__c )
||  ISBLANK(Retrun_Tracking_Number__c)
)</errorConditionFormula>
    <errorMessage>Please fill the return date and the return tracking number</errorMessage>
</ValidationRule>
