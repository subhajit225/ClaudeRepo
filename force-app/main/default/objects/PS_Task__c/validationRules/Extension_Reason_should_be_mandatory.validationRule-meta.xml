<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Extension_Reason_should_be_mandatory</fullName>
    <active>true</active>
    <errorConditionFormula>AND(NOT(ISNULL(Extended_End_date__c)), ISBLANK(Extension_Reason__c ))</errorConditionFormula>
    <errorDisplayField>Extension_Reason__c</errorDisplayField>
    <errorMessage>Extension reason is mandatory while adding extended end date</errorMessage>
</ValidationRule>
