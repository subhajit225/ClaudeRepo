<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Task_status_updation_validation</fullName>
    <active>true</active>
    <errorConditionFormula>NOT($Permission.Rubrik_Professional_Services_Operations) &amp;&amp; ISCHANGED( Task_Status__c ) &amp;&amp;
