<style>
.msgContainer{
border: 1.2px solid #236fbd;
    background-color: aliceblue;
    margin: 10px;
    border-radius: 7px;
    padding: 10px;
    width: max-content;
}
.msgHeader{
font-family: Arial,Helvetica,sans-serif;
    font-size: 1.083em;
    color: #167cb1;
    font-weight: bold;
}

.msgContent{
color: #167cb1;
}
.message{
  width: max-content;
  padding-right: 40px;
}

 .pbTitle{
    font-weight:600;
 }
body .bPageBlock .pbHeader {
    margin:10px; 
}
.highlight
    {
        background-color: #2cc11a40;
    }

