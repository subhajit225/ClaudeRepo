   background-color: white;
   //text-align: center !important;
}
tr.dataRow td{
  //text-align: center !important;
} */
.loadCenter{
  position: fixed;
  top: 50%;
  left: 50%;
}

.close{
    width: 27px;
    position: absolute;
    border: 1px solid;
    background: white;
    border-radius: 50% !important;
    top: 15px;
    //height: 10%;
    right: 7px;
}


.infomsg{
    color: #167cb1;
    font-weight: bold;
    padding-left:31px;
}
.overview_background{
   background-color: white;
}
.custPopup{  
            z-index: 9999;
            padding:10px;
            position: absolute;
            top:10px;
            height: 90vh;
            width: 70vw;
           
        }
        .popupBackground{
            background-color:black;
            opacity: 0.20;
            filter: alpha(opacity = 20);
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            z-index: 9998;
        }
        
        .odd { 
        background-color:white;
        }
        .even {
        background-color: lightgrey;
        }
   .custombtn{
    background-color: rgba(221, 219, 218, 0.25);
    border: solid #80808094 1px;
    border-radius: 4px;
    padding: 5px;
    margin: 2px;
    font-weight: 0.2 px;
    display: inline-block;
    margin: 6px;
    cursor: pointer;
        }
