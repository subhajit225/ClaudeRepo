<script type="text/javascript">
  function setLoader(status,elename) {
    if (status) {
    debugger;
      if(elename=='loadingAccSearch') 
      document.querySelectorAll("[id$=accTable]")[0].style.display = 'none';
           document.getElementById(elename).style.display = 'block';
    }
    else {
      document.getElementById(elename).style.display = 'none';
    }
  }
  function getStateName(){
  debugger;
   var stateNode = document.querySelectorAll("[id$=statecode]")[0]; 
   document.getElementById('{!$Component.accSearchForm.BillingStateName}').value = stateNode.options[stateNode.selectedIndex].text;
  }
</script>
   <apex:form id="accSearchForm">
          

  <apex:inputHidden id="BillingStateName" value="{!BillingStateName}" />
   <apex:outputPanel rendered="{!ShowAccount}">
      <apex:pageBlock title="Account Search" mode="maindetail">
              <apex:pageBlockButtons location="top"> 
                <apex:commandButton onclick="getStateName()" action="{!createSearchAccount}" value="Search/Create Account" reRender="accTable,error" status="loading"/>             
                    <apex:actionStatus id="loading" onstart="setLoader(true,'loadingAccSearch')" onstop="setLoader(false,'loadingAccSearch')" /> 
            </apex:pageBlockButtons>
            <apex:pageBlockSection title="" collapsible="false" columns="2">
                 <apex:inputfield value="{!searchAccount.Name}" style="width:250px;"/>  
                  <apex:inputfield label="Billing Country" value="{!searchAccount.Billingcountrycode}" required="true"/> 
                  <apex:inputfield label="Billing State" value="{!searchAccount.BillingStateCode}" id="statecode"/>
                 <apex:inputfield label="Billing City" value="{!searchAccount.BillingCity}"/>
                  <apex:inputfield label="Billing Street" value="{!searchAccount.BillingStreet}"/>
                  
                  <apex:inputfield label="Billing Postal code" value="{!searchAccount.BillingpostalCode}"/>
                  <apex:inputfield value="{!searchAccount.isFederalIntel__c}"/>
                 <apex:inputfield label="Telephone" value="{!searchAccount.Phone}"/>
                 <apex:inputfield label="Website" value="{!searchAccount.Website}"/>
                 </apex:pageBlockSection>
                 
   </apex:pageBlock>
    <!--<apex:outputText styleclass="infomsg mainTitle" value="Note:
To search for account — Enter Account Name & Billing Country
To create new account — Enter Account Name, Billing Street, Billing Country, and either Billing City, Billing State or Billing Postal Code"/> -->

<div class="msgContainer">
    <div class="msgHeader"> NOTE </div>
     <div class="msgContent"> To search for an Account - Enter Account Name &amp; Billing Country  </div>
     <apex:outputText styleClass="msgContent" value="To create new Account - Enter Account Name, Billing Street, Billing Country, and either Billing City, Billing State or Billing Postal Code" rendered="{!$ObjectType.Account.fields.isFederalIntel__c.Updateable == false}"></apex:outputText>
     <div><apex:outputText styleClass="msgContent" value="To create a new Federal Account - Enter Account Name & Billing Country" rendered="{!$ObjectType.Account.fields.isFederalIntel__c.Updateable }"></apex:outputText></div>
     <apex:outputText styleClass="msgContent" value="To create new Non-Federal Account - Enter Account Name, Billing Street, Billing Country, and either Billing City, Billing State or Billing Postal Code" rendered="{!$ObjectType.Account.fields.isFederalIntel__c.Updateable }"></apex:outputText>
    
</div>
   <div class="slds-m-horizontal_small slds-m-top_xx-large">
   <apex:pageMessages id="error"></apex:pageMessages>
   </div>
 <div id="loadingAccSearch" style="display:none;margin-top: 60px;">
    <div style="text-align: center;"> Loading...
      <img src="/img/loading.gif" alt="Loading graphic" style="height: 25px;"/>
    </div>
  </div>
   
  
   
   
    <apex:outputPanel id="accTable">
       <apex:pagemessage severity="info" summary="Salesforce internal search result" strength="2" rendered="{!searchType=='SF Internal'}"/>
 <!--  <div style="margin-top:50px;"> -->
   
    <div style="padding:10px;"/>
    <apex:pageBlock title="Similar accounts found" rendered="{!potentialMatch.size>0}"> 
    <apex:variable var="index" value="{!0}"/>
       <div style="overflow: scroll; max-height: 200px;">
        <apex:pageBlockTable value="{!potentialMatch}" var="accRes" rowClasses="even,odd"> <!--style="display: block;  max-height: 200px;overflow-y: scroll"-->
               <apex:column value="{!accRes.accountName}"> 
             <apex:facet name="header">Name</apex:facet>
          </apex:column>
          <apex:column value="{!accRes.accountStatus}"> 
             <apex:facet name="header">Status</apex:facet>
          </apex:column>
           <apex:column value="{!accRes.recTypeName}"> 
                            <apex:facet name="header">Record Type</apex:facet> 
                        </apex:column>      
         <apex:column value="{!accRes.AccountOwner}"> 
                           <apex:facet name="header">Owner</apex:facet>
                        </apex:column> 
          <apex:column value="{!accRes.sourceID}" > 
                            <apex:facet name="header">ID</apex:facet>
                        </apex:column> 
                        <apex:column value="{!accRes.addressLine1} {!accRes.addressLine2}" > 
                            <apex:facet name="header">Billing Street</apex:facet>
                        </apex:column>
                        <apex:column value="{!accRes.city}" > 
                            <apex:facet name="header">Billing City</apex:facet>
                        </apex:column>
                        <apex:column value="{!accRes.state}"> 
                            <apex:facet name="header">Billing State</apex:facet>
                        </apex:column>
                        <apex:column value="{!accRes.postalCode}"> 
                            <apex:facet name="header">Billing Postal Code</apex:facet>
                        </apex:column>
                        <apex:column value="{!accRes.country}" > 
                            <apex:facet name="header">Billing Country</apex:facet>
                        </apex:column> 
         <apex:column > 
           <apex:commandLink rendered="{!IF(accRes.sourceID==null,true,false)}" action="{!RequestAccCreation}" value="Create" styleClass="btn"  style="padding: 4px 3px;color: #000000c4;
    text-decoration: none;"> 
           <apex:param name="create" value="{!index}-pm"
                assignTo="{!selectedRow}"/>
                </apex:commandLink>
           <apex:commandLink rendered="{!IF(accRes.sourceID!=null,true,false)}" action="{!AccRedirect}" value="View" styleClass="btn" style="padding: 4px 3px;color: #000000c4;
    text-decoration: none;">
           <apex:param name="edit" value="{!accRes.sourceID}"
                assignTo="{!RedirectTo}"/>
                </apex:commandLink>
          <apex:variable var="index" value="{!index +1}"/>
         </apex:column>
         </apex:pageBlockTable>
         </div>
   </apex:pageBlock> 
   
   <div style="padding:10px;"/>
   <apex:pageBlock title="{!IF(exactMatch.size==1,IF(exactMatch[0].newAccount=='Y'||exactMatch[0].newAccount=='y','Create New Account','Account already exists'),'Account already exists')}" rendered="{!exactMatch.size>0}"> 
       <apex:variable var="em_index" value="{!0}"/>
      <apex:pageBlockTable value="{!exactMatch}" var="newaccRes" rowClasses="even,odd"> <!--style="display: block;  max-height: 200px;overflow-y: scroll"-->
          <apex:column value="{!newaccRes.accountName}"> 
                            <apex:facet name="header">Name</apex:facet>
                        </apex:column> 
                        <apex:column value="{!newaccRes.accountStatus}" rendered="{!IF(exactMatch.size==1,IF(exactMatch[0].newAccount=='Y'||exactMatch[0].newAccount=='y',false,true),true)}"> 
                            <apex:facet name="header">Status</apex:facet> 
                        </apex:column> 
                       <apex:column value="{!newaccRes.recTypeName}" rendered="{!IF(exactMatch.size==1,IF(exactMatch[0].newAccount=='Y'||exactMatch[0].newAccount=='y',false,true),true)}"> 
                            <apex:facet name="header">Record Type</apex:facet> 
                        </apex:column> 
                        <apex:column value="{!newaccRes.AccountOwner}" rendered="{!IF(exactMatch.size==1,IF(exactMatch[0].newAccount=='Y'||exactMatch[0].newAccount=='y',false,true),true)}"> 
                            <apex:facet name="header">Owner</apex:facet>
                        </apex:column> 
                        <apex:column value="{!newaccRes.sourceID}" rendered="{!IF(exactMatch.size==1,IF(exactMatch[0].newAccount=='Y'||exactMatch[0].newAccount=='y',false,true),true)}"> 
                            <apex:facet name="header">ID</apex:facet> 
                        </apex:column> 
                        <apex:column value="{!newaccRes.addressLine1} {!newaccRes.addressLine2}" > 
                            <apex:facet name="header">Billing Street</apex:facet>
                        </apex:column>
                        <apex:column value="{!newaccRes.city}" > 
                            <apex:facet name="header">Billing City</apex:facet>
                        </apex:column>
                        <apex:column value="{!newaccRes.state}"> 
                            <apex:facet name="header">Billing State</apex:facet>
                        </apex:column>
                        <apex:column value="{!newaccRes.postalCode}"> 
                            <apex:facet name="header">Billing Postal Code</apex:facet>
                        </apex:column>
                        <apex:column value="{!newaccRes.country}" > 
                            <apex:facet name="header">Billing Country</apex:facet>
                        </apex:column> 
         <apex:column > 
          <apex:commandLink rendered="{!IF(newaccRes.sourceID==null,true,false)}" action="{!RequestAccCreation}" value="Create" styleClass="btn"  style="padding: 4px 3px;color: #000000c4;
    text-decoration: none;"> 
           <apex:param name="create" value="{!em_index}-em"
                assignTo="{!selectedRow}"/>
                </apex:commandLink>
           <apex:commandLink rendered="{!IF(newaccRes.sourceID!=null,true,false)}" action="{!AccRedirect}" value="View" styleClass="btn" style="padding: 4px 3px;color: #000000c4;
    text-decoration: none;">
           <apex:param name="edit" value="{!newaccRes.sourceID}"
                assignTo="{!RedirectTo}"/>
                </apex:commandLink>
                <apex:variable var="em_index" value="{!em_index +1}"/>
         </apex:column>
         </apex:pageBlockTable>
   </apex:pageBlock>  
  
    
  <!-- </div>  -->
   </apex:outputPanel>
  
 
 <!-- Pop-up screen for detail view of account -->
