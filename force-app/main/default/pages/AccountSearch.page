        </apex:outputPanel>   
        
        <!-- Account Record Type -->
        
        
        <apex:outputPanel rendered="{!ShowAccount == false}" id="accRecType" >
        <div class="bPageTitle"><div class="ptBody">
        <div class="content">
    <img src="/img/s.gif" alt="Account" class="pageTitleIcon" title="Account"/>
    <h1 class="pageType">New Account<span class="titleSeparatingColon">:</span></h1>
    <h2 class="pageDescription"> Select Account Record Type</h2><div class="blank">&nbsp;</div></div>
        </div></div>
        <apex:pageMessages ></apex:pageMessages>
           <div class="bDescription">Select a record type for the new account.&nbsp;To skip this page in the future, change your record type settings on your personal setup page.</div>
         
         <apex:pageBlock title="Select Account Record Type"> 
              <apex:pageBlockButtons location="bottom">
               <!-- <apex:commandButton action="{!CreateAccount}" value="Continue" oncomplete="{!if(errAccInsert==false,'Postaccount()',null)}" status="startCreateProc" rerender="accRecType"/> 
                 <apex:actionFunction name="Postaccount" action="{!PostAccounttoCM}" rerender="accRecType" status="stopCreateProc" /> <!--rendered="{!errAccInsert== false}"-->
                   <apex:commandButton action="{!CreateAccount}" value="Continue" oncomplete="Postaccount()" status="startCreateProc"/> <!--rerender="accRecType" -->
                 <apex:actionFunction name="Postaccount" action="{!PostAccounttoCM}" rerender="accRecType" status="stopCreateProc" /> <!--rendered="{!errAccInsert== false}"-->
                   <apex:actionStatus id="startCreateProc" onstart="setLoader(true,'loadingAccCreate')" /> 
                  <apex:actionStatus id="stopCreateProc"   onstop="setLoader(false,'loadingAccCreate')" /> 

                <!-- <apex:actionStatus id="processing" onstart="setLoader(true,'loadingAccCreate')" onstop="setLoader(false,'loadingAccCreate')" /> -->
                <apex:commandButton action="{!Cancel}" value="Cancel" />
            </apex:pageBlockButtons>
            <apex:pageBlockSection columns="1">
        <apex:inputfield label="Record Type of new record" value="{!accToinsert.RecordTypeId}" required="true"/> <!--accToinsert-->   
        </apex:pageBlockSection>
        </apex:pageBlock>  
        <h3 class="recordTypesHeading">Available Account Record Types</h3>
        <apex:pageBlock mode="maindetail">
        <apex:pageBlockTable value="{!AccRectype}" var="RT" id="theTable">
               <apex:column style="border: 1px solid #ededed">
            <apex:facet name="header">Record Type Name</apex:facet>
   
            <apex:outputText value="{!RT.Name}"/>
        </apex:column>

        <apex:column style="text-align:left;border: 1px solid #ededed">
            <apex:facet name="header">Description</apex:facet>
            
            <apex:outputText value="{!RT.Description}"/>
        </apex:column>

    </apex:pageBlockTable>
    </apex:pageBlock> 
   <div id="loadingAccCreate" style="display:none;">
    <div class="popupBackground"/>
    <div class="loadCenter">
    <div style="text-align: center;"> Loading...
      <img src="/img/loading.gif" alt="Loading graphic" style="height: 25px;"/>
    </div> </div>
  </div>
        </apex:outputPanel>
