<apex:page standardController="How_To__kav" extensions="ArticleSubscriptionController" cache="false" showHeader="false" standardStylesheets="false" tabStyle="How_To__kav" ><!--kb Subscription-Added extension-->
    <link rel="shortcut icon" href="{!URLFOR($Resource.RubrikCustomerCommunity,'RubrikCommunity/Images/favicon.ico')}" type="image/x-icon" />
    <link rel="icon" href="{!URLFOR($Resource.RubrikCustomerCommunity,'RubrikCommunity/Images/favicon1.png')}" type="image/png" />
    <c:visualstrapblock >
        <script>
            window.onload = function() {
                
                var url =location.pathname;
                console.log(url );
                url = url.toLowerCase();
                console.log(url );
                if(url.includes('/articles/how_to/')){
                    url = url.replace('/articles/how_to/','/s/article/');
                     console.log(url );
                    //window.location.href = url;
                }else{
                    document.getElementById("showBlock").style.display="block";
                }
            };
        </script>
        <style>
            .btnpad{padding: 15px;}
            ol ul li {list-style-type: disc !important;list-style-position: inside !important;}
            ul li {list-style-type: disc !important;list-style-position: inside !important;}
            ol li {list-style-type: decimal !important;list-style-position: inside !important;}
            .artTitle{font-size:30px;font-family: "Gotham-light";padding-bottom:20px !important;color:#333;}
            .artRating{padding-top:20px !important;}
            .artRating .articleRendererToolbar{padding:8px;}
            .artPublishDate{font-size:12px;font-family: "Gotham-light";color:#4a4a4a;}
            .artPostedBy{text-transform:uppercase;font-size:11px;font-weight:bold;font-family: "Gotham-light";color:#19a7b5;}
            .artDesc{padding-top:24px !important;}
            .descHeading{font-size:16px;font-family:"Gotham-medium";padding-bottom:18px !important;color:#666;}
            .descBody{font-size:16px;font-family:"Gotham-light";padding-bottom:10px !important;color:#666;}
            .container{width:90%;padding:0 40px !important;}
            .articleRendererBorderRight{border:none;}
            h1,h2,h3{font-size:16px !important;font-weight:bold !important;}
            .rowcontainer{padding:50px 0px !important;}
            .eachContainer{padding-bottom:48px !important;}
            .articleContainer{width:90%;padding:50px 40px; margin:0 auto;}
            <!--kb Subscription-Start-->
            .tooltip1 {
            position: relative;
            display: inline;
            }
            
            .tooltip1 .tooltiptext {
            visibility: hidden;
            width: 400px;
            background-color: #555;
            color: #fff;
            text-align: center;
            border-radius: 6px;
            padding: 5px 0;
            position: absolute;
            z-index: 1;
            bottom: 125%;
            left: 50%;
            margin-left: -380px;
            opacity: 0;
            transition: opacity 0.3s;
            }
            
            .tooltip1 .tooltiptext::after {
            content: "";
            position: absolute;
            top: 100%;
            left: 95%;
            margin-left: -5px;
            border-width: 5px;
            border-style: solid;
            border-color: #555 transparent transparent transparent;
            }
            
            .tooltip1:hover .tooltiptext {
            visibility: visible;
            opacity: 1;
            line-height: 16px;
            }
            <!--kb Subscription-End-->
        </style>
        <div id="showBlock" style="display:none;">
        <!--start header-->
        <c:siteheader />
        <!--end Header-->
        <!--start the Container-->
        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad">
            <div class="articleContainer">
                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad artTitle">{!How_To__kav.Title}</div>
                <div class="col-lg-10 col-md-10 col-sm-10 col-xs-10 nopad" style="line-height:10px;"><!--kb Subscription-col-lg-12 col-md-12 col-sm-12 col-xs-12-->
                    <span class="artPublishDate">Created: </span>
                    <apex:outputText value="{0,date,MMM' 'dd', 'yyyy}" styleClass="artPublishDate">
                        <apex:param value="{!How_To__kav.FirstPublishedDate}" /> 
                    </apex:outputText>
                    <span class="artPublishDate"> <b>&middot;</b> Last modified: </span>
                    <apex:outputText value="{0,date,MMM' 'dd', 'yyyy}" styleClass="artPublishDate">
                        <apex:param value="{!How_To__kav.LastModifiedDate}" /> 
                    </apex:outputText>
                    <!-- <span class="artPublishDate">| BY</span>
                    <span class="artPostedBy">{!How_To__kav.createdby.name}</span> -->
                </div>
                <!--kb Subscription-Start-->
                 <div class="col-lg-2 col-md-2 col-sm-2 col-xs-2 nopad" style="line-height:10px;text-align:right;">
                     <apex:form >
                         <apex:outputPanel id="panel1">
                             <div class="slds-truncate" title="Remove">
                                 <apex:commandButton oncomplete="document.getElementById('modalPress').click();" status="pageStatus" action="{!editSubscription}"  reRender="panel1,modalrs" styleClass="btn btn-primary" value="{!IF(isSubscribed , 'Unsubscribe', 'Subscribe')}" />
                                 <div class="tooltip1"> 
                                     <img style="width: 20px;" src="data:image/png;base64,"/>
                                     <span class="tooltiptext">{!$Label.S_R_Article_subscribe_info_label}</span>
                                 </div>
                             </div>
                             <button type="button" style="display:none;" id="modalPress" class="btn btn-primary"  data-backdrop="static" data-keyboard="false" data-toggle="modal" data-target="#exampleModalCenter">
                             </button>
                             <div class="modal fade" id="exampleModalCenter" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
                                 <div class="modal-dialog modal-dialog-centered" role="document">
                                     <div class="modal-content">
                                         
                                         <div class="modal-body">
                                             You have {!IF(isSubscribed ,'subscribed' , 'unsubscribed' )} to this article.<br/>
                                             <br />
                                         </div>
                                         <div class="modal-footer">
                                             <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                         </div>
                                     </div>
                                 </div>
                             </div>      
                         </apex:outputPanel>
                     </apex:form>
                     <!--kb Subscription-End-->
                </div>
                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad artRating">
                    <knowledge:articleRendererToolbar rendered="true" canVote="true" showChatter="false" articleId="{!$CurrentPage.parameters.id}"/>
                </div>
                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad artDesc">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad eachContainer" style="{!IF(How_To__kav.Summary__c != null,'','display:none;')}">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descHeading">Summary</div>
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descBody">
                            <apex:outputText escape="false" value="{!How_To__kav.Summary__c}"/>
                        </div>
                    </div>
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad eachContainer" style="{!IF(How_To__kav.Environment__c != null,'','display:none;')}">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descHeading">Environment</div>
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descBody">
                            <apex:outputText escape="false" value="{!How_To__kav.Environment__c}"/>
                        </div>
                    </div>
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad eachContainer" style="{!IF(How_To__kav.Version__c != null,'','display:none;')}">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descHeading">Version</div>
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descBody">
                            <apex:outputText escape="false" value="{!How_To__kav.Version__c}"/>
                        </div>
                    </div>
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad eachContainer" style="{!IF(How_To__kav.Cause__c != null,'','display:none;')}">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descHeading">Cause</div>
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descBody">
                            <apex:outputText escape="false" value="{!How_To__kav.Cause__c}"/>
                        </div>
                    </div>
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad eachContainer" style="{!IF(How_To__kav.Resolution__c != null,'','display:none;')}">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descHeading">Resolution</div>
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descBody">
                            <apex:outputText escape="false" value="{!How_To__kav.Resolution__c}"/>
                        </div>
                    </div>
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad eachContainer">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descHeading">Attachment</div>
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad descBody">
                            {!if(isBlank(How_To__kav.Attachment__Name__s),"There is no attachment for this Knowledge Base article.",'')}
                            <apex:outputLink value="/servlet/fileField?entityId={!How_To__kav.Id}&field=Attachment__Body__s">
                                <apex:outputfield value="{!How_To__kav.Attachment__Name__s}"/>
                            </apex:outputLink>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--End the Container-->
        <!--start the footer-->
        <c:sitefooter />
        </div>
    </c:visualstrapblock>
</apex:page>