<apex:page standardController="Case" lightningStylesheets="true" docType="html-5.0">
    <div style="overflow: scroll; width: auto; height: 200px;">
        <apex:form >
            <apex:pageBlock >
                <apex:variable var="sizeOfCaseIdeaLink" value="{!0}"/>

                <apex:pageBlockTable value="{!Case.Aha_Idea_Links__r}" var="idealink"  rendered="{!NOT(ISNULL(Case.Aha_Idea_Links__r))}">
                    <apex:column headerValue="Aha Idea Number">
                        <apex:outputlink value="/{!idealink.Aha_Ideas__c}">{!idealink.Aha_Idea_Number__c}</apex:outputlink>
                    </apex:column>
                    <apex:column value="{!idealink.Aha_Ideas__c}"/>
                    <apex:column value="{!idealink.Idea_Status__c}"/>
                    <apex:column value="{!idealink.Feature_Name__c}"/>
                    <apex:column value="{!idealink.Feature_Status__c}"/>
                </apex:pageBlockTable>
                <apex:repeat value="{!Case.Aha_Idea_Links__r}">
                    <apex:variable var="sizeOfCaseIdeaLink" value="{!sizeOfCaseIdeaLink + 1}"/>
                </apex:repeat>
                <apex:outputText value="No records found." rendered="{!if(sizeOfCaseIdeaLink == 0,true,false)}"/>
            </apex:pageBlock>
        </apex:form>
    </div>
</apex:page>