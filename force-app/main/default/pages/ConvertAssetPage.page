<apex:page docType="html-5.0" controller="ConvertAssetController" lightningStylesheets="false" sidebar="false" showHeader="false">

    <apex:slds />

    <apex:includescript value="//code.jquery.com/jquery-1.11.1.min.js" />
    <apex:includescript value="//cdn.datatables.net/1.10.4/js/jquery.dataTables.min.js" />
    <apex:stylesheet value="//cdn.datatables.net/1.10.4/css/jquery.dataTables.css" />

    <style>
        .hideError {
            display: none !important;
        }

        .customMessage * {
            color: #fff!important font-size: medium;
            font-weight: bold;
        }

        .errorSpan {
            font-size: medium;
            font-weight: bold;
        }

        .overlay {
            display: none;
            height: 100%;
            left: 0;
            position: fixed;
            top: 0;
            opacity: 0.3;
            -moz-opacity: 0.3;
            width: 100%;
            -ms-filter: "progid:DXImageTransform.Microsoft.Alpha(Opacity=30)";
            filter: alpha(opacity=30);
            background: #000;
            -khtml-opacity: 0.3;
            z-index: 1000;
        }

        .loader {
            background: url('/img/loading32.gif') scroll no-repeat 0 0;
            width: 32px;
            height: 32px;
            position: absolute;
            left: 50%;
            top: 50%;
            z-index: 9999;
        }
    </style>

    <script>
        let j$ = jQuery.noConflict();
        let assetEndDatePrevValue = 120;

        function navigateToQle() {
            window.top.location.href = '{!$Page.SBQQ__sb}?id={!$CurrentPage.Parameters.newid}';
        }

        function cancelAndNavigateToQle() {
            event.preventDefault();
            event.stopPropagation();

            navigateToQle();
        }

        function fetchAssetFromEndDate() {
            var selectedAssetEndDate = j$('[id$="assetEndDate"]').val();

            if (selectedAssetEndDate < 120) {
                j$("#endDateMessage").removeClass("hideError");
                j$('[id$="assetEndDate"]').val(assetEndDatePrevValue);
            } else {
                j$("#endDateMessage").addClass("hideError");
                assetEndDatePrevValue = selectedAssetEndDate;
                refreshAssets();
            }
        }

        function initDataTable() {
            if (j$.fn.dataTable.isDataTable('[id$="expiredAssetTable"]')) return;
            if (j$.fn.dataTable.isDataTable('[id$="convertAssetTable"]')) return;
            if (j$.fn.dataTable.isDataTable('[id$="futureAssetTable"]')) return;

            j$('[id$="expiredAssetTable"]').DataTable({
                "searching": false,
                "columnDefs": [
                    {
                        "targets": [0], //first column / numbering column
                        "orderable": false, //set not orderable
                    },
                ]
            });

            j$('[id$="convertAssetTable"]').DataTable({
                "searching": false,
                "columnDefs": [
                    {
                        "targets": [0], //first column / numbering column
                        "orderable": false, //set not orderable
                    },
                ]
            });

            j$('[id$="futureAssetTable"]').DataTable({
                "searching": false,
                "columnDefs": [
                    {
                        "targets": [0], //first column / numbering column
                        "orderable": false, //set not orderable
                    },
                ]
            });
        }

        function startLoading() {
            j$('.loadingBox').show();
        }

        function stopLoading() {
            j$('.loadingBox').hide();
        }

        j$(document).ready(() => {
            initDataTable();

            // Select all checkbox code
            j$("[id$='SelectAll']").click(function (evt) {
                j$(".childCheckbox").prop("checked", evt.target.checked);
            });

            j$(".childCheckbox").click(function () {
                const all = j$(".childCheckbox").length;
                const checked = j$(".childCheckbox:checked").length;

                j$("[id$='SelectAll']").prop("checked", all == checked);
            });
        })

        function alterRubrikEdition(el) {
            if ({!isOnPremException
        } == true && j$(el).closest("tr").find("[id$='licenseTypeInput']").val() == 'On Prem') {
            j$(el).closest("tr").find("[id$='rubrikEditionInput']").children("option[value='Foundation']").hide();
            j$(el).closest("tr").find("[id$='rubrikEditionInput']").children("option[value='Proactive']").hide();
            j$(el).closest("tr").find("[id$='rubrikEditionInput']").val('Enterprise');
        }
        if ({!isOnPremException} == false || j$(el).closest("tr").find("[id$='licenseTypeInput']").val() != 'On Prem') {
            j$(el).closest("tr").find("[id$='rubrikEditionInput']").children("option[value='Foundation']").show();
            j$(el).closest("tr").find("[id$='rubrikEditionInput']").children("option[value='Proactive']").show();
        }
        }
    </script>

    <apex:pageMessages />

    <div id="load_scrl" class="loadingBox loader" style="display:none"> </div>
    <div class="loadingBox overlay"> </div>

    <apex:form >
        <apex:actionStatus onstart="startLoading();" onstop="stopLoading();" id="loadStatus" />

        <apex:actionFunction name="refreshAssets" action="{!fetchEligibleAssetsForConversion}" status="loadStatus" />

        <div id="endDateMessage" class="slds-notify slds-notify--alert slds-theme--error customMessage slds-theme--alert-texture hideError">
            <span class="errorSpan" id="errorSpan">Asset end date should not be less than 120</span>
        </div>

        <div class="slds-page-header slds-m-vertical_small">
            <div class="slds-page-header__row">
                <div class="slds-page-header__col-title">
                    <div class="slds-media">
                        <div class="slds-media__figure">
                            <span class="slds-icon_container slds-icon-standard-opportunity" title="opportunity">
                                <svg class="slds-icon slds-page-header__icon" aria-hidden="true">
                                </svg>
                            </span>
                        </div>
                        <div class="slds-media__body">
                            <p class="slds-page-header__name-meta">{!conversionQuote.Name}</p>
                            <div class="slds-page-header__name">
                                <div class="slds-page-header__name-title">
                                    <h1>
                                        <apex:outputPanel rendered="{!NOT(showConversionPage)}" styleClass="slds-page-header__title slds-truncate">Conversion: Asset Selection</apex:outputPanel>
                                        <apex:outputPanel rendered="{!showConversionPage}" styleClass="slds-page-header__title slds-truncate">Asset Upgrades</apex:outputPanel>
                                    </h1>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <apex:outputPanel layout="block" rendered="{!NOT(showConversionPage)}">
                <div class="slds-text-align_center">
                    <apex:inputText styleClass="slds-input" value="{!strSearchAsset}" style="width: 25%" />
                    <apex:commandButton value="Search" action="{!fetchEligibleAssetsForConversion}" status="loadStatus" styleClass="slds-button slds-button_neutral slds-m-left_small"
                    />
                    <apex:commandButton value="Clear" action="{!clearSearch}" status="loadStatus" styleClass="slds-button slds-button_neutral"
                    />
                </div>
            </apex:outputPanel>

            <apex:outputPanel layout="block" rendered="{!showConversionPage}" styleClass="slds-m-vertical_small">
                <div class="slds-text-align_center slds-m-vertical_small">
                    <apex:commandButton value="Save" action="{!convertAssets}" reRender="secondPage" styleClass="slds-button slds-button_neutral"
                        oncomplete="if('{!isConversionError}' == 'false') navigateToQle();" status="loadStatus" />
                    <apex:commandButton action="{!cancelAndBack}" value="Cancel" styleClass="slds-button slds-button_neutral" />
                </div>
            </apex:outputPanel>
        </div>

      <apex:outputPanel layout="block" rendered="{!NOT(showConversionPage)}">
            <!--  <div class="slds-text-align_center slds-m-vertical_small">
                <apex:outputPanel layout="block" rendered="{!showAssetEndDate}">
                    <span class="slds-m-right_medium">Asset End Date</span>
                    <apex:input id="assetEndDate" type="number" value="{!assetEndDateDays}" onchange="fetchAssetFromEndDate();" styleClass="slds-input"
                        style="width: 25%" />
                </apex:outputPanel>
            </div>  commenting for CPQ22-2984 -->

            <div class="slds-text-align_center slds-m-vertical_small">
                Please select an Edition, Payment Option, Support Type and License Type for the Asset(s) you want to convert. These attributes
                will determine the software product.
            </div>
        </apex:outputPanel>

        <!-- First page for selection of assets -->
        <apex:outputPanel layout="block" id="firstPage" rendered="{!NOT(showConversionPage)}" styleClass="slds-m-vertical_small">
            <!-- Assets having support date in the past -->
            <p class="slds-text-align_center slds-text-color_error" style="font-size: 0.8rem; font-weight: bold;">
                The support on these assets has expired. The support must be renewed before the assets may be converted.
            </p>

