                </tbody>
            </table>  commenting for CPQ22-2984 -->
        </apex:outputPanel> 

        <!-- Second page for conversion -->
        <apex:outputPanel layout="block" id="secondPage" rendered="{!showConversionPage}" styleClass="slds-m-vertical_small">
            <apex:repeat value="{!selectedWrappers}" var="selectedWrapper">
                <apex:variable value="{!selectedWrapper.asset}" var="currentAsset" />

                <!-- Existing asset information -->
                <div class="slds-theme_shade slds-p-around_small slds-grid" style="font-size: 1.15em">
                    <span class="slds-size_1-of-5">
                        <p style="font-weight: bold">Asset Name</p>
                        <p>{!currentAsset.Name}</p>
                    </span>
                    <span class="slds-size_1-of-5">
                        <p style="font-weight: bold">Rubrik Edition</p>
                        <p>{!existingAssetMap[currentAsset.Name].Rubrik_Suite__c}</p>
                    </span>
                    <span class="slds-size_1-of-5">
                        <p style="font-weight: bold">Payment Option</p>
                        <p>{!existingAssetMap[currentAsset.Name].Payment_Options__c}</p>
                    </span>
                    <span class="slds-size_1-of-5">
                        <p style="font-weight: bold">Support Type</p>
                        <p>{!existingAssetMap[currentAsset.Name].Support_Type__c}</p>
                    </span>
                    <span class="slds-size_1-of-5">
                        <p style="font-weight: bold">License Type</p>
                        <p>Perpetual</p>
                    </span>
                </div>

                <!-- Conversion message if missing mapping -->
                <apex:outputPanel rendered="{!NOT(selectedWrapper.isConversionPossible)}">
                    <div class="slds-m-vertical_small">
                        <p class="slds-text-align_center slds-text-color_error" style="font-size: 1rem">
                            {!selectedWrapper.conversionError}
                        </p>
                    </div>
                </apex:outputPanel>

                <!-- Conversion information -->
                <apex:outputPanel rendered="{!selectedWrapper.isConversionPossible}">
                    <div class="slds-m-vertical_small">
                        <table class="slds-table slds-table_bordered slds-table_cell-buffer">
                            <thead>
                                <tr style="font-size: 1.15em">
                                    <td class="slds-size_1-of-3" style="font-weight: bold">Upgrade From</td>
                                    <td class="slds-size_1-of-3" style="font-weight: bold">Upgrade To</td>
                                    <td class="slds-size_1-of-3" style="font-weight: bold">Product Description</td>
                                </tr>
                            </thead>

                            <tbody>
                                <tr>
                                    <td class="slds-size_1-of-3">
                                        {!selectedWrapper.asset.Product2.Name}
                                    </td>
                                    <td class="slds-size_1-of-3">
                                        {!selectedWrapper.convertSaasProduct.Name}
                                    </td>
                                    <td class="slds-size_1-of-3" style="white-space: pre-wrap">{!selectedWrapper.convertSaasProduct.Description}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </apex:outputPanel>

                <div class="slds-m-top_x-large" style="width: 100%;height: 2px;background: #4cb10d;" />
            </apex:repeat>

        </apex:outputPanel>

        <apex:outputPanel layout="block" rendered="{!NOT(showConversionPage)}" styleClass="slds-m-vertical_small">
            <div class="slds-text-align_center slds-m-vertical_small">
                <apex:commandButton action="{!fetchConversionProducts}" status="loadStatus" value="Save" styleClass="slds-button slds-button_neutral"
                />  
                <apex:commandButton onclick="cancelAndNavigateToQle();" value="Cancel" styleClass="slds-button slds-button_neutral" />
            </div>
        </apex:outputPanel>

        <apex:outputPanel layout="block" rendered="{!showConversionPage}" styleClass="slds-m-vertical_small">
            <div class="slds-text-align_center slds-m-vertical_small">
                <apex:commandButton value="Save" action="{!convertAssets}" reRender="secondPage" status="loadStatus" styleClass="slds-button slds-button_neutral"
                    oncomplete="if('{!isConversionError}' == 'false') navigateToQle();" />
                <apex:commandButton action="{!cancelAndBack}" value="Cancel" styleClass="slds-button slds-button_neutral" />
            </div>
        </apex:outputPanel>
    </apex:form>

    
</apex:page>