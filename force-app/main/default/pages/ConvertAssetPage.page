                    <tr class="slds-line-height_reset">
                        <th class="" scope="col">
                             <div class="slds-truncate" title="Select">
                                <input type="checkbox" id="SelectAll" name="SelectAll" value="SelectAll" rendered="{!isDealOpsExp}" />
                            </div> 
                            
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="Name">Asset Name</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="ProductCode">Product Code</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="StartDate">Support Start Date</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="EndDate">Support End Date</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="Network">Network</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="RubrikEdition">Rubrik Edition</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="PaymentOptions">Payment Options</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="SupportType">Support Type</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="LicenseType">License Type</div>
                        </th>
                    </tr>
                </thead>

                <tbody>
                    <apex:repeat value="{!lstWrapperAssets}" var="wrapper1">
                        <apex:outputPanel rendered="{!wrapper1.asset.Premium_Support_End_Date__c < TODAY()-30}">
                            <tr>
                                <td>
                                     <apex:inputCheckbox value="{!wrapper1.selected}" styleClass="childCheckbox" rendered="{!isDealOpsExp}" /> 
                                </td>
                                <td>{!wrapper1.asset.SerialNumber}</td>
                                <td>{!wrapper1.asset.ProductCode}</td>
                                <td>
                                    <apex:outputText value="{0, date, MMMM d','  yyyy}">
                                        <apex:param value="{!wrapper1.asset.Support_Start_Date__c}" />
                                    </apex:outputText>
                                </td>
                                <td>
                                    <apex:outputText value="{0, date, MMMM d','  yyyy}">
                                        <apex:param value="{!wrapper1.asset.Premium_Support_End_Date__c}" />
                                    </apex:outputText>
                                </td>
                                <td>{!wrapper1.asset.Product_Nic_Type__c}</td>
                                <td>
                                 <apex:selectList id="rubrikEditionInput" value="{!wrapper1.asset.Rubrik_Suite__c}" size="1" >
                                        <apex:selectOption itemValue="Foundation" itemLabel="Foundation" rendered="{!OR(!isOnPremException, wrapper1.licenseType != 'On Prem')}"
                                        />
                                        <apex:selectOption itemValue="Business" itemLabel="Business" />
                                        <apex:selectOption itemValue="Enterprise" itemLabel="Enterprise" />
                                        <apex:selectOption itemValue="Proactive" itemLabel="Proactive"/>
                                    </apex:selectList>
                                </td>
                                <td>
                                 <apex:selectList id="paymentOptionsInput" value="{!wrapper1.asset.Payment_Options__c}" size="1">
                                        <apex:selectOption itemValue="Prepay" itemLabel="Prepay" />
                                        <apex:selectOption itemValue="Annual" itemLabel="Annual" />
                                    </apex:selectList>
                                </td>
                                <td>
                                <apex:selectList id="supportTypeInput" value="{!wrapper1.asset.Support_Type__c}" size="1">
                                        <apex:selectOption itemValue="Premium" itemLabel="Premium" />
                                        <apex:selectOption itemValue="L3" itemLabel="L3" />
                                    </apex:selectList>
                                </td>
                                <td>
                                <apex:selectList id="licenseTypeInput" value="{!wrapper1.licenseType}" size="1" onchange="alterRubrikEdition(this);">
                                        <!-- <apex:actionSupport event="onchange" status="loadStatus" /> -->
                                        <apex:selectOption itemValue="SaaS" itemLabel="SaaS" />
                                        <apex:selectOption itemValue="On Prem" itemLabel="On Prem" rendered="{!OR(isFederalAccount, isOnPremException)}" />
                                 </apex:selectList>
                                </td>
                            </tr>
                        </apex:outputPanel>
                    </apex:repeat>
                </tbody>
            </table>

            <!-- Assets available for conversion  -->
            <p class="slds-text-align_center slds-text-color_error" style="font-size: 0.8rem; font-weight: bold;">
                Following assets are eligible for conversion
            </p>

            <table id="convertAssetTable" class="slds-table slds-table_cell-buffer slds-table_bordered">
                <thead>
                    <tr class="slds-line-height_reset">
                        <th class="" scope="col">
                            <div class="slds-truncate" title="Select">
                                <input type="checkbox" id="SelectAll" name="SelectAll" value="SelectAll" />
                            </div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="Name">Asset Name</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="ProductCode">Product Code</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="StartDate">Support Start Date</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="EndDate">Support End Date</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="Network">Network</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="RubrikEdition">Rubrik Edition</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="PaymentOptions">Payment Options</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="SupportType">Support Type</div>
                        </th>
                        <th class="" scope="col">
                            <div class="slds-truncate" title="LicenseType">License Type</div>
                        </th>
                    </tr>
                </thead>

                <tbody>
                    <apex:repeat value="{!lstWrapperAssets}" var="wrapper2">
                        <apex:outputPanel rendered="{!wrapper2.asset.Premium_Support_End_Date__c >= TODAY()-30 /* && wrapper2.asset.Premium_Support_End_Date__c <= assetEndDateRequired} */ }">
                            <tr>
                                <td>
                                    <apex:inputCheckbox value="{!wrapper2.selected}" styleClass="childCheckbox" />
                                </td>
                                <td>{!wrapper2.asset.SerialNumber}</td>
                                <td>{!wrapper2.asset.ProductCode}</td>
                                <td>
                                    <apex:outputText value="{0, date, MMMM d','  yyyy}">
                                        <apex:param value="{!wrapper2.asset.Support_Start_Date__c}" />
                                    </apex:outputText>
                                </td>
                                <td>
                                    <apex:outputText value="{0, date, MMMM d','  yyyy}">
                                        <apex:param value="{!wrapper2.asset.Premium_Support_End_Date__c}" />
                                    </apex:outputText>
                                </td>
                                <td>{!wrapper2.asset.Product_Nic_Type__c}</td>
                                <td>
                                    <apex:selectList id="rubrikEditionInput2" value="{!wrapper2.asset.Rubrik_Suite__c}" size="1">
                                        <apex:selectOption itemValue="Foundation" itemLabel="Foundation" rendered="{!OR(!isOnPremException, wrapper2.licenseType != 'On Prem')}"
                                        />
                                        <apex:selectOption itemValue="Business" itemLabel="Business" />
                                        <apex:selectOption itemValue="Enterprise" itemLabel="Enterprise" />
                                        <apex:selectOption itemValue="Proactive" itemLabel="Proactive" id="a01"/>
                                    </apex:selectList>
                                </td>
                                <td>
                                    <apex:selectList id="paymentOptionsInput2" value="{!wrapper2.asset.Payment_Options__c}" size="1">
                                        <apex:selectOption itemValue="Prepay" itemLabel="Prepay" />
                                        <apex:selectOption itemValue="Annual" itemLabel="Annual" />
                                    </apex:selectList>
                                </td>
                                <td>
                                    <apex:selectList id="supportTypeInput2" value="{!wrapper2.asset.Support_Type__c}" size="1">
                                        <apex:selectOption itemValue="Premium" itemLabel="Premium" />
                                        <apex:selectOption itemValue="L3" itemLabel="L3" />
                                    </apex:selectList>
                                </td>
                                <td>
                                    <apex:selectList id="licenseTypeInput2" value="{!wrapper2.licenseType}" size="1" onchange="alterRubrikEdition(this);">
                                        <!-- <apex:actionSupport event="onchange" status="loadStatus" /> -->
                                        <apex:selectOption itemValue="SaaS" itemLabel="SaaS" />
                                        <apex:selectOption itemValue="On Prem" itemLabel="On Prem" rendered="{!OR(isFederalAccount, isOnPremException)}" />
                                    </apex:selectList>
                                </td>
                            </tr>
                        </apex:outputPanel>
                    </apex:repeat>
                </tbody>
            </table>

            <!-- Assets having support end date greater than entered asset end date -->
          <!--  <p class="slds-text-align_center slds-text-color_error" style="font-size: 0.8rem; font-weight: bold;">
                These assets are not eligible for conversion until the renewal is within {!assetEndDateDays} days
            </p>  commenting for CPQ22-2984 -->

