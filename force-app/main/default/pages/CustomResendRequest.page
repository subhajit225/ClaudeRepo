<apex:page standardController="sbaa__Approval__c" extensions="CustomResendController" showQuickActionVfHeader="false" showHeader="false" standardStylesheets="false" sidebar="false" applyHtmlTag="false" applyBodyTag="false" docType="html-5.0">
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" lang="en">
        <head>
            <meta charset="utf-8" />
            <meta http-equiv="x-ua-compatible" content="ie=edge" />
            <meta name="viewport" content="width=device-width, initial-scale=1" />
            <apex:stylesheet value="{!URLFOR($Resource.sbaa__SLDS214, 'assets/styles/salesforce-lightning-design-system-vf.min.css')}" />

            <style>
                #aa {
                    margin: 0;
                }
                .resendRequestApp {
                    padding: 8px;
                }
                .msgIcon {
                    display: none!important
                }
                .customMessage * {
                    color: #fff!important
                }
                .customMessage {
                    margin: 5px 0!important;
                    opacity: 1!important;
                    width: 100%;
                    font-size: 12px;
                    border: 0px;
                    padding-left: 10px;
                }
                .message {
                    opacity: .1
                }
                .buttonToRight {
                    text-align: right;
                }
            </style>
        </head>

        <body id="aa">
            <!-- REQUIRED SLDS WRAPPER -->
            <div class="sbaa">
                <!-- MASTHEAD -->
                <div class="slds-page-header">
                    <p class="slds-text-heading--medium slds-text-align--center">
                        Resend Request
                    </p>
                </div>
                <!-- / MASTHEAD -->
                <!-- PRIMARY CONTENT WRAPPER -->
                <div class="resendRequestApp">
                    <apex:form >
                        <apex:pageMessages />
                        <!--apex:pageBlock rendered="{!isApprovalRequested == false}">
                            <div class="buttonToRight">
                                <apex:commandButton styleClass="slds-button slds-button--neutral" action="{!onReturn}" value="{!$Label.sbaa__lbl_cancel}" onclick="disableOnSubmit(this);"/>
                            </div>
                        </apex:pageBlock-->
                        <apex:pageBlock >
                            <apex:outputLabel styleClass="slds-form-element__label" for="textarea-input-01" value="Comments"/>
                            <apex:inputTextarea id="textarea-input-01" styleClass="slds-textarea" value="{!comments}" rows="5"/>
                            <div class="buttonToRight">
                                <apex:commandButton styleClass="slds-button slds-button--neutral" action="{!cancel}" value="Cancel" disabled="{!disableButton}" />
                                <apex:commandButton styleClass="slds-button slds-button--brand" action="{!resendRequest}" value="Resend Request" disabled="{!disableButton}"/>
                            </div>
                        </apex:pageBlock>
                    </apex:form>
                </div>
            </div>
        </body>
    </html>
</apex:page>