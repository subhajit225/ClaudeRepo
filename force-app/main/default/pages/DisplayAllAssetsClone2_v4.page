            function alterRubrikEdition(el) {
                if ({!isOnPremException
                    } == true && j$(el).closest("tr").find("[id$='licenseTypeInput']").val() == 'On Prem') {
                    j$(el).closest("tr").find("[id$='rubrikEditionInput']").children("option[value='Foundation']").hide();//a comment1da
                      j$(el).closest("tr").find("[id$='rubrikEditionInput']").children("option[value='Proactive']").hide();//a comment1das
                    j$(el).closest("tr").find("[id$='rubrikEditionInput']").val('Enterprise');//a comment1dae
                }
                if ({!isOnPremException} == false || j$(el).closest("tr").find("[id$='licenseTypeInput']").val() != 'On Prem') {//a comment1dat
                    j$(el).closest("tr").find("[id$='rubrikEditionInput']").children("option[value='Foundation']").show();//a comment1dau
