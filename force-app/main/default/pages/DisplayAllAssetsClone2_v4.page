            // validation and save of final Save
            function UpgradeAssetSave(){
                j$(".slds-button").prop('disabled', true);
                var names ={};
                var count = 0;
                var assetlist = [];
                var validAsset =[];
                var populatedAsset =[];
                var leftovers = '';
                j$("input[type='radio'].read-option").each(function() {
                    names[j$(this).attr('name')] = true;
                    var upgradeSource =  j$(this).attr('name');
                    if(validAsset.indexOf(upgradeSource) == -1){
                        validAsset.push(upgradeSource);
                    }
                    if(this.checked == true)
                    {
                        var newValue = this.id;
                        console.log(newValue);
                        populatedAsset.push(upgradeSource);
                        assetlist.push(newValue);
                        count++
                    } 
                });
                var namelength = 0
                j$.each(names, function() { // then count them
                    namelength++;
                });
                for (i=0; i<validAsset.length; i++){
                    if(populatedAsset.indexOf(validAsset[i]) == -1){
                        if (leftovers ==''){
                            leftovers = validAsset[i];
                        }else {
                            leftovers = leftovers +', '+ validAsset[i] ;
                        }    
                    }
                }
                if ( namelength == count){
                    j$('[id$="optionSelected"]').val(assetlist);
                    j$('[id$="errorMsg"]').addClass("hideError");
                    saveQuoteLines();
                } else {
                    console.log();
                    j$('[id$="errorMsg"]').removeClass("hideError");
                    j$('[id$="errorSpan"]').text("Please select Upgrade for "+leftovers);
                    console.log("Kill it--> throw error");
                    j$(".slds-button").prop('disabled', false);
                }
            }
            
            function isCombinationNotValid(rubrikEdition, payemntOption, supportType){
                var validAssetFieldCombinations = {!validAssetFieldCombinations};
                var RUBRIK_SUIT_MAP = {
                    'Foundation' : 'Foundation Edition',
                    'Business' : 'Business Edition',
                    'Complete Pro' : 'Complete Edition Pro',
                    'Enterprise' : 'Enterprise Edition',
                      'Proactive' : 'Proactive Edition',
                    'Complete' : 'Complete Edition',
                    'Complete Elite' : 'Complete Edition Elite'
                };
                var combination = RUBRIK_SUIT_MAP[rubrikEdition]+'_'+payemntOption+'_'+supportType;                
                return !validAssetFieldCombinations.includes(combination);
            }
            
