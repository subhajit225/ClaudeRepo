<apex:page standardController="Case" lightningStylesheets="true" >
        <apex:slds />
    <div class="slds-scope"> 
    <apex:form >
        <apex:pageBlock >
            <apex:pageBlockSection >
                <apex:inputField id="ArticleCandidate" value="{!Case.KCS_Article_Candidate__c }"/>
                </apex:pageBlockSection>
            <apex:pageBlockSection >
                <apex:inputField id="ArticleStatus" label="KCS Article Status" value="{!Case.KCS_Article_Status__c }"/>
                </apex:pageBlockSection>
            <apex:pageBlockSection >
                <apex:inputField id="SuppImprovReq" label="KCS Supportability Improvements Requested" value="{!Case.Supportability_Improvement_Requested__c }"/>
                </apex:pageBlockSection>
            <apex:pageBlockSection >
                <apex:inputField id="SuppComm" value="{!Case.KCS_or_Supportability_comments__c }"/> 
            </apex:pageBlockSection>
            <apex:pageBlockSection >
                <apex:inputField id="Cause" label="KCS Supportability Improvements Requested" value="{!Case.Cause__c }"/>
            </apex:pageBlockSection>
            <apex:pageBlockSection >
                <apex:inputField id="AddNotes" value="{!Case.Additional_Notes__c }"/> 
            </apex:pageBlockSection>
            <apex:pageBlockButtons >
                <apex:commandButton action="{!save}" value="Save"/>
                <apex:commandButton action="{!cancel}" value="Cancel"/>                
            </apex:pageBlockButtons>
        </apex:pageBlock>
    </apex:form>                
   </div> 
</apex:page>