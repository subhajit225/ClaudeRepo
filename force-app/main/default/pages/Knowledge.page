            .row{margin:0px!important;}
            body{margin:0px!important;}
            .su-p-input-header__link{z-index:0 !important}
            .ArticleContainerBlock{width:90%;margin:0 auto;padding:0 40px;}
            .headerbacktop{margin:0px !important;height: 36px !important;}
            .nopad{padding:0px;}
            .myMobileCategory{padding: 5px!important;display:block !important;background-color:#009DAC !important;float:left !important;margin:30px 0px!important;position:fixed!important;bottom:20px;right:40px;z-index: 1;}
            .align-right{text-align:right;}
            align-left{text-align:left;}
            .visualstrap .table > thead > tr > th, .visualstrap .table > tbody > tr > th, .visualstrap .table > tfoot > tr > th, .visualstrap .table > thead > tr > td, .visualstrap .table > tbody > tr > td, .visualstrap .table > tfoot > tr > td {border-top: 0px !important;}
            .top-margin{margin-top:50px;}
            .categBlock{border:1px solid #eee;padding5px !important;}
            .categTitle{font-size:11px;text-transform:uppercase;font-family:"Gotham-light";padding-bottom:5px !important;padding-top:20px !important;}
            .categName{font-size:12px;padding-left:5px !important;display:inline;}
            .artHeading{font-size:20px;font-family:"Gotham-medium";padding-bottom:20px !important;border-bottom:1px solid #eee;}
            .eachBlock{padding-bottom:30px !important;padding-top:30px !important;border-bottom:1px solid #eee;}
            .tileStyle{padding:5px !important;cursor:pointer;padding-left:0px !important;}
            .artTitle{font-size:20px !important;font-family:"Gotham-light" !important;padding-bottom:10px !important;color:#1d2632 !important;}
            .artTitle:hover{color:#009DAC !important;}
            .artDesc{font-size:14px;font-family:"Gotham-light";padding-bottom:10px !important;color:#666;}
            .artPublishDate{font-size:12px;font-family:"Gotham-light";color:#4a4a4a;}
            .artPostedBy{text-transform:uppercase;font-size:11px;font-weight:bold;font-family: "Gotham-light";color:#19a7b5;}
            .pagination{padding:20px 0px !important;}
            .required{background-color:#009DAC;}
            .selected{color:#009DAC;background-color:#eee;}
            .mobileCateg{font-size:20px!important;}
            .mobileCategName{font-size:18px!important;}
            @media only screen and (min-width : 320px) and (max-width : 480px) {
            .artHeading{margin-top:50px}
            .ArticleContainerBlock{padding:0px;}
            }
            @media only screen and (min-width : 480px) and (max-width : 767px){
            .artHeading{margin-top:50px}
            .ArticleContainerBlock{padding:0px;}
            }
            @media screen and (orientation: landscape) {
            .tileStyleMobile{padding:5px !important;}
            }
            #knowledgeCategory{position: fixed;background-color:white;z-index: 1;right:40px;bottom:20px}  
            .susearchBoxContainer.su-p-input-header {margin: 15px auto;width: 90%;padding: 0 40px;}  
            .spinnerBg{
            width: 100%;
            height: 100%;
            position: absolute;
            background-color: #000;
            opacity: 0.2;
            z-index: 999999;
            }
            .spinner{
            width: 100%;
            height: 100%;
            position: absolute;
            background-image: url("https://cdn-images-1.medium.com/max/1600/1*9EBHIOzhE1XfMYoKz1JcsQ.gif");
            background-size: 70px;
            background-repeat: no-repeat;
            background-attachment: fixed;
            background-position: center;
            z-index: 9999999;
            opacity: 1;
            }
            
            .tooltip1 {
            position: relative;
            display: inline;
            }
            
            .tooltip1 .tooltiptext {
            visibility: hidden;
            width: 400px;
            background-color: #555;
            color: #fff;
            text-align: center;
            border-radius: 6px;
            padding: 5px 0;
            position: absolute;
            z-index: 1;
            bottom: 125%;
            left: 50%;
            margin-left: -380px;
            opacity: 0;
            transition: opacity 0.3s;
            }
            
            .tooltip1 .tooltiptext::after {
            content: "";
            position: absolute;
            top: 100%;
            left: 95%;
            margin-left: -5px;
            border-width: 5px;
            border-style: solid;
            border-color: #555 transparent transparent transparent;
            }
            
            .tooltip1:hover .tooltiptext {
            visibility: visible;
            opacity: 1;
            line-height: 16px;
            }
            .buttonTop{
            padding-bottom: 10px !important;
            border-bottom: 1px solid #eee;
            }
        </style>
