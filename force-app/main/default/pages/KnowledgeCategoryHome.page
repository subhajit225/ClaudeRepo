                                <apex:outputPanel id="subBlock">
                                    <script>
                                    var j$ = jQuery.noConflict();
                                    j$(document).ready(function(){
                                        j$(".image-checkbox").each(function () {
                                            if (j$(this).find('input[type="checkbox"]').first().attr("checked")) {
                                                j$(this).addClass('image-checkbox-checked');
                                            }
                                            else {
                                                j$(this).removeClass('image-checkbox-checked');
                                            }
                                        });
                                        j$(".image-checkboxAll").each(function () {
                                            if (j$(this).find('input[type="checkbox"]').first().attr("checked")) {
                                                j$(this).addClass('image-checkboxAll-checked');
                                            }
                                            else {
                                                j$(this).removeClass('image-checkboxAll-checked');
                                            }
                                        });
                                        
                                        // sync the state to the input
                                        j$(".image-checkbox").on("click", function (e) {
                                            j$(this).toggleClass('image-checkbox-checked');
                                            var $checkbox = j$(this).find('input[type="checkbox"]');
                                            $checkbox.prop("checked",!$checkbox.prop("checked"))
                                            
                                            var total = j$(".image-checkbox").find('input[type="checkbox"]').length;
                                            var checkedTotal = j$(".image-checkbox").find('input[type="checkbox"]:checked').length;
                                            console.log(total +'-----'+ checkedTotal);
                                            if(total == checkedTotal){
                                                j$(".image-checkboxAll").find('input[type="checkbox"]').prop('checked', true);
                                                j$(".image-checkboxAll").addClass('image-checkboxAll-checked');
                                            }else{
                                                j$(".image-checkboxAll").find('input[type="checkbox"]').prop('checked', false);
                                                j$(".image-checkboxAll").removeClass('image-checkboxAll-checked');
                                            }
                                            e.preventDefault();
                                        });
                                        j$(".image-checkboxAll").on("change", function (e) {
                                            j$(this).toggleClass('image-checkboxAll-checked');
                                            var status = j$(this).find('input[type="checkbox"]')[0].checked; // "select all" checked status
                                            console.log(status);
                                            j$('.image-checkbox').each(function(){ //iterate all listed checkbox items
                                                if(status){
                                                    j$(this).removeClass('image-checkbox-checked');
                                                }else{
                                                    j$(this).addClass('image-checkbox-checked');
                                                } 
                                                j$(this).toggleClass('image-checkbox-checked');
                                                var $checkbox = j$(this).find('input[type="checkbox"]');
                                                $checkbox.prop("checked",status)
                                            });
                                        });
                                    });
                                    </script>
