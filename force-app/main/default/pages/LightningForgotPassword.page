<apex:page id="forgotPassword" showHeader="false" controller="ForgotPasswordController" cache="false" title="{!$Label.site.forgot_password}" standardStylesheets="false" sidebar="false" applyBodyTag="false" docType="html-5.0" action="{!forwardToCustomPage}">

<c:importbs />
<c:communitystyle />
 <c:visualstrapblock >

 <style>
     label {
            display: inline-block;
            color: #4A4A4A;
            font-family: Gotham-Light;
            font-size: 14px;
            line-height: 14px;
            }
    .inputrubrik {
         box-shadow: inset 0 1px 3px 0 rgba(0,0,0,0.06);
        border: 1px solid #E6E6E6;
        border-radius: 2px;
    }

    .loginreturn {
    font-size: 12px;
    line-height: 12px;
    color: #3BBDCA;
    }

    .error-msg-box table {
        color: red;
        margin-left: 32% !important;
        margin-bottom: 22px !important;
    }

    .error-msg-box span > h4 {
        display: none !important;
    }

  </style>

   <div class="container">
        <div class="row rowcontainer" >
          <div class="col-md-12">
            <div class="row">
                <div class="col-md-12 error-msg-box">
                    <div class="col"><apex:pageMessages ></apex:pageMessages></div>
                </div>
            </div>
      <!--start form code-->
              
          <apex:form id="loginForm" forceSSL="true">
              <!--Shiva Change-->
              
              
              
              <apex:outputPanel id="finalBlock">
                  <div id="modalBox" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
                      <div class="modal-dialog modal-dialog-centered" role="document">
                          <div class="modal-content">
                              
                              <div class="modal-body">
                                  {!msgInfo}<br/>
                                  <br />
                              </div>
                              <div class="modal-footer">
                                  <apex:outputPanel rendered="{!logRedirect}">
                                      <button type="button" class="btn btn-secondary" data-dismiss="modal" onclick="window.location.href ='/SelfRegisterPage';">Close</button>
                                  </apex:outputPanel>
                                  <apex:outputPanel rendered="{!!logRedirect}">
                                      <button type="button" class="btn btn-secondary" data-dismiss="modal" onclick="window.location.href ='/';">Close</button>
                                  </apex:outputPanel>
                              </div>
                          </div>
                      </div>
                  </div>
              </apex:outputPanel>
              <!--Shiva Change END-->
                    <div class="container-fluid">
                    <div class="row">
                        <div class="col-md-4">

                        </div>

                        <div class="col-md-4">
                                 <div class="form-group text-center">
                                 <apex:image value="{!$Resource.rubrikpartnerlogodark}" style="height:54px" rendered="{!IF(CONTAINS($CurrentPage.URL, 'partner'),true, false)}"/>
                                 <apex:image value="{!$Resource.rubriksupportlogodark}" style="height:54px" rendered="{!IF(CONTAINS($CurrentPage.URL, 'partner'),false, true)}"/>
                                     <br/>
                                     </div>

                                 <div class="form-group text-left">
                                     <h2>Forgot Password?</h2>
                                     </div>
                                 <div class="form-group text-left">
                                     Please enter the Email Address associated with your account.
                                     </div>

                                <div class="form-group">
                                    <label for="username">
                                       E-mail Address
                                    </label>
                                  <apex:inputtext id="username" value="{!username}" styleClass="form-control block inputrubrik" required="true"/>
                                </div>
                              <apex:pageBlock rendered="{!IF((CONTAINS($CurrentPage.URL, 'partner')),true,false)}">
                                 <apex:commandButton action="{!forgotPartnerPassword}" value="Reset" style="width:100%;height:42px;" styleClass="btn rubrik-btn" id="loginButton"/>&nbsp;&nbsp;&nbsp;
                              </apex:pageBlock>
                              <apex:pageBlock rendered="{!IF((CONTAINS($CurrentPage.URL, 'support')) || (CONTAINS($CurrentPage.URL, 'customers')) || (CONTAINS($CurrentPage.URL, 'CustomerSupport')),true,false)}">
                                 <apex:commandButton action="{!forgotCustomerPassword}" value="Reset" style="width:100%;height:42px;" styleClass="btn rubrik-btn" id="loginButton"/>&nbsp;&nbsp;&nbsp;
                              </apex:pageBlock>
                                 <div class="col-md-4">
                                 <!--bottom row-->
                                 </div>
                                 <div class="form-group text-center">
                                     <a href="https://support.rubrik.com/s/" class="loginreturn">Return to Log in</a><br />
                                     </div>
                                 Once your password reset request is submitted. You should receive a password reset email within a couple minutes. If you do not receive the email, please return to the log in page and click Request Access. If you are a Partner, please <a href="https://rubrikpartnerregistration.secure.force.com/PartnerRegistrationForm">register for the Partner Portal</a>.

                        </div>

                    </div>
                </div>
          </apex:form>
          <!--end form code-->

        </div>
        </div>
        </div>


   </c:visualstrapblock>
    <script>
    function callModal(){
        $('#modalPress').click();
        $('#modalBox').css('top','30%');
        //return false;
    }
    </script>
    <button type="button" id="modalPress" class="btn btn-primary"  data-backdrop="static" data-keyboard="false" data-toggle="modal" style="display:none;" data-target="#modalBox">
    </button>
    <apex:outputText value="{!jsScript}" escape="false"/>
</apex:page>