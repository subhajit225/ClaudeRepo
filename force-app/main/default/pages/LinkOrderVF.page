<apex:page showHeader="false" sidebar="false" tabStyle="Order" standardController="Order">
    <apex:includeLightning />    
    <div id="LightningComponentid" />   
<!-- the Id of div tag which will be used to render your LWC component  -->
    <script>
        $Lightning.use("c:LinkOrderApp", function() {
            $Lightning.createComponent("c:linkOrders",
            { 
                recordId : '{!$CurrentPage.parameters.id}',
                isInsideVF: true
            },
            "LightningComponentid", // the Id of div tag where your component will be rendered
            function(cmp) {
                console.log('Calling the LWC Component');
            });
        });
    </script>
</apex:page>