<apex:form id="theForm">
<apex:pageblock id="theBlock">
<div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
<div class="col-lg-8 col-md-12 col-sm-12 col-xs-12">
<apex:pageblocksection columns="1" id="theSection" title="New Case Details">
    <div class="col-md-6">
        <apex:inputfield id="subject" onChange="showResults()" styleclass="subject form-control input-sm" value="{!Case.Subject}">
        </apex:inputfield>
        <apex:repeat value="{!$ObjectType.Case.FieldSets.NewCommunityCase}" var="field">
            <apex:inputfield styleclass="form-control input-sm" value="{!Case[field]}" />
        </apex:repeat>
        <b>
            For Priority 1 (P1) issues with critical business impact, please call Rubrik Support after
            your case is submitted using the phone numbers listed on the
            <a href="https://www.rubrik.com/support/#contact-numbers" target="_blank"> Support page</a>. For a list of case priorities and response times, reference the <a href="https://www.rubrik.com/wp-content/uploads/2018/03/Rubrik-Support-Services-Policy.pdf" target="_blank">Support Services Policy</a>.
        </b>
        <br/>
        <apex:inputfield id="contactmethod" styleclass="form-control input-sm" value="{!Case.Contact_method__c}" />
        <apex:pageBlockSectionItem >
            <apex:outputLabel value="" for="supportTunnel">Support Tunnel Number &nbsp;<a href="#" data-tooltip="{!$ObjectType.Case.fields.Support_Tunnel__c.inlineHelpText}" ><i class="fa fa-question-circle-o"  style="color:#005fb2;"  aria-hidden="true"></i></a>&nbsp;</apex:outputLabel>
            <apex:inputField value="{!Case.Support_Tunnel__c}" styleclass="form-control input-sm"  id="supportTunnel"/>
        </apex:pageBlockSectionItem>
    </div>
    <div class="col-md-12" id="analytics_div">
        <apex:inputtextarea style="height:200px;width:400px" styleclass="form-control input-sm" value="{!Case.Description}">
        </apex:inputtextarea>
        <apex:inputText id="Su_analytics_id" label="" styleClass="Su_analytics_id" value="{!Case.su_vf_community__SearchUnifySessionId__c}" />
    </div>
</apex:pageblocksection>
</div>
