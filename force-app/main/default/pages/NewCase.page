<script type="text/javascript">
function guid() { 
function s4() { return Math.floor((1 + Math.random()) * 0x10000) .toString(16) .substring(1); }
return s4() + s4() + '-' + s4() + '-' + s4() + '-' + s4() + '-' + s4() + s4() + s4(); 
} 
function caseCreateCalling(){
var sessionId = guid();
//trackCaseCreation(sessionId);                      
gza('caseCreated',{'caseUid': sessionId});        
document.getElementsByClassName('Su_analytics_id')[0].value = sessionId;
}
</script>
