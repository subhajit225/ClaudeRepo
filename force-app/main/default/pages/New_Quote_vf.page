<apex:page lightningStylesheets="true" >
    <apex:includeLightning />
    <apex:includeScript value="/soap/ajax/42.0/connection.js"/>
    <apex:includeScript value="/soap/ajax/42.0/apex.js"/> 
    <apex:includeScript value="/support/console/46.0/integration.js"/>
    <div id="lightning" />
    <script>
     window.onload = function(){
         if("{!$User.UITheme}" != 'Theme3'){
        sforce.console.getEnclosingTabId(closeSubtab);
             }
    }
     if("{!$User.UITheme}" != 'Theme3'){
       var showNFR = 0;
         if("{!$CurrentPage.parameters.ShowNFROnePager__c}" == 'Yes') {
             showNFR = 1;
         }
         
         sforce.one.createRecord('SBQQ__Quote__c',null,{ 
            'SBQQ__Opportunity2__c' : "{!$CurrentPage.parameters.SBQQOpportunity2__c}",
            'SBQQ__SalesRep__c' : "{!$CurrentPage.parameters.SBQQ__SalesRep__c}",
            'SBQQ__PrimaryContact__c' : "{!$CurrentPage.parameters.SBQQ__PrimaryContact__c}",
            'SBQQ__Account__c' : "{!$CurrentPage.parameters.SBQQ__Account__c}",
            'ShowNFROnePager__c': showNFR,
            'SBQQ__Partner__c' :    "{!$CurrentPage.parameters.SBQQ__Partner__c}",
            'SBQQ__Distributor__c' :   "{!$CurrentPage.parameters.SBQQ__Distributor__c}",
            'SBQQ__PriceBook__c'   : "{!$CurrentPage.parameters.SBQQ__PricebookId__c}",
             'SBQQ__PricebookId__c' : "{!$CurrentPage.parameters.SBQQ__PricebookId__c}"
            
        });
        
        
    }else{
        window.location.href = "/a6T/e?CF00N1W000002sbNk={!JSENCODE($CurrentPage.parameters.SBQQOpportunity2Name)}&CF00N1W000002sbNk_lkid={!$CurrentPage.parameters.SBQQOpportunity2__c}&CF00N1W000002sbO4={!JSENCODE($CurrentPage.parameters.SBQQ__SalesRepName)}&CF00N1W000002sbO4_lkid={!$CurrentPage.parameters.SBQQ__SalesRep__c}&CF00N1W000002sbNx={!JSENCODE($CurrentPage.parameters.SBQQ__PrimaryContactName)}&CF00N1W000002sbNx_lkid={!$CurrentPage.parameters.SBQQ__PrimaryContact__c}&CF00N1W000002sbNE={!JSENCODE($CurrentPage.parameters.SBQQ__AccountName)}&CF00N1W000002sbNE_lkid={!$CurrentPage.parameters.SBQQ__Account__c}&00N1W000002sc1k={!IF($CurrentPage.parameters.ShowNFROnePager__c ='Yes',1,0)}&CF00N1W000002sbNs={!JSENCODE($CurrentPage.parameters.SBQQ__PartnerName)}&CF00N1W000002sbNs_lkid={!$CurrentPage.parameters.SBQQ__Partner__c}&CF00N1W000002sbNW={!JSENCODE($CurrentPage.parameters.SBQQ__DistributorName)}&CF00N1W000002sbNW_lkid={!$CurrentPage.parameters.SBQQ__Distributor__c}&00N1W000002sbNw=01s1W0000003MzoQAE&CF00N1W000002sbNv=CPQ PriceBook&CF00N1W000002sbNv_lkid=01s1W0000003MzoQAE&nooverride=1&retURL=%2F{!$CurrentPage.parameters.SBQQOpportunity2__c}&saveURL=%2Fapex%2Fsbqq__sb&scontrolCaching=1&sfdc.override=1";
    }
    
    var closeSubtab = function closeSubtab(result) {
            //Now that we have the tab ID, we can close it
            var tabId = result.id;
            sforce.console.closeTab(tabId);
        };
    </script>
</apex:page>