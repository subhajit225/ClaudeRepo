<apex:page standardController="Opportunity" lightningStylesheets="true" docType="html-5.0">
    <div style="overflow: scroll; width: auto; height: 200px;">
        <apex:form >
            <apex:pageBlock >
                <apex:variable var="sizeOfOpportunityIdeaLink" value="{!0}"/>
                <apex:pageBlockTable value="{!Opportunity.Aha_Idea_Links__r}" var="idealink"  rendered="{!NOT(ISNULL(Opportunity.Aha_Idea_Links__r))}">
                    <apex:column headerValue="Aha Idea Number">
                        <apex:outputlink value="/{!idealink.Aha_Ideas__c}">{!idealink.Aha_Idea_Number__c}</apex:outputlink>
                    </apex:column>
                    <apex:column value="{!idealink.Aha_Ideas__c}"/>
                    <apex:column value="{!idealink.Idea_Status__c}"/>
                </apex:pageBlockTable>
                <apex:repeat value="{!Opportunity.Aha_Idea_Links__r}">
                    <apex:variable var="sizeOfOpportunityIdeaLink" value="{!sizeOfOpportunityIdeaLink + 1}"/>
                </apex:repeat>
                <apex:outputText value="No records founds" rendered="{!if(sizeOfOpportunityIdeaLink == 0,true,false)}"/>
            </apex:pageBlock>
        </apex:form>
    </div>
</apex:page>