                <apex:commandButton value="Cancel" action="{!cancel}"/>
            </apex:pageBlockButtons>
            
            <apex:pageBlockSection title="Order Information" columns="2">
                <apex:inputField value="{!Order.AccountId}" required="true"/>
                <apex:inputField value="{!Order.Status}"/>
                <apex:inputField value="{!Order.EffectiveDate}"/>
                <apex:inputField value="{!Order.Cancellation_Reason__c}"/>
                
                <apex:inputField value="{!Order.OpportunityId}" rendered="{!order.Type='Revenue'}" required="true"/>
                <apex:inputField value="{!Order.OpportunityId}" rendered="{!order.Type='RMA'}" required="false"/>
                <apex:inputField value="{!Order.Change_Needed_Reasons__c}"/>
                <apex:inputField value="{!Order.Description}"/>
                <apex:inputField value="{!Order.Integration_Failure__c}"/>
                <apex:pageBlockSectionItem />
