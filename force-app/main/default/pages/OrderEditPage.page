                <apex:pageBlockSectionItem />
                <apex:inputField value="{!Order.Payment_Terms__c}"/>
                
                
                
            </apex:pageBlockSection>
            
            <apex:pageBlockSection title="Shipping Information" columns="2">
                <apex:pageBlockSectionItem rendered="{!order.Type='Revenue'}">
                    <apex:outputLabel value="{! $ObjectType.Order.fields.Ship_To_Name__c.label }" for="accountLookup" />
                    <apex:actionRegion >
                        <apex:inputField value="{! Order.Ship_To_Name__c }" id="accountLookup" required="{!order.Type='Revenue'}" >
                            <apex:actionSupport event="onchange" action="{! selectShippingAddress }" reRender="contactLookup,darkSite,tstpopup" />
                        </apex:inputField>
                    </apex:actionRegion>
                    
                </apex:pageBlockSectionItem>
                <apex:inputField value="{!Order.ShipToName__c}" rendered="{!order.Type='RMA'}" />
                 <apex:inputField value="{!Order.Shipping_Carrier__c}" />
                <apex:inputField value="{!Order.ShipToContactName__c}" />
                
                
                <apex:inputField value="{!Order.Service_Level__c}" rendered="{!order.Type=='Revenue'}"/>
                <apex:inputField value="{!Order.Service_Type__c}" rendered="{!order.Type =='RMA'}"/>
                
                
                <apex:pageBlockSectionItem >
                    <apex:outputLabel >Shipping Address Label</apex:outputLabel>
                    <apex:selectList id="darkSite" value="{!selectedShippingAddress}" size="1" styleClass="slds-size--1-of-1" title="Select Shipping Address">
                        <apex:selectOptions value="{!shippingAddressesOptions}"/>
                        <apex:actionSupport event="onchange" action="{!onSelectShippingAddress}" rerender="shippingCountryId,shippingStreetId,shippingCityId,shippingStateId,shippingPostalId"/>
                    </apex:selectList>
                </apex:pageBlockSectionItem>
                
                <apex:inputField value="{!Order.Shipping_Method__c}"/>
                <apex:inputField label="Shipping Country" value="{!Order.ShippingCountryCode}" id="shippingCountryId" required="false" >
                
                </apex:InputField>
                
                <apex:inputField value="{!Order.Shipping_Account_Number__c}" />
                <apex:inputField value="{!Order.ShippingStreet}" id="shippingStreetId" required="false"/>
                <apex:inputField value="{!Order.Deliver_By__c}"/>
                <apex:inputField value="{!Order.ShippingCity}" id="shippingCityId" required="false"/>
                <apex:inputField value="{!Order.Ship_to_Email__c}" id="shiptoemail"/>
                <apex:inputField label="Shipping State/Province" value="{!Order.ShippingStateCode}" id="shippingStateId" required="false"/>
                
                <apex:inputField value="{!Order.Ship_To_Phone_Number__c}" id="shiptophone"/>
                <apex:inputField value="{!Order.ShippingPostalCode}" id="shippingPostalId" required="false"/>
                <apex:inputField value="{!Order.Est_Ship_Date__c}" />
                
                <apex:pageBlockSectionItem />
                
                <apex:pageBlockSectionItem />
                
                
            </apex:pageBlockSection>
            <apex:pageBlockSection title="Fullfillment Information" columns="2">
                <apex:inputField value="{!Order.Order_Status__c}"/>
                
                
                <apex:inputField value="{!Order.Actual_Order_Ship_Date__c}"/>
                <apex:inputField value="{!Order.Tracking_No__c}"/>
                
                
            </apex:pageBlockSection>
        </apex:pageBlock>
    </apex:form>
