<apex:page standardController="Order" showHeader="true" 
      tabStyle="order" >
   <style>
      .activeTab {background-color: #236FBD; color:white; 
         background-image:none}
      .inactiveTab { background-color: lightgrey; color:black; 
         background-image:none}
   </style>
  
   <apex:pageBlock title="POC {!order.type}" rendered="{!order.RecordType.Name == 'Revenue Order'}">
         <apex:detail relatedList="false" title="false"  />
       </apex:pageBlock>
   <apex:pageBlock title="Order {!order.orderNumber}" rendered="{!order.RecordType.Name != 'Revenue Order'}">
         <apex:detail relatedList="false" title="false" />
       </apex:pageBlock>    
   
      
         <apex:relatedList subject="{!order}" list="OrderItems" />
      
         
      
         <apex:relatedList subject="{!order}" 
                           list="Error_Log__r" />
                          
</apex:page>