                You are already registered as a partner using this email address. Please contact <a href="mailto:channels@rubrik.com">channels@rubrik.com</a> if you have questions. 
                    <script>
                function showMessageonSave(){
                
                    if({!OR(isRequired,zipLength)}) {
                        document.getElementById('ziperrorDiv').style.display='block';
                    }
                    
                     
                    if({!isduplicateContactBool} == true && {!isRequired==false} && {!zipLength==false}) {
                        document.getElementById('requestFormDiv').style.display='none';
                        document.getElementById('duplicateConMessageDiv').style.display='block';
                    } 
                
                    else if ({!isduplicateContactBool} == false && {!ziplength} == false && {!isRequired} == false ){
                    document.getElementById('requestFormDiv').style.display='none';
                    document.getElementById('successMessageDiv').style.display='block';
                    //setTimeout('window.close()', 5000);
                    }
                    //else{
                    //document.getElementById('successMessageDiv').style.display='block';
                    //document.getElementById('requestFormDiv').style.display='none';
                    //}
                }
                
            // Mutation object
            var MutationObserver = window.MutationObserver || window.WebKitMutationObserver || window.MozMutationObserver;
            
            // Defining observer 
            var observer = new MutationObserver(function(mutations) { 
                // If the myListClass was removed from the list - re-assign it
                if(!jQuery('#selectList1 select').first().hasClass('slds-select')){
                    jQuery('#selectList1 select').first().addClass('slds-select required');
                }
                if(!jQuery('#selectList2 select').first().hasClass('slds-select')){
                    jQuery('#selectList2 select').first().addClass('slds-select required');
                }
                if(!jQuery('#selectList3 select').first().hasClass('slds-select')){
                    jQuery('#selectList3 select').first().addClass('slds-select required');
                }
                
                if(!jQuery('#selectList4 select').first().hasClass('slds-select')){
                    jQuery('#selectList4 select').first().addClass('slds-select required');
                }
            });
            
            // A target object fot the observer
            var myNode1 = document.querySelector('#selectList1'); 
            var myNode2 = document.querySelector('#selectList2');
            var myNode3 = document.querySelector('#selectList3');
            var myNode4 = document.querySelector('#selectList4');
            // Assigning observer to the dependent picklist
            observer.observe(myNode1, {
                childList: true,
                subtree: true,
                attributes: true
            });
            observer.observe(myNode2, {
                childList: true,
                subtree: true,
                attributes: true
            });
            observer.observe(myNode3, {
                childList: true,
                subtree: true,
                attributes: true
            });
            observer.observe(myNode4, {
                childList: true,
                subtree: true,
                attributes: true
            });
                            
                
                
                
                
                
