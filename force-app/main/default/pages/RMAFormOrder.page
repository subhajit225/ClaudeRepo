  <script>
    function getAccountId(data){  
        const urlParams = new URLSearchParams(location.search);
        const caseId = urlParams.get("id");
        const accountId = getElementByIdCS('RMAForm:shippingInformation:account_lookup_lkid').value;
        const csNumber = "{!newcase.CaseNumber}";
        location.href = `/apex/RMAFormOrder?id=${caseId}&accId=${accountId}&csNum=${csNumber}`;
    }
    const sessionId = "{!$Api.Session_ID}";

    const j$ = jQuery.noConflict();
    j$('.lookupInput a').css({ "border": "none", "width": "50px","padding": "1px","position": "absolute","margin-left": "-6%", "background": "transparent","box-shadow": "none"});         
    j$('.lookupInput').css({ "width":"100%"});
  
    /**js for other option for failure reason**/
    j$(".failure-select").change(function () {
      var tableRow = j$(this).closest("tr");
      if (j$(this).val() == "Other") {
        console.log("in if", tableRow);
        j$(tableRow).find(".other-input").removeClass("slds-hide");
      } else {
        j$(tableRow).find(".other-input").addClass("slds-hide");
      }
    });


    j$(".datepicker").datepicker({
      beforeShowDay: j$.datepicker.noWeekends,
      dateFormat: "mm/dd/yy",
      minDate: 1,
    });
    j$(".slds-info-button").hover(
      function (e) {
        j$(this)
          .closest("div.slds-tooltip-block")
          .find(".slds-popover_tooltip")
          .addClass("slds-rise-from-ground")
          .removeClass("slds-fall-into-ground");
      },
      function (e) {
        j$(this)
          .closest("div.slds-tooltip-block")
          .find(".slds-popover_tooltip")
          .removeClass("slds-rise-from-ground")
          .addClass("slds-fall-into-ground");
      }
    );

    const domElements = new Object();

    // domElements["smartHandsTime"] = document.getElementById(
    //   "{! $Component.shippingInformation.smartHandsTime }"
    // );

    const callServer = (params, callMethod) => {
      console.log(
        `%cCall Server: ${JSON.stringify({
          params,
          TYPE: callMethod,
        })}`,
        cssStyle0
      );
      return new Promise((resolve, reject) => {
        if(callMethod =='SAVE_RMA' || callMethod =='GET_VALIDITY_AND_NRD_POLICY'){
            disableElem(domElements.saveRma);  
        }
        Visualforce.remoting.Manager.invokeAction(
          "{!$RemoteAction.RMAFormOrderController.singleSourceOfTruth}",
          JSON.stringify({
            params,
            TYPE: callMethod,
          }),
          (result, event) => {
            try {
              if(callMethod =='SAVE_RMA' || callMethod =='GET_VALIDITY_AND_NRD_POLICY'  ){
                 enableElem(domElements.saveRma);  
              }
              if (event.status && event.type === "rpc") {
                let a = "quot";
                result = JSON.parse(result.replaceAll(`&${a};`, `\"`));
                varResult = result;
                console.log(
                  `%cCall Server Result for ${callMethod}`,
                  cssStyleBgGreenFgWhite
                );
                resolve(result);
              } else if (event.type === "exception") {
                console.error(`Exception: ${event.message}`);
                showHeaderErrorToast(event.message);
              } else {
                console.error(`Error: ${event.message}`);
                showHeaderErrorToast(event.message);
              }
            } catch {
              showHeaderErrorToast(
                "Some thing unexpected happened, try refreshing or contact Admin"
              );
            }
          }
        );
      });
    };

    document.body.dispatchEvent(
      new CustomEvent("loadedDomMappings", {
        detail: {
          isLoaded: true,
        },
        bubbles: true
      })
    );
  </script>
