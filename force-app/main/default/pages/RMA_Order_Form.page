                            <script>
                                function EmailValidation() {
                                var emailAddress= document.getElementById('RMAForm:requestForm:AdditionalEmail').value ;
                                if(!emailAddress)
                                 {
                                 return true;
                                 }
                                var patt= new RegExp('^[a-zA-Z][a-zA-Z0-9]*(?:[\.|\-|\_][a-zA-Z0-9]+)*@[rR][uU][bB][rR][iI][kK].[cC][oO][mM](?:,[a-zA-Z][a-zA-Z0-9]*(?:[\.|\-|\_][a-zA-Z0-9]+)*@[rR][uU][bB][rR][iI][kK].[cC][oO][mM])*$');
                                console.log('Entering into EmailValidation emailAddress'+emailAddress);
                                var flag=patt.test(emailAddress);
                                console.log('Entering into EmailValidation flag '+flag);
                                if(flag==false){
                                     var thisvar = $j("input[id$='AdditionalEmail']");
                                      $j(thisvar).css("border-color", "#8C0005");
                                      var errorContent = "<div class='dealRError' style='right: 5.5px; margin-bottom: -34px; z-index: 100; position: relative;'><div class='dealRErrorArrowWrap' style='position: initial;'><div class='dealRErrorArrow'></div></div><div class='dealRErrorMsg'>Please Enter comma seperated Rubrik Email address(example@Rubrik.com)</div></div>";
                                       if(! $j(thisvar).parent().find(".dealRError").length)
                                       $j(thisvar).after($j(errorContent).fadeIn(500));
                                       
                                   return false;

                                }
                                return flag;
                                
                                                               
                                }
                                </script>

                            
                            </div>
