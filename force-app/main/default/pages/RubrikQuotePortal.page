    <!-- ── Right panel: Form ── -->
    <div class="right-panel">
        <div class="form-wrap">

            <div id="form-section">
                <h1 class="form-title">Access Your <span>OVF</span></h1>
                <div class="divider"></div>
                <p class="form-subtitle">Enter your quote number and registered email address to view your OVF</p>

                <!-- Quote Number -->
                <div class="field-group">
                    <label class="field-label" for="quoteNum">
                        <svg class="label-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M5 5.5h6M5 8h6M5 10.5h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        Quote Number
                    </label>
                    <input type="text" id="quoteNum" class="field-input" placeholder="e.g. Q-00001234" maxlength="30" autocomplete="off"/>
                    <span id="quoteErr" class="field-error hidden"></span>
                </div>

                <!-- Email -->
                <div class="field-group">
                    <label class="field-label" for="emailAddr">
                        <svg class="label-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <rect x="2" y="3.5" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M2 6l6 3.5L14 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        Email Address
                    </label>
                    <input type="email" id="emailAddr" class="field-input" placeholder="you@company.com" autocomplete="email"/>
                    <span id="emailErr" class="field-error hidden"></span>
                </div>

                <!-- Submit -->
                <button id="submitBtn" class="btn-submit" onclick="handleSubmit()">
                    <span id="btnLabel">View OVF</span>
                    <svg id="btnArrow" class="btn-arrow" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span id="btnSpinner" class="spinner hidden" aria-hidden="true"></span>
                </button>

                <div id="serverErr" class="alert-error hidden" role="alert">
                    <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M8 5v3.5M8 11h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    <span id="serverErrMsg"></span>
                </div>
            </div>

            <!-- OVF Form section (shown after successful email validation) -->
            <div id="ovf-section" class="hidden">
                <!-- Progress step indicator -->
                <div class="progress-steps">
                    <div class="step done" id="step1-indicator">
                        <div class="step-circle done">
                            <svg viewBox="0 0 16 16" fill="none"><path d="M3 8l3.5 3.5L13 5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                        <span class="step-label">Verify Identity</span>
                    </div>
                    <div class="step-connector" id="step-connector"></div>
                    <div class="step" id="step2-indicator">
                        <div class="step-circle" id="step2-circle">2</div>
                        <span class="step-label">Complete OVF</span>
                    </div>
                </div>

