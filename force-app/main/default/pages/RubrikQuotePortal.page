<script>
    /* ── Rotating 3D particle sphere ── */
    (function() {
        var canvas = document.getElementById('particleSphere');
        if (!canvas) return;
        var ctx = canvas.getContext('2d');
        if (!ctx) return;

        var PARTICLE_COUNT = 2500;
        var particles = [];
        var glowParticles = [];
        var angleX = 0;
        var angleY = 0;
        var animId = null;

        /* Build sphere points using spherical coordinates */
        function initParticles() {
            particles = [];
            for (var i = 0; i < PARTICLE_COUNT; i++) {
                var theta = Math.acos(2 * Math.random() - 1);  /* polar angle */
                var phi = 2 * Math.PI * Math.random();          /* azimuthal angle */
                particles.push({ theta: theta, phi: phi });
            }
        }

        function resize() {
            canvas.width  = canvas.offsetWidth;
            canvas.height = canvas.offsetHeight;
        }

        function draw() {
            if (!ctx) return;
            var w = canvas.width;
            var h = canvas.height;
            var cx = w / 2;
            var cy = h / 2;
            var radius = 0.48 * Math.min(canvas.width, canvas.height) / 2;

            ctx.clearRect(0, 0, canvas.width, canvas.height);
            var bgGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.max(canvas.width, canvas.height) * 0.8);
            bgGrad.addColorStop(0, '#050d1a');
            bgGrad.addColorStop(1, '#000000');
            ctx.fillStyle = bgGrad;
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            var coreGlow = ctx.createRadialGradient(cx, cy, 0, cx, cy, radius * 0.7);
            coreGlow.addColorStop(0, 'rgba(255,120,40,0.22)');
            coreGlow.addColorStop(1, 'rgba(255,120,40,0)');
            ctx.fillStyle = coreGlow;
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            var halo = ctx.createRadialGradient(cx, cy, radius * 0.75, cx, cy, radius * 1.15);
            halo.addColorStop(0, 'rgba(30,80,180,0)');
            halo.addColorStop(0.5, 'rgba(30,80,180,0.12)');
            halo.addColorStop(1, 'rgba(30,80,180,0)');
            ctx.fillStyle = halo;
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            var cosAX = Math.cos(angleX);
            var sinAX = Math.sin(angleX);
            var cosAY = Math.cos(angleY);
            var sinAY = Math.sin(angleY);

            /* Disable shadow for main particle pass */
            ctx.shadowBlur = 0;
            glowParticles.length = 0;

            for (var i = 0; i < particles.length; i++) {
                var p = particles[i];

                /* Convert spherical to 3D cartesian */
                var x = radius * Math.sin(p.theta) * Math.cos(p.phi);
                var y = radius * Math.sin(p.theta) * Math.sin(p.phi);
                var z = radius * Math.cos(p.theta);

                /* Wave distortion in world-space (before rotation) */
                var waveY = y + Math.sin(p.theta * 6) * (radius * 0.015);

                /* Rotate around X axis */
                var y1 = waveY * cosAX - z * sinAX;
                var z1 = waveY * sinAX + z * cosAX;

                /* Rotate around Y axis */
                var x2 = x * cosAY + z1 * sinAY;
                var z2 = -x * sinAY + z1 * cosAY;

                /* Depth factor: map z from [-radius, radius] to [0, 1] */
                var depth = (z2 + radius) / (2 * radius);

                /* Size and opacity based on depth (closer = bigger/brighter) */
                var size = 0.5 + depth * 2.0;
                var alpha = 0.08 + depth * 0.72;

                /* Project 3D to 2D (simple orthographic) */
                var sx = cx + x2;
                var sy = cy + y1;

                /* Dual-color particles: amber for front, teal for back */
                var zNorm = depth;
                var particleColor;
                if (zNorm > 0.3) {
                    var warmBlend = (zNorm - 0.3) / 0.7;
                    var r = Math.round(0 + warmBlend * 200);
                    var g = Math.round(157 - warmBlend * 80);
                    var b = Math.round(172 - warmBlend * 140);
                    particleColor = 'rgba(' + r + ',' + g + ',' + b + ',' + alpha.toFixed(2) + ')';
                } else {
                    particleColor = 'rgba(0,157,172,' + alpha.toFixed(2) + ')';
                }

                ctx.beginPath();
                ctx.arc(sx, sy, size, 0, 2 * Math.PI);
                ctx.fillStyle = particleColor;
                ctx.fill();

                /* Collect front-facing particles for ambient glow pass */
                if (zNorm > 0.5) {
                    glowParticles.push({ sx: sx, sy: sy, size: size });
                }
            }

            /* Single ambient glow pass: sub-samples to ~80 draws when glowParticles.length > 80; otherwise all collected particles are drawn */
            ctx.shadowBlur = 8;
            ctx.shadowColor = 'rgba(0,200,190,0.5)';
            var glowStep = Math.max(1, Math.floor(glowParticles.length / 80));
            for (var g = 0; g < glowParticles.length; g += glowStep) {
                var gp = glowParticles[g];
                ctx.beginPath();
                ctx.arc(gp.sx, gp.sy, gp.size * 3.5, 0, 2 * Math.PI);
                ctx.fillStyle = 'rgba(0,200,190,0.06)';
                ctx.fill();
            }
            ctx.shadowBlur = 0;

            /* Slow continuous rotation */
            angleX += 0.003;
            angleY += 0.005;

            animId = requestAnimationFrame(draw);
        }

        function startAnimation() {
            if (animId) return;
            resize();
            initParticles();
            animId = requestAnimationFrame(draw);
        }

        function stopAnimation() {
            if (animId) {
                cancelAnimationFrame(animId);
                animId = null;
            }
        }

        /* Expose stop function to window for OVF mode */
        window.stopParticleAnimation = stopAnimation;

        /* Only start on desktop */
        if (window.innerWidth > 768) {
            startAnimation();
        }

        var resizeTimer;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(function() {
                if (window.innerWidth > 768) {
                    startAnimation();
                } else {
                    stopAnimation();
                }
            }, 120);
        });
    })();

    /* ── Dynamic OVF field rendering ── */
    function getInputType(sfType) {
        if (sfType === 'email') return 'email';
        if (sfType === 'phone') return 'tel';
        if (sfType === 'textarea') return 'textarea';
        return 'text';
    }

    function getAutocomplete(apiName) {
        var map = {
            'Company_Name__c': 'organization',
            'Address_1__c': 'address-line1',
            'Address_2__c': 'address-line2',
            'City__c': 'address-level2',
            'State__c': 'address-level1',
            'Zip_Code__c': 'postal-code',
            'Country__c': 'country-name',
            'Contact_Name__c': 'name',
            'Contact_Email__c': 'email',
            'Contact_Phone__c': 'tel'
        };
        return map[apiName] || 'off';
    }

    var REQUIRED_FIELDS = {
        'buyer_name__c': true,
        'buyer_billing_id__c': true,
        'contact_name__c': true,
        'contact_email__c': true,
        'company_name__c': true
    };

    var FIELD_SECTIONS = [
        {
            title: 'Order Details',
            icon: '',
            fields: ['buyer_name__c','buyer_billing_id__c','buyer_tenant_id__c','reseller_name__c','marketplace_seller_id__c']
        },
        {
            title: 'Company Information',
            icon: '',
            fields: ['company_name__c','address_1__c','address_2__c','city__c','state__c','zip_code__c','country__c']
        },
        {
            title: 'Contact Details',
            icon: '',
            fields: ['contact_name__c','contact_email__c','contact_phone__c']
        }
    ];

    function createFieldElement(f) {
        var inputType = getInputType(f.fieldType);
        var autocomplete = getAutocomplete(f.apiName);
        var div = document.createElement('div');
        div.className = 'field-group';

        var label = document.createElement('label');
        label.className = 'field-label';
        label.setAttribute('for', 'ovf_' + f.apiName);
        label.textContent = f.label;
        div.appendChild(label);

        var input;
        if (inputType === 'textarea') {
            input = document.createElement('textarea');
            input.rows = 3;
            input.style.height = 'auto';
            input.style.padding = '10px 16px';
        } else {
            input = document.createElement('input');
            input.type = inputType;
        }
        input.id = 'ovf_' + f.apiName;
        input.className = 'field-input';
        input.setAttribute('maxlength', f.maxLength);
        input.setAttribute('autocomplete', autocomplete);
        input.placeholder = f.label;
        if (f.isRequired || REQUIRED_FIELDS[f.apiName.toLowerCase()]) {
            input.setAttribute('required', 'required');
            label.textContent = f.label + ' *';
        }
        div.appendChild(input);
        return div;
    }

    function renderOVFFields() {
        var container = document.getElementById('ovf-fields-container');
        if (!container || !window.OVF_FIELDS) return;
        container.innerHTML = '';

        /* Build a lookup: lowercase apiName -> field object */
        var fieldMap = {};
        var assigned = {};
        for (var i = 0; i < OVF_FIELDS.length; i++) {
            fieldMap[OVF_FIELDS[i].apiName.toLowerCase()] = OVF_FIELDS[i];
        }

        /* Render each defined section */
        for (var s = 0; s < FIELD_SECTIONS.length; s++) {
            var section = FIELD_SECTIONS[s];
            var sectionFields = [];
            for (var j = 0; j < section.fields.length; j++) {
                var key = section.fields[j].toLowerCase();
                if (fieldMap[key]) {
                    sectionFields.push(fieldMap[key]);
                    assigned[key] = true;
                }
            }
            if (sectionFields.length === 0) continue;

            var card = document.createElement('div');
            card.className = 'section-card';

            var header = document.createElement('div');
            header.className = 'section-header';

            var title = document.createElement('span');
            title.className = 'section-title';
            title.textContent = section.title;
            header.appendChild(title);
            card.appendChild(header);

            var fieldsGrid = document.createElement('div');
            fieldsGrid.className = 'section-fields ovf-grid';
            for (var k = 0; k < sectionFields.length; k++) {
                fieldsGrid.appendChild(createFieldElement(sectionFields[k]));
            }
            card.appendChild(fieldsGrid);
            container.appendChild(card);
        }

        /* Catch-all section for unmatched fields */
        var otherFields = [];
        for (var m = 0; m < OVF_FIELDS.length; m++) {
            if (!assigned[OVF_FIELDS[m].apiName.toLowerCase()]) {
                otherFields.push(OVF_FIELDS[m]);
            }
        }
        if (otherFields.length > 0) {
            var otherCard = document.createElement('div');
            otherCard.className = 'section-card';

            var otherHeader = document.createElement('div');
            otherHeader.className = 'section-header';

            var otherTitle = document.createElement('span');
            otherTitle.className = 'section-title';
            otherTitle.textContent = 'Additional Information';
            otherHeader.appendChild(otherTitle);
            otherCard.appendChild(otherHeader);

            var otherGrid = document.createElement('div');
            otherGrid.className = 'section-fields ovf-grid';
            for (var n = 0; n < otherFields.length; n++) {
                otherGrid.appendChild(createFieldElement(otherFields[n]));
            }
            otherCard.appendChild(otherGrid);
            container.appendChild(otherCard);
        }
    }

    /* ── Form logic ── */
    var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    var currentQuoteId = null;
    var currentContactName  = null;
    var currentContactEmail = null;
    var currentContactPhone = null;
    var currentCompanyName  = null;
    var currentShippingAddress1 = null;
    var currentShippingAddress2 = null;
    var currentShippingCity     = null;
    var currentShippingState    = null;
    var currentShippingZipCode  = null;
    var currentShippingCountry  = null;

    function $el(id) { return document.getElementById(id); }
    function show(id) { $el(id).classList.remove('hidden'); }
    function hide(id) { $el(id).classList.add('hidden'); }
    function setErr(inp, err, msg) { $el(inp).classList.add('has-error'); $el(err).textContent = msg; show(err); }
    function clrErr(inp, err)      { $el(inp).classList.remove('has-error'); hide(err); }

    function handleSubmit() {
        var q = $el('quoteNum').value.trim();
        var e = $el('emailAddr').value.trim();
        var ok = true;
        clrErr('quoteNum','quoteErr'); clrErr('emailAddr','emailErr'); hide('serverErr');

        if (!q) { setErr('quoteNum','quoteErr','Quote number is required.'); ok = false; }
        if (!e) { setErr('emailAddr','emailErr','Email address is required.'); ok = false; }
        else if (!EMAIL_RE.test(e)) { setErr('emailAddr','emailErr','Please enter a valid email address.'); ok = false; }
        if (!ok) return;

        $el('submitBtn').disabled = true;
        $el('btnLabel').textContent = 'Verifying\u2026';
        hide('btnArrow'); show('btnSpinner');

        Visualforce.remoting.Manager.invokeAction(
            '{!$RemoteAction.RubrikQuoteLookupController.lookupQuoteVF}',
            q, e,
            function(result, event) {
                $el('submitBtn').disabled = false;
                $el('btnLabel').textContent = 'View OVF';
                hide('btnSpinner'); show('btnArrow');

                if (event.status && result !== null) {
                    currentQuoteId = result.quoteId;
                    currentContactName  = result.contactName  || '';
                    currentContactEmail = result.contactEmail || '';
                    currentContactPhone = result.contactPhone || '';
                    currentCompanyName  = result.companyName  || '';
                    currentShippingAddress1 = result.shippingAddress1 || '';
                    currentShippingAddress2 = result.shippingAddress2 || '';
                    currentShippingCity     = result.shippingCity     || '';
                    currentShippingState    = result.shippingState    || '';
                    currentShippingZipCode  = result.shippingZipCode  || '';
                    currentShippingCountry  = result.shippingCountry  || '';

                    /* ── Staged animation: email-verification -> OVF form ── */
                    if (window._ovfAnimating) return;
                    window._ovfAnimating = true;

                    var formSection = document.getElementById('form-section');
                    var ovfSection = document.getElementById('ovf-section');
                    var splitEl = document.querySelector('.split');

                    /* Stage 1 (0ms): Stop particles, start fading out form-section */
                    if (window.stopParticleAnimation) { window.stopParticleAnimation(); }
                    formSection.classList.add('fading-out');
                    formSection.setAttribute('aria-hidden', 'true');
                    formSection.setAttribute('inert', '');

                    /* Stage 2 (300ms): Add ovf-mode (triggers panel width + particle/overlay fade) */
                    setTimeout(function() {
                        splitEl.classList.add('ovf-mode');
                        // Populate and show the quote card in the sidebar
                        var quoteCard = document.getElementById('ovf-quote-card');
                        var quoteNumEl = document.getElementById('ovf-quote-number');
                        if (quoteCard && quoteNumEl) {
                            var quoteInput = document.getElementById('quoteNum');
                            quoteNumEl.textContent = quoteInput ? quoteInput.value.trim() : '';
                            quoteCard.style.display = 'block';
                        }
                        /* Hide form section fully after its fade */
                        setTimeout(function() {
                            formSection.classList.add('hidden');
                            formSection.classList.remove('fading-out');
                            formSection.removeAttribute('aria-hidden');
                            formSection.removeAttribute('inert');
                        }, 370);

                        /* Stage 3 (300ms after Stage 2 = 600ms total): Show OVF section with fade-in */
                        setTimeout(function() {
                            ovfSection.classList.remove('hidden');
                            requestAnimationFrame(function() {
                                requestAnimationFrame(function() {
                                    ovfSection.classList.add('faded-in');
                                    window._ovfAnimating = false;
                                });
                            });

                            /* Render OVF fields and activate step indicator */
                            renderOVFFields();
                            /* Auto-fill contact fields from OCR */
                            var cnEl = document.getElementById('ovf_Contact_Name__c');
                            var ceEl = document.getElementById('ovf_Contact_Email__c');
                            var cpEl = document.getElementById('ovf_Contact_Phone__c');
                            if (cnEl && currentContactName)  { cnEl.value = currentContactName; }
                            if (ceEl && currentContactEmail) { ceEl.value = currentContactEmail; }
                            if (cpEl) { cpEl.value = currentContactPhone || ''; }
                            var cnameEl = document.getElementById('ovf_Company_Name__c');
                            var bnameEl = document.getElementById('ovf_Buyer_Name__c');
                            if (cnameEl) { cnameEl.value = currentCompanyName || ''; }
                            if (bnameEl) { bnameEl.value = currentContactName || ''; }
                            var addr1El    = document.getElementById('ovf_Address_1__c');
                            var addr2El    = document.getElementById('ovf_Address_2__c');
                            var cityEl     = document.getElementById('ovf_City__c');
                            var stateEl    = document.getElementById('ovf_State__c');
                            var zipEl      = document.getElementById('ovf_Zip_Code__c');
                            var countryEl  = document.getElementById('ovf_Country__c');
                            if (addr1El)   { addr1El.value   = currentShippingAddress1; }
                            if (addr2El)   { addr2El.value   = currentShippingAddress2; }
                            if (cityEl)    { cityEl.value    = currentShippingCity; }
                            if (stateEl)   { stateEl.value   = currentShippingState; }
                            if (zipEl)     { zipEl.value     = currentShippingZipCode; }
                            if (countryEl) { countryEl.value = currentShippingCountry; }
                            document.getElementById('step2-circle').classList.add('active');
                            document.getElementById('step2-indicator').classList.add('active');
                            document.getElementById('step-connector').classList.add('done');
                        }, 300);
                    }, 300);
                } else if (event.status) {
                    $el('serverErrMsg').textContent = 'No quote found matching those details. Please check and try again.';
                    show('serverErr');
                } else {
                    $el('serverErrMsg').textContent = event.message || 'Something went wrong. Please try again.';
                    show('serverErr');
                }
            },
            { escape: true }
        );
    }

    function handleOVFSubmit() {
        hide('ovfServerErr');

        // Client-side required field validation
        if (window.OVF_FIELDS) {
            var missingRequired = false;
            for (var i = 0; i < OVF_FIELDS.length; i++) {
                var apiName = OVF_FIELDS[i].apiName.toLowerCase();
                if (OVF_FIELDS[i].isRequired || REQUIRED_FIELDS[apiName]) {
                    var inputEl = document.getElementById('ovf_' + OVF_FIELDS[i].apiName);
                    if (inputEl && !inputEl.value.trim()) {
                        inputEl.classList.add('has-error');
                        missingRequired = true;
                    } else if (inputEl) {
                        inputEl.classList.remove('has-error');
                    }
                }
            }
            if (missingRequired) {
                $el('ovfServerErrMsg').textContent = 'Please fill in all required fields.';
                show('ovfServerErr');
                return;
            }
        }

        $el('ovfSubmitBtn').disabled = true;
        $el('ovfBtnLabel').textContent = 'Submitting\u2026';
        hide('ovfBtnArrow'); show('ovfBtnSpinner');

        var fieldValues = {};
        if (window.OVF_FIELDS) {
            for (var i = 0; i < OVF_FIELDS.length; i++) {
                var apiName = OVF_FIELDS[i].apiName;
                var inputEl = document.getElementById('ovf_' + apiName);
                fieldValues[apiName] = inputEl ? inputEl.value.trim() : '';
            }
        }

        Visualforce.remoting.Manager.invokeAction(
            '{!$RemoteAction.RubrikQuoteLookupController.submitOVFDynamic}',
            currentQuoteId,
            JSON.stringify(fieldValues),
            function(result, event) {
                $el('ovfSubmitBtn').disabled = false;
                $el('ovfBtnLabel').textContent = 'Submit OVF';
                hide('ovfBtnSpinner'); show('ovfBtnArrow');

                if (event.status && result !== null) {
                    hide('ovf-section');
                    show('thankyou-section');
                } else {
                    var msg = (event.status)
                        ? 'Failed to submit OVF. Please try again.'
                        : (event.message || 'Something went wrong. Please try again.');
                    $el('ovfServerErrMsg').textContent = msg;
                    show('ovfServerErr');
                }
            },
            { escape: true }
        );
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            if (!$el('form-section').classList.contains('hidden')) {
                handleSubmit();
            } else if (!$el('ovf-section').classList.contains('hidden')) {
                handleOVFSubmit();
            }
        }
    });
</script>
</body>
</html>
</apex:page>
