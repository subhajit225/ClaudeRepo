        function autoCF(){
        var accountObjects;
        var userObjects;
        var queryTerm;
        $('[id$=updateItemTextBox]').autocomplete({
            minLength: 2,
            source: function(request, response) {
                        queryTerm = request.term;
                        if($('[id$=ddlUpdateField]').val()=='Account'){
                                SearchPatchManagerVFC.searchAccount(request.term, function(result, event){
                                    if(event.type == 'exception') {
                                          alert(event.message);
                                    } else {
                                         accountObjects = result;
                                         response(accountObjects);
                                    }
                                });
                        }else if($('[id$=ddlUpdateField]').val()=='Owner' || $('[id$=ddlUpdateField]').val()=='SDR' || $('[id$=ddlUpdateField]').val()=='SMB Owner'){
                                SearchPatchManagerVFC.searchUser(request.term, function(result, event){
                                    if(event.type == 'exception') {
                                          alert(event.message);
                                    } else {
                                         userObjects = result;
                                         response(userObjects);
                                    }
                                });
                        }else{
                            userObjects=null;
                            accountObjects=null;
                            response(accountObjects);
                        }
                   },
            focus: function( event, ui ) {
                    $('[id$=updateItemTextBox]').val( ui.item.Name );
                    return false;
                    },
            select: function( event, ui ) {
                        $('[id$=updateItemTextBox]').val( ui.item.Name );
                        $('[id$=updateItemId]').val( ui.item.Id );
                        return false;
                    },
         })
         .data( "autocomplete" )._renderItem = function( ul, item ) {
            var entry = "<a>" + item.Name;
           
            entry = entry + "</a>";
            entry = entry.replace(queryTerm, "<b>" + queryTerm + "</b>");
            return $( "<li></li>" )
                .data( "item.autocomplete", item )
                .append( entry )
                .appendTo( ul );
        };
        }
        
