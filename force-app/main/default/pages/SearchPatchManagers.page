        var globalSelectionList = new Array();
        function selectAllCheckboxes(objSelect){
            globalSelectionList = new Array();
            if(objSelect.checked){
                    $('.selectCheck').each(function(){ 
                        this.checked=true;
                        console.log(this.value);
                        globalSelectionList.push(this.value);
                    });
                    
                   
                    
                }else{
                    $('.selectCheck').each(function(){this.checked=false;});
                    globalSelectionList = new Array();
                    
                }
        }
        function selectIndividual(objSelect){
            if(objSelect.checked == false) {
                var delOne = globalSelectionList.indexOf(objSelect.value);
                globalSelectionList.splice(delOne,1);
                console.log(JSON.stringify(globalSelectionList));
            }   
            else {
                globalSelectionList.push(objSelect.value);
                console.log(JSON.stringify(globalSelectionList));
