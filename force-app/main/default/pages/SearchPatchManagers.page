<!-- The Modal -->
<div id="myModal" class="modal">

  <!-- Modal content -->
  <div class="modal-content">
    <span class="close">&times;</span>
    <apex:pageBlock id="searchBlock" >
            <apex:pageBlockSection id="searchSection" title="Update Records" columns="2" >
                <apex:OutputPanel >
                    <apex:selectList id="ddlUpdateField" value="{!selectedItem}" size="1" multiselect="false" required="true">
                        <apex:selectOptions value="{!ListItems}" />
                    </apex:selectList>
                 </apex:OutputPanel>
                 <apex:outputPanel >
                    <apex:inputText id="updateItemTextBox" value="{!searchTerm}" styleClass="placeHolder"/>
                    <apex:selectList id="pLeadSorces" value="{!pleadsource}"
                     size="1" >
                        <apex:selectOptions value="{!LeadSorces}"/>
                    </apex:selectList>
                    <apex:selectList id="pIndustries" value="{!pindustry}"
                         size="1" >
                        <apex:selectOptions value="{!Industries}"/>
                    </apex:selectList>
                      <apex:selectList id="pObjectType" value="{!pobjecttype}"
                         size="1" >
                        <apex:selectOptions value="{!ObjectTypes}"/>
                    </apex:selectList>
                     <apex:inputField value="{!patchForOwner.CountryGlobal__c}" id="pCountry" onchange="setCountry(this)"/>
                     <apex:inputField value="{!patchForOwner.StateGlobal__c}" id="pState" onchange="setState(this)" style="display:none" />
                     <apex:inputHidden id="updateItemId" value="{!itemFieldId}" />
                     <apex:inputHidden Id="selectedItemIds" value="{!selectedItemId}" />
                     
                     <apex:inputHidden id="updateStateHidden" value="{!updateStateHidden}" />
                     <apex:inputHidden id="updateCountryHidden" value="{!updateCountryHidden}" />
                     
                 </apex:outputPanel>
            </apex:pageBlockSection>
        <apex:pageBlockButtons location="bottom">
            <apex:commandButton id="btnUpdate2" action="{!updateRecordsPatchManager}" value="Update"/>
            <apex:commandButton id="btnCancel"  action="{!cancel}" value="Cancel" />
        </apex:pageBlockButtons>
        </apex:pageBlock>
  </div>

</div>
  <!-- The Modal -->
<div id="myModal1" class="modal">

  <!-- Modal content -->
  <div class="modal-content">
    <span class="close">&times;</span>
    <div style="display:block;clear:both;padding:10px;">
    <center>   <div id="errorCod" class="errorMsg" style="display:none"><strong>Error:</strong> <span id="errorMsg" class="errorMsg"></span></div></center> 
    <h1>
        Add new <span>Patch Manager</span>
    </h1>
    </div>
    <div style="display:block;clear:both;">
    <center>
    
        
    <table cellspacing="0" width="100%"  class="clstbl">
        <tr><td>City</td><td><apex:inputText id="txtCity" value="{!city}" /></td><td>State</td>
         <!--   <td><apex:inputText id="txtState" value="{!state}" /></td> -->
            <td>
                <apex:inputField id="txtState" value="{!patchForOwner.StateGlobal__c}"/>
            </td>
        </tr>
        <tr><td>County</td><td><apex:inputText id="txtCounty" value="{!county}" /></td><td>Zip code</td><td><apex:inputText id="txtZip" value="{!zipcode}" /></td></tr>
        <tr><td>Country</td>
        <!--    <td><apex:inputText id="txtCountry" value="{!country}" /></td> -->
            <td>
                <apex:inputField id="txtCountry" value="{!patchForOwner.CountryGlobal__c}"/>
            </td>
            <td>SIC</td><td><apex:inputText id="txtSic" value="{!sic}" /></td></tr>
            <tr><td>SDR</td>
                <td>
                <apex:inputText id="txtSdr" value="{!sdr}" />   
                <apex:inputHidden id="sdrId" value="{!sdrId}" />
                </td>
                <td>SMB Owner</td><td>
                <apex:inputText id="txtSMBOwner" value="{!smbOwner}"/>
                <apex:inputHidden id="smbOwnerId" value="{!smbOwnerId}" />
                </td>
            </tr>
        <tr>
            <td>Account</td><td>
                <apex:inputText id="txtAccount" value="{!account}" />
                <apex:inputHidden id="accountId" value="{!accountId}" />
                </td>
            <td>Lead Source</td><td>
                <apex:selectList id="LeadSorces" value="{!leadsource}"
