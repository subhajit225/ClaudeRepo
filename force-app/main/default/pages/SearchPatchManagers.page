    <body>
    <apex:form >
        <!--<apex:actionFunction action="{!updateRecordsPatchManager}" name="updateRecordsPatchManager" reRender="pbId"/>-->
        <apex:actionFunction name="refreshPageSize" action="{!refreshPageSize}" status="fetchStatus" reRender="pbId"/>
        <apex:inputHidden value="{!selectedAllValue}" id="selectAllList"/>
      
        <apex:pageMessages /> 
    <div class="container">
        <section>
            <h1>Search <span>Patch Managers</span></h1>
            <hr />
        </section>
        
        <section>
            <button id="btnUpdate">Update</button>
            <button id="btnDeleteAll">Delete all</button>
            <button id="btnCreate">Create new</button>
            <apex:outputLabel rendered="{!isOutOfBound}" style="margin-left:885px;"><span style="color:red;">*</span> Use filters to reduce the number of records.</apex:outputLabel>
            <apex:actionFunction name="AddPM" action="{!addNewPM}" />
            <apex:actionFunction name="searchManagers" action="{!searchManagers}" reRender="pbId"/>
        </section>
        
        <apex:pageBlock id="pbId" tabStyle="PatchManager__c">
            
            <apex:pageBlockSection columns="12" title="All Patch Managers" collapsible="false" >
                <apex:inputText value="{!srchCity}" html-placeholder="City" styleclass="search-box"/>
                <apex:inputText value="{!srchStateGlobal}" html-placeholder="State" styleclass="search-box"/>
                <apex:inputText value="{!srchCountryGlobal}" html-placeholder="Country" styleclass="search-box"/>
                
                <apex:inputText value="{!srchZipCode}" html-placeholder="Zip Code" styleclass="search-box"/>
                         
                
                <apex:inputText value="{!srchSDR}" html-placeholder="SDR" styleclass="search-box"/>
                <apex:inputText value="{!srchSMBOwner}" html-placeholder="SMB Owner" styleclass="search-box"/>
                <apex:inputText value="{!srchOwner}" html-placeholder="Owner" styleclass="search-box"/>
                <apex:inputText value="{!srchCounty}" html-placeholder="County" styleclass="search-box"/>   
                <apex:inputText value="{!srchLeadSourceDetail}" html-placeholder="Lead Source Detail" styleclass="search-box"/>                
                <apex:inputText value="{!srchLeadSource}" html-placeholder="Lead Source" styleclass="search-box"/>
                <apex:inputText value="{!srchIndustry}" html-placeholder="Industry" styleclass="search-box"/>
                <apex:inputText value="{!srchAccount}" html-placeholder="Account" styleclass="search-box"/>
                <apex:selectList id="objType" value="{!srchObjectType}" style="width:100%" size="1" required="true">
                    <apex:selectOptions value="{!picklistValue}"/>
                </apex:selectList> 
                <!--<apex:inputText value="{!srchObjectType}" html-placeholder="Object Type"/>-->
                <apex:commandButton id="searchButton" action="{!searchManagers}" value="Search" />
                <apex:commandButton value="Clear All" id="clearAll" onclick="return clearAll();" style="margin-left: -133px;" />
                <apex:selectList label="Sort by: " size="1" value="{!selectedName}" onchange="searchManagers()">
                    <apex:selectOptions value="{!selectedNameFields}"/>
                </apex:selectList>
                <apex:inputCheckbox value="{!descSort}" onclick="searchManagers()" label="Desc/Asc"/>
            </apex:pageBlockSection>
            <apex:pageBlockSection columns="1">
               
                <apex:pageBlockTable id="dtTable" value="{!PatchManagers}" var="patchObj">
                    <apex:column >
                        <apex:facet name="header"><input type="checkbox" name="idAll" id="selectAllOpt" class="selectCheck1" value="{!selectAll}" onclick="selectAllCheckboxes(this)"/></apex:facet>
                        <input type="checkbox" name="id" data-grp="selOpt" class="selectCheck" value="{!patchObj.Id}" onclick="selectIndividual(this)"/>
                    </apex:column>
                    <apex:column headerValue="Delete"><a id="{!patchObj.Id}" style="text-decoration:underline;cursor: pointer;" onclick="deletePM('{!patchObj.Id}')">Delete</a></apex:column>
                    <apex:column headerValue="City"><apex:outputField value="{!patchObj.City__c}"/></apex:column>
                    <apex:column headerValue="SearchCity"><apex:outputField value="{!patchObj.SearchCity__c}"/></apex:column>
                    <apex:column headerValue="State Global"><apex:outputField value="{!patchObj.StateGlobal__c}"/></apex:column>
                    <apex:column headerValue="Search State"><apex:outputField value="{!patchObj.SearchState__c}"/></apex:column>
                    <apex:column headerValue="Country"><apex:outputField value="{!patchObj.CountryGlobal__c}"/></apex:column>
                    <apex:column headerValue="Search Country"><apex:outputField value="{!patchObj.SearchCountry__c}"/></apex:column>
                    <apex:column headerValue="Zip Code"><apex:outputField value="{!patchObj.Zip_code__c}"/></apex:column>
                    <apex:column headerValue="County"><apex:outputField value="{!patchObj.County__c}"/></apex:column>
                    <apex:column headerValue="SDR"><apex:outputField value="{!patchObj.SDR__r.Name}"/></apex:column>
                    <apex:column headerValue="SMB Owner"><apex:outputField value="{!patchObj.SMB_Owner__c}"/></apex:column>
                    <apex:column headerValue="Owner"><apex:outputField value="{!patchObj.Owner.Name}"/></apex:column>
                    <apex:column headerValue="CDM"><apex:outputField value="{!patchObj.CDM__r.Name}"/></apex:column>
                    <apex:column headerValue="Account"><apex:outputField value="{!patchObj.Account__r.Name}"/></apex:column>
                    <apex:column headerValue="Industry Category"><apex:outputField value="{!patchObj.Industry_Category__c}"/></apex:column>
                    <apex:column headerValue="Lead Source"><apex:outputField value="{!patchObj.LeadSource__c}"/></apex:column>
                    <apex:column headerValue="Lead Source Detail"><apex:outputField value="{!patchObj.Lead_Source_Detail__c}"/></apex:column>
                    <apex:column headerValue="Object Type"><apex:inputField value="{!patchObj.Object_Type__c}"/></apex:column>
                    
                </apex:pageBlockTable>
                 
                <apex:panelGrid columns="8"> 
                 
                <apex:selectList value="{!size}" multiselect="false" size="1" onchange="refreshPageSize();" style="width:40px;height:25px;">
                    <apex:selectOptions value="{!paginationSizeOptions}"/>
                </apex:selectList>
                 
                <apex:commandButton status="fetchStatus" reRender="pbId" value="First" action="{!setMan.first}" disabled="{!!setMan.hasPrevious}" title="First Page"/> 
  
                <apex:commandButton status="fetchStatus" reRender="pbId" value="Previous" action="{!setMan.previous}" disabled="{!!setMan.hasPrevious}" title="Previous Page" oncomplete="loadCheckboxes()"/> 
  
                <apex:commandButton id="nextButton" onclick="nextClick()" status="fetchStatus" reRender="pbId" value="Next" action="{!setMan.next}" disabled="{!!setMan.hasNext}" title="Next Page" oncomplete="loadCheckboxes()" /> 
  
                <apex:commandButton status="fetchStatus" reRender="pbId" value="Last" action="{!setMan.last}" disabled="{!!setMan.hasNext}" title="Last Page"/> 
  
                <apex:outputText >{!(setMan.pageNumber * size)+1-size}-{!IF((setMan.pageNumber * size)>noOfRecords, noOfRecords,
                     (setMan.pageNumber * size))} of {!noOfRecords}
                </apex:outputText> 
                       
                <apex:outputPanel >                      
                    <apex:actionStatus id="fetchStatus" >
                        <apex:facet name="start" >
                          <img src="/img/loading.gif" />                    
                        </apex:facet>
                    </apex:actionStatus>
                </apex:outputPanel> 
  
            </apex:panelGrid>  
            </apex:pageBlockSection>
        </apex:pageBlock>
