                    <apex:selectOptions value="{!LeadSorces}"/>
                </apex:selectList>
            </td>
        </tr>
        <tr>
            <td>Industry</td><td>
            <apex:selectList id="Industries" value="{!industry}"
                     size="1" >
                    <apex:selectOptions value="{!Industries}"/>
