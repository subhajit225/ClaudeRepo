    <script type="text/javascript" language="javascript">
        function deletePM(str){
            if(str!=null){
                var strAtr=str;
                var matches = [];
                matches.push(strAtr);
                var strJson=JSON.stringify(matches);
                if(matches.length>0){
                    var r = confirm("Are you sure you want to delete this record!");
                    if (r == true) {
                       SearchPatchManagerVFC.deleteUser(strJson, function(result, event){
                            if(event.type == 'exception') {
                                alert(event.message);
                            } else {
                                alert('Deleted successfully!');
                                searchManagers();
                                var rawf=$('#row_'+str);
                                $('#patchmanager').DataTable().row('#row_'+str).remove().draw(false);
                            }
                       });
                    }
                }
        }
    }
