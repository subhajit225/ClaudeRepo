                </div>
            </div>
        </div>
        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad" style="background-image: url('{!URLFOR($Resource.RubrikCustomerCommunity,'RubrikCommunity/Images/banner.png')}');background-repeat: no-repeat;background-size: cover;">
