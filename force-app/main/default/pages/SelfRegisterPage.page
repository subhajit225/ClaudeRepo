    <script>
        window.onload = function() {
            
            var url =location.pathname.toLowerCase();
            if(url.includes('/selfregisterpage')){
                url = url.replace('/selfregisterpage','/s/login/SelfRegister');
                 console.log(url );
                window.location.href = url;
            }else{
                document.getElementById("showBlock").style.display="block";
            }
        };
    </script>
    <script>
        var j$ = jQuery.noConflict();
        j$(document).ready(function(){
            
        });
        function checkValidation(){
            var lastName = j$("[id$='lastName']");
            var firstName = j$("[id$='firstName']");
            var email = j$("[id$='email']");
            var title = j$("[id$='title']");
            var phone = j$("[id$='phone']"); 
            var count = 0; 
            if(firstName.val() == '' || firstName.val() == null){
                firstName.next().show(); 
                count++;
            }else{
                firstName.next().hide();
            }
            if(lastName.val() == '' || lastName.val() == null){
                lastName.next().show();
                count++;
            }else{
                lastName.next().hide();
            }
            var Email = email.val();
            var pattern = /^([\w-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([\w-]+\.)+))([a-zA-Z]{2,6}|[0-9]{1,3})(\]?)$/;
            console.log(pattern.test(Email));
            if((email.val() == '' || email.val() == null) || !pattern.test(Email)){
                email.next().show();
                count++;
            }else{
                email.next().hide();
            }
            if(title.val() == '' || title.val() == null){
                title.next().show();
                count++;
            }else{
                title.next().hide();
            }
            var intRegex = /^[+]?([0-9]*[\.\s\-\(\)]|[0-9]+){3,24}$/;
            if(phone.val() == '' || phone.val() == null || !intRegex.test(phone.val())){
                phone.next().show();
                count++;
            }else{
                phone.next().hide();
            }
            if(count == 0){
                j$("[id$='loginButton']").attr('disabled','disabled');
                submitFormData();
                return false;
            }
        }
      </script>
    <c:importbs />
    <c:communitystyle />
    <c:visualstrapblock >
        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 nopad" style="background-color: #2E4E52">
