            <table-body>
                <table-row>
                    <table-cell display-align="center">
                        <block text-align="left" font-size = "10px"> 
                            <apex:outputText >
                                Payment #1 ${!QW.Payment_year_1} is billable upon shipment.
                            </apex:outputText>
                        </block>
                    </table-cell>
                </table-row>
            </table-body>
        </table>
        </apex:outputPanel>
