<apex:page showHeader="false" sidebar="false" cache="false"  controller="SevenYearPayments" contentType="text/xml" action="{!init}">
 <block>
    <apex:outputPanel layout="none" rendered="{!IF(OR (AND(Quote.Payment_year_1__c!=null, Quote.Payment_year_1__c > 0), AND(Quote.Payment_year_2__c!=null, Quote.Payment_year_2__c > 0), AND(Quote.Payment_year_3__c!=null,Quote.Payment_year_3__c > 0), AND(Quote.Payment_year_4__c!=null , Quote.Payment_year_4__c > 0), AND(Quote.Payment_year_5__c!=null,Quote.Payment_year_5__c > 0), AND(Quote.Payment_year_6__c !=null,Quote.Payment_year_6__c > 0), AND(Quote.Payment_year_7__c!=null,Quote.Payment_year_7__c > 0)), true, false)}">
        <table table-layout="fixed" >
            <table-body>
                <table-row>
                    <table-cell display-align="center">
                        <block text-align="left" font-size = "10px" margin-bottom = "5px"> 
                            <apex:outputText >
                                All payments are due within the contractual payment terms.
                            </apex:outputText>
                        </block>
                    </table-cell>
                </table-row>
            </table-body>
        </table>
        </apex:outputPanel>
        <apex:outputPanel layout="none" rendered="{!IF(AND(Quote.Payment_year_1__c!=null,Quote.Payment_year_1__c > 0),true,false)}">
