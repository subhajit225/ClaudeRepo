function formcheck() {
    //alert('inn');
  var fields = $(".ss-item-required")
        .find("select, textarea, input").serializeArray();
  var counter=0;
  $.each(fields, function(i, field) {
    console.log(field.value);
    if (!field.value){
      counter++;
    }
   }); 
   console.log(counter);
   if (counter == 2){
      $("#errorMsg").show();
      return false;
   }
   else{
       $("#errorMsg").hide();
       Search();
   }
  
  
}
function formUpdateCheck() {
    //alert('inn');
  var fields = $(".ss-check-required")
        .find("select, textarea, input").serializeArray();
  
  var counter=0;
  $.each(fields, function(i, field) {
    console.log(field.value);
    if (field.value != true){
    console.log('in');
      counter++;
    }
   }); 
   console.log('check counter--'+counter);
   /*if (counter > 1){
      $("#errorMsgCheckbox").show();
      return false;
   }
   else */
   if (counter = 0 ){
   $("#errorMsgCheckbox").html('Please select atleast one Jira issue to link');
       $("#errorMsgCheckbox").show();
       return false;
   }
   else{
       $("#errorMsgCheckbox").hide();
       update();
   }
  
 
}
 $(document).ready(function(){
    $('.check').click(function() {
        $('.check').not(this).prop('checked', false);
    });
});

window.onunload = refreshParent;
