<apex:page showHeader="true" sidebar="true" controller="DuplicateEntitlementsController" lightningStylesheets="true">
    <apex:slds rendered="{!$User.UITheme != 'Theme3'}"/> 
	<apex:pageBlock title="Manage Duplicate Entitlements">
			<table style="border-collapse: collapse;border: 1px solid black;">
				<tr style="background-color: darkgray;">
					<th style="border: 1px solid black; padding: 5px;">Id</th>
					<th style="border: 1px solid black; padding: 5px;">Entitlement Name</th>
					<th style="border: 1px solid black; padding: 5px;">Contract Line</th>
					<th style="border: 1px solid black; padding: 5px;">Service Contract</th>
					<th style="border: 1px solid black; padding: 5px;">Asset</th>
					<th style="border: 1px solid black; padding: 5px;">Order Item</th>
					<th style="border: 1px solid black; padding: 5px;">Order</th>
                    <th style="border: 1px solid black; padding: 5px;">Start Date</th>
                    <th style="border: 1px solid black; padding: 5px;">End Date</th>
                    <th style="border: 1px solid black; padding: 5px;">Renewal Price</th>
                    <th style="border: 1px solid black; padding: 5px;">Annual Contract Value</th>
                    <th style="border: 1px solid black; padding: 5px;">Status</th>
				</tr>
				<apex:variable var="color_bool" value="{!1}"   />
				<apex:repeat value="{!duplicateMap}" var="key">
					<apex:repeat value="{!duplicateMap[key]}" var="ent">
						<tr style="background-color: {!IF(color_bool==1, 'lightgray', 'white')}">
							<td style="border: 1px solid black; padding: 5px;">
								<apex:outputText value="{!ent.Id}"/>
							</td>
							<td style="border: 1px solid black; padding: 5px;">
								<apex:outputLink value="/{!ent.Id}" target="_blank">{!ent.Name}</apex:outputLink>
							</td>
							<td style="border: 1px solid black; padding: 5px;">
								<apex:outputLink value="/{!ent.ContractLineItemId}" target="_blank">{!ent.ContractLineItem.LineItemNumber}</apex:outputLink>
							</td>
							<td style="border: 1px solid black; padding: 5px;">
								<apex:outputLink value="/{!ent.ServiceContractId}" target="_blank">{!ent.ServiceContract.Name}</apex:outputLink>
							</td>
							<td style="border: 1px solid black; padding: 5px;">
								<apex:outputLink value="/{!ent.AssetId}" target="_blank">{!ent.Asset.Name}</apex:outputLink>
							</td>
							<td style="border: 1px solid black; padding: 5px;">
								<apex:outputLink value="/{!ent.Order_Service_Item__c}" target="_blank">{!ent.Order_Service_Item__r.OrderItemNumber}</apex:outputLink>
							</td>
							<td style="border: 1px solid black; padding: 5px;">
								<apex:outputLink value="/{!ent.Order_Service_Item__r.OrderId}" target="_blank">{!ent.Order_Service_Item__r.Order.OrderNumber}</apex:outputLink>
							</td>
                            <td style="border: 1px solid black; padding: 5px;">
								<apex:outputField value="{!ent.StartDate}"/>
							</td>
                            <td style="border: 1px solid black; padding: 5px;">
								<apex:outputField value="{!ent.EndDate}"/>
							</td>
                            <td style="border: 1px solid black; padding: 5px;">
								<apex:outputField value="{!ent.Renewal_Price__c}"/>
							</td>
                            <td style="border: 1px solid black; padding: 5px;">
								<apex:outputField value="{!ent.AnnualContractValue__c}"/>
							</td>
                            <td style="border: 1px solid black; padding: 5px;">
								<apex:outputField value="{!ent.Status}"/>
							</td>
						</tr>
					</apex:repeat>
					<apex:variable var="color_bool" value="{! IF(color_bool==1, 0, 1)}"   />
				</apex:repeat>
			</table>
	</apex:pageBlock>	
</apex:page>